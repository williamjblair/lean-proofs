#print axioms k5_infinity_polynomial_irreducible
#print axioms k5_runge_unit_inverse
#print axioms k5_runge_unit_power_inverse
#print axioms k5_runge_unit_real_small
#print axioms k5_runge_unit_real_lt_nine_over_125
#print axioms k5_runge_unit_power_real_small
#print axioms k5_runge_unit_pow_146_lt_ten_pow_neg_166

end Erdos686Variant
end Erdos686
