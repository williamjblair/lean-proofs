set_option maxRecDepth 400000 in
set_option maxHeartbeats 40000000 in
-- Kernel-only certificate check (`decide +kernel`, no `native_decide`):
-- evaluates the 10925-node Farey descent tree (depth 4992, hence the
-- `maxRecDepth` bump), including 745 exact 11th-power candidate
-- refutations on integers up to ~4414 bits (hence the `maxHeartbeats`
-- bump).  The `+kernel` variant bypasses the elaborator evaluator, whose
-- fixed C stack cannot hold the deep recursion of this tree; the proof
-- term and axioms are identical to plain `decide`.
theorem k11FareyCert_check :
    fareyCheck 4 50 1 9 1552 (8 * 10 ^ 120) k11EqRefuted 1 1 8 7 k11FareyCert =
      true := by
  decide +kernel

/--
**No `k = 11`, `N = 4` gap solution with `221 ≤ d < 10^120`** (extended
range; the headline `10^60` statement is
`no_gap_solution_four_eleven_below`).  Composes the banked ratio window and
row-1 quotient confinement with the centered-Thue descent certificate.
-/
theorem no_gap_solution_four_eleven_below_ext {n d : ℕ}
    (hd : 221 ≤ d) (hB : d < 10 ^ 120) :
    blockProduct 11 (n + d) ≠ 4 * blockProduct 11 n := by
  intro heq
  obtain ⟨hup, hlo⟩ := ratio_window_four_nat heq
  have hqd : 7 * d ≤ n + 1 := row_base_lower_k11 hd hup
  have hqd' : n + 1 < 8 * d := row_base_upper_k11 hlo
  have hn : 1546 ≤ n := by omega
  have hsol : K11CenteredEq (n + d + 6) (n + 6) := k11_centered_of_eq heq
  have hbl := k11_scaled_lower hn hlo
  have hbu := k11_scaled_upper hn hup
  have hYlo : 1552 ≤ n + 6 := by omega
  have hYmax : n + 6 ≤ 8 * 10 ^ 120 := by
    generalize hP : (10 : ℕ) ^ 120 = P at hB ⊢
    omega
  have hlow : (n + 6) * 1 + 1 ≤ (n + d + 6) * 1 := by omega
  have hhigh : (n + d + 6) * 7 + 1 ≤ (n + 6) * 8 := by omega
  exact fareyCheck_sound
    (Sol := fun X Y => K11CenteredEq X Y ∧
      113387 * Y < 100000 * X ∧ 100000 * X < 113476 * Y)
    (fun X Y h hS => k11EqRefuted_sound X Y h hS.1)
    (fun X Y hS h1 _h2 => k11_thue_window hS.1 hS.2.1 hS.2.2 h1)
    ⟨hsol, hbl, hbu⟩ hYlo hYmax (by omega)
    k11FareyCert 1 1 8 7 (by norm_num) k11FareyCert_check hlow hhigh

/--
**No `k = 11`, `N = 4` gap solution with `221 ≤ d < 10^60`.**  Together with
the banked `d ≤ 220` small-core certificate this closes `k = 11` up to the
tail `NoLargeGapSolutionFour 11 (10^60)`
(see `no_gap_solution_four_eleven_of_tail`).
-/
theorem no_gap_solution_four_eleven_below {n d : ℕ}
    (hd : 221 ≤ d) (hB : d < 10 ^ 60) :
    blockProduct 11 (n + d) ≠ 4 * blockProduct 11 n :=
  no_gap_solution_four_eleven_below_ext hd
    (lt_of_lt_of_le hB (Nat.pow_le_pow_right (by norm_num) (by norm_num)))

/--
Conditional closure for `k = 11`, `d ≥ 221`: the certified strip
`221 ≤ d < 10^60` plus the tail hypothesis `NoLargeGapSolutionFour 11 (10^60)`
refute every gap solution with `d ≥ 221`.
-/
theorem no_gap_solution_four_eleven_of_tail
    (htail : NoLargeGapSolutionFour 11 (10 ^ 60)) {n d : ℕ} (hd : 221 ≤ d) :
    blockProduct 11 (n + d) ≠ 4 * blockProduct 11 n := by
  rcases Nat.lt_or_ge d (10 ^ 60) with h | h
  · exact no_gap_solution_four_eleven_below hd h
  · exact htail n d h

/-- Variant of `no_gap_solution_four_eleven_of_tail` from the weaker tail at
`10^120` (the full certified range). -/
theorem no_gap_solution_four_eleven_of_tail_ext
    (htail : NoLargeGapSolutionFour 11 (10 ^ 120)) {n d : ℕ} (hd : 221 ≤ d) :
    blockProduct 11 (n + d) ≠ 4 * blockProduct 11 n := by
  rcases Nat.lt_or_ge d (10 ^ 120) with h | h
  · exact no_gap_solution_four_eleven_below_ext hd h
  · exact htail n d h

