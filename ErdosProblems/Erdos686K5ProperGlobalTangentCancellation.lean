open scoped BigOperators

/-- External multiplier removed from the distinguished upper term. -/
def k5UpperFourMultiplier (t i : â„•) : â„• :=
  if i = t then 4 else 1

lemma k5UpperFourMultiplier_mul_upperTermAfterFour
    {n d t i : â„•} (hfour : 4 âˆ£ n + d + t) :
    k5UpperFourMultiplier t i * upperTermAfterFour n d t i = n + d + i := by
  by_cases hit : i = t
  آ· subst i
    simp only [k5UpperFourMultiplier, upperTermAfterFour, if_pos]
    exact Nat.mul_div_cancel' hfour
  آ· simp [k5UpperFourMultiplier, upperTermAfterFour, hit]

/-- Row coefficient in the uncancelled tangent defect. -/
def k5LowerTangentWeight (j : â„•) : â„¤ :=
  4 * localBlockCoefficient 5 j

/-- Column coefficient after expressing the original upper term through its
distinguished-factor-four modification. -/
def k5ModifiedUpperTangentWeight (t i : â„•) : â„¤ :=
  localBlockCoefficient 5 i * (k5UpperFourMultiplier t i : â„¤)

lemma k5OwnerSquareDefect_eq_modified_bipartite
    {n d t j i : â„•} (hfour : 4 âˆ£ n + d + t) :
    k5OwnerSquareDefect n d j i =
      k5ModifiedUpperTangentWeight t i *
          (upperTermAfterFour n d t i : â„¤) -
        k5LowerTangentWeight j * (n + j : â„¤) := by
  have hmul := k5UpperFourMultiplier_mul_upperTermAfterFour
    (n := n) (d := d) (t := t) (i := i) hfour
  have hmulZ :
      (k5UpperFourMultiplier t i : â„¤) *
          (upperTermAfterFour n d t i : â„¤) = (n + d + i : â„•) := by
    exact_mod_cast hmul
  unfold k5OwnerSquareDefect k5ModifiedUpperTangentWeight
    k5LowerTangentWeight
  rw [â†گ hmulZ]
  push_cast
  ring

/-- Row-ideal quotient in the universal `K_{2,2}` tangent identity. -/
def bipartiteTangentRowQuotient
    (xâ‚پ xâ‚‚ yâ‚پ yâ‚‚ pâ‚پ pâ‚‚ qâ‚پ qâ‚‚ : â„¤) : â„¤ :=
  pâ‚پ * pâ‚‚ * (pâ‚پ * xâ‚پ - qâ‚پ * yâ‚پ - qâ‚‚ * yâ‚‚) *
    (pâ‚‚ * xâ‚‚ - qâ‚پ * yâ‚پ - qâ‚‚ * yâ‚‚)

/-- Column-ideal quotient in the universal `K_{2,2}` tangent identity. -/
def bipartiteTangentColumnQuotient
    (xâ‚پ xâ‚‚ yâ‚پ yâ‚‚ pâ‚پ pâ‚‚ qâ‚پ qâ‚‚ : â„¤) : â„¤ :=
  qâ‚پ * qâ‚‚ *
    (pâ‚پ ^ 2 * xâ‚پ ^ 2 - pâ‚پ * qâ‚پ * xâ‚پ * yâ‚پ -
      pâ‚پ * qâ‚‚ * xâ‚پ * yâ‚‚ + pâ‚‚ ^ 2 * xâ‚‚ ^ 2 -
      pâ‚‚ * qâ‚پ * xâ‚‚ * yâ‚پ - pâ‚‚ * qâ‚‚ * xâ‚‚ * yâ‚‚ +
      qâ‚پ * qâ‚‚ * yâ‚پ * yâ‚‚)

/-- Exact polynomial ideal certificate.  Each monomial in the four-edge
product chooses a vertex cover of `K_{2,2}`, hence contains either both row
variables or both column variables.  The displayed identity is the expanded
ordinary-kernel certificate of that combinatorial fact. -/
theorem bipartite_tangent_product_ideal_identity
    (xâ‚پ xâ‚‚ yâ‚پ yâ‚‚ pâ‚پ pâ‚‚ qâ‚پ qâ‚‚ : â„¤) :
    (qâ‚پ * yâ‚پ - pâ‚پ * xâ‚پ) * (qâ‚‚ * yâ‚‚ - pâ‚پ * xâ‚پ) *
        (qâ‚پ * yâ‚پ - pâ‚‚ * xâ‚‚) * (qâ‚‚ * yâ‚‚ - pâ‚‚ * xâ‚‚) =
      (xâ‚پ * xâ‚‚) *
          bipartiteTangentRowQuotient xâ‚پ xâ‚‚ yâ‚پ yâ‚‚ pâ‚پ pâ‚‚ qâ‚پ qâ‚‚ +
        (yâ‚پ * yâ‚‚) *
          bipartiteTangentColumnQuotient xâ‚پ xâ‚‚ yâ‚پ yâ‚‚ pâ‚پ pâ‚‚ qâ‚پ qâ‚‚ := by
  unfold bipartiteTangentRowQuotient bipartiteTangentColumnQuotient
  ring

/-- The specialized row quotient for two proper-global rows and columns. -/
def k5ProperTangentRowQuotient
    (n d t jâ‚پ jâ‚‚ iâ‚پ iâ‚‚ : â„•) : â„¤ :=
  bipartiteTangentRowQuotient
    (n + jâ‚پ) (n + jâ‚‚)
    (upperTermAfterFour n d t iâ‚پ) (upperTermAfterFour n d t iâ‚‚)
    (k5LowerTangentWeight jâ‚پ) (k5LowerTangentWeight jâ‚‚)
    (k5ModifiedUpperTangentWeight t iâ‚پ)
    (k5ModifiedUpperTangentWeight t iâ‚‚)

/-- The specialized column quotient for two proper-global rows and columns. -/
def k5ProperTangentColumnQuotient
    (n d t jâ‚پ jâ‚‚ iâ‚پ iâ‚‚ : â„•) : â„¤ :=
  bipartiteTangentColumnQuotient
    (n + jâ‚پ) (n + jâ‚‚)
    (upperTermAfterFour n d t iâ‚پ) (upperTermAfterFour n d t iâ‚‚)
    (k5LowerTangentWeight jâ‚پ) (k5LowerTangentWeight jâ‚‚)
    (k5ModifiedUpperTangentWeight t iâ‚پ)
    (k5ModifiedUpperTangentWeight t iâ‚‚)

theorem k5_four_tangent_defects_ideal_identity
    {n d t jâ‚پ jâ‚‚ iâ‚پ iâ‚‚ : â„•} (hfour : 4 âˆ£ n + d + t) :
    k5OwnerSquareDefect n d jâ‚پ iâ‚پ *
        k5OwnerSquareDefect n d jâ‚پ iâ‚‚ *
        k5OwnerSquareDefect n d jâ‚‚ iâ‚پ *
        k5OwnerSquareDefect n d jâ‚‚ iâ‚‚ =
      (((n + jâ‚پ) * (n + jâ‚‚) : â„•) : â„¤) *
          k5ProperTangentRowQuotient n d t jâ‚پ jâ‚‚ iâ‚پ iâ‚‚ +
        ((upperTermAfterFour n d t iâ‚پ *
            upperTermAfterFour n d t iâ‚‚ : â„•) : â„¤) *
          k5ProperTangentColumnQuotient n d t jâ‚پ jâ‚‚ iâ‚پ iâ‚‚ := by
  rw [k5OwnerSquareDefect_eq_modified_bipartite hfour,
    k5OwnerSquareDefect_eq_modified_bipartite hfour,
    k5OwnerSquareDefect_eq_modified_bipartite hfour,
    k5OwnerSquareDefect_eq_modified_bipartite hfour]
  exact bipartite_tangent_product_ideal_identity
    (n + jâ‚پ) (n + jâ‚‚)
    (upperTermAfterFour n d t iâ‚پ) (upperTermAfterFour n d t iâ‚‚)
    (k5LowerTangentWeight jâ‚پ) (k5LowerTangentWeight jâ‚‚)
    (k5ModifiedUpperTangentWeight t iâ‚پ)
    (k5ModifiedUpperTangentWeight t iâ‚‚)

/-- Exact first-power congruence after cancelling the four-crossing owner
from the tangent square.  The two displayed natural cofactors are coprime.
This is the finite-index polynomial cancellation interface for the next CRT
or resultant step. -/
theorem k5_proper_global_crossing_dvd_coprime_cofactor_tangent_combination
    {n d t jâ‚پ jâ‚‚ iâ‚پ iâ‚‚ : â„•}
    (data : CanonicalOwnerData 5 n d t)
    (hjâ‚پ : jâ‚پ âˆˆ Finset.Icc 1 5) (hjâ‚‚ : jâ‚‚ âˆˆ Finset.Icc 1 5)
    (hiâ‚پ : iâ‚پ âˆˆ Finset.Icc 1 5) (hiâ‚‚ : iâ‚‚ âˆˆ Finset.Icc 1 5)
    (hjneq : jâ‚پ â‰  jâ‚‚) (hineq : iâ‚پ â‰  iâ‚‚)
    (hfour : 4 âˆ£ n + d + t)
    (hjâ‚پone : canonicalLowerResidual data jâ‚پ = 1)
    (hjâ‚‚one : canonicalLowerResidual data jâ‚‚ = 1)
    (hiâ‚پone : canonicalUpperResidual data iâ‚پ = 1)
    (hiâ‚‚one : canonicalUpperResidual data iâ‚‚ = 1)
    (heq : blockProduct 5 (n + d) = 4 * blockProduct 5 n) :
    let A := (n + jâ‚پ) * (n + jâ‚‚)
    let B := upperTermAfterFour n d t iâ‚پ * upperTermAfterFour n d t iâ‚‚
    let X := canonicalOwnerCell data jâ‚پ iâ‚پ *
      canonicalOwnerCell data jâ‚پ iâ‚‚ *
      canonicalOwnerCell data jâ‚‚ iâ‚پ *
      canonicalOwnerCell data jâ‚‚ iâ‚‚
    Nat.Coprime (A / X) (B / X) âˆ§
      ((X : â„•) : â„¤) âˆ£
        k5ProperTangentRowQuotient n d t jâ‚پ jâ‚‚ iâ‚پ iâ‚‚ * (A / X : â„•) +
          k5ProperTangentColumnQuotient n d t jâ‚پ jâ‚‚ iâ‚پ iâ‚‚ * (B / X : â„•) := by
  dsimp only
  let A : â„• := (n + jâ‚پ) * (n + jâ‚‚)
  let B : â„• := upperTermAfterFour n d t iâ‚پ * upperTermAfterFour n d t iâ‚‚
  let X : â„• := canonicalOwnerCell data jâ‚پ iâ‚پ *
    canonicalOwnerCell data jâ‚پ iâ‚‚ *
    canonicalOwnerCell data jâ‚‚ iâ‚پ *
    canonicalOwnerCell data jâ‚‚ iâ‚‚
  let U : â„¤ := k5ProperTangentRowQuotient n d t jâ‚پ jâ‚‚ iâ‚پ iâ‚‚
  let V : â„¤ := k5ProperTangentColumnQuotient n d t jâ‚پ jâ‚‚ iâ‚پ iâ‚‚
  let a : â„• := A / X
  let b : â„• := B / X
  let F : â„¤ := k5OwnerSquareDefect n d jâ‚پ iâ‚پ *
    k5OwnerSquareDefect n d jâ‚پ iâ‚‚ *
    k5OwnerSquareDefect n d jâ‚‚ iâ‚پ *
    k5OwnerSquareDefect n d jâ‚‚ iâ‚‚
  have hgcd : Nat.gcd A B = X := by
    dsimp [A, B, X]
    exact k5_proper_global_row_column_gcd_eq_crossings data
      hjâ‚پ hjâ‚‚ hiâ‚پ hiâ‚‚ hjneq hineq
        hjâ‚پone hjâ‚‚one hiâ‚پone hiâ‚‚one
  have hXpos : 0 < X := by
    dsimp [X]
    have hâ‚پâ‚پ := canonicalOwnerCell_pos data (j := jâ‚پ) (i := iâ‚پ)
    have hâ‚پâ‚‚ := canonicalOwnerCell_pos data (j := jâ‚پ) (i := iâ‚‚)
    have hâ‚‚â‚پ := canonicalOwnerCell_pos data (j := jâ‚‚) (i := iâ‚پ)
    have hâ‚‚â‚‚ := canonicalOwnerCell_pos data (j := jâ‚‚) (i := iâ‚‚)
    positivity
  have hcop : Nat.Coprime (A / X) (B / X) := by
    rw [â†گ hgcd]
    exact Nat.coprime_div_gcd_div_gcd (by simpa [hgcd] using hXpos)
  have hA : X âˆ£ A := by rw [â†گ hgcd]; exact Nat.gcd_dvd_left A B
  have hB : X âˆ£ B := by rw [â†گ hgcd]; exact Nat.gcd_dvd_right A B
  have hAeq : X * (A / X) = A := Nat.mul_div_cancel' hA
  have hBeq : X * (B / X) = B := Nat.mul_div_cancel' hB
  have hAcast : (A : â„¤) = (X : â„¤) * (a : â„¤) := by
    dsimp [a]
    exact_mod_cast hAeq.symm
  have hBcast : (B : â„¤) = (X : â„¤) * (b : â„¤) := by
