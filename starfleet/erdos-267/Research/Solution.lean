/-- The binary window length squared is at most linear in the window radius. -/
theorem clog_twoWindow_add_one_sq_le (w : ℕ) :
    (Nat.clog 2 (2 * w + 1) + 1) ^ 2 ≤ 25 * (w + 1) := by
  let s := Nat.sqrt w
  let x := s + 1
  have hwlt : w < x ^ 2 := by
    simpa [x, pow_two] using Nat.lt_succ_sqrt w
  have hW : 2 * w + 1 ≤ 2 * x ^ 2 + 1 := by omega
  have hpow : 2 * x ^ 2 + 1 ≤ 2 ^ (2 * x) := by
    simpa using Nat.two_mul_sq_add_one_le_two_pow_two_mul x
  have hclog : Nat.clog 2 (2 * w + 1) ≤ 2 * x :=
    (Nat.clog_le_iff_le_pow (by norm_num)).mpr (hW.trans hpow)
  have hsSq : s ^ 2 ≤ w := by
    simpa [pow_two] using Nat.sqrt_le w
  have hs : s ≤ w := Nat.sqrt_le_self w
  calc
    (Nat.clog 2 (2 * w + 1) + 1) ^ 2 ≤ (2 * x + 1) ^ 2 :=
      Nat.pow_le_pow_left (Nat.add_le_add_right hclog 1) 2
    _ ≤ 25 * (w + 1) := by
      dsimp [x]
      nlinarith

/-- Consequently the target-specific reverse cutoff is bounded linearly in
`w`, with a constant depending only on the ratio block and 2-adic ceiling. -/
theorem reverseWindowLogCutoffPosition_le_linearWindowBound
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (q K G w Dtarget X V : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (hDlt : Dtarget < n K)
    (hn : n K ≤ (4 * (2 * w + 1)) ^ 8)
    (hG : G ≤ K + q * (8 * Nat.clog 2 (2 * w + 1) + 1))
    (hd : (laterPositionRange K G).card ≤
      q * (8 * Nat.clog 2 (2 * w + 1) + 1))
    (hX : X < (2 * n K) * sharpPrefixPeriod n K) :
    reverseWindowLogCutoffPosition
      n K G (n K * (2 * w + 1) ^ 8) w Dtarget X V q ≤
      1250000 * (q + V + 2) ^ 3 * (w + 1) := by
  have hbin := reverseWindowLogCutoffPosition_le_binaryWindowBound
    n hpos hmono c hc hratio q K G w Dtarget X V hq hDlt hn hG hd hX
  calc
    _ ≤ 50000 * (q + V + 2) ^ 3 *
        (Nat.clog 2 (2 * w + 1) + 1) ^ 2 := hbin
    _ ≤ 50000 * (q + V + 2) ^ 3 * (25 * (w + 1)) := by
      gcongr
      exact clog_twoWindow_add_one_sq_le w
    _ = 1250000 * (q + V + 2) ^ 3 * (w + 1) := by ring

end Research

/-!
# Asymptotic density and norm estimates for reverse windows
-/

namespace Research

set_option maxRecDepth 10000

open Filter Topology Real goldenRatio

/-- Deterministic linear upper bound for every favorable reverse cutoff. -/
def reverseWindowLinearBound (q V w : ℕ) : ℕ :=
  1250000 * (q + V + 2) ^ 3 * (w + 1)

/-- One golden factor per radius beats the principal cap at the linear reverse
cutoff bound. -/
theorem tendsto_reverseWindowLinearBound_tailCap (q V : ℕ) :
    Tendsto (fun w : ℕ =>
      (φ⁻¹) ^ w *
        (2 * cutoffTailCap (reverseWindowLinearBound q V w)))
      atTop (𝓝 0) := by
  let r : ℝ := φ⁻¹
  let A : ℝ := (1250000 * (q + V + 2) ^ 3 : ℕ)
  let C : ℝ := 4 * cutoffTailLinearConstant * A * r⁻¹
  let g : ℕ → ℝ := fun w => C * ((w + 1 : ℕ) : ℝ) * r ^ (w + 1)
  have hrpos : 0 < r := by dsimp [r]; exact inv_pos.mpr Real.goldenRatio_pos
  have hr0 : 0 ≤ r := hrpos.le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hg : Tendsto g atTop (𝓝 0) := by
    have hbase := tendsto_pow_const_mul_const_pow_of_lt_one 1 hr0 hr1
    have hshift := hbase.comp (Filter.tendsto_add_atTop_nat 1)
    have hconst := hshift.const_mul C
    simpa [g, mul_assoc] using hconst
  apply squeeze_zero
  · intro w
    have ht := cutoffTailCap_nonneg (reverseWindowLinearBound q V w)
    positivity
  · intro w
    have hcap := cutoffTailCap_le_linear (reverseWindowLinearBound q V w)
    have hbound : ((reverseWindowLinearBound q V w : ℕ) : ℝ) + 1 ≤
        2 * A * ((w + 1 : ℕ) : ℝ) := by
      have hAnat : 1 ≤ 1250000 * (q + V + 2) ^ 3 := by
        have hp : 1 ≤ (q + V + 2) ^ 3 := one_le_pow₀ (by omega)
        exact hp.trans (Nat.le_mul_of_pos_left _ (by norm_num))
      have hA : (1 : ℝ) ≤ A := by
        dsimp [A]
        exact_mod_cast hAnat
      have hw : (1 : ℝ) ≤ ((w + 1 : ℕ) : ℝ) := by
        exact_mod_cast Nat.succ_le_succ (Nat.zero_le w)
      have hAw : (1 : ℝ) ≤ A * ((w + 1 : ℕ) : ℝ) := by
        calc
          (1 : ℝ) = 1 * 1 := by ring
          _ ≤ A * ((w + 1 : ℕ) : ℝ) :=
            mul_le_mul hA hw (by norm_num) (le_trans (by norm_num) hA)
      have heq : ((reverseWindowLinearBound q V w : ℕ) : ℝ) =
          A * ((w + 1 : ℕ) : ℝ) := by
        dsimp [reverseWindowLinearBound, A]
        push_cast
        ring
      rw [heq]
      linarith
    have hlinear : cutoffTailCap (reverseWindowLinearBound q V w) ≤
        2 * cutoffTailLinearConstant * A * ((w + 1 : ℕ) : ℝ) := by
      calc
        _ ≤ cutoffTailLinearConstant *
            (((reverseWindowLinearBound q V w : ℕ) : ℝ) + 1) := hcap
        _ ≤ cutoffTailLinearConstant *
            (2 * A * ((w + 1 : ℕ) : ℝ)) :=
          mul_le_mul_of_nonneg_left hbound cutoffTailLinearConstant_nonneg
        _ = _ := by ring
    calc
      r ^ w * (2 * cutoffTailCap (reverseWindowLinearBound q V w)) ≤
          r ^ w * (2 * (2 * cutoffTailLinearConstant * A *
            ((w + 1 : ℕ) : ℝ))) := by gcongr
      _ = g w := by
        dsimp [g, C]
        rw [pow_succ]
        field_simp [hrpos.ne']
        ring
  · exact hg

/-- The same linear cutoff is beaten after multiplying principal and conjugate
caps. -/
theorem tendsto_reverseWindowLinearBound_normProduct
    (q V : ℕ) (T : ℝ) :
    Tendsto (fun w : ℕ =>
      (φ⁻¹) ^ w *
        (2 * cutoffTailCap (reverseWindowLinearBound q V w)) *
        (2 * cutoffConjugateCap T (reverseWindowLinearBound q V w)))
      atTop (𝓝 0) := by
  let r : ℝ := φ⁻¹
  let A : ℝ := (1250000 * (q + V + 2) ^ 3 : ℕ)
  let C : ℝ := 16 * cutoffTailLinearConstant *
    cutoffConjugateLinearConstant T * A ^ 2 * r⁻¹
  let g : ℕ → ℝ := fun w =>
    C * ((w + 1 : ℕ) : ℝ) ^ 2 * r ^ (w + 1)
  have hrpos : 0 < r := by dsimp [r]; exact inv_pos.mpr Real.goldenRatio_pos
  have hr0 : 0 ≤ r := hrpos.le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hg : Tendsto g atTop (𝓝 0) := by
    have hbase := tendsto_pow_const_mul_const_pow_of_lt_one 2 hr0 hr1
    have hshift := hbase.comp (Filter.tendsto_add_atTop_nat 1)
    have hconst := hshift.const_mul C
    simpa [g, mul_assoc] using hconst
  apply squeeze_zero
  · intro w
    have ht := cutoffTailCap_nonneg (reverseWindowLinearBound q V w)
    have hc := cutoffConjugateCap_nonneg T (reverseWindowLinearBound q V w)
    positivity
  · intro w
    have ht := cutoffTailCap_le_linear (reverseWindowLinearBound q V w)
    have hc := cutoffConjugateCap_le_linear T
      (reverseWindowLinearBound q V w)
    have hbound : ((reverseWindowLinearBound q V w : ℕ) : ℝ) + 1 ≤
        2 * A * ((w + 1 : ℕ) : ℝ) := by
      have hAnat : 1 ≤ 1250000 * (q + V + 2) ^ 3 := by
        have hp : 1 ≤ (q + V + 2) ^ 3 := one_le_pow₀ (by omega)
        exact hp.trans (Nat.le_mul_of_pos_left _ (by norm_num))
      have hA : (1 : ℝ) ≤ A := by
        dsimp [A]
        exact_mod_cast hAnat
      have hw : (1 : ℝ) ≤ ((w + 1 : ℕ) : ℝ) := by
        exact_mod_cast Nat.succ_le_succ (Nat.zero_le w)
      have hAw : (1 : ℝ) ≤ A * ((w + 1 : ℕ) : ℝ) := by
        calc
          (1 : ℝ) = 1 * 1 := by ring
          _ ≤ A * ((w + 1 : ℕ) : ℝ) :=
            mul_le_mul hA hw (by norm_num) (le_trans (by norm_num) hA)
      have heq : ((reverseWindowLinearBound q V w : ℕ) : ℝ) =
          A * ((w + 1 : ℕ) : ℝ) := by
        dsimp [reverseWindowLinearBound, A]
        push_cast
        ring
      rw [heq]
      linarith
    have ht' : cutoffTailCap (reverseWindowLinearBound q V w) ≤
        2 * cutoffTailLinearConstant * A * ((w + 1 : ℕ) : ℝ) := by
      calc
        _ ≤ cutoffTailLinearConstant *
            (((reverseWindowLinearBound q V w : ℕ) : ℝ) + 1) := ht
        _ ≤ cutoffTailLinearConstant *
            (2 * A * ((w + 1 : ℕ) : ℝ)) :=
          mul_le_mul_of_nonneg_left hbound cutoffTailLinearConstant_nonneg
        _ = _ := by ring
    have hc' : cutoffConjugateCap T (reverseWindowLinearBound q V w) ≤
        2 * cutoffConjugateLinearConstant T * A *
          ((w + 1 : ℕ) : ℝ) := by
      calc
        _ ≤ cutoffConjugateLinearConstant T *
            (((reverseWindowLinearBound q V w : ℕ) : ℝ) + 1) := hc
        _ ≤ cutoffConjugateLinearConstant T *
            (2 * A * ((w + 1 : ℕ) : ℝ)) :=
          mul_le_mul_of_nonneg_left hbound
            (cutoffConjugateLinearConstant_nonneg T)
        _ = _ := by ring
    have ht0 := cutoffTailCap_nonneg (reverseWindowLinearBound q V w)
    have hc0 := cutoffConjugateCap_nonneg T (reverseWindowLinearBound q V w)
    have htU : 0 ≤ 2 * cutoffTailLinearConstant * A *
        ((w + 1 : ℕ) : ℝ) := ht0.trans ht'
    have hcU : 0 ≤ 2 * cutoffConjugateLinearConstant T * A *
        ((w + 1 : ℕ) : ℝ) := hc0.trans hc'
    calc
      r ^ w * (2 * cutoffTailCap (reverseWindowLinearBound q V w)) *
          (2 * cutoffConjugateCap T (reverseWindowLinearBound q V w)) ≤
        r ^ w * (2 * (2 * cutoffTailLinearConstant * A *
          ((w + 1 : ℕ) : ℝ))) *
          (2 * (2 * cutoffConjugateLinearConstant T * A *
            ((w + 1 : ℕ) : ℝ))) := by gcongr
      _ = g w := by
        dsimp [g, C]
        rw [pow_succ]
        field_simp [hrpos.ne']
        ring
  · exact hg

/-- The center-density factor at the logarithmic threshold is linear in the
radius. -/
theorem reverseWindow_Dmax_le_linear
    (q w d : ℕ)
    (hd : d ≤ q * (8 * Nat.clog 2 (2 * w + 1) + 1)) :
    (2 * d + 1) * (2 * d + 2) ≤
      10000 * (q + 1) ^ 2 * (w + 1) := by
  let l := Nat.clog 2 (2 * w + 1)
  let L := l + 1
  have hqpos : q * (8 * l + 1) ≤ 9 * q * L := by
    calc
      _ ≤ q * (9 * L) := by
        apply Nat.mul_le_mul_left
        dsimp [L]
        omega
      _ = _ := by ring
  have hd0 : d ≤ q * (8 * l + 1) := by simpa [l] using hd
  have hd' : d ≤ 9 * q * L := hd0.trans hqpos
  have hab : q * L ≤ (q + 1) * L := Nat.mul_le_mul_right L (by omega)
  have hbase : 2 ≤ 2 * ((q + 1) * L) := by
    have : 0 < (q + 1) * L := mul_pos (by omega) (by dsimp [L]; omega)
    omega
  have h18 : 18 * q * L ≤ 18 * (q + 1) * L := by
    simpa [mul_assoc] using Nat.mul_le_mul_left 18 hab
  have h2 : 2 ≤ 2 * (q + 1) * L := by simpa [mul_assoc] using hbase
  have h2d2 : 2 * d + 2 ≤ 20 * (q + 1) * L := by
    calc
      2 * d + 2 ≤ 18 * q * L + 2 := by
        have hh := Nat.add_le_add_right (Nat.mul_le_mul_left 2 hd') 2
        calc
          _ ≤ 2 * (9 * q * L) + 2 := hh
          _ = 18 * q * L + 2 := by ring
      _ ≤ 18 * (q + 1) * L + 2 * (q + 1) * L :=
        Nat.add_le_add h18 h2
      _ = _ := by ring
  have h2d1 : 2 * d + 1 ≤ 20 * (q + 1) * L := by omega
  have hprod : (2 * d + 1) * (2 * d + 2) ≤
      400 * (q + 1) ^ 2 * L ^ 2 := by
    calc
      _ ≤ (20 * (q + 1) * L) * (20 * (q + 1) * L) :=
        Nat.mul_le_mul h2d1 h2d2
      _ = _ := by ring
  calc
    _ ≤ 400 * (q + 1) ^ 2 * L ^ 2 := hprod
    _ ≤ 400 * (q + 1) ^ 2 * (25 * (w + 1)) := by
      gcongr
      simpa [l, L] using clog_twoWindow_add_one_sq_le w
    _ = 10000 * (q + 1) ^ 2 * (w + 1) := by ring

/-- A one-over-radius majorant for every favorable reverse density. -/
noncomputable def reverseWindowDensityMajorantConstant
    (c : ℝ) (q V : ℕ) : ℝ :=
  let CD : ℝ := 10000 * (q + 1) ^ 2
  let AH : ℝ := 1250000 * (q + V + 2) ^ 3
  let scale : ℝ := 4 * 2 ^ V
  2 * CD * (12 + 2 * scale) * (c⁻¹ * (1 - c⁻¹)⁻¹) +
    2 * CD * AH +
    8 * CD * scale * (1 - c⁻¹)⁻¹

/-- The density majorant tends to zero. -/
theorem tendsto_reverseWindowDensityMajorant (c : ℝ) (q V : ℕ) :
    Tendsto (fun w : ℕ =>
      reverseWindowDensityMajorantConstant c q V * (w : ℝ)⁻¹)
      atTop (𝓝 0) := by
  have hinv : Tendsto (fun w : ℕ => (w : ℝ)⁻¹) atTop (𝓝 0) :=
    tendsto_inv_atTop_zero.comp (tendsto_natCast_atTop_atTop (R := ℝ))
  simpa using hinv.const_mul (reverseWindowDensityMajorantConstant c q V)

/-- Every target satisfying the displayed eighth-power, threshold, position,
and cutoff bounds satisfies the reverse density inequality for all sufficiently
large radii. -/
theorem eventually_reverseWindow_density
    (c : ℝ) (hc : 1 < c) (q V : ℕ) :
    ∀ᶠ w : ℕ in atTop, 0 < w ∧
      ∀ nval nG d H : ℕ,
        w ^ 8 ≤ nval →
        nval * (2 * w + 1) ^ 8 < nG →
        d ≤ q * (8 * Nat.clog 2 (2 * w + 1) + 1) →
        H ≤ reverseWindowLinearBound q V w →
        let W : ℕ := 2 * w + 1
        let p : ℕ := (4 * nval) * 2 ^ V
        let Z : ℕ := (4 * 2 ^ V) * w
        let Dmax : ℕ := (2 * d + 1) * (2 * d + 2)
        let Bexc : ℕ := (w + 1) ^ 3
        (Dmax : ℝ) *
          (((4 * W + 2 * Z : ℕ) : ℝ) *
              (c⁻¹ * (1 - c⁻¹)⁻¹ * (nval : ℝ)⁻¹) +
            2 * (H : ℝ) / (Bexc : ℝ) +
            4 * (p : ℝ) * ((1 - c⁻¹)⁻¹ * (nG : ℝ)⁻¹)) < 1 := by
  have hden : 0 < 1 - c⁻¹ := sub_pos.mpr (inv_lt_one_of_one_lt₀ hc)
  let Cmaj := reverseWindowDensityMajorantConstant c q V
  have htend := tendsto_reverseWindowDensityMajorant c q V
  have hevent : ∀ᶠ w : ℕ in atTop, Cmaj * (w : ℝ)⁻¹ < 1 :=
    htend.eventually_lt_const (by norm_num)
  filter_upwards [eventually_ge_atTop 1, hevent] with w hw hmajor
  refine ⟨by omega, ?_⟩
  intro nval nG d H hnval hnG hd hH
  let W : ℕ := 2 * w + 1
  let p : ℕ := (4 * nval) * 2 ^ V
  let scale : ℕ := 4 * 2 ^ V
  let Z : ℕ := scale * w
  let Dmax : ℕ := (2 * d + 1) * (2 * d + 2)
  let Bexc : ℕ := (w + 1) ^ 3
  let CD : ℝ := 10000 * (q + 1) ^ 2
  let AH : ℝ := 1250000 * (q + V + 2) ^ 3
  have hwR : (0 : ℝ) < w := by exact_mod_cast hw
  have hwOne : (1 : ℝ) ≤ w := by exact_mod_cast hw
  have hW : W ≤ 3 * w := by dsimp [W]; omega
  have hWlower : w ≤ W := by dsimp [W]; omega
  have hDnat : Dmax ≤ 10000 * (q + 1) ^ 2 * (w + 1) := by
    dsimp [Dmax]
    exact reverseWindow_Dmax_le_linear q w d hd
  have hDreal : (Dmax : ℝ) ≤ CD * (((w + 1 : ℕ) : ℝ)) := by
    dsimp [CD]
    exact_mod_cast hDnat
  have hDtwo : (Dmax : ℝ) ≤ 2 * CD * (w : ℝ) := by
    have hwadd : ((w + 1 : ℕ) : ℝ) ≤ 2 * (w : ℝ) := by
      exact_mod_cast (by omega : w + 1 ≤ 2 * w)
    calc
      (Dmax : ℝ) ≤ CD * ((w + 1 : ℕ) : ℝ) := hDreal
      _ ≤ CD * (2 * (w : ℝ)) :=
        mul_le_mul_of_nonneg_left hwadd (by dsimp [CD]; positivity)
      _ = 2 * CD * (w : ℝ) := by ring
  have hHreal : (H : ℝ) ≤ AH * (((w + 1 : ℕ) : ℝ)) := by
    dsimp [AH, reverseWindowLinearBound] at *
    exact_mod_cast hH
  have hnvalR : (w : ℝ) ^ 8 ≤ (nval : ℝ) := by exact_mod_cast hnval
  have hnvalPos : (0 : ℝ) < nval :=
    lt_of_lt_of_le (pow_pos hwR 8) hnvalR
  have hnGR : (nval : ℝ) * (W : ℝ) ^ 8 < (nG : ℝ) := by
    exact_mod_cast (by simpa [W] using hnG)
  have hscaleR : (scale : ℝ) = 4 * (2 : ℝ) ^ V := by
    dsimp [scale]
    push_cast
    ring
  have hpR : (p : ℝ) = (scale : ℝ) * (nval : ℝ) := by
    dsimp [p, scale]
    push_cast
    ring
  have hZr : (Z : ℝ) = (scale : ℝ) * (w : ℝ) := by
    dsimp [Z]
    push_cast
    ring
  have hcoeff : ((4 * W + 2 * Z : ℕ) : ℝ) ≤
      (12 + 2 * (scale : ℝ)) * (w : ℝ) := by
    push_cast
    rw [hZr]
    have hWR : (W : ℝ) ≤ 3 * (w : ℝ) := by exact_mod_cast hW
    nlinarith
  have hnvalInv : (nval : ℝ)⁻¹ ≤ ((w : ℝ) ^ 8)⁻¹ :=
    inv_anti₀ (pow_pos hwR 8) hnvalR
  have hterm1 : (Dmax : ℝ) *
      (((4 * W + 2 * Z : ℕ) : ℝ) *
        (c⁻¹ * (1 - c⁻¹)⁻¹ * (nval : ℝ)⁻¹)) ≤
      (2 * CD * (12 + 2 * (scale : ℝ)) *
        (c⁻¹ * (1 - c⁻¹)⁻¹)) * (w : ℝ)⁻¹ := by
    let tail : ℝ := c⁻¹ * (1 - c⁻¹)⁻¹
    have htail : 0 ≤ tail := by dsimp [tail]; positivity
    have hpair : (Dmax : ℝ) * ((4 * W + 2 * Z : ℕ) : ℝ) ≤
        (2 * CD * (w : ℝ)) *
          ((12 + 2 * (scale : ℝ)) * (w : ℝ)) :=
      mul_le_mul hDtwo hcoeff (by positivity) (by positivity)
    have hpairTail := mul_le_mul_of_nonneg_right hpair htail
    have hprod :
        ((Dmax : ℝ) * ((4 * W + 2 * Z : ℕ) : ℝ) * tail) *
            (nval : ℝ)⁻¹ ≤
          (((2 * CD * (w : ℝ)) *
              ((12 + 2 * (scale : ℝ)) * (w : ℝ))) * tail) *
            ((w : ℝ) ^ 8)⁻¹ :=
      mul_le_mul hpairTail hnvalInv (by positivity) (by positivity)
    have hi : (w : ℝ)⁻¹ ≤ 1 := (inv_le_one₀ hwR).mpr hwOne
    have hp : ((w : ℝ)⁻¹) ^ 5 ≤ 1 := pow_le_one₀ (by positivity) hi
    have hfac : 0 ≤
        (2 * CD * (12 + 2 * (scale : ℝ)) * tail) * (w : ℝ)⁻¹ := by
      positivity
    calc
      _ = ((Dmax : ℝ) * ((4 * W + 2 * Z : ℕ) : ℝ) * tail) *
          (nval : ℝ)⁻¹ := by dsimp [tail]; ring
      _ ≤ (((2 * CD * (w : ℝ)) *
              ((12 + 2 * (scale : ℝ)) * (w : ℝ))) * tail) *
            ((w : ℝ) ^ 8)⁻¹ := hprod
      _ = (2 * CD * (12 + 2 * (scale : ℝ)) * tail) *
          (w : ℝ)⁻¹ * ((w : ℝ)⁻¹) ^ 5 := by
        field_simp [hwR.ne']
      _ ≤ (2 * CD * (12 + 2 * (scale : ℝ)) * tail) *
          (w : ℝ)⁻¹ * 1 := mul_le_mul_of_nonneg_left hp hfac
      _ = _ := by dsimp [tail]; ring
  have hBexcR : (Bexc : ℝ) = (((w + 1 : ℕ) : ℝ)) ^ 3 := by
    dsimp [Bexc]
    push_cast
    rfl
  have hterm2 : (Dmax : ℝ) *
      (2 * (H : ℝ) / (Bexc : ℝ)) ≤
      (2 * CD * AH) * (w : ℝ)⁻¹ := by
    have hwaddPos : (0 : ℝ) < ((w + 1 : ℕ) : ℝ) := by positivity
    have hwCastLe : (w : ℝ) ≤ ((w + 1 : ℕ) : ℝ) := by
      exact_mod_cast (show w ≤ w + 1 by omega)
    have hwInv : ((w + 1 : ℕ) : ℝ)⁻¹ ≤ (w : ℝ)⁻¹ :=
      inv_anti₀ hwR hwCastLe
    have hDH : (Dmax : ℝ) * (H : ℝ) ≤
        (CD * ((w + 1 : ℕ) : ℝ)) *
          (AH * ((w + 1 : ℕ) : ℝ)) :=
      mul_le_mul hDreal hHreal (by positivity) (by positivity)
    have htwoDH := mul_le_mul_of_nonneg_left hDH (by norm_num : (0 : ℝ) ≤ 2)
    have hwithInv := mul_le_mul_of_nonneg_right htwoDH
      (inv_nonneg.mpr (by positivity : (0 : ℝ) ≤ (Bexc : ℝ)))
    calc
      _ = (2 * ((Dmax : ℝ) * (H : ℝ))) * (Bexc : ℝ)⁻¹ := by
        rw [div_eq_mul_inv]
        ring
      _ ≤ (2 * ((CD * ((w + 1 : ℕ) : ℝ)) *
          (AH * ((w + 1 : ℕ) : ℝ)))) * (Bexc : ℝ)⁻¹ := hwithInv
      _ = (2 * CD * AH) * (((w + 1 : ℕ) : ℝ))⁻¹ := by
        rw [hBexcR]
        field_simp [hwaddPos.ne']
      _ ≤ (2 * CD * AH) * (w : ℝ)⁻¹ := by
        exact mul_le_mul_of_nonneg_left hwInv (by positivity)
  have hpRatio : (p : ℝ) * (nG : ℝ)⁻¹ ≤
      (scale : ℝ) * ((W : ℝ) ^ 8)⁻¹ := by
    rw [hpR]
    have hprodPos : 0 < (nval : ℝ) * (W : ℝ) ^ 8 :=
      mul_pos hnvalPos (pow_pos (by positivity) 8)
    have hinv : (nG : ℝ)⁻¹ ≤
        ((nval : ℝ) * (W : ℝ) ^ 8)⁻¹ :=
      inv_anti₀ hprodPos hnGR.le
    calc
      (scale : ℝ) * (nval : ℝ) * (nG : ℝ)⁻¹ ≤
          (scale : ℝ) * (nval : ℝ) *
            ((nval : ℝ) * (W : ℝ) ^ 8)⁻¹ :=
        mul_le_mul_of_nonneg_left hinv (by positivity)
      _ = (scale : ℝ) * ((W : ℝ) ^ 8)⁻¹ := by
        field_simp [hnvalPos.ne']
  have hpowW : (w : ℝ) ^ 8 ≤ (W : ℝ) ^ 8 := by
    have hwCast : (w : ℝ) ≤ (W : ℝ) := by exact_mod_cast hWlower
    exact pow_le_pow_left₀ (by positivity) hwCast 8
  have hWinv : ((W : ℝ) ^ 8)⁻¹ ≤ ((w : ℝ) ^ 8)⁻¹ :=
    inv_anti₀ (pow_pos hwR 8) hpowW
  have hterm3 : (Dmax : ℝ) *
      (4 * (p : ℝ) * ((1 - c⁻¹)⁻¹ * (nG : ℝ)⁻¹)) ≤
      (8 * CD * (scale : ℝ) * (1 - c⁻¹)⁻¹) * (w : ℝ)⁻¹ := by
    let u : ℝ := (1 - c⁻¹)⁻¹
    have hu : 0 ≤ u := by dsimp [u]; positivity
    have hpair : (Dmax : ℝ) * ((p : ℝ) * (nG : ℝ)⁻¹) ≤
        (2 * CD * (w : ℝ)) *
          ((scale : ℝ) * ((W : ℝ) ^ 8)⁻¹) :=
      mul_le_mul hDtwo hpRatio (by positivity) (by positivity)
    have hpair' : (Dmax : ℝ) * ((p : ℝ) * (nG : ℝ)⁻¹) ≤
        (2 * CD * (w : ℝ)) *
          ((scale : ℝ) * ((w : ℝ) ^ 8)⁻¹) := by
      refine hpair.trans ?_
      gcongr
    have hscaled := mul_le_mul_of_nonneg_left hpair'
      (show 0 ≤ 4 * u by positivity)
    have hi : (w : ℝ)⁻¹ ≤ 1 := (inv_le_one₀ hwR).mpr hwOne
    have hpw : ((w : ℝ)⁻¹) ^ 6 ≤ 1 := pow_le_one₀ (by positivity) hi
    have hfac : 0 ≤
        (8 * CD * (scale : ℝ) * u) * (w : ℝ)⁻¹ := by positivity
    calc
      _ = (4 * u) * ((Dmax : ℝ) *
          ((p : ℝ) * (nG : ℝ)⁻¹)) := by dsimp [u]; ring
      _ ≤ (4 * u) * ((2 * CD * (w : ℝ)) *
          ((scale : ℝ) * ((w : ℝ) ^ 8)⁻¹)) := hscaled
      _ = (8 * CD * (scale : ℝ) * u) *
          (w : ℝ)⁻¹ * ((w : ℝ)⁻¹) ^ 6 := by
        field_simp [hwR.ne']
        ring
      _ ≤ (8 * CD * (scale : ℝ) * u) *
          (w : ℝ)⁻¹ * 1 := mul_le_mul_of_nonneg_left hpw hfac
      _ = _ := by dsimp [u]; ring
  have hsum : (Dmax : ℝ) *
      (((4 * W + 2 * Z : ℕ) : ℝ) *
          (c⁻¹ * (1 - c⁻¹)⁻¹ * (nval : ℝ)⁻¹) +
        2 * (H : ℝ) / (Bexc : ℝ) +
        4 * (p : ℝ) * ((1 - c⁻¹)⁻¹ * (nG : ℝ)⁻¹)) ≤
      Cmaj * (w : ℝ)⁻¹ := by
    calc
      _ = (Dmax : ℝ) *
            (((4 * W + 2 * Z : ℕ) : ℝ) *
              (c⁻¹ * (1 - c⁻¹)⁻¹ * (nval : ℝ)⁻¹)) +
          (Dmax : ℝ) * (2 * (H : ℝ) / (Bexc : ℝ)) +
          (Dmax : ℝ) *
            (4 * (p : ℝ) * ((1 - c⁻¹)⁻¹ * (nG : ℝ)⁻¹)) := by ring
      _ ≤ (2 * CD * (12 + 2 * (scale : ℝ)) *
              (c⁻¹ * (1 - c⁻¹)⁻¹)) * (w : ℝ)⁻¹ +
          (2 * CD * AH) * (w : ℝ)⁻¹ +
          (8 * CD * (scale : ℝ) * (1 - c⁻¹)⁻¹) *
            (w : ℝ)⁻¹ := add_le_add (add_le_add hterm1 hterm2) hterm3
      _ = Cmaj * (w : ℝ)⁻¹ := by
        dsimp [Cmaj, reverseWindowDensityMajorantConstant, CD, AH]
        rw [hscaleR]
        ring
  simpa [W, p, Z, Dmax, Bexc, scale] using hsum.trans_lt hmajor

end Research

/-!
# Quarter-eighth-root radii for reverse windows
-/

namespace Research

open Filter Topology

/-- A quarter of the canonical eighth-root target scale. -/
def reverseTargetRadius (n : ℕ → ℕ) (K : ℕ) : ℕ :=
  targetEighthRoot n K / 4

/-- The quarter-eighth-root radius still tends to infinity. -/
theorem tendsto_reverseTargetRadius_atTop
    (n : ℕ → ℕ) (hmono : StrictMono n) :
    Tendsto (reverseTargetRadius n) atTop atTop := by
  rw [tendsto_atTop]
  intro w
  have hroot := tendsto_targetEighthRoot_atTop n hmono
  filter_upwards [hroot.eventually_ge_atTop (w * 4)] with K hK
  apply (Nat.le_div_iff_mul_le (by norm_num : 0 < 4)).2
  simpa [mul_comm] using hK

/-- The reverse radius is below the canonical root, while four times the
corresponding two-sided width controls the target from above. -/
theorem reverseTargetRadius_eighthPower_package
    (n : ℕ → ℕ) (K : ℕ) :
    let w := reverseTargetRadius n K
    w ^ 8 ≤ n K ∧ n K ≤ (4 * (2 * w + 1)) ^ 8 := by
  let e := targetEighthRoot n K
  let w := reverseTargetRadius n K
  have hwle : w ≤ e := by
    dsimp [w, reverseTargetRadius, e]
    exact Nat.div_le_self _ _
  have hrootUpper : n K ≤ (e + 1) ^ 8 :=
    (target_lt_eighthRoot_add_one_pow n K).le
  have heLt : e < 4 * (w + 1) := by
    dsimp [w, reverseTargetRadius, e]
    simpa using Nat.lt_mul_div_succ e (by norm_num : 0 < 4)
  have heOne : e + 1 ≤ 4 * (2 * w + 1) := by omega
  refine ⟨?_, hrootUpper.trans (Nat.pow_le_pow_left heOne 8)⟩
  exact (Nat.pow_le_pow_left hwle 8).trans
    (targetEighthRoot_pow_le n K)

/-- Eventual prefix-gcd growth at the canonical root gives the strict
quarter-gcd window needed by reverse isolation. -/
theorem four_reverseTargetRadius_lt_prefixGcd
    (n : ℕ → ℕ) (K : ℕ)
    (hroot : 0 < targetEighthRoot n K)
    (hgcd : 2 * targetEighthRoot n K ≤
      (4 * n K).gcd (sharpPrefixPeriod n K)) :
    4 * reverseTargetRadius n K <
      (4 * n K).gcd (sharpPrefixPeriod n K) := by
  have hfour : 4 * reverseTargetRadius n K ≤ targetEighthRoot n K := by
    dsimp [reverseTargetRadius]
    simpa [mul_comm] using Nat.mul_div_le (targetEighthRoot n K) 4
  omega

/-- The exceptional-modulus size condition is automatic at the reverse radius
for every fixed two-adic ceiling. -/
theorem eventually_reverseTargetRadius_exceptional_size
    (n : ℕ → ℕ) (hmono : StrictMono n) (V : ℕ) :
    ∀ᶠ K : ℕ in atTop,
      let w := reverseTargetRadius n K
      2 * (4 * 2 ^ V) * ((w + 1) ^ 3) ^ 2 * w ≤ n K := by
  have hradius := tendsto_reverseTargetRadius_atTop n hmono
  filter_upwards [hradius.eventually_ge_atTop (max 1 (2 ^ V))] with K hK
  let w := reverseTargetRadius n K
  have hw1 : 1 ≤ w := (le_max_left _ _).trans hK
  have hwV : 2 ^ V ≤ w := (le_max_right _ _).trans hK
  have hsucc : w + 1 ≤ 2 * w := by omega
  have hfour : 4 * w ≤ targetEighthRoot n K := by
    dsimp [w, reverseTargetRadius]
    simpa [mul_comm] using Nat.mul_div_le (targetEighthRoot n K) 4
  calc
    2 * (4 * 2 ^ V) * ((w + 1) ^ 3) ^ 2 * w
        ≤ 2 * (4 * w) * (((2 * w) ^ 3) ^ 2) * w := by
          gcongr
    _ = 512 * w ^ 8 := by ring
    _ ≤ 65536 * w ^ 8 :=
      Nat.mul_le_mul_right (w ^ 8) (by norm_num)
    _ = (4 * w) ^ 8 := by ring
    _ ≤ targetEighthRoot n K ^ 8 := Nat.pow_le_pow_left hfour 8
    _ ≤ n K := targetEighthRoot_pow_le n K

end Research

/-!
# Reverse-window contradiction in the bounded two-adic branch
-/

namespace Research

open Filter Topology Real goldenRatio

set_option maxHeartbeats 3000000
set_option maxRecDepth 10000

/-- No positive ratio-gap sequence of uniformly bounded selected two-adic
order can have a fixed scaled-golden Lambert total. -/
theorem boundedOrder_scaledGolden_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (V : ℕ) (hV : ∀ k, twoAdicOrder (n k) ≤ V)
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    False := by
  classical
  let ε : ℝ := (((qden : ℕ) : ℝ)⁻¹) ^ 2
  have hε : 0 < ε := by dsimp [ε]; positivity
  have hdensityW := eventually_reverseWindow_density c hc q V
  have htailW : ∀ᶠ w : ℕ in atTop,
      (φ⁻¹) ^ w *
        (2 * cutoffTailCap (reverseWindowLinearBound q V w)) < 1 :=
    (tendsto_reverseWindowLinearBound_tailCap q V).eventually
      (gt_mem_nhds (by norm_num : (0 : ℝ) < 1))
  have hnormW : ∀ᶠ w : ℕ in atTop,
      (φ⁻¹) ^ w *
        (2 * cutoffTailCap (reverseWindowLinearBound q V w)) *
        (2 * cutoffConjugateCap Tconj
          (reverseWindowLinearBound q V w)) < ε :=
    (tendsto_reverseWindowLinearBound_normProduct q V Tconj).eventually
      (gt_mem_nhds hε)
  have hradius := tendsto_reverseTargetRadius_atTop n hmono
  have hnumerical : ∀ᶠ K : ℕ in atTop,
      let w := reverseTargetRadius n K
      (0 < w ∧
        ∀ nval nG d H : ℕ,
          w ^ 8 ≤ nval →
          nval * (2 * w + 1) ^ 8 < nG →
          d ≤ q * (8 * Nat.clog 2 (2 * w + 1) + 1) →
          H ≤ reverseWindowLinearBound q V w →
          let W : ℕ := 2 * w + 1
          let p : ℕ := (4 * nval) * 2 ^ V
          let Z : ℕ := (4 * 2 ^ V) * w
          let Dmax : ℕ := (2 * d + 1) * (2 * d + 2)
          let Bexc : ℕ := (w + 1) ^ 3
          (Dmax : ℝ) *
            (((4 * W + 2 * Z : ℕ) : ℝ) *
                (c⁻¹ * (1 - c⁻¹)⁻¹ * (nval : ℝ)⁻¹) +
              2 * (H : ℝ) / (Bexc : ℝ) +
              4 * (p : ℝ) * ((1 - c⁻¹)⁻¹ * (nG : ℝ)⁻¹)) < 1) ∧
      (φ⁻¹) ^ w *
        (2 * cutoffTailCap (reverseWindowLinearBound q V w)) < 1 ∧
      (φ⁻¹) ^ w *
        (2 * cutoffTailCap (reverseWindowLinearBound q V w)) *
        (2 * cutoffConjugateCap Tconj
          (reverseWindowLinearBound q V w)) < ε := by
    exact hradius.eventually (hdensityW.and (htailW.and hnormW))
  have hgcd := eventually_two_eighthRoot_le_prefixGcd_of_pair
    n hpos hmono c hc hratio qden hqden T Tconj hsum htotal q hqpos hq
  have hsize := eventually_reverseTargetRadius_exceptional_size n hmono V
  obtain ⟨Kodd, hKodd⟩ :=
    exists_eventually_odd_reduced_sharpPeriod n hpos V hV
  have hodd : ∀ᶠ K : ℕ in atTop,
      Odd (fibLambertPeriod (n K) /
        (fibLambertPeriod (n K)).gcd (sharpPrefixPeriod n K)) := by
    apply Filter.eventually_atTop.mpr
    refine ⟨Kodd + 1, ?_⟩
    intro K hK
    exact hKodd K (by omega)
  have hall := hgcd.and (hsize.and (hodd.and hnumerical))
  obtain ⟨N, hN⟩ := Filter.eventually_atTop.mp hall
  obtain ⟨K, hNK, hnew⟩ :=
    exists_new_sharpPeriod_after n hpos hmono N
  have hdata := hN K hNK.le
  rcases hdata with ⟨hgcdK, hsizeK, hoddK, hnumK⟩
  let w := reverseTargetRadius n K
  let P := sharpPrefixPeriod n K
  have hw : 0 < w := hnumK.1.1
  have hrootPos : 0 < targetEighthRoot n K := by
    dsimp [w, reverseTargetRadius] at hw
    omega
  have hwindow : 4 * w < (4 * n K).gcd P := by
    exact four_reverseTargetRadius_lt_prefixGcd n K hrootPos
      (by simpa [P] using hgcdK)
  have hP : 0 < P := sharpPrefixPeriod_pos n hpos K
  have htwoQuot :=
    odd_three_reduced_twoPeriod_of_new_odd_reduced_sharpPeriod
      P (n K) hP (hpos K) (by simpa [P] using hnew)
        (by simpa [P] using hoddK)
  obtain ⟨X, r, v, hPX, hXbound, hX, hrpos, hrn, hdist⟩ :=
    exists_exact_belowHalf_multiplier_of_odd_reduced_twoPeriod
      P (n K) (hpos K) htwoQuot.1 htwoQuot.2
  let Dtarget := n K - r
  have hDpos : 0 < Dtarget := by dsimp [Dtarget]; omega
  have hDlt : Dtarget < n K := by dsimp [Dtarget]; omega
  have hg4dvd : (4 * n K).gcd P ∣ 2 * (2 * n K).gcd P := by
    exact gcd_four_mul_dvd_two_mul_gcd_two_mul (n K) P
  have hg4le : (4 * n K).gcd P ≤ 2 * (2 * n K).gcd P :=
    Nat.le_of_dvd (by positivity) hg4dvd
  have hwD : w < Dtarget := by
    have : 4 * w < 4 * Dtarget := by
      calc
        4 * w < (4 * n K).gcd P := hwindow
        _ ≤ 2 * (2 * n K).gcd P := hg4le
        _ = 4 * Dtarget := by
          dsimp [Dtarget]
          rw [← hdist]
          ring
    omega
  have hwr : w < r := by
    let d := (2 * n K).gcd P
    have hdpos : 0 < d := by
      dsimp [d]
      exact Nat.gcd_pos_of_pos_left P (by omega)
    have hfac : d * ((2 * n K) / d) = 2 * n K :=
      Nat.mul_div_cancel' (by dsimp [d]; exact Nat.gcd_dvd_left _ _)
    have hmul := Nat.mul_le_mul_left d htwoQuot.2
    have hthreeD : 3 * Dtarget ≤ n K := by
      rw [hfac] at hmul
      have hdEq : d = 2 * Dtarget := by
        dsimp [d, Dtarget]
        omega
      rw [hdEq] at hmul
      nlinarith
    have hfourD : 4 * w < 4 * Dtarget := by
      exact (Nat.mul_lt_mul_left (by norm_num : 0 < 4)).2 hwD
    dsimp [Dtarget] at hthreeD ⊢
    omega
  obtain ⟨hA, hpre, hmid, hpost⟩ :=
    reverse_belowHalf_dyadicChain_sandwiched_pattern_anyParity
      (n K) 1 w X r v (hpos K) (by norm_num) hX hrpos hrn hwr hwD
  have hDdvd : Dtarget ∣ n K := by
    apply (Nat.mul_dvd_mul_iff_left (by norm_num : 0 < 2)).mp
    rw [show 2 * Dtarget = (2 * n K).gcd P by
      dsimp [Dtarget]
      omega]
    exact Nat.gcd_dvd_left _ _
  let Q := n K / Dtarget
  have hQ : n K = Q * Dtarget := by
    dsimp [Q]
    exact (Nat.div_mul_cancel hDdvd).symm
  have hXcenter : Dtarget + X = n K * (2 * v + 1) := by
    have hDr : Dtarget + r = n K := by
      dsimp [Dtarget]
      omega
    rw [hX, ← add_assoc, hDr]
    ring
  let W := 2 * w + 1
  let Bval := n K * W ^ 8
  obtain ⟨G, hKG, hBG, hvalues, hGbound, hdcard⟩ :=
    exists_logarithmic_polynomial_threshold_package
      n hpos hmono c hc hratio q hq K W (by dsimp [W]; omega)
  let H := reverseWindowLogCutoffPosition
    n K G Bval w Dtarget X V q
  have hrootBounds := reverseTargetRadius_eighthPower_package n K
  have hnlow : w ^ 8 ≤ n K := by simpa [w] using hrootBounds.1
  have hnupper : n K ≤ (4 * (2 * w + 1)) ^ 8 := by
    simpa [w] using hrootBounds.2
  have hHbound : H ≤ reverseWindowLinearBound q V w := by
    dsimp [H]
    apply reverseWindowLogCutoffPosition_le_linearWindowBound
      n hpos hmono c hc hratio q K G w Dtarget X V hq
    · exact hDlt
    · exact hnupper
    · simpa [W] using hGbound
    · simpa [W] using hdcard
    · simpa [P] using hXbound
  have hdensity :
      let p := (4 * n K) * 2 ^ V
      let Z := (4 * 2 ^ V) * w
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      (Dmax : ℝ) *
        (((4 * W + 2 * Z : ℕ) : ℝ) *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          2 * (H : ℝ) / (((w + 1) ^ 3 : ℕ) : ℝ) +
          4 * (p : ℝ) * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1 := by
    exact hnumK.1.2 (n K) (n G) (laterPositionRange K G).card H
      hnlow (by simpa [Bval, W] using hBG)
      (by simpa [W] using hdcard) hHbound
  have htailMono : cutoffTailCap H ≤
      cutoffTailCap (reverseWindowLinearBound q V w) :=
    cutoffTailCap_mono hHbound
  have hconjMono : cutoffConjugateCap Tconj H ≤
      cutoffConjugateCap Tconj (reverseWindowLinearBound q V w) :=
    cutoffConjugateCap_mono Tconj hHbound
  have hpostCap :
      (φ⁻¹) ^ (w + 1) * (2 * cutoffTailCap H) < 1 := by
    have hr : 0 ≤ (φ⁻¹ : ℝ) := by positivity
    have hrle : φ⁻¹ ≤ (1 : ℝ) :=
      (inv_le_one₀ Real.goldenRatio_pos).2 Real.one_lt_goldenRatio.le
    have hpow : (φ⁻¹) ^ (w + 1) ≤ (φ⁻¹) ^ w := by
      rw [pow_succ]
      exact mul_le_of_le_one_right (pow_nonneg hr w) hrle
    have ht0 : 0 ≤ 2 * cutoffTailCap H :=
      mul_nonneg (by norm_num) (cutoffTailCap_nonneg H)
    have htB0 : 0 ≤ 2 * cutoffTailCap
        (reverseWindowLinearBound q V w) :=
      mul_nonneg (by norm_num)
        (cutoffTailCap_nonneg (reverseWindowLinearBound q V w))
    have htmono : 2 * cutoffTailCap H ≤
        2 * cutoffTailCap (reverseWindowLinearBound q V w) :=
      mul_le_mul_of_nonneg_left htailMono (by norm_num)
    calc
      (φ⁻¹) ^ (w + 1) * (2 * cutoffTailCap H) ≤
          (φ⁻¹) ^ w *
            (2 * cutoffTailCap (reverseWindowLinearBound q V w)) :=
        mul_le_mul hpow htmono ht0 (pow_nonneg hr w)
      _ < 1 := hnumK.2.1
  have hpreCap :
      (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap Tconj H) < ε := by
    have hpow : 0 ≤ (φ⁻¹ : ℝ) ^ w := by positivity
    have htmono : 2 * cutoffTailCap H ≤
        2 * cutoffTailCap (reverseWindowLinearBound q V w) :=
      mul_le_mul_of_nonneg_left htailMono (by norm_num)
    have hcmono : 2 * cutoffConjugateCap Tconj H ≤
        2 * cutoffConjugateCap Tconj
          (reverseWindowLinearBound q V w) :=
      mul_le_mul_of_nonneg_left hconjMono (by norm_num)
    have hfirst : (φ⁻¹) ^ w * (2 * cutoffTailCap H) ≤
        (φ⁻¹) ^ w *
          (2 * cutoffTailCap (reverseWindowLinearBound q V w)) :=
      mul_le_mul_of_nonneg_left htmono hpow
    have hcH0 : 0 ≤ 2 * cutoffConjugateCap Tconj H :=
      mul_nonneg (by norm_num) (cutoffConjugateCap_nonneg Tconj H)
    have hbaseB0 : 0 ≤ (φ⁻¹) ^ w *
        (2 * cutoffTailCap (reverseWindowLinearBound q V w)) :=
      mul_nonneg hpow (mul_nonneg (by norm_num)
        (cutoffTailCap_nonneg (reverseWindowLinearBound q V w)))
    calc
      _ ≤ (φ⁻¹) ^ w *
          (2 * cutoffTailCap (reverseWindowLinearBound q V w)) *
          (2 * cutoffConjugateCap Tconj H) :=
        mul_le_mul_of_nonneg_right hfirst hcH0
      _ ≤ (φ⁻¹) ^ w *
          (2 * cutoffTailCap (reverseWindowLinearBound q V w)) *
          (2 * cutoffConjugateCap Tconj
            (reverseWindowLinearBound q V w)) :=
        mul_le_mul_of_nonneg_left hcmono hbaseB0
      _ < ε := hnumK.2.2
  apply logarithmic_reverseWindow_finsetBlock_pair_contradiction
    n hpos hmono c hc hratio qden hqden T Tconj hsum htotal
      q hq K G Bval w Dtarget Q X V v ((w + 1) ^ 3) {K}
  · exact hKG
  · dsimp [Bval]
    exact mul_pos (hpos K) (pow_pos (by dsimp [W]; omega) 8)
  · simpa [Bval, W] using hvalues
  · exact hw
  · exact hwD
  · exact hDlt
  · positivity
  · exact hQ
  · exact hXcenter
  · intro j _ _ _
    exact hV j
  · simpa [w] using hsizeK
  · simp
  · intro k hk
    have hkEq : k = K := Finset.mem_singleton.mp hk
    subst k
    exact hKG
  · exact hPX
  · intro k hk
    have hkEq : k = K := Finset.mem_singleton.mp hk
    subst k
    exact dvd_trans (fibLambertPeriod_dvd_four_mul (n K))
      ⟨2 ^ V, by ring⟩
  · intro s hs
    simpa [Dtarget, selectedPositionFinsetCoeff_singleton,
      dyadicChainCoeff] using hpre s hs
  · simpa [Dtarget, selectedPositionFinsetCoeff_singleton,
      dyadicChainCoeff] using hmid
  · intro s hs
    simpa [Dtarget, selectedPositionFinsetCoeff_singleton,
      dyadicChainCoeff] using hpost s hs
  · simpa [H, W] using hdensity
  · simpa [H] using hpostCap
  · simpa [H, ε] using hpreCap

end Research

/-!
# Erdős problem 267
-/

namespace Research

open Real goldenRatio

/-- Every positive strictly increasing Fibonacci reciprocal subseries with a
uniform multiplicative index gap greater than one is irrational. -/
theorem irrational_reciprocal_fib_of_ratio_gap
    (n : ℕ → ℕ) (hpos : ∀ k : ℕ, 0 < n k)
    (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k : ℕ, c * (n k : ℝ) ≤ n (k + 1)) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  rw [irrational_iff_ne_rational]
  intro a b hb hrat
  let r : ℚ := (a : ℚ) / (b : ℚ)
  have hcast : (r : ℝ) = (a : ℝ) / (b : ℝ) := by
    simp [r]
  have hrat' : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) = (r : ℝ) :=
    hrat.trans hcast.symm
  obtain ⟨q, hqpos, hq⟩ := exists_ratio_doubling_block c hc
  obtain ⟨cfg, _hcover, hbounded, _htails⟩ :=
    exists_covered_boundedOrder_remainder_of_rational
      n hpos hmono c hc hratio q hqpos hq r hrat'
  obtain ⟨V, hV⟩ := hbounded
  have hposCfg := cfg.sequence_pos hpos
  have hmonoCfg := cfg.sequence_strictMono hmono
  have hratioCfg := cfg.sequence_ratioGap hmono c hratio
  obtain ⟨qden, hqden, hpair⟩ := cfg.total_pair
  have hsumCfg :=
    hasSum_selectedFibLambertCoeff cfg.sequence hposCfg hmonoCfg
  exact boundedOrder_scaledGolden_contradiction
    cfg.sequence hposCfg hmonoCfg c hc hratioCfg
      qden hqden
      ((√5)⁻¹ * (∑' t : ℕ,
        (Nat.fib (cfg.sequence t) : ℝ)⁻¹))
      cfg.conjugate hsumCfg
      (by simpa [DyadicDeletionConfig.sequence] using hpair)
      V hV q hqpos hq

end Research
