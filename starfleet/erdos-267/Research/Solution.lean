import Mathlib

/-!
# The elementary denominator method at the endpoint ratio two
-/

namespace Research

open Filter Topology
open Real goldenRatio
open scoped BigOperators

/-- A sharp upper bound for Fibonacci numbers, in a division-free form. -/
theorem goldenRatio_mul_fib_le_pow (n : ℕ) :
    φ * (Nat.fib n : ℝ) ≤ φ ^ n := by
  cases n with
  | zero => simp
  | succ k =>
      have h := Real.goldenRatio_mul_fib_succ_add_fib k
      have hf : (0 : ℝ) ≤ Nat.fib k := by positivity
      nlinarith

/-- A sharp lower bound for positive-index Fibonacci numbers, also written
without division. -/
theorem goldenRatio_pow_le_sq_mul_fib (n : ℕ) (hn : 0 < n) :
    φ ^ n ≤ φ ^ 2 * (Nat.fib n : ℝ) := by
  obtain ⟨k, rfl⟩ := Nat.exists_eq_succ_of_ne_zero (Nat.ne_of_gt hn)
  have h := Real.goldenRatio_mul_fib_succ_add_fib k
  have hmono : (Nat.fib k : ℝ) ≤ Nat.fib (k + 1) := by
    exact_mod_cast Nat.fib_le_fib_succ
  calc
    φ ^ (k + 1) = φ * (Nat.fib (k + 1) : ℝ) + Nat.fib k := h.symm
    _ ≤ φ * (Nat.fib (k + 1) : ℝ) + Nat.fib (k + 1) := by gcongr
    _ = φ ^ 2 * (Nat.fib (k + 1) : ℝ) := by rw [Real.goldenRatio_sq]; ring

/-- Under doubling gaps, all indices before `n N`, together with one extra copy
of the first index, fit below `n N`. -/
theorem sum_range_add_first_le_of_doubling
    (n : ℕ → ℕ) (hdouble : ∀ k : ℕ, 2 * n k ≤ n (k + 1)) :
    ∀ N : ℕ, (∑ k ∈ Finset.range N, n k) + n 0 ≤ n N := by
  intro N
  induction N with
  | zero => simp
  | succ N ih =>
      rw [Finset.sum_range_succ]
      have hd := hdouble N
      omega

/-- Strict monotonicity gives the additive lower bound needed for every shifted
tail. -/
theorem add_index_le_of_strictMono (n : ℕ → ℕ) (hmono : StrictMono n)
    (N j : ℕ) : n N + j ≤ n (N + j) := by
  simpa [add_comm] using hmono.add_le_nat j N

/-- A reciprocal Fibonacci term is bounded by a geometric term in the inverse
golden ratio. -/
theorem inv_fib_le_golden_geometric (m : ℕ) (hm : 0 < m) :
    (Nat.fib m : ℝ)⁻¹ ≤ φ ^ 2 * (φ⁻¹) ^ m := by
  have hf : (0 : ℝ) < Nat.fib m := by exact_mod_cast Nat.fib_pos.mpr hm
  have hp : 0 < φ ^ m := pow_pos Real.goldenRatio_pos _
  have h := goldenRatio_pow_le_sq_mul_fib m hm
  rw [inv_pow]
  have hdiv : (1 : ℝ) / Nat.fib m ≤ φ ^ 2 / φ ^ m :=
    (div_le_div_iff₀ hf hp).2 (by simpa [mul_comm] using h)
  simpa [one_div, div_eq_mul_inv, mul_assoc] using hdiv

/-- Every shifted reciprocal-Fibonacci tail is summable and admits a uniform
geometric upper bound. -/
theorem summable_and_tsum_shift_le
    (n : ℕ → ℕ) (hpos : ∀ k : ℕ, 0 < n k) (hmono : StrictMono n) (N : ℕ) :
    Summable (fun j : ℕ => (Nat.fib (n (N + j)) : ℝ)⁻¹) ∧
      (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤
        (φ ^ 2 * (φ⁻¹) ^ (n N)) * φ ^ 2 := by
  let r : ℝ := φ⁻¹
  let C : ℝ := φ ^ 2 * r ^ (n N)
  have hr0 : 0 ≤ r := by dsimp [r]; exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by dsimp [r]; exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have habs : |r| < 1 := by simpa [abs_of_nonneg hr0] using hr1
  have hg : Summable (fun j : ℕ => C * r ^ j) := by
    have h := (summable_geometric_of_abs_lt_one habs).const_smul C
    simpa only [smul_eq_mul] using h
  have hle (j : ℕ) :
      (Nat.fib (n (N + j)) : ℝ)⁻¹ ≤ C * r ^ j := by
    have hidx : n N + j ≤ n (N + j) := add_index_le_of_strictMono n hmono N j
    have hfirst := inv_fib_le_golden_geometric (n (N + j)) (hpos (N + j))
    have hpow : r ^ (n (N + j)) ≤ r ^ (n N + j) :=
      (pow_right_anti₀ hr0 hr1.le) hidx
    calc
      (Nat.fib (n (N + j)) : ℝ)⁻¹ ≤ φ ^ 2 * r ^ (n (N + j)) := by
        simpa [r] using hfirst
      _ ≤ φ ^ 2 * r ^ (n N + j) := by gcongr
      _ = C * r ^ j := by simp [C, pow_add]; ring
  have hf : Summable (fun j : ℕ => (Nat.fib (n (N + j)) : ℝ)⁻¹) :=
    hg.of_nonneg_of_le (fun _ => inv_nonneg.mpr (by positivity)) hle
  refine ⟨hf, ?_⟩
  have hsumle := Summable.tsum_le_tsum hle hf hg
  have hgeom : (1 - r)⁻¹ = φ ^ 2 := by
    apply inv_eq_of_mul_eq_one_right
    dsimp [r]
    field_simp [Real.goldenRatio_ne_zero]
    nlinarith [Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 5)]
  have hsumg : (∑' j : ℕ, C * r ^ j) = C * (1 - r)⁻¹ := by
    have h := (hasSum_geometric_of_abs_lt_one habs).const_smul C
    simpa only [smul_eq_mul] using h.tsum_eq
  rw [hsumg, hgeom] at hsumle
  simpa [C, r] using hsumle

/-- Product form of the upper golden-ratio bound for a finite collection of
Fibonacci numbers. -/
theorem prod_fib_le_golden_geometric (n : ℕ → ℕ) (N : ℕ) :
    (∏ k ∈ Finset.range N, (Nat.fib (n k) : ℝ)) ≤
      (φ⁻¹) ^ N * φ ^ (∑ k ∈ Finset.range N, n k) := by
  have hterm (k : ℕ) :
      (Nat.fib (n k) : ℝ) ≤ φ⁻¹ * φ ^ (n k) := by
    have h := goldenRatio_mul_fib_le_pow (n k)
    have hp := Real.goldenRatio_pos
    rw [← div_eq_inv_mul]
    exact (le_div_iff₀ hp).2 (by simpa [mul_comm] using h)
  calc
    (∏ k ∈ Finset.range N, (Nat.fib (n k) : ℝ)) ≤
        ∏ k ∈ Finset.range N, (φ⁻¹ * φ ^ (n k)) := by
          apply Finset.prod_le_prod
          · intro k hk
            positivity
          · intro k hk
            exact hterm k
    _ = (φ⁻¹) ^ N * φ ^ (∑ k ∈ Finset.range N, n k) := by
      rw [Finset.prod_mul_distrib, Finset.prod_const, Finset.card_range,
        Finset.prod_pow_eq_pow_sum]

/-- Cancellation inequality between powers of the golden ratio and its
inverse. -/
theorem golden_pow_mul_inv_pow_le (a b c : ℕ) (h : a + c ≤ b) :
    φ ^ a * (φ⁻¹) ^ b ≤ (φ⁻¹) ^ c := by
  have hr0 : 0 ≤ φ⁻¹ := (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : φ⁻¹ ≤ 1 := (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio).le
  calc
    φ ^ a * (φ⁻¹) ^ b ≤ φ ^ a * (φ⁻¹) ^ (a + c) := by
      exact mul_le_mul_of_nonneg_left ((pow_right_anti₀ hr0 hr1) h) (by positivity)
    _ = (φ⁻¹) ^ c := by
      rw [pow_add]
      calc
        φ ^ a * ((φ⁻¹) ^ a * (φ⁻¹) ^ c) =
            (φ * φ⁻¹) ^ a * (φ⁻¹) ^ c := by rw [mul_pow]; ring
        _ = (φ⁻¹) ^ c := by
          have hmul : φ * φ⁻¹ = (1 : ℝ) := mul_inv_cancel₀ Real.goldenRatio_ne_zero
          rw [hmul, one_pow, one_mul]

/-- At ratio at least two, the common product denominator times every shifted
tail tends to zero.  This includes the endpoint omitted by the cruder exponent
count. -/
theorem tendsto_prod_fib_mul_tail_zero_of_doubling
    (n : ℕ → ℕ) (hpos : ∀ k : ℕ, 0 < n k)
    (hmono : StrictMono n) (hdouble : ∀ k : ℕ, 2 * n k ≤ n (k + 1)) :
    Tendsto
      (fun N : ℕ =>
        (∏ k ∈ Finset.range N, (Nat.fib (n k) : ℝ)) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹))
      atTop (𝓝 0) := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by dsimp [r]; exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by dsimp [r]; exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hbound (N : ℕ) :
      (∏ k ∈ Finset.range N, (Nat.fib (n k) : ℝ)) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤
        φ ^ 4 * r ^ (N + n 0) := by
    have hprod := prod_fib_le_golden_geometric n N
    have htail := (summable_and_tsum_shift_le n hpos hmono N).2
    have hsumidx := sum_range_add_first_le_of_doubling n hdouble N
    have hcancel := golden_pow_mul_inv_pow_le
      (∑ k ∈ Finset.range N, n k) (n N) (n 0) hsumidx
    calc
      (∏ k ∈ Finset.range N, (Nat.fib (n k) : ℝ)) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤
          (r ^ N * φ ^ (∑ k ∈ Finset.range N, n k)) *
            ((φ ^ 2 * r ^ (n N)) * φ ^ 2) := by gcongr
      _ = φ ^ 4 * r ^ N *
          (φ ^ (∑ k ∈ Finset.range N, n k) * r ^ (n N)) := by
            dsimp [r] at hcancel ⊢
            ring
      _ ≤ φ ^ 4 * r ^ N * r ^ (n 0) := by
            exact mul_le_mul_of_nonneg_left (by simpa [r] using hcancel) (by positivity)
      _ = φ ^ 4 * r ^ (N + n 0) := by rw [pow_add]; ring
  have hnonneg (N : ℕ) :
      0 ≤ (∏ k ∈ Finset.range N, (Nat.fib (n k) : ℝ)) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) := by
    positivity
  have hmajor : Tendsto (fun N : ℕ => φ ^ 4 * r ^ (N + n 0)) atTop (𝓝 0) := by
    have hp := tendsto_pow_atTop_nhds_zero_of_lt_one hr0 hr1
    simpa [pow_add, mul_assoc] using
      (tendsto_const_nhds.mul (hp.mul_const (r ^ (n 0))))
  exact squeeze_zero hnonneg hbound hmajor

end Research

/-!
# A product-denominator irrationality criterion
-/

namespace Research

open Filter Topology
open scoped BigOperators

/-- Product common denominator for the first `N` reciprocal terms. -/
def reciprocalDenomProd (d : ℕ → ℕ) (N : ℕ) : ℕ :=
  ∏ k ∈ Finset.range N, d k

/-- Integer numerator obtained after scaling the first `N` reciprocal terms by
the product common denominator. -/
def reciprocalScaledNumerator (d : ℕ → ℕ) (N : ℕ) : ℕ :=
  ∑ k ∈ Finset.range N, reciprocalDenomProd d N / d k

/-- Multiplying a finite reciprocal sum by the product denominator gives the
explicit integer numerator. -/
theorem denomProd_mul_partialSum_eq_scaledNumerator
    (d : ℕ → ℕ) (hpos : ∀ k : ℕ, 0 < d k) (N : ℕ) :
    (reciprocalDenomProd d N : ℝ) *
        (∑ k ∈ Finset.range N, (d k : ℝ)⁻¹) =
      (reciprocalScaledNumerator d N : ℝ) := by
  rw [Finset.mul_sum]
  simp only [reciprocalScaledNumerator, Nat.cast_sum]
  apply Finset.sum_congr rfl
  intro k hk
  have hdvd : d k ∣ reciprocalDenomProd d N := by
    exact Finset.dvd_prod_of_mem d hk
  have hcast : (d k : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt (hpos k))
  rw [Nat.cast_div hdvd hcast]
  simp [div_eq_mul_inv]

/-- Mahler's elementary criterion specialized to unit fractions: if the product
common denominator times the positive shifted tail tends to zero, then the
series sum is irrational. -/
theorem irrational_tsum_reciprocals_of_prod_tail_zero
    (d : ℕ → ℕ) (hpos : ∀ k : ℕ, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hlim : Tendsto
      (fun N : ℕ =>
        (reciprocalDenomProd d N : ℝ) *
          (∑' j : ℕ, (d (N + j) : ℝ)⁻¹))
      atTop (𝓝 0)) :
    Irrational (∑' k : ℕ, (d k : ℝ)⁻¹) := by
  rw [irrational_iff_ne_rational]
  intro a b hb hrat
  let S : ℝ := ∑' k : ℕ, (d k : ℝ)⁻¹
  let D : ℕ → ℕ := fun N => reciprocalDenomProd d N
  let A : ℕ → ℕ := fun N => reciprocalScaledNumerator d N
  let P : ℕ → ℝ := fun N => ∑ k ∈ Finset.range N, (d k : ℝ)⁻¹
  let T : ℕ → ℝ := fun N => ∑' j : ℕ, (d (N + j) : ℝ)⁻¹
  have hDpos (N : ℕ) : 0 < D N := by
    dsimp [D, reciprocalDenomProd]
    exact Finset.prod_pos fun k hk => hpos k
  have hsplit (N : ℕ) : P N + T N = S := by
    have h := hsum.sum_add_tsum_nat_add N
    simpa [P, T, S, add_comm] using h
  have hTpos (N : ℕ) : 0 < T N := by
    have ht : Summable (fun j : ℕ => (d (N + j) : ℝ)⁻¹) := by
      have := (summable_nat_add_iff N).2 hsum
      simpa [add_comm] using this
    exact ht.tsum_pos (fun _ => inv_nonneg.mpr (by positivity)) 0
      (inv_pos.mpr (by exact_mod_cast hpos N))
  have hDP (N : ℕ) : (D N : ℝ) * P N = (A N : ℝ) := by
    simpa [D, A, P] using denomProd_mul_partialSum_eq_scaledNumerator d hpos N
  have hlower (N : ℕ) :
      (1 : ℝ) ≤ |(b : ℝ)| * ((D N : ℝ) * T N) := by
    let z : ℤ := a * (D N : ℤ) - b * (A N : ℤ)
    have hinter :
        (b : ℝ) * (D N : ℝ) * T N = (z : ℝ) := by
      have hT : T N = S - P N := by linarith [hsplit N]
      rw [hT]
      change (b : ℝ) * (D N : ℝ) * (S - P N) = (z : ℝ)
      have hrat' : S = (a : ℝ) / (b : ℝ) := by simpa [S] using hrat
      rw [hrat']
      calc
        (b : ℝ) * (D N : ℝ) * ((a : ℝ) / (b : ℝ) - P N) =
            (a : ℝ) * (D N : ℝ) - (b : ℝ) * ((D N : ℝ) * P N) := by
              field_simp [Int.cast_ne_zero.mpr hb]
        _ = (a : ℝ) * (D N : ℝ) - (b : ℝ) * (A N : ℝ) := by rw [hDP]
        _ = (z : ℝ) := by dsimp [z]; push_cast; ring
    have hz : z ≠ 0 := by
      intro hz0
      have hleft : (b : ℝ) * (D N : ℝ) * T N ≠ 0 := by
        exact mul_ne_zero (mul_ne_zero (Int.cast_ne_zero.mpr hb)
          (by exact_mod_cast (Nat.ne_of_gt (hDpos N)))) (ne_of_gt (hTpos N))
      apply hleft
      rw [hinter, hz0]
      norm_num
    have hzlower : (1 : ℝ) ≤ |(z : ℝ)| := by
      exact_mod_cast Int.one_le_abs hz
    have habs : |(z : ℝ)| = |(b : ℝ)| * ((D N : ℝ) * T N) := by
      have hDabs : |(D N : ℝ)| = (D N : ℝ) :=
        abs_of_pos (by exact_mod_cast hDpos N)
      have hTabs : |T N| = T N := abs_of_pos (hTpos N)
      rw [← hinter, abs_mul, abs_mul, hDabs, hTabs]
      ring
    rwa [habs] at hzlower
  have hlim' : Tendsto (fun N : ℕ => |(b : ℝ)| * ((D N : ℝ) * T N))
      atTop (𝓝 0) := by
    have hc : Tendsto (fun _ : ℕ => |(b : ℝ)|) atTop (𝓝 |(b : ℝ)|) :=
      tendsto_const_nhds
    have h := hc.mul hlim
    simpa [D, T, mul_assoc] using h
  have hfalse : (1 : ℝ) ≤ 0 := ge_of_tendsto' hlim' hlower
  norm_num at hfalse

/-- Erdős Problem 267 has an affirmative answer at the full endpoint
`n_{k+1}/n_k ≥ 2` (not merely for a strict bound above two). -/
theorem irrational_reciprocal_fib_of_doubling
    (n : ℕ → ℕ) (hpos : ∀ k : ℕ, 0 < n k)
    (hmono : StrictMono n) (hdouble : ∀ k : ℕ, 2 * n k ≤ n (k + 1)) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  apply irrational_tsum_reciprocals_of_prod_tail_zero
    (d := fun k => Nat.fib (n k))
  · intro k
    exact Nat.fib_pos.mpr (hpos k)
  · have h := (summable_and_tsum_shift_le n hpos hmono 0).1
    simpa using h
  · simpa [reciprocalDenomProd] using
      tendsto_prod_fib_mul_tail_zero_of_doubling n hpos hmono hdouble

end Research

/-!
# Divisibility-chain subclasses
-/

namespace Research

open Filter Topology
open Real goldenRatio
open scoped BigOperators

/-- Mahler's criterion with an arbitrary integer scaling denominator for each
partial sum. -/
theorem irrational_tsum_unitFractions_of_scaled_tail_zero
    (d D A : ℕ → ℕ) (hpos : ∀ k : ℕ, 0 < d k)
    (hDpos : ∀ N : ℕ, 0 < D N)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hscaled : ∀ N : ℕ,
      (D N : ℝ) * (∑ k ∈ Finset.range N, (d k : ℝ)⁻¹) = (A N : ℝ))
    (hlim : Tendsto
      (fun N : ℕ => (D N : ℝ) * (∑' j : ℕ, (d (N + j) : ℝ)⁻¹))
      atTop (𝓝 0)) :
    Irrational (∑' k : ℕ, (d k : ℝ)⁻¹) := by
  rw [irrational_iff_ne_rational]
  intro a b hb hrat
  let S : ℝ := ∑' k : ℕ, (d k : ℝ)⁻¹
  let P : ℕ → ℝ := fun N => ∑ k ∈ Finset.range N, (d k : ℝ)⁻¹
  let T : ℕ → ℝ := fun N => ∑' j : ℕ, (d (N + j) : ℝ)⁻¹
  have hsplit (N : ℕ) : P N + T N = S := by
    have h := hsum.sum_add_tsum_nat_add N
    simpa [P, T, S, add_comm] using h
  have hTpos (N : ℕ) : 0 < T N := by
    have ht : Summable (fun j : ℕ => (d (N + j) : ℝ)⁻¹) := by
      have := (summable_nat_add_iff N).2 hsum
      simpa [add_comm] using this
    exact ht.tsum_pos (fun _ => inv_nonneg.mpr (by positivity)) 0
      (inv_pos.mpr (by exact_mod_cast hpos N))
  have hDP (N : ℕ) : (D N : ℝ) * P N = (A N : ℝ) := by
    simpa [P] using hscaled N
  have hlower (N : ℕ) : (1 : ℝ) ≤ |(b : ℝ)| * ((D N : ℝ) * T N) := by
    let z : ℤ := a * (D N : ℤ) - b * (A N : ℤ)
    have hinter : (b : ℝ) * (D N : ℝ) * T N = (z : ℝ) := by
      have hT : T N = S - P N := by linarith [hsplit N]
      rw [hT]
      change (b : ℝ) * (D N : ℝ) * (S - P N) = (z : ℝ)
      have hrat' : S = (a : ℝ) / (b : ℝ) := by simpa [S] using hrat
      rw [hrat']
      calc
        (b : ℝ) * (D N : ℝ) * ((a : ℝ) / (b : ℝ) - P N) =
            (a : ℝ) * (D N : ℝ) - (b : ℝ) * ((D N : ℝ) * P N) := by
              field_simp [Int.cast_ne_zero.mpr hb]
        _ = (a : ℝ) * (D N : ℝ) - (b : ℝ) * (A N : ℝ) := by rw [hDP]
        _ = (z : ℝ) := by dsimp [z]; push_cast; ring
    have hz : z ≠ 0 := by
      intro hz0
      have hleft : (b : ℝ) * (D N : ℝ) * T N ≠ 0 := by
        exact mul_ne_zero (mul_ne_zero (Int.cast_ne_zero.mpr hb)
          (by exact_mod_cast (Nat.ne_of_gt (hDpos N)))) (ne_of_gt (hTpos N))
      apply hleft
      rw [hinter, hz0]
      norm_num
    have hzlower : (1 : ℝ) ≤ |(z : ℝ)| := by
      exact_mod_cast Int.one_le_abs hz
    have habs : |(z : ℝ)| = |(b : ℝ)| * ((D N : ℝ) * T N) := by
      have hDabs : |(D N : ℝ)| = (D N : ℝ) :=
        abs_of_pos (by exact_mod_cast hDpos N)
      have hTabs : |T N| = T N := abs_of_pos (hTpos N)
      rw [← hinter, abs_mul, abs_mul, hDabs, hTabs]
      ring
    rwa [habs] at hzlower
  have hlim' : Tendsto (fun N : ℕ => |(b : ℝ)| * ((D N : ℝ) * T N))
      atTop (𝓝 0) := by
    have hc : Tendsto (fun _ : ℕ => |(b : ℝ)|) atTop (𝓝 |(b : ℝ)|) :=
      tendsto_const_nhds
    have h := hc.mul hlim
    simpa [T, mul_assoc] using h
  have hfalse : (1 : ℝ) ≤ 0 := ge_of_tendsto' hlim' hlower
  norm_num at hfalse

/-- A simple endpoint denominator for a nested divisibility chain. -/
def nestedDenom (d : ℕ → ℕ) : ℕ → ℕ
  | 0 => 1
  | N + 1 => d N

/-- Corresponding scaled numerator. -/
def nestedNumerator (d : ℕ → ℕ) (N : ℕ) : ℕ :=
  ∑ k ∈ Finset.range N, nestedDenom d N / d k

/-- Divisibility propagates along a chain. -/
theorem dvd_of_dvd_succ_chain (d : ℕ → ℕ) (hchain : ∀ k, d k ∣ d (k + 1))
    {i j : ℕ} (hij : i ≤ j) : d i ∣ d j := by
  induction j, hij using Nat.le_induction with
  | base => exact dvd_refl _
  | succ j hij ih => exact ih.trans (hchain j)

/-- Every denominator occurring before `N` divides the nested endpoint
denominator. -/
theorem dvd_nestedDenom (d : ℕ → ℕ) (hchain : ∀ k, d k ∣ d (k + 1))
    {k N : ℕ} (hk : k ∈ Finset.range N) : d k ∣ nestedDenom d N := by
  have hklt : k < N := Finset.mem_range.mp hk
  cases N with
  | zero => simp at hklt
  | succ M =>
      dsimp [nestedDenom]
      exact dvd_of_dvd_succ_chain d hchain (Nat.le_of_lt_succ hklt)

/-- The nested endpoint clears every finite reciprocal sum. -/
theorem nestedDenom_mul_partialSum_eq
    (d : ℕ → ℕ) (hpos : ∀ k, 0 < d k) (hchain : ∀ k, d k ∣ d (k + 1))
    (N : ℕ) :
    (nestedDenom d N : ℝ) * (∑ k ∈ Finset.range N, (d k : ℝ)⁻¹) =
      (nestedNumerator d N : ℝ) := by
  rw [Finset.mul_sum]
  simp only [nestedNumerator, Nat.cast_sum]
  apply Finset.sum_congr rfl
  intro k hk
  have hdvd := dvd_nestedDenom d hchain hk
  have hcast : (d k : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt (hpos k))
  rw [Nat.cast_div hdvd hcast]
  simp [div_eq_mul_inv]

/-- If successive index gaps dominate the step number, the single nested
endpoint denominator times the tail tends to zero. -/
theorem tendsto_nested_fib_denom_mul_tail_zero
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hgap : ∀ k, n k + k ≤ n (k + 1)) :
    Tendsto
      (fun N : ℕ =>
        (nestedDenom (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹))
      atTop (𝓝 0) := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by dsimp [r]; exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by dsimp [r]; exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hrpow (m : ℕ) : r ^ m ≤ 1 := by
    simpa using (pow_le_one₀ hr0 hr1.le)
  have hbound (N : ℕ) :
      (nestedDenom (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤ φ ^ 4 * r ^ N := by
    have htail := (summable_and_tsum_shift_le n hpos hmono N).2
    cases N with
    | zero =>
        rw [nestedDenom]
        norm_num only [Nat.cast_one]
        calc
          (1 : ℝ) * (∑' j : ℕ, (Nat.fib (n (0 + j)) : ℝ)⁻¹) ≤
              (φ ^ 2 * r ^ (n 0)) * φ ^ 2 := by simpa [r] using htail
          _ = φ ^ 4 * r ^ (n 0) := by ring
          _ ≤ φ ^ 4 * 1 := mul_le_mul_of_nonneg_left (hrpow (n 0)) (by positivity)
          _ = φ ^ 4 * r ^ 0 := by simp
    | succ M =>
        have hfib : (Nat.fib (n M) : ℝ) ≤ r * φ ^ (n M) := by
          have h := goldenRatio_mul_fib_le_pow (n M)
          dsimp [r]
          rw [← div_eq_inv_mul]
          exact (le_div_iff₀ Real.goldenRatio_pos).2 (by simpa [mul_comm] using h)
        have hcancel := golden_pow_mul_inv_pow_le (n M) (n (M + 1)) M (hgap M)
        dsimp [nestedDenom]
        calc
          (Nat.fib (n M) : ℝ) *
              (∑' j : ℕ, (Nat.fib (n (M + 1 + j)) : ℝ)⁻¹) ≤
              (r * φ ^ (n M)) * ((φ ^ 2 * r ^ (n (M + 1))) * φ ^ 2) := by
                gcongr
          _ = φ ^ 4 * r * (φ ^ (n M) * r ^ (n (M + 1))) := by ring
          _ ≤ φ ^ 4 * r * r ^ M := by
                exact mul_le_mul_of_nonneg_left (by simpa [r] using hcancel) (by positivity)
          _ = φ ^ 4 * r ^ (M + 1) := by rw [pow_succ]; ring
  have hnonneg (N : ℕ) :
      0 ≤ (nestedDenom (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) := by positivity
  have hmajor : Tendsto (fun N : ℕ => φ ^ 4 * r ^ N) atTop (𝓝 0) := by
    have hc : Tendsto (fun _ : ℕ => φ ^ 4) atTop (𝓝 (φ ^ 4)) := tendsto_const_nhds
    simpa using hc.mul (tendsto_pow_atTop_nhds_zero_of_lt_one hr0 hr1)
  exact squeeze_zero hnonneg hbound hmajor

/-- A uniform real ratio gap gives the expected geometric lower bound on the
indices. -/
theorem index_geometric_lower_of_ratio
    (n : ℕ → ℕ) (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1)) :
    ∀ k, (n 0 : ℝ) * c ^ k ≤ n k := by
  intro k
  induction k with
  | zero => simp
  | succ k ih =>
      calc
        (n 0 : ℝ) * c ^ (k + 1) = c * ((n 0 : ℝ) * c ^ k) := by rw [pow_succ]; ring
        _ ≤ c * (n k : ℝ) := mul_le_mul_of_nonneg_left ih (le_of_lt (lt_trans zero_lt_one hc))
        _ ≤ n (k + 1) := hratio k

/-- After deleting finitely many terms, a uniform ratio gap forces the additive
gap to dominate the new term number. -/
theorem exists_shift_index_gap_of_ratio
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1)) :
    ∃ K : ℕ, ∀ k : ℕ, n (K + k) + k ≤ n (K + k + 1) := by
  have hdecay := tendsto_pow_const_div_const_pow_of_one_lt 1 hc
  have heps : 0 < c - 1 := sub_pos.mpr hc
  have hev : ∀ᶠ q : ℕ in atTop, (q : ℝ) ^ 1 / c ^ q < c - 1 :=
    (tendsto_order.1 hdecay).2 _ heps
  rcases (eventually_atTop.1 hev) with ⟨K, hK⟩
  refine ⟨K, fun k => ?_⟩
  let q := K + k
  have hqK : K ≤ q := by dsimp [q]; omega
  have hsmall := hK q hqK
  simp only [pow_one] at hsmall
  have hcq : 0 < c ^ q := pow_pos (lt_trans zero_lt_one hc) _
  have hqexp : (q : ℝ) < (c - 1) * c ^ q := by
    exact (div_lt_iff₀ hcq).mp hsmall
  have hgeom := index_geometric_lower_of_ratio n c hc hratio q
  have hn0 : (1 : ℝ) ≤ n 0 := by exact_mod_cast hpos 0
  have hcqn : c ^ q ≤ (n q : ℝ) := by
    calc
      c ^ q ≤ (n 0 : ℝ) * c ^ q := by nlinarith [pow_nonneg (le_of_lt (lt_trans zero_lt_one hc)) q]
      _ ≤ n q := hgeom
  have hq_n : (q : ℝ) < (c - 1) * (n q : ℝ) :=
    lt_of_lt_of_le hqexp (mul_le_mul_of_nonneg_left hcqn heps.le)
  have hstep := hratio q
  have hqstep : (n q : ℝ) + q < n (q + 1) := by
    nlinarith
  have hnat : n q + q ≤ n (q + 1) := by exact_mod_cast (le_of_lt hqstep)
  dsimp [q] at hnat ⊢
  omega

/-- Every positive Fibonacci reciprocal series whose indices form a divisibility
chain and whose additive gaps eventually dominate the term number is
irrational. -/
theorem irrational_reciprocal_fib_of_nested_indices
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hdiv : ∀ k, n k ∣ n (k + 1))
    (hgap : ∀ k, n k + k ≤ n (k + 1)) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  let d : ℕ → ℕ := fun k => Nat.fib (n k)
  have hdpos : ∀ k, 0 < d k := fun k => Nat.fib_pos.mpr (hpos k)
  have hdchain : ∀ k, d k ∣ d (k + 1) := fun k => Nat.fib_dvd _ _ (hdiv k)
  apply irrational_tsum_unitFractions_of_scaled_tail_zero d
    (nestedDenom d) (nestedNumerator d) hdpos
  · intro N
    cases N <;> simp [nestedDenom, hdpos]
  · have h := (summable_and_tsum_shift_le n hpos hmono 0).1
    simpa [d] using h
  · exact nestedDenom_mul_partialSum_eq d hdpos hdchain
  · simpa [d] using tendsto_nested_fib_denom_mul_tail_zero n hpos hmono hgap

/-- The full nested-divisibility subclass of Erdős Problem 267: every uniform
ratio constant strictly above one suffices. -/
theorem irrational_reciprocal_fib_of_nested_ratio
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hdiv : ∀ k, n k ∣ n (k + 1))
    (c : ℝ) (hc : 1 < c) (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1)) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  obtain ⟨K, hK⟩ := exists_shift_index_gap_of_ratio n hpos c hc hratio
  let m : ℕ → ℕ := fun k => n (K + k)
  have hmpos : ∀ k, 0 < m k := fun k => hpos (K + k)
  have hmmono : StrictMono m := hmono.comp add_right_strictMono
  have hmdiv : ∀ k, m k ∣ m (k + 1) := by
    intro k
    dsimp [m]
    simpa [add_assoc] using hdiv (K + k)
  have hmgap : ∀ k, m k + k ≤ m (k + 1) := by
    intro k
    dsimp [m]
    simpa [add_assoc] using hK k
  have htail := irrational_reciprocal_fib_of_nested_indices m hmpos hmmono hmdiv hmgap
  let q : ℚ := ∑ k ∈ Finset.range K, (Nat.fib (n k) : ℚ)⁻¹
  have hqcast :
      (q : ℝ) = ∑ k ∈ Finset.range K, (Nat.fib (n k) : ℝ)⁻¹ := by
    simp [q]
  have hsum := (summable_and_tsum_shift_le n hpos hmono 0).1
  have hsplit := hsum.sum_add_tsum_nat_add K
  have heq :
      (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
        (q : ℝ) + ∑' k : ℕ, (Nat.fib (m k) : ℝ)⁻¹ := by
    rw [hqcast]
    symm
    simpa [m, add_comm] using hsplit
  rw [heq]
  exact htail.ratCast_add q

end Research

/-!
# Least-common-multiple denominator criterion
-/

namespace Research

open Filter Topology
open Real goldenRatio
open scoped BigOperators

/-- Least common multiple of the first `N` denominators. -/
def reciprocalLcm (d : ℕ → ℕ) (N : ℕ) : ℕ :=
  (Finset.range N).lcm d

/-- Numerator after scaling a partial reciprocal sum by its lcm. -/
def reciprocalLcmNumerator (d : ℕ → ℕ) (N : ℕ) : ℕ :=
  ∑ k ∈ Finset.range N, reciprocalLcm d N / d k

/-- A finite reciprocal sum is cleared by the lcm of its denominators. -/
theorem reciprocalLcm_mul_partialSum_eq
    (d : ℕ → ℕ) (hpos : ∀ k, 0 < d k) (N : ℕ) :
    (reciprocalLcm d N : ℝ) * (∑ k ∈ Finset.range N, (d k : ℝ)⁻¹) =
      (reciprocalLcmNumerator d N : ℝ) := by
  rw [Finset.mul_sum]
  simp only [reciprocalLcmNumerator, Nat.cast_sum]
  apply Finset.sum_congr rfl
  intro k hk
  have hdvd : d k ∣ reciprocalLcm d N := Finset.dvd_lcm hk
  have hcast : (d k : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt (hpos k))
  rw [Nat.cast_div hdvd hcast]
  simp [div_eq_mul_inv]

/-- Positivity of the finite lcm when all entries are positive. -/
theorem reciprocalLcm_pos (d : ℕ → ℕ) (hpos : ∀ k, 0 < d k) (N : ℕ) :
    0 < reciprocalLcm d N := by
  apply Nat.pos_of_ne_zero
  rw [ne_eq, reciprocalLcm, Finset.lcm_eq_zero_iff]
  push Not
  intro k hk
  exact Nat.ne_of_gt (hpos k)

/-- If `g` divides both a new denominator `b` and an existing common
multiple `B` of `a`, then adjoining `b` costs at most the quotient `b/g`. -/
theorem lcm_dvd_mul_div_of_common_dvd
    (a b B g : ℕ) (hg : 0 < g) (haB : a ∣ B) (hgB : g ∣ B) (hgb : g ∣ b) :
    Nat.lcm a b ∣ B * (b / g) := by
  apply Nat.lcm_dvd
  · exact haB.trans (dvd_mul_right B (b / g))
  · obtain ⟨x, rfl⟩ := hgB
    obtain ⟨y, rfl⟩ := hgb
    have hdiv : g * y / g = y := Nat.mul_div_cancel_left y hg
    rw [hdiv]
    exact ⟨x, by ring⟩

/-- The finite lcm is obtained recursively by adjoining the last entry. -/
theorem reciprocalLcm_succ (d : ℕ → ℕ) (N : ℕ) :
    reciprocalLcm d (N + 1) = Nat.lcm (d N) (reciprocalLcm d N) := by
  simp [reciprocalLcm, Finset.range_add_one, Finset.lcm_insert, lcm_eq_nat_lcm]

/-- Exact gcd-overlap bound for selected Fibonacci denominators.  Each `e k`
is an index divisor of `n k`; except at the first term, it must also divide one
earlier selected index. -/
theorem reciprocalLcm_fib_dvd_overlap_product
    (n e : ℕ → ℕ) (hepos : ∀ k, 0 < e k) (he0 : e 0 = 1)
    (hediv : ∀ k, e k ∣ n k)
    (heprev : ∀ k, 0 < k → ∃ i < k, e k ∣ n i) :
    ∀ N,
      reciprocalLcm (fun k => Nat.fib (n k)) N ∣
        ∏ k ∈ Finset.range N, Nat.fib (n k) / Nat.fib (e k) := by
  intro N
  induction N with
  | zero => simp [reciprocalLcm]
  | succ N ih =>
      rw [show N + 1 = Nat.succ N by rfl, Finset.prod_range_succ,
        reciprocalLcm_succ]
      have hgd : Nat.fib (e N) ∣ Nat.fib (n N) := Nat.fib_dvd _ _ (hediv N)
      have hgpos : 0 < Nat.fib (e N) := Nat.fib_pos.mpr (hepos N)
      have hgB : Nat.fib (e N) ∣
          ∏ k ∈ Finset.range N, Nat.fib (n k) / Nat.fib (e k) := by
        by_cases hN : N = 0
        · subst N
          simp [he0]
        · obtain ⟨i, hi, hei⟩ := heprev N (Nat.pos_of_ne_zero hN)
          have himem : i ∈ Finset.range N := Finset.mem_range.mpr hi
          have hgfib : Nat.fib (e N) ∣ Nat.fib (n i) := Nat.fib_dvd _ _ hei
          have hflcm : Nat.fib (n i) ∣ reciprocalLcm (fun k => Nat.fib (n k)) N :=
            Finset.dvd_lcm himem
          exact (hgfib.trans hflcm).trans ih
      have h := lcm_dvd_mul_div_of_common_dvd
        (reciprocalLcm (fun k => Nat.fib (n k)) N) (Nat.fib (n N))
        (∏ k ∈ Finset.range N, Nat.fib (n k) / Nat.fib (e k))
        (Nat.fib (e N)) hgpos ih hgB hgd
      simpa [Nat.lcm_comm] using h

/-- The cost of adjoining `F_n` after reusing the common factor `F_e` has a
sharp enough golden-ratio upper bound. -/
theorem fib_div_fib_le_overlap_geometric
    (n e : ℕ) (_hn : 0 < n) (he : 0 < e) (hed : e ∣ n) :
    ((Nat.fib n / Nat.fib e : ℕ) : ℝ) ≤
      φ * φ ^ n * (φ⁻¹) ^ e := by
  have hfed : Nat.fib e ∣ Nat.fib n := Nat.fib_dvd _ _ hed
  have hfe0 : (Nat.fib e : ℝ) ≠ 0 := by
    exact_mod_cast (Nat.ne_of_gt (Nat.fib_pos.mpr he))
  rw [Nat.cast_div hfed hfe0, div_eq_mul_inv]
  have hfn : (Nat.fib n : ℝ) ≤ φ⁻¹ * φ ^ n := by
    have h := goldenRatio_mul_fib_le_pow n
    rw [← div_eq_inv_mul]
    exact (le_div_iff₀ Real.goldenRatio_pos).2 (by simpa [mul_comm] using h)
  have hfe := inv_fib_le_golden_geometric e he
  calc
    (Nat.fib n : ℝ) * (Nat.fib e : ℝ)⁻¹ ≤
        (φ⁻¹ * φ ^ n) * (φ ^ 2 * (φ⁻¹) ^ e) := by gcongr
    _ = φ * φ ^ n * (φ⁻¹) ^ e := by
      field_simp [Real.goldenRatio_ne_zero]

/-- A cumulative gcd-overlap budget which beats the next index forces the lcm
denominator times the tail to zero. -/
theorem tendsto_fib_lcm_tail_zero_of_overlap_budget
    (n e : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hepos : ∀ k, 0 < e k) (he0 : e 0 = 1)
    (hediv : ∀ k, e k ∣ n k)
    (heprev : ∀ k, 0 < k → ∃ i < k, e k ∣ n i)
    (hbudget : ∀ N,
      (∑ k ∈ Finset.range N, n k) + 2 * N ≤
        n N + ∑ k ∈ Finset.range N, e k) :
    Tendsto
      (fun N : ℕ =>
        (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹))
      atTop (𝓝 0) := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by dsimp [r]; exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by dsimp [r]; exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hlcm_bound (N : ℕ) :
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) ≤
        φ ^ N * φ ^ (∑ k ∈ Finset.range N, n k) *
          r ^ (∑ k ∈ Finset.range N, e k) := by
    have hdvd := reciprocalLcm_fib_dvd_overlap_product n e hepos he0 hediv heprev N
    have hquotpos (k : ℕ) : 0 < Nat.fib (n k) / Nat.fib (e k) := by
      apply Nat.div_pos
      · exact Nat.le_of_dvd (Nat.fib_pos.mpr (hpos k))
          (Nat.fib_dvd _ _ (hediv k))
      · exact Nat.fib_pos.mpr (hepos k)
    have hnat : reciprocalLcm (fun k => Nat.fib (n k)) N ≤
        ∏ k ∈ Finset.range N, Nat.fib (n k) / Nat.fib (e k) :=
      Nat.le_of_dvd (Finset.prod_pos fun k hk => hquotpos k) hdvd
    calc
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) ≤
          (∏ k ∈ Finset.range N, Nat.fib (n k) / Nat.fib (e k) : ℕ) := by
            exact_mod_cast hnat
      _ = ∏ k ∈ Finset.range N,
          ((Nat.fib (n k) / Nat.fib (e k) : ℕ) : ℝ) := by push_cast; rfl
      _ ≤ ∏ k ∈ Finset.range N,
          (φ * φ ^ (n k) * r ^ (e k)) := by
            apply Finset.prod_le_prod
            · intro k hk
              positivity
            · intro k hk
              simpa [r] using fib_div_fib_le_overlap_geometric
                (n k) (e k) (hpos k) (hepos k) (hediv k)
      _ = φ ^ N * φ ^ (∑ k ∈ Finset.range N, n k) *
          r ^ (∑ k ∈ Finset.range N, e k) := by
            repeat' rw [Finset.prod_mul_distrib]
            rw [Finset.prod_const, Finset.card_range,
              Finset.prod_pow_eq_pow_sum, Finset.prod_pow_eq_pow_sum]
  have hbound (N : ℕ) :
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤
        φ ^ 4 * r ^ N := by
    have htail := (summable_and_tsum_shift_le n hpos hmono N).2
    have hcancel := golden_pow_mul_inv_pow_le
      ((∑ k ∈ Finset.range N, n k) + N)
      (n N + ∑ k ∈ Finset.range N, e k) N (by
        have hb := hbudget N
        omega)
    calc
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤
          (φ ^ N * φ ^ (∑ k ∈ Finset.range N, n k) *
            r ^ (∑ k ∈ Finset.range N, e k)) *
              ((φ ^ 2 * r ^ (n N)) * φ ^ 2) := by
                gcongr
                exact hlcm_bound N
      _ = φ ^ 4 *
          (φ ^ ((∑ k ∈ Finset.range N, n k) + N) *
            r ^ (n N + ∑ k ∈ Finset.range N, e k)) := by
              rw [pow_add, pow_add]
              ring
      _ ≤ φ ^ 4 * r ^ N := by
              exact mul_le_mul_of_nonneg_left (by simpa [r] using hcancel) (by positivity)
  have hnonneg (N : ℕ) :
      0 ≤ (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) := by positivity
  have hmajor : Tendsto (fun N : ℕ => φ ^ 4 * r ^ N) atTop (𝓝 0) := by
    have hc : Tendsto (fun _ : ℕ => φ ^ 4) atTop (𝓝 (φ ^ 4)) := tendsto_const_nhds
    simpa using hc.mul (tendsto_pow_atTop_nhds_zero_of_lt_one hr0 hr1)
  exact squeeze_zero hnonneg hbound hmajor

/-- The overlap-budget condition is therefore a concrete sufficient condition
for irrationality below ratio two. -/
theorem irrational_reciprocal_fib_of_overlap_budget
    (n e : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hepos : ∀ k, 0 < e k) (he0 : e 0 = 1)
    (hediv : ∀ k, e k ∣ n k)
    (heprev : ∀ k, 0 < k → ∃ i < k, e k ∣ n i)
    (hbudget : ∀ N,
      (∑ k ∈ Finset.range N, n k) + 2 * N ≤
        n N + ∑ k ∈ Finset.range N, e k) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  exact irrational_tsum_unitFractions_of_scaled_tail_zero
    (fun k => Nat.fib (n k))
    (reciprocalLcm (fun k => Nat.fib (n k)))
    (reciprocalLcmNumerator (fun k => Nat.fib (n k)))
    (fun k => Nat.fib_pos.mpr (hpos k))
    (reciprocalLcm_pos _ (fun k => Nat.fib_pos.mpr (hpos k)))
    (by
      have h := (summable_and_tsum_shift_le n hpos hmono 0).1
      simpa using h)
    (reciprocalLcm_mul_partialSum_eq _
      (fun k => Nat.fib_pos.mpr (hpos k)))
    (tendsto_fib_lcm_tail_zero_of_overlap_budget n e hpos hmono
      hepos he0 hediv heprev hbudget)

/-- Exact lcm form of Mahler's criterion.  This isolates the remaining
arithmetic task in Erdős 267: control the lcm of the selected Fibonacci
numbers. -/
theorem irrational_tsum_reciprocals_of_lcm_tail_zero
    (d : ℕ → ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hlim : Tendsto
      (fun N : ℕ =>
        (reciprocalLcm d N : ℝ) * (∑' j : ℕ, (d (N + j) : ℝ)⁻¹))
      atTop (𝓝 0)) :
    Irrational (∑' k : ℕ, (d k : ℝ)⁻¹) := by
  exact irrational_tsum_unitFractions_of_scaled_tail_zero d
    (reciprocalLcm d) (reciprocalLcmNumerator d) hpos
    (reciprocalLcm_pos d hpos) hsum
    (reciprocalLcm_mul_partialSum_eq d hpos) hlim

end Research

/-!
# Concrete local consequences of the Fibonacci lcm overlap budget
-/

namespace Research

open scoped BigOperators

/-- A local bound on the cost of each new denominator implies the cumulative
index-overlap budget.  The first step follows just from strict monotonicity and
`e 0 = 1`. -/
theorem overlap_budget_of_local
    (n e : ℕ → ℕ) (hmono : StrictMono n) (he0 : e 0 = 1)
    (hlocal : ∀ k, 0 < k → 2 * n k + 2 ≤ n (k + 1) + e k) :
    ∀ N,
      (∑ k ∈ Finset.range N, n k) + 2 * N ≤
        n N + ∑ k ∈ Finset.range N, e k := by
  intro N
  induction N with
  | zero => simp
  | succ N ih =>
      rw [Finset.sum_range_succ, Finset.sum_range_succ]
      by_cases hN : N = 0
      · subst N
        have hm := hmono (show 0 < 1 by omega)
        simp [he0] at ih ⊢
        omega
      · have hl := hlocal N (Nat.pos_of_ne_zero hN)
        omega

/-- Local reusable-divisor overlap is enough for irrationality. -/
theorem irrational_reciprocal_fib_of_local_overlap
    (n e : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hepos : ∀ k, 0 < e k) (he0 : e 0 = 1)
    (hediv : ∀ k, e k ∣ n k)
    (heprev : ∀ k, 0 < k → ∃ i < k, e k ∣ n i)
    (hlocal : ∀ k, 0 < k → 2 * n k + 2 ≤ n (k + 1) + e k) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  exact irrational_reciprocal_fib_of_overlap_budget n e hpos hmono
    hepos he0 hediv heprev (overlap_budget_of_local n e hmono he0 hlocal)

/-- The divisor shared with the immediately preceding selected index. -/
def consecutiveIndexGcd (n : ℕ → ℕ) : ℕ → ℕ
  | 0 => 1
  | k + 1 => Nat.gcd (n (k + 1)) (n k)

/-- A concrete consecutive-gcd condition implies irrationality. -/
theorem irrational_reciprocal_fib_of_consecutive_gcd_overlap
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hlocal : ∀ k,
      2 * n (k + 1) + 2 ≤
        n (k + 2) + Nat.gcd (n (k + 1)) (n k)) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  let e := consecutiveIndexGcd n
  apply irrational_reciprocal_fib_of_local_overlap n e hpos hmono
  · intro k
    cases k with
    | zero => simp [e, consecutiveIndexGcd]
    | succ k =>
        exact Nat.gcd_pos_of_pos_left _ (hpos (k + 1))
  · simp [e, consecutiveIndexGcd]
  · intro k
    cases k with
    | zero => simp [e, consecutiveIndexGcd]
    | succ k =>
        exact Nat.gcd_dvd_left (n (k + 1)) (n k)
  · intro k hk
    cases k with
    | zero => simp at hk
    | succ k =>
        refine ⟨k, Nat.lt_succ_self k, ?_⟩
        exact Nat.gcd_dvd_right (n (k + 1)) (n k)
  · intro k hk
    obtain ⟨j, rfl⟩ := Nat.exists_eq_succ_of_ne_zero (Nat.ne_of_gt hk)
    simpa [e, consecutiveIndexGcd, Nat.add_assoc] using hlocal j

/-- Irrationality of a shifted reciprocal-Fibonacci tail implies irrationality
of the full series; the deleted prefix is rational. -/
theorem irrational_reciprocal_fib_of_shift
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n) (K : ℕ)
    (htail : Irrational
      (∑' k : ℕ, (Nat.fib (n (K + k)) : ℝ)⁻¹)) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  let q : ℚ := ∑ k ∈ Finset.range K, (Nat.fib (n k) : ℚ)⁻¹
  have hqcast :
      (q : ℝ) = ∑ k ∈ Finset.range K, (Nat.fib (n k) : ℝ)⁻¹ := by
    simp [q]
  have hsum := (summable_and_tsum_shift_le n hpos hmono 0).1
  have hsplit := hsum.sum_add_tsum_nat_add K
  have heq :
      (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
        (q : ℝ) + ∑' k : ℕ, (Nat.fib (n (K + k)) : ℝ)⁻¹ := by
    rw [hqcast]
    symm
    simpa [add_comm] using hsplit
  rw [heq]
  exact htail.ratCast_add q

/-- It is enough that the consecutive-gcd overlap condition hold eventually. -/
theorem irrational_reciprocal_fib_of_eventual_consecutive_gcd_overlap
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K : ℕ)
    (hlocal : ∀ k,
      2 * n (K + k + 1) + 2 ≤
        n (K + k + 2) + Nat.gcd (n (K + k + 1)) (n (K + k))) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  let m : ℕ → ℕ := fun k => n (K + k)
  have hmpos : ∀ k, 0 < m k := fun k => hpos (K + k)
  have hmmono : StrictMono m := hmono.comp add_right_strictMono
  have hmtail := irrational_reciprocal_fib_of_consecutive_gcd_overlap
    m hmpos hmmono (by
      intro k
      simpa [m, Nat.add_assoc] using hlocal k)
  exact irrational_reciprocal_fib_of_shift n hpos hmono K (by simpa [m] using hmtail)

end Research

/-!
# Mahler's denominator argument along unbounded subsequences of cut points
-/

namespace Research

open Filter Topology
open Real goldenRatio
open scoped BigOperators

/-- Mahler's integer-denominator argument only needs small scaled tails along
an arbitrary sequence of cut points. -/
theorem irrational_tsum_unitFractions_of_scaled_tail_zero_at_cuts
    (d D A q : ℕ → ℕ) (hpos : ∀ k, 0 < d k)
    (hDpos : ∀ N, 0 < D N)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hscaled : ∀ N,
      (D N : ℝ) * (∑ k ∈ Finset.range (q N), (d k : ℝ)⁻¹) = (A N : ℝ))
    (hlim : Tendsto
      (fun N : ℕ => (D N : ℝ) * (∑' j : ℕ, (d (q N + j) : ℝ)⁻¹))
      atTop (𝓝 0)) :
    Irrational (∑' k : ℕ, (d k : ℝ)⁻¹) := by
  rw [irrational_iff_ne_rational]
  intro a b hb hrat
  let S : ℝ := ∑' k : ℕ, (d k : ℝ)⁻¹
  let P : ℕ → ℝ := fun N => ∑ k ∈ Finset.range (q N), (d k : ℝ)⁻¹
  let T : ℕ → ℝ := fun N => ∑' j : ℕ, (d (q N + j) : ℝ)⁻¹
  have hsplit (N : ℕ) : P N + T N = S := by
    have h := hsum.sum_add_tsum_nat_add (q N)
    simpa [P, T, S, add_comm] using h
  have hTpos (N : ℕ) : 0 < T N := by
    have ht : Summable (fun j : ℕ => (d (q N + j) : ℝ)⁻¹) := by
      have := (summable_nat_add_iff (q N)).2 hsum
      simpa [add_comm] using this
    exact ht.tsum_pos (fun _ => inv_nonneg.mpr (by positivity)) 0
      (inv_pos.mpr (by exact_mod_cast hpos (q N)))
  have hDP (N : ℕ) : (D N : ℝ) * P N = (A N : ℝ) := by
    simpa [P] using hscaled N
  have hlower (N : ℕ) : (1 : ℝ) ≤ |(b : ℝ)| * ((D N : ℝ) * T N) := by
    let z : ℤ := a * (D N : ℤ) - b * (A N : ℤ)
    have hinter : (b : ℝ) * (D N : ℝ) * T N = (z : ℝ) := by
      have hT : T N = S - P N := by linarith [hsplit N]
      rw [hT]
      change (b : ℝ) * (D N : ℝ) * (S - P N) = (z : ℝ)
      have hrat' : S = (a : ℝ) / (b : ℝ) := by simpa [S] using hrat
      rw [hrat']
      calc
        (b : ℝ) * (D N : ℝ) * ((a : ℝ) / (b : ℝ) - P N) =
            (a : ℝ) * (D N : ℝ) - (b : ℝ) * ((D N : ℝ) * P N) := by
              field_simp [Int.cast_ne_zero.mpr hb]
        _ = (a : ℝ) * (D N : ℝ) - (b : ℝ) * (A N : ℝ) := by rw [hDP]
        _ = (z : ℝ) := by dsimp [z]; push_cast; ring
    have hz : z ≠ 0 := by
      intro hz0
      have hleft : (b : ℝ) * (D N : ℝ) * T N ≠ 0 := by
        exact mul_ne_zero (mul_ne_zero (Int.cast_ne_zero.mpr hb)
          (by exact_mod_cast (Nat.ne_of_gt (hDpos N)))) (ne_of_gt (hTpos N))
      apply hleft
      rw [hinter, hz0]
      norm_num
    have hzlower : (1 : ℝ) ≤ |(z : ℝ)| := by
      exact_mod_cast Int.one_le_abs hz
    have habs : |(z : ℝ)| = |(b : ℝ)| * ((D N : ℝ) * T N) := by
      have hDabs : |(D N : ℝ)| = (D N : ℝ) :=
        abs_of_pos (by exact_mod_cast hDpos N)
      have hTabs : |T N| = T N := abs_of_pos (hTpos N)
      rw [← hinter, abs_mul, abs_mul, hDabs, hTabs]
      ring
    rwa [habs] at hzlower
  have hlim' : Tendsto (fun N : ℕ => |(b : ℝ)| * ((D N : ℝ) * T N))
      atTop (𝓝 0) := by
    have hc : Tendsto (fun _ : ℕ => |(b : ℝ)|) atTop (𝓝 |(b : ℝ)|) :=
      tendsto_const_nhds
    have h := hc.mul hlim
    simpa [T, mul_assoc] using h
  have hfalse : (1 : ℝ) ≤ 0 := ge_of_tendsto' hlim' hlower
  norm_num at hfalse

/-- Lcm form of the preceding arbitrary-cut criterion. -/
theorem irrational_tsum_reciprocals_of_lcm_tail_zero_at_cuts
    (d q : ℕ → ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hlim : Tendsto
      (fun N : ℕ =>
        (reciprocalLcm d (q N) : ℝ) *
          (∑' j : ℕ, (d (q N + j) : ℝ)⁻¹))
      atTop (𝓝 0)) :
    Irrational (∑' k : ℕ, (d k : ℝ)⁻¹) := by
  exact irrational_tsum_unitFractions_of_scaled_tail_zero_at_cuts d
    (fun N => reciprocalLcm d (q N))
    (fun N => reciprocalLcmNumerator d (q N)) q hpos
    (fun N => reciprocalLcm_pos d hpos (q N)) hsum
    (fun N => reciprocalLcm_mul_partialSum_eq d hpos (q N)) hlim

/-- Pointwise version of the overlap estimate.  Unlike F-008's limit theorem,
this requires its cumulative budget at just one cut point. -/
theorem fib_lcm_mul_tail_le_of_overlap_budget_at
    (n e : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hepos : ∀ k, 0 < e k) (he0 : e 0 = 1)
    (hediv : ∀ k, e k ∣ n k)
    (heprev : ∀ k, 0 < k → ∃ i < k, e k ∣ n i)
    (N : ℕ)
    (hbudget : (∑ k ∈ Finset.range N, n k) + 2 * N ≤
      n N + ∑ k ∈ Finset.range N, e k) :
    (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
        (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤
      φ ^ 4 * (φ⁻¹) ^ N := by
  let r : ℝ := φ⁻¹
  have hlcm_bound :
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) ≤
        φ ^ N * φ ^ (∑ k ∈ Finset.range N, n k) *
          r ^ (∑ k ∈ Finset.range N, e k) := by
    have hdvd := reciprocalLcm_fib_dvd_overlap_product n e hepos he0 hediv heprev N
    have hquotpos (k : ℕ) : 0 < Nat.fib (n k) / Nat.fib (e k) := by
      apply Nat.div_pos
      · exact Nat.le_of_dvd (Nat.fib_pos.mpr (hpos k))
          (Nat.fib_dvd _ _ (hediv k))
      · exact Nat.fib_pos.mpr (hepos k)
    have hnat : reciprocalLcm (fun k => Nat.fib (n k)) N ≤
        ∏ k ∈ Finset.range N, Nat.fib (n k) / Nat.fib (e k) :=
      Nat.le_of_dvd (Finset.prod_pos fun k hk => hquotpos k) hdvd
    calc
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) ≤
          (∏ k ∈ Finset.range N, Nat.fib (n k) / Nat.fib (e k) : ℕ) := by
            exact_mod_cast hnat
      _ = ∏ k ∈ Finset.range N,
          ((Nat.fib (n k) / Nat.fib (e k) : ℕ) : ℝ) := by push_cast; rfl
      _ ≤ ∏ k ∈ Finset.range N,
          (φ * φ ^ (n k) * r ^ (e k)) := by
            apply Finset.prod_le_prod
            · intro k hk
              positivity
            · intro k hk
              simpa [r] using fib_div_fib_le_overlap_geometric
                (n k) (e k) (hpos k) (hepos k) (hediv k)
      _ = φ ^ N * φ ^ (∑ k ∈ Finset.range N, n k) *
          r ^ (∑ k ∈ Finset.range N, e k) := by
            repeat' rw [Finset.prod_mul_distrib]
            rw [Finset.prod_const, Finset.card_range,
              Finset.prod_pow_eq_pow_sum, Finset.prod_pow_eq_pow_sum]
  have htail := (summable_and_tsum_shift_le n hpos hmono N).2
  have hcancel := golden_pow_mul_inv_pow_le
    ((∑ k ∈ Finset.range N, n k) + N)
    (n N + ∑ k ∈ Finset.range N, e k) N (by omega)
  calc
    (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
        (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤
        (φ ^ N * φ ^ (∑ k ∈ Finset.range N, n k) *
          r ^ (∑ k ∈ Finset.range N, e k)) *
            ((φ ^ 2 * r ^ (n N)) * φ ^ 2) := by
              gcongr
    _ = φ ^ 4 *
        (φ ^ ((∑ k ∈ Finset.range N, n k) + N) *
          r ^ (n N + ∑ k ∈ Finset.range N, e k)) := by
            rw [pow_add, pow_add]
            ring
    _ ≤ φ ^ 4 * r ^ N := by
            exact mul_le_mul_of_nonneg_left (by simpa [r] using hcancel) (by positivity)
    _ = φ ^ 4 * (φ⁻¹) ^ N := by rfl

/-- It is enough for the cumulative overlap budget to hold at any unbounded
sequence of cut points, rather than at every cut point. -/
theorem irrational_reciprocal_fib_of_overlap_budget_subsequence
    (n e s : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hepos : ∀ k, 0 < e k) (he0 : e 0 = 1)
    (hediv : ∀ k, e k ∣ n k)
    (heprev : ∀ k, 0 < k → ∃ i < k, e k ∣ n i)
    (hs : Tendsto s atTop atTop)
    (hbudget : ∀ t,
      (∑ k ∈ Finset.range (s t), n k) + 2 * s t ≤
        n (s t) + ∑ k ∈ Finset.range (s t), e k) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  have hsum := (summable_and_tsum_shift_le n hpos hmono 0).1
  have hnonneg (t : ℕ) :
      0 ≤ (reciprocalLcm (fun k => Nat.fib (n k)) (s t) : ℝ) *
        (∑' j : ℕ, (Nat.fib (n (s t + j)) : ℝ)⁻¹) := by positivity
  have hbound (t : ℕ) :
      (reciprocalLcm (fun k => Nat.fib (n k)) (s t) : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (s t + j)) : ℝ)⁻¹) ≤
        φ ^ 4 * (φ⁻¹) ^ (s t) :=
    fib_lcm_mul_tail_le_of_overlap_budget_at n e hpos hmono hepos he0
      hediv heprev (s t) (hbudget t)
  have hr0 : 0 ≤ φ⁻¹ := (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : φ⁻¹ < 1 := inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hpow : Tendsto (fun N : ℕ => (φ⁻¹) ^ N) atTop (𝓝 0) :=
    tendsto_pow_atTop_nhds_zero_of_lt_one hr0 hr1
  have hmajor : Tendsto (fun t : ℕ => φ ^ 4 * (φ⁻¹) ^ (s t))
      atTop (𝓝 0) := by
    simpa using tendsto_const_nhds.mul (hpow.comp hs)
  have hlim : Tendsto
      (fun t : ℕ =>
        (reciprocalLcm (fun k => Nat.fib (n k)) (s t) : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (s t + j)) : ℝ)⁻¹))
      atTop (𝓝 0) := squeeze_zero hnonneg hbound hmajor
  exact irrational_tsum_reciprocals_of_lcm_tail_zero_at_cuts
    (fun k => Nat.fib (n k)) s (fun k => Nat.fib_pos.mpr (hpos k))
    (by simpa using hsum) hlim

end Research

/-!
# Finite index-divisibility covers for Fibonacci lcm bounds
-/

namespace Research

open Filter Topology
open Real goldenRatio
open scoped BigOperators

/-- If every selected index before a cut divides one of the indices in `J`,
then the corresponding Fibonacci lcm divides the product over `J`.  The cover
indices need not occur earlier than the indices they cover. -/
theorem reciprocalLcm_fib_dvd_cover_product
    (n : ℕ → ℕ) (N : ℕ) (J : Finset ℕ)
    (hcover : ∀ k < N, ∃ j ∈ J, n k ∣ n j) :
    reciprocalLcm (fun k => Nat.fib (n k)) N ∣
      ∏ j ∈ J, Nat.fib (n j) := by
  rw [reciprocalLcm]
  apply Finset.lcm_dvd
  intro k hk
  obtain ⟨j, hj, hd⟩ := hcover k (Finset.mem_range.mp hk)
  exact (Nat.fib_dvd _ _ hd).trans
    (Finset.dvd_prod_of_mem (fun j => Nat.fib (n j)) hj)

/-- Golden-ratio upper bound for a Fibonacci product over an arbitrary finite
set of selected positions. -/
theorem prod_fib_finset_le_golden_geometric
    (n : ℕ → ℕ) (J : Finset ℕ) :
    (∏ j ∈ J, (Nat.fib (n j) : ℝ)) ≤
      (φ⁻¹) ^ J.card * φ ^ (∑ j ∈ J, n j) := by
  have hterm (j : ℕ) :
      (Nat.fib (n j) : ℝ) ≤ φ⁻¹ * φ ^ (n j) := by
    have h := goldenRatio_mul_fib_le_pow (n j)
    rw [← div_eq_inv_mul]
    exact (le_div_iff₀ Real.goldenRatio_pos).2 (by simpa [mul_comm] using h)
  calc
    (∏ j ∈ J, (Nat.fib (n j) : ℝ)) ≤
        ∏ j ∈ J, (φ⁻¹ * φ ^ (n j)) := by
          apply Finset.prod_le_prod
          · intro j hj
            positivity
          · intro j hj
            exact hterm j
    _ = (φ⁻¹) ^ J.card * φ ^ (∑ j ∈ J, n j) := by
          rw [Finset.prod_mul_distrib, Finset.prod_const,
            Finset.prod_pow_eq_pow_sum]

/-- A divisibility cover whose total index weight lies sufficiently below the
next index forces irrationality.  This nonlocal criterion permits an early
index to be covered by a later index in the same finite prefix. -/
theorem irrational_reciprocal_fib_of_divisibility_covers
    (n s : ℕ → ℕ) (J : ℕ → Finset ℕ)
    (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hs : Tendsto s atTop atTop)
    (hcover : ∀ t k, k < s t → ∃ j ∈ J t, n k ∣ n j)
    (hbudget : ∀ t,
      (∑ j ∈ J t, n j) + s t ≤ n (s t) + (J t).card) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by dsimp [r]; exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by dsimp [r]; exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hpoint (t : ℕ) :
      (reciprocalLcm (fun k => Nat.fib (n k)) (s t) : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (s t + j)) : ℝ)⁻¹) ≤
        φ ^ 4 * r ^ (s t) := by
    have hdvd := reciprocalLcm_fib_dvd_cover_product n (s t) (J t) (hcover t)
    have hprodpos : 0 < ∏ j ∈ J t, Nat.fib (n j) :=
      Finset.prod_pos fun j hj => Nat.fib_pos.mpr (hpos j)
    have hnat : reciprocalLcm (fun k => Nat.fib (n k)) (s t) ≤
        ∏ j ∈ J t, Nat.fib (n j) := Nat.le_of_dvd hprodpos hdvd
    have hlcm :
        (reciprocalLcm (fun k => Nat.fib (n k)) (s t) : ℝ) ≤
          r ^ (J t).card * φ ^ (∑ j ∈ J t, n j) := by
      calc
        (reciprocalLcm (fun k => Nat.fib (n k)) (s t) : ℝ) ≤
            (∏ j ∈ J t, Nat.fib (n j) : ℕ) := by exact_mod_cast hnat
        _ = ∏ j ∈ J t, (Nat.fib (n j) : ℝ) := by push_cast; rfl
        _ ≤ r ^ (J t).card * φ ^ (∑ j ∈ J t, n j) := by
          simpa [r] using prod_fib_finset_le_golden_geometric n (J t)
    have htail := (summable_and_tsum_shift_le n hpos hmono (s t)).2
    have hcancel := golden_pow_mul_inv_pow_le
      (∑ j ∈ J t, n j) (n (s t) + (J t).card) (s t) (hbudget t)
    calc
      (reciprocalLcm (fun k => Nat.fib (n k)) (s t) : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (s t + j)) : ℝ)⁻¹) ≤
          (r ^ (J t).card * φ ^ (∑ j ∈ J t, n j)) *
            ((φ ^ 2 * r ^ (n (s t))) * φ ^ 2) := by gcongr
      _ = φ ^ 4 *
          (φ ^ (∑ j ∈ J t, n j) *
            r ^ (n (s t) + (J t).card)) := by
              rw [pow_add]
              ring
      _ ≤ φ ^ 4 * r ^ (s t) := by
              exact mul_le_mul_of_nonneg_left
                (by simpa [r] using hcancel) (by positivity)
  have hnonneg (t : ℕ) :
      0 ≤ (reciprocalLcm (fun k => Nat.fib (n k)) (s t) : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (s t + j)) : ℝ)⁻¹) := by positivity
  have hmajor : Tendsto (fun t : ℕ => φ ^ 4 * r ^ (s t)) atTop (𝓝 0) := by
    have hp : Tendsto (fun N : ℕ => r ^ N) atTop (𝓝 0) :=
      tendsto_pow_atTop_nhds_zero_of_lt_one hr0 hr1
    simpa using tendsto_const_nhds.mul (hp.comp hs)
  have hlim : Tendsto
      (fun t : ℕ =>
        (reciprocalLcm (fun k => Nat.fib (n k)) (s t) : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (s t + j)) : ℝ)⁻¹))
      atTop (𝓝 0) := squeeze_zero hnonneg hpoint hmajor
  exact irrational_tsum_reciprocals_of_lcm_tail_zero_at_cuts
    (fun k => Nat.fib (n k)) s (fun k => Nat.fib_pos.mpr (hpos k))
    (by simpa using (summable_and_tsum_shift_le n hpos hmono 0).1) hlim

end Research

/-!
# The nonlocal divisibility-cover example `n_k = 2^k + 1`
-/

namespace Research

open Filter Topology
open scoped BigOperators

/-- The geometric sum of powers of two in natural arithmetic. -/
theorem sum_range_two_pow (N : ℕ) :
    (∑ k ∈ Finset.range N, 2 ^ k) = 2 ^ N - 1 := by
  induction N with
  | zero => simp
  | succ N ih =>
      rw [Finset.sum_range_succ, ih, pow_succ]
      have hp := Nat.one_le_two_pow (n := N)
      omega

/-- The corresponding exact sum over a natural interval. -/
theorem sum_Ico_two_pow {a b : ℕ} (hab : a ≤ b) :
    (∑ k ∈ Finset.Ico a b, 2 ^ k) = 2 ^ b - 2 ^ a := by
  have h := Finset.sum_range_add_sum_Ico (fun k => 2 ^ k) hab
  rw [sum_range_two_pow, sum_range_two_pow] at h
  have ha := Nat.one_le_two_pow (n := a)
  have hb := Nat.one_le_two_pow (n := b)
  have hp := Nat.pow_le_pow_right (by omega : 0 < 2) hab
  omega

/-- A convenient bound for the sparse initial part of the cover. -/
theorem sum_three_mul_shifted_two_pow_le :
    ∀ m : ℕ, 2 ≤ m →
      (∑ k ∈ Finset.range m, (2 ^ (3 * k) + 1)) ≤ 2 ^ (3 * m - 1) := by
  intro m hm
  obtain ⟨q, rfl⟩ := Nat.exists_eq_add_of_le hm
  induction q with
  | zero => norm_num
  | succ q ih =>
      let m := 2 + q
      have hm1 : 1 ≤ 3 * m := by dsimp [m]; omega
      have hterm : 2 ^ (3 * m) = 2 * 2 ^ (3 * m - 1) := by
        conv_lhs => rw [show 3 * m = (3 * m - 1) + 1 by omega]
        rw [pow_succ]
        ring
      have hnext : 2 ^ (3 * (m + 1) - 1) = 8 * 2 ^ (3 * m - 1) := by
        rw [show 3 * (m + 1) - 1 = (3 * m - 1) + 3 by omega, pow_add]
        norm_num
        ring
      have hp := Nat.one_le_two_pow (n := 3 * m - 1)
      have ih' := ih (by omega)
      have ih_m :
          (∑ k ∈ Finset.range m, (2 ^ (3 * k) + 1)) ≤
            2 ^ (3 * m - 1) := by simpa [m] using ih'
      rw [show 2 + (q + 1) = m + 1 by dsimp [m]; omega,
        Finset.sum_range_succ]
      rw [hterm, hnext]
      omega

/-- The exponential margin in the cover dominates its linear bookkeeping. -/
theorem eight_mul_le_three_pow_margin :
    ∀ m : ℕ, 2 ≤ m → 8 * m ≤ 2 ^ (3 * m - 1) + 1 := by
  intro m hm
  obtain ⟨q, rfl⟩ := Nat.exists_eq_add_of_le hm
  induction q with
  | zero => norm_num
  | succ q ih =>
      let m := 2 + q
      have hnext : 2 ^ (3 * (m + 1) - 1) = 8 * 2 ^ (3 * m - 1) := by
        rw [show 3 * (m + 1) - 1 = (3 * m - 1) + 3 by omega, pow_add]
        norm_num
        ring
      have hp := Nat.one_le_two_pow (n := 3 * m - 1)
      have ih' := ih (by omega)
      have ih_m : 8 * m ≤ 2 ^ (3 * m - 1) + 1 := by simpa [m] using ih'
      simpa [m, Nat.add_assoc] using (show
        8 * (m + 1) ≤ 2 ^ (3 * (m + 1) - 1) + 1 by
          rw [hnext]
          omega)

/-- The positions used to cover the prefix ending at `9m`: sparse triple
positions below `3m`, together with the entire final interval. -/
def shiftedTwoPowCover (m : ℕ) : Finset ℕ :=
  (Finset.range m).image (fun k => 3 * k) ∪ Finset.Ico (3 * m) (9 * m)

/-- The two pieces of `shiftedTwoPowCover` are disjoint. -/
theorem shiftedTwoPowCover_disjoint (m : ℕ) :
    Disjoint ((Finset.range m).image (fun k => 3 * k))
      (Finset.Ico (3 * m) (9 * m)) := by
  rw [Finset.disjoint_left]
  intro j hj hIco
  obtain ⟨k, hk, rfl⟩ := Finset.mem_image.mp hj
  have hklt := Finset.mem_range.mp hk
  have hjlo := (Finset.mem_Ico.mp hIco).1
  omega

/-- Exact cardinality of the cover. -/
theorem shiftedTwoPowCover_card (m : ℕ) :
    (shiftedTwoPowCover m).card = 7 * m := by
  rw [shiftedTwoPowCover, Finset.card_union_of_disjoint
    (shiftedTwoPowCover_disjoint m),
    Finset.card_image_of_injective _ (by intro a b h; dsimp at h; omega),
    Finset.card_range, Nat.card_Ico]
  omega

/-- Cubing the underlying power proves the required index divisibility. -/
theorem shifted_two_pow_dvd_triple (k : ℕ) :
    2 ^ k + 1 ∣ 2 ^ (3 * k) + 1 := by
  have h := (show Odd 3 by norm_num).nat_add_dvd_pow_add_pow (2 ^ k) 1
  simpa [Nat.pow_mul, mul_comm] using h

/-- Every position before `9m` is covered by `shiftedTwoPowCover m`. -/
theorem shiftedTwoPowCover_covers (m k : ℕ) (hk : k < 9 * m) :
    ∃ j ∈ shiftedTwoPowCover m, 2 ^ k + 1 ∣ 2 ^ j + 1 := by
  by_cases hlate : 3 * m ≤ k
  · refine ⟨k, ?_, dvd_refl _⟩
    exact Finset.mem_union_right _ (Finset.mem_Ico.mpr ⟨hlate, hk⟩)
  · refine ⟨3 * k, ?_, shifted_two_pow_dvd_triple k⟩
    by_cases hearly : k < m
    · exact Finset.mem_union_left _
        (Finset.mem_image.mpr ⟨k, Finset.mem_range.mpr hearly, rfl⟩)
    · exact Finset.mem_union_right _ (Finset.mem_Ico.mpr ⟨by omega, by omega⟩)

/-- Weight bound required by the general divisibility-cover theorem. -/
theorem shiftedTwoPowCover_budget (m : ℕ) (hm : 2 ≤ m) :
    (∑ j ∈ shiftedTwoPowCover m, (2 ^ j + 1)) + 9 * m ≤
      (2 ^ (9 * m) + 1) + (shiftedTwoPowCover m).card := by
  have hd := shiftedTwoPowCover_disjoint m
  have himage :
      (∑ j ∈ (Finset.range m).image (fun k => 3 * k), (2 ^ j + 1)) =
        ∑ k ∈ Finset.range m, (2 ^ (3 * k) + 1) := by
    exact Finset.sum_image (by intro a ha b hb h; dsimp at h; omega)
  have hfirst := sum_three_mul_shifted_two_pow_le m hm
  have hpow := sum_Ico_two_pow (show 3 * m ≤ 9 * m by omega)
  have hcardIco : (Finset.Ico (3 * m) (9 * m)).card = 6 * m := by
    rw [Nat.card_Ico]
    omega
  have hsecond :
      (∑ j ∈ Finset.Ico (3 * m) (9 * m), (2 ^ j + 1)) =
        (2 ^ (9 * m) - 2 ^ (3 * m)) + 6 * m := by
    rw [Finset.sum_add_distrib, hpow]
    simp only [Finset.sum_const, smul_eq_mul, mul_one, hcardIco]
  have hmargin := eight_mul_le_three_pow_margin m hm
  have hcard :
      ((Finset.range m).image (fun k => 3 * k) ∪
        Finset.Ico (3 * m) (9 * m)).card = 7 * m := by
    simpa [shiftedTwoPowCover] using shiftedTwoPowCover_card m
  rw [shiftedTwoPowCover, Finset.sum_union hd, himage, hsecond, hcard]
  have hp : 2 ^ (3 * m) = 2 * 2 ^ (3 * m - 1) := by
    conv_lhs => rw [show 3 * m = (3 * m - 1) + 1 by omega]
    rw [pow_succ]
    ring
  have hle : 2 ^ (3 * m) ≤ 2 ^ (9 * m) :=
    Nat.pow_le_pow_right (by omega : 0 < 2) (by omega)
  omega

/-- The classical below-ratio-two example `n_k=2^k+1` has irrational
reciprocal-Fibonacci sum. -/
theorem irrational_reciprocal_fib_shifted_two_powers :
    Irrational (∑' k : ℕ, (Nat.fib (2 ^ k + 1) : ℝ)⁻¹) := by
  let n : ℕ → ℕ := fun k => 2 ^ k + 1
  let s : ℕ → ℕ := fun t => 9 * (t + 2)
  let J : ℕ → Finset ℕ := fun t => shiftedTwoPowCover (t + 2)
  apply irrational_reciprocal_fib_of_divisibility_covers n s J
  · intro k
    simp [n]
  · intro a b hab
    dsimp [n]
    have hp := Nat.pow_lt_pow_right (by omega : 1 < 2) hab
    omega
  · apply Filter.tendsto_atTop.mpr
    intro B
    filter_upwards [eventually_ge_atTop B] with t ht
    dsimp [s]
    omega
  · intro t k hk
    simpa [n, s, J] using shiftedTwoPowCover_covers (t + 2) k hk
  · intro t
    simpa [n, s, J] using shiftedTwoPowCover_budget (t + 2) (by omega)

end Research

/-!
# Canonical divisibility-maximal covers
-/

namespace Research

open Filter Topology
open scoped BigOperators

/-- Positions in a finite prefix whose selected index divides no selected index
at a strictly later position of that prefix. -/
def divisibilityMaxima (n : ℕ → ℕ) (N : ℕ) : Finset ℕ :=
  (Finset.range N).filter fun j =>
    ∀ l < N, n j ∣ n l → l ≤ j

/-- Every finite-prefix position is index-divisibility-covered by a maximal
position. -/
theorem divisibilityMaxima_cover (n : ℕ → ℕ) (N k : ℕ) (hk : k < N) :
    ∃ j ∈ divisibilityMaxima n N, n k ∣ n j := by
  let S := (Finset.range N).filter fun l => n k ∣ n l
  have hSne : S.Nonempty := by
    refine ⟨k, Finset.mem_filter.mpr ⟨Finset.mem_range.mpr hk, dvd_refl _⟩⟩
  obtain ⟨j, hjS, hjmax⟩ := Finset.exists_max_image S id hSne
  have hjS' := Finset.mem_filter.mp hjS
  refine ⟨j, ?_, hjS'.2⟩
  rw [divisibilityMaxima, Finset.mem_filter]
  refine ⟨hjS'.1, ?_⟩
  intro l hl hdiv
  apply hjmax l
  rw [Finset.mem_filter]
  exact ⟨Finset.mem_range.mpr hl, hjS'.2.trans hdiv⟩

/-- The canonical maximal positions give a concrete version of F-011.  Thus
only the total weight of divisibility-maximal indices in each prefix needs to
be estimated. -/
theorem irrational_reciprocal_fib_of_maximal_cover_budget
    (n s : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hs : Tendsto s atTop atTop)
    (hbudget : ∀ t,
      (∑ j ∈ divisibilityMaxima n (s t), n j) + s t ≤
        n (s t) + (divisibilityMaxima n (s t)).card) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  exact irrational_reciprocal_fib_of_divisibility_covers n s
    (fun t => divisibilityMaxima n (s t)) hpos hmono hs
    (fun t k hk => divisibilityMaxima_cover n (s t) k hk) hbudget

end Research

/-!
# Exact integer tail states forced by a rational reciprocal sum
-/

namespace Research

open Filter Topology
open scoped BigOperators

/-- If a positive unit-fraction sum is represented as `a/b`, this is the
integer obtained by clearing the first `N` denominators from its tail. -/
def rationalTailState (d : ℕ → ℕ) (a b N : ℕ) : ℤ :=
  (a : ℤ) * reciprocalDenomProd d N -
    (b : ℤ) * reciprocalScaledNumerator d N

/-- The integer state is exactly the product denominator times the analytic
tail. -/
theorem rationalTailState_cast_eq_scaled_tail
    (d : ℕ → ℕ) (a b : ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hb : 0 < b)
    (hrat : (∑' k : ℕ, (d k : ℝ)⁻¹) = (a : ℝ) / (b : ℝ))
    (N : ℕ) :
    (rationalTailState d a b N : ℝ) =
      (b : ℝ) * (reciprocalDenomProd d N : ℝ) *
        (∑' j : ℕ, (d (N + j) : ℝ)⁻¹) := by
  let P : ℝ := ∑ k ∈ Finset.range N, (d k : ℝ)⁻¹
  let T : ℝ := ∑' j : ℕ, (d (N + j) : ℝ)⁻¹
  have hsplit : P + T = ∑' k : ℕ, (d k : ℝ)⁻¹ := by
    have h := hsum.sum_add_tsum_nat_add N
    simpa [P, T, add_comm] using h
  have hDP :
      (reciprocalDenomProd d N : ℝ) * P =
        (reciprocalScaledNumerator d N : ℝ) := by
    simpa [P] using denomProd_mul_partialSum_eq_scaledNumerator d hpos N
  have hb0 : (b : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt hb)
  change (rationalTailState d a b N : ℝ) =
    (b : ℝ) * (reciprocalDenomProd d N : ℝ) * T
  rw [show T = (a : ℝ) / (b : ℝ) - P by linarith [hsplit, hrat]]
  dsimp [rationalTailState]
  push_cast
  rw [← hDP]
  field_simp

/-- Every state forced by a rational positive sum is a strictly positive
integer. -/
theorem rationalTailState_pos
    (d : ℕ → ℕ) (a b : ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hb : 0 < b)
    (hrat : (∑' k : ℕ, (d k : ℝ)⁻¹) = (a : ℝ) / (b : ℝ))
    (N : ℕ) :
    0 < rationalTailState d a b N := by
  have hcast := rationalTailState_cast_eq_scaled_tail d a b hpos hsum hb hrat N
  have hD : 0 < reciprocalDenomProd d N := by
    exact Finset.prod_pos fun k hk => hpos k
  have ht : Summable (fun j : ℕ => (d (N + j) : ℝ)⁻¹) := by
    have h := (summable_nat_add_iff N).2 hsum
    simpa [add_comm] using h
  have hT : 0 < ∑' j : ℕ, (d (N + j) : ℝ)⁻¹ :=
    ht.tsum_pos (fun _ => inv_nonneg.mpr (by positivity)) 0
      (inv_pos.mpr (by exact_mod_cast hpos N))
  have hr : (0 : ℝ) < (rationalTailState d a b N : ℝ) := by
    rw [hcast]
    positivity
  exact_mod_cast hr

/-- The product denominator grows by the next denominator. -/
theorem reciprocalDenomProd_succ (d : ℕ → ℕ) (N : ℕ) :
    reciprocalDenomProd d (N + 1) = reciprocalDenomProd d N * d N := by
  simp [reciprocalDenomProd, Finset.prod_range_succ]

/-- Exact Engel-type recurrence for the positive integer tail states:
`z_{N+1} = d_N z_N - b D_N`. -/
theorem rationalTailState_succ
    (d : ℕ → ℕ) (a b : ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hb : 0 < b)
    (hrat : (∑' k : ℕ, (d k : ℝ)⁻¹) = (a : ℝ) / (b : ℝ))
    (N : ℕ) :
    rationalTailState d a b (N + 1) =
      (d N : ℤ) * rationalTailState d a b N -
        (b : ℤ) * reciprocalDenomProd d N := by
  have hN := rationalTailState_cast_eq_scaled_tail d a b hpos hsum hb hrat N
  have hNs := rationalTailState_cast_eq_scaled_tail d a b hpos hsum hb hrat (N + 1)
  have hshift :
      (∑' j : ℕ, (d (N + j) : ℝ)⁻¹) =
        (d N : ℝ)⁻¹ + ∑' j : ℕ, (d (N + 1 + j) : ℝ)⁻¹ := by
    have ht : Summable (fun j : ℕ => (d (N + j) : ℝ)⁻¹) := by
      have h := (summable_nat_add_iff N).2 hsum
      simpa [add_comm] using h
    have h := (ht.sum_add_tsum_nat_add 1).symm
    simpa [add_assoc, add_comm, add_left_comm] using h
  have hd0 : (d N : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt (hpos N))
  have hreal :
      (rationalTailState d a b (N + 1) : ℝ) =
        (d N : ℝ) * (rationalTailState d a b N : ℝ) -
          (b : ℝ) * (reciprocalDenomProd d N : ℝ) := by
    rw [hNs, reciprocalDenomProd_succ, Nat.cast_mul, hN, hshift]
    field_simp
    ring
  exact_mod_cast hreal

/-- Fibonacci specialization of the exact positive integer recurrence. -/
theorem rational_fibonacci_tail_states
    (n : ℕ → ℕ) (a b : ℕ) (hpos : ∀ k, 0 < n k)
    (hmono : StrictMono n) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) = (a : ℝ) / (b : ℝ)) :
    let z := rationalTailState (fun k => Nat.fib (n k)) a b
    let D := reciprocalDenomProd (fun k => Nat.fib (n k))
    (∀ N, 0 < z N) ∧
      (∀ N, z (N + 1) =
        (Nat.fib (n N) : ℤ) * z N - (b : ℤ) * D N) := by
  let d : ℕ → ℕ := fun k => Nat.fib (n k)
  have hdpos : ∀ k, 0 < d k := fun k => Nat.fib_pos.mpr (hpos k)
  have hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹) := by
    simpa [d] using (summable_and_tsum_shift_le n hpos hmono 0).1
  dsimp only
  constructor
  · exact fun N => rationalTailState_pos d a b hdpos hsum hb (by simpa [d] using hrat) N
  · exact fun N => rationalTailState_succ d a b hdpos hsum hb (by simpa [d] using hrat) N

end Research

/-!
# Prime-divisibility invariants of rational tail states
-/

namespace Research

open scoped BigOperators

/-- Natural-number version of the positive integer tail state. -/
def rationalTailStateNat (d : ℕ → ℕ) (a b N : ℕ) : ℕ :=
  (rationalTailState d a b N).toNat

/-- Once rationality supplies positivity, coercing the natural state back to
`ℤ` recovers the original state exactly. -/
theorem rationalTailStateNat_cast
    (d : ℕ → ℕ) (a b : ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hb : 0 < b)
    (hrat : (∑' k : ℕ, (d k : ℝ)⁻¹) = (a : ℝ) / (b : ℝ))
    (N : ℕ) :
    (rationalTailStateNat d a b N : ℤ) = rationalTailState d a b N := by
  exact Int.toNat_of_nonneg
    (le_of_lt (rationalTailState_pos d a b hpos hsum hb hrat N))

/-- Subtraction-free natural form of the exact recurrence. -/
theorem rationalTailStateNat_succ_add
    (d : ℕ → ℕ) (a b : ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hb : 0 < b)
    (hrat : (∑' k : ℕ, (d k : ℝ)⁻¹) = (a : ℝ) / (b : ℝ))
    (N : ℕ) :
    rationalTailStateNat d a b (N + 1) + b * reciprocalDenomProd d N =
      d N * rationalTailStateNat d a b N := by
  have hz := rationalTailState_succ d a b hpos hsum hb hrat N
  have hcN := rationalTailStateNat_cast d a b hpos hsum hb hrat N
  have hcNs := rationalTailStateNat_cast d a b hpos hsum hb hrat (N + 1)
  exact_mod_cast (show
    (rationalTailStateNat d a b (N + 1) : ℤ) +
        (b * reciprocalDenomProd d N : ℕ) =
      (d N * rationalTailStateNat d a b N : ℕ) by
        push_cast
        rw [hcN, hcNs, hz]
        ring)

/-- A prime appearing for the first time in `d_N` cannot divide the next tail
state, provided it does not divide the fixed rational denominator `b`. -/
theorem prime_not_dvd_tailState_after_first_denominator
    (d : ℕ → ℕ) (a b p : ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hb : 0 < b)
    (hrat : (∑' k : ℕ, (d k : ℝ)⁻¹) = (a : ℝ) / (b : ℝ))
    (hp : p.Prime) (hpb : ¬p ∣ b) (N : ℕ)
    (hpnew : ∀ i < N, ¬p ∣ d i) (hpd : p ∣ d N) :
    ¬p ∣ rationalTailStateNat d a b (N + 1) := by
  have hrec := rationalTailStateNat_succ_add d a b hpos hsum hb hrat N
  have hpD : ¬p ∣ reciprocalDenomProd d N := by
    rw [← hp.coprime_iff_not_dvd]
    apply Nat.Coprime.prod_right
    intro i hi
    exact hp.coprime_iff_not_dvd.mpr (hpnew i (Finset.mem_range.mp hi))
  have hpbD : ¬p ∣ b * reciprocalDenomProd d N :=
    hp.not_dvd_mul hpb hpD
  intro hpz
  have hpright : p ∣ d N * rationalTailStateNat d a b N :=
    dvd_mul_of_dvd_left hpd _
  have hpsum : p ∣ rationalTailStateNat d a b (N + 1) +
      b * reciprocalDenomProd d N := by rwa [hrec]
  have hpbd : p ∣ b * reciprocalDenomProd d N :=
    (Nat.dvd_add_iff_right hpz).mpr (by simpa [add_comm] using hpsum)
  exact hpbD hpbd

/-- Once `p` is already in the product denominator, nondivisibility of both the
current denominator and current state propagates to the next state. -/
theorem prime_not_dvd_tailState_propagates
    (d : ℕ → ℕ) (a b p : ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hb : 0 < b)
    (hrat : (∑' k : ℕ, (d k : ℝ)⁻¹) = (a : ℝ) / (b : ℝ))
    (hp : p.Prime) (N : ℕ)
    (hpD : p ∣ reciprocalDenomProd d N)
    (hpd : ¬p ∣ d N)
    (hpz : ¬p ∣ rationalTailStateNat d a b N) :
    ¬p ∣ rationalTailStateNat d a b (N + 1) := by
  have hrec := rationalTailStateNat_succ_add d a b hpos hsum hb hrat N
  intro hpzs
  have hpbd : p ∣ b * reciprocalDenomProd d N := dvd_mul_of_dvd_right hpD _
  have hpsum : p ∣ rationalTailStateNat d a b (N + 1) +
      b * reciprocalDenomProd d N := dvd_add hpzs hpbd
  have hpprod : p ∣ d N * rationalTailStateNat d a b N := by rwa [← hrec]
  rcases hp.dvd_mul.mp hpprod with h | h
  · exact hpd h
  · exact hpz h

/-- If an already-seen prime reappears in the current denominator, then it must
divide the next state. -/
theorem prime_dvd_tailState_after_reappearance
    (d : ℕ → ℕ) (a b p : ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hb : 0 < b)
    (hrat : (∑' k : ℕ, (d k : ℝ)⁻¹) = (a : ℝ) / (b : ℝ))
    (N : ℕ) (hpD : p ∣ reciprocalDenomProd d N) (hpd : p ∣ d N) :
    p ∣ rationalTailStateNat d a b (N + 1) := by
  have hrec := rationalTailStateNat_succ_add d a b hpos hsum hb hrat N
  have hpbd : p ∣ b * reciprocalDenomProd d N := dvd_mul_of_dvd_right hpD _
  have hpright : p ∣ d N * rationalTailStateNat d a b N :=
    dvd_mul_of_dvd_left hpd _
  have hpsum : p ∣ rationalTailStateNat d a b (N + 1) +
      b * reciprocalDenomProd d N := by rwa [hrec]
  exact (Nat.dvd_add_iff_right hpbd).mpr (by simpa [add_comm] using hpsum)

end Research

/-!
# Exact rational tail states with least-common-multiple denominators
-/

namespace Research

/-- Integer state obtained by clearing a finite prefix with its exact lcm. -/
def rationalLcmTailState (d : ℕ → ℕ) (a b N : ℕ) : ℤ :=
  (a : ℤ) * reciprocalLcm d N -
    (b : ℤ) * reciprocalLcmNumerator d N

/-- New lcm factor paid when adjoining `d_N`. -/
def reciprocalLcmGrowth (d : ℕ → ℕ) (N : ℕ) : ℕ :=
  reciprocalLcm d (N + 1) / reciprocalLcm d N

/-- Complementary factor of the enlarged lcm after dividing by `d_N`. -/
def reciprocalLcmCofactor (d : ℕ → ℕ) (N : ℕ) : ℕ :=
  reciprocalLcm d (N + 1) / d N

/-- The old lcm divides the enlarged lcm. -/
theorem reciprocalLcm_dvd_succ (d : ℕ → ℕ) (N : ℕ) :
    reciprocalLcm d N ∣ reciprocalLcm d (N + 1) := by
  rw [reciprocalLcm_succ]
  exact Nat.dvd_lcm_right _ _

/-- The newly adjoined denominator divides the enlarged lcm. -/
theorem denominator_dvd_reciprocalLcm_succ (d : ℕ → ℕ) (N : ℕ) :
    d N ∣ reciprocalLcm d (N + 1) := by
  rw [reciprocalLcm_succ]
  exact Nat.dvd_lcm_left _ _

/-- Exact factorizations associated with lcm growth. -/
theorem reciprocalLcm_growth_mul (d : ℕ → ℕ) (_hpos : ∀ k, 0 < d k) (N : ℕ) :
    reciprocalLcmGrowth d N * reciprocalLcm d N = reciprocalLcm d (N + 1) := by
  rw [reciprocalLcmGrowth, Nat.div_mul_cancel (reciprocalLcm_dvd_succ d N)]

theorem reciprocalLcm_cofactor_mul (d : ℕ → ℕ) (N : ℕ) :
    reciprocalLcmCofactor d N * d N = reciprocalLcm d (N + 1) := by
  rw [reciprocalLcmCofactor,
    Nat.div_mul_cancel (denominator_dvd_reciprocalLcm_succ d N)]

/-- Exact analytic meaning of the lcm state. -/
theorem rationalLcmTailState_cast_eq_scaled_tail
    (d : ℕ → ℕ) (a b : ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hb : 0 < b)
    (hrat : (∑' k : ℕ, (d k : ℝ)⁻¹) = (a : ℝ) / (b : ℝ))
    (N : ℕ) :
    (rationalLcmTailState d a b N : ℝ) =
      (b : ℝ) * (reciprocalLcm d N : ℝ) *
        (∑' j : ℕ, (d (N + j) : ℝ)⁻¹) := by
  let P : ℝ := ∑ k ∈ Finset.range N, (d k : ℝ)⁻¹
  let T : ℝ := ∑' j : ℕ, (d (N + j) : ℝ)⁻¹
  have hsplit : P + T = ∑' k : ℕ, (d k : ℝ)⁻¹ := by
    have h := hsum.sum_add_tsum_nat_add N
    simpa [P, T, add_comm] using h
  have hLP :
      (reciprocalLcm d N : ℝ) * P =
        (reciprocalLcmNumerator d N : ℝ) := by
    simpa [P] using reciprocalLcm_mul_partialSum_eq d hpos N
  have hb0 : (b : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt hb)
  change (rationalLcmTailState d a b N : ℝ) =
    (b : ℝ) * (reciprocalLcm d N : ℝ) * T
  rw [show T = (a : ℝ) / (b : ℝ) - P by linarith [hsplit, hrat]]
  dsimp [rationalLcmTailState]
  push_cast
  rw [← hLP]
  field_simp

/-- Lcm states are strictly positive integers. -/
theorem rationalLcmTailState_pos
    (d : ℕ → ℕ) (a b : ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hb : 0 < b)
    (hrat : (∑' k : ℕ, (d k : ℝ)⁻¹) = (a : ℝ) / (b : ℝ))
    (N : ℕ) :
    0 < rationalLcmTailState d a b N := by
  have hcast := rationalLcmTailState_cast_eq_scaled_tail d a b hpos hsum hb hrat N
  have hL := reciprocalLcm_pos d hpos N
  have ht : Summable (fun j : ℕ => (d (N + j) : ℝ)⁻¹) := by
    have h := (summable_nat_add_iff N).2 hsum
    simpa [add_comm] using h
  have hT : 0 < ∑' j : ℕ, (d (N + j) : ℝ)⁻¹ :=
    ht.tsum_pos (fun _ => inv_nonneg.mpr (by positivity)) 0
      (inv_pos.mpr (by exact_mod_cast hpos N))
  have hr : (0 : ℝ) < (rationalLcmTailState d a b N : ℝ) := by
    rw [hcast]
    positivity
  exact_mod_cast hr

/-- Exact lcm-state recurrence.  It pays only the genuinely new lcm factor,
not the full new denominator. -/
theorem rationalLcmTailState_succ
    (d : ℕ → ℕ) (a b : ℕ) (hpos : ∀ k, 0 < d k)
    (hsum : Summable (fun k : ℕ => (d k : ℝ)⁻¹))
    (hb : 0 < b)
    (hrat : (∑' k : ℕ, (d k : ℝ)⁻¹) = (a : ℝ) / (b : ℝ))
    (N : ℕ) :
    rationalLcmTailState d a b (N + 1) =
      (reciprocalLcmGrowth d N : ℤ) * rationalLcmTailState d a b N -
        (b : ℤ) * reciprocalLcmCofactor d N := by
  have hN := rationalLcmTailState_cast_eq_scaled_tail d a b hpos hsum hb hrat N
  have hNs := rationalLcmTailState_cast_eq_scaled_tail d a b hpos hsum hb hrat (N + 1)
  have hshift :
      (∑' j : ℕ, (d (N + j) : ℝ)⁻¹) =
        (d N : ℝ)⁻¹ + ∑' j : ℕ, (d (N + 1 + j) : ℝ)⁻¹ := by
    have ht : Summable (fun j : ℕ => (d (N + j) : ℝ)⁻¹) := by
      have h := (summable_nat_add_iff N).2 hsum
      simpa [add_comm] using h
    have h := (ht.sum_add_tsum_nat_add 1).symm
    simpa [add_assoc, add_comm, add_left_comm] using h
  have hLpos := reciprocalLcm_pos d hpos N
  have hLNpos := reciprocalLcm_pos d hpos (N + 1)
  have hg : reciprocalLcmGrowth d N * reciprocalLcm d N =
      reciprocalLcm d (N + 1) := reciprocalLcm_growth_mul d hpos N
  have hc : reciprocalLcmCofactor d N * d N =
      reciprocalLcm d (N + 1) := reciprocalLcm_cofactor_mul d N
  have hd0 : (d N : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt (hpos N))
  have hreal :
      (rationalLcmTailState d a b (N + 1) : ℝ) =
        (reciprocalLcmGrowth d N : ℝ) *
            (rationalLcmTailState d a b N : ℝ) -
          (b : ℝ) * reciprocalLcmCofactor d N := by
    rw [hNs, hN, hshift]
    have hg' : (reciprocalLcmGrowth d N : ℝ) * reciprocalLcm d N =
        reciprocalLcm d (N + 1) := by exact_mod_cast hg
    have hc' : (reciprocalLcmCofactor d N : ℝ) * d N =
        reciprocalLcm d (N + 1) := by exact_mod_cast hc
    have hgc : (reciprocalLcmGrowth d N : ℝ) * reciprocalLcm d N =
        (reciprocalLcmCofactor d N : ℝ) * d N := hg'.trans hc'.symm
    calc
      (b : ℝ) * reciprocalLcm d (N + 1) *
          (∑' j : ℕ, (d (N + 1 + j) : ℝ)⁻¹) =
          (b : ℝ) * ((reciprocalLcmGrowth d N : ℝ) * reciprocalLcm d N) *
            (∑' j : ℕ, (d (N + 1 + j) : ℝ)⁻¹) := by rw [hg']
      _ = (reciprocalLcmGrowth d N : ℝ) *
            ((b : ℝ) * reciprocalLcm d N *
              ((d N : ℝ)⁻¹ +
                ∑' j : ℕ, (d (N + 1 + j) : ℝ)⁻¹)) -
            (b : ℝ) * reciprocalLcmCofactor d N := by
              field_simp
              linear_combination -hgc
  exact_mod_cast hreal

end Research

/-!
# Simultaneous reuse of several coprime Fibonacci overlap factors
-/

namespace Research

open Filter Topology
open Real goldenRatio
open scoped BigOperators

/-- Product of the Fibonacci factors indexed by a finite overlap set. -/
def multiOverlapFactor (E : ℕ → Finset ℕ) (k : ℕ) : ℕ :=
  ∏ e ∈ E k, Nat.fib e

/-- General exact lcm bound when each new denominator reuses an arbitrary
common factor already present in the preceding lcm. -/
theorem reciprocalLcm_dvd_commonFactor_product
    (d g : ℕ → ℕ) (hgpos : ∀ k, 0 < g k)
    (hgd : ∀ k, g k ∣ d k)
    (hgprev : ∀ k, g k ∣ reciprocalLcm d k) :
    ∀ N, reciprocalLcm d N ∣ ∏ k ∈ Finset.range N, d k / g k := by
  intro N
  induction N with
  | zero => simp [reciprocalLcm]
  | succ N ih =>
      rw [show N + 1 = Nat.succ N by rfl, Finset.prod_range_succ,
        reciprocalLcm_succ]
      have hgB : g N ∣ ∏ k ∈ Finset.range N, d k / g k :=
        (hgprev N).trans ih
      have h := lcm_dvd_mul_div_of_common_dvd
        (reciprocalLcm d N) (d N)
        (∏ k ∈ Finset.range N, d k / g k) (g N)
        (hgpos N) ih hgB (hgd N)
      simpa [Nat.lcm_comm] using h

/-- A pairwise-coprime product of Fibonacci factors divides the selected
Fibonacci denominator. -/
theorem multiOverlapFactor_dvd_fib
    (n : ℕ → ℕ) (E : ℕ → Finset ℕ)
    (hpair : ∀ k,
      (↑(E k) : Set ℕ).Pairwise
        (Function.onFun IsCoprime fun e => Nat.fib e))
    (hediv : ∀ k e, e ∈ E k → e ∣ n k) (k : ℕ) :
    multiOverlapFactor E k ∣ Nat.fib (n k) := by
  apply Finset.prod_dvd_of_coprime (hpair k)
  intro e he
  exact Nat.fib_dvd _ _ (hediv k e he)

/-- If every overlap factor at a positive position divides some earlier
selected index, their coprime product is already in the preceding lcm. -/
theorem multiOverlapFactor_dvd_previous_lcm
    (n : ℕ → ℕ) (E : ℕ → Finset ℕ) (hE0 : E 0 = ∅)
    (hpair : ∀ k,
      (↑(E k) : Set ℕ).Pairwise
        (Function.onFun IsCoprime fun e => Nat.fib e))
    (heprev : ∀ k e, e ∈ E k → 0 < k → ∃ i < k, e ∣ n i) (k : ℕ) :
    multiOverlapFactor E k ∣ reciprocalLcm (fun i => Nat.fib (n i)) k := by
  by_cases hk : k = 0
  · subst k
    simp [multiOverlapFactor, hE0]
  · apply Finset.prod_dvd_of_coprime (hpair k)
    intro e he
    obtain ⟨i, hi, hd⟩ := heprev k e he (Nat.pos_of_ne_zero hk)
    exact (Nat.fib_dvd _ _ hd).trans (Finset.dvd_lcm (Finset.mem_range.mpr hi))

/-- Exact lcm bound obtained by simultaneously reusing all factors in each
coprime overlap set. -/
theorem reciprocalLcm_fib_dvd_multiOverlap_product
    (n : ℕ → ℕ) (E : ℕ → Finset ℕ)
    (hepos : ∀ k e, e ∈ E k → 0 < e) (hE0 : E 0 = ∅)
    (hpair : ∀ k,
      (↑(E k) : Set ℕ).Pairwise
        (Function.onFun IsCoprime fun e => Nat.fib e))
    (hediv : ∀ k e, e ∈ E k → e ∣ n k)
    (heprev : ∀ k e, e ∈ E k → 0 < k → ∃ i < k, e ∣ n i) :
    ∀ N, reciprocalLcm (fun k => Nat.fib (n k)) N ∣
      ∏ k ∈ Finset.range N, Nat.fib (n k) / multiOverlapFactor E k := by
  apply reciprocalLcm_dvd_commonFactor_product
  · intro k
    exact Finset.prod_pos fun e he => Nat.fib_pos.mpr (hepos k e he)
  · exact multiOverlapFactor_dvd_fib n E hpair hediv
  · exact multiOverlapFactor_dvd_previous_lcm n E hE0 hpair heprev

/-- Golden-ratio bound for the quotient after simultaneously reusing a finite
coprime family of Fibonacci factors. -/
theorem fib_div_multiOverlap_le_geometric
    (n : ℕ → ℕ) (E : ℕ → Finset ℕ)
    (_hpos : ∀ k, 0 < n k)
    (hepos : ∀ k e, e ∈ E k → 0 < e)
    (hpair : ∀ k,
      (↑(E k) : Set ℕ).Pairwise
        (Function.onFun IsCoprime fun e => Nat.fib e))
    (hediv : ∀ k e, e ∈ E k → e ∣ n k) (k : ℕ) :
    ((Nat.fib (n k) / multiOverlapFactor E k : ℕ) : ℝ) ≤
      φ⁻¹ * φ ^ (n k) *
        (φ ^ (2 * (E k).card) * (φ⁻¹) ^ (∑ e ∈ E k, e)) := by
  have hgd := multiOverlapFactor_dvd_fib n E hpair hediv k
  have hgpos : 0 < multiOverlapFactor E k :=
    Finset.prod_pos fun e he => Nat.fib_pos.mpr (hepos k e he)
  have hg0 : (multiOverlapFactor E k : ℝ) ≠ 0 := by
    exact_mod_cast (Nat.ne_of_gt hgpos)
  rw [Nat.cast_div hgd hg0, div_eq_mul_inv]
  have hfn : (Nat.fib (n k) : ℝ) ≤ φ⁻¹ * φ ^ (n k) := by
    have h := goldenRatio_mul_fib_le_pow (n k)
    rw [← div_eq_inv_mul]
    exact (le_div_iff₀ Real.goldenRatio_pos).2 (by simpa [mul_comm] using h)
  have hinv : (multiOverlapFactor E k : ℝ)⁻¹ ≤
      φ ^ (2 * (E k).card) * (φ⁻¹) ^ (∑ e ∈ E k, e) := by
    calc
      (multiOverlapFactor E k : ℝ)⁻¹ =
          ∏ e ∈ E k, (Nat.fib e : ℝ)⁻¹ := by
            rw [multiOverlapFactor]
            push_cast
            exact (Finset.prod_inv_distrib _).symm
      _ ≤ ∏ e ∈ E k, (φ ^ 2 * (φ⁻¹) ^ e) := by
            apply Finset.prod_le_prod
            · intro e he
              positivity
            · intro e he
              exact inv_fib_le_golden_geometric e (hepos k e he)
      _ = φ ^ (2 * (E k).card) * (φ⁻¹) ^ (∑ e ∈ E k, e) := by
            rw [Finset.prod_mul_distrib, Finset.prod_const,
              Finset.prod_pow_eq_pow_sum]
            congr 1
            rw [← pow_mul]
  gcongr

/-- A cumulative budget using several coprime reusable factors at each step
forces exact-lcm tail decay. -/
theorem tendsto_fib_lcm_tail_zero_of_multiOverlap_budget
    (n : ℕ → ℕ) (E : ℕ → Finset ℕ)
    (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hepos : ∀ k e, e ∈ E k → 0 < e) (hE0 : E 0 = ∅)
    (hpair : ∀ k,
      (↑(E k) : Set ℕ).Pairwise
        (Function.onFun IsCoprime fun e => Nat.fib e))
    (hediv : ∀ k e, e ∈ E k → e ∣ n k)
    (heprev : ∀ k e, e ∈ E k → 0 < k → ∃ i < k, e ∣ n i)
    (hbudget : ∀ N,
      (∑ k ∈ Finset.range N, n k) +
          (∑ k ∈ Finset.range N, 2 * (E k).card) ≤
        n N + ∑ k ∈ Finset.range N, (∑ e ∈ E k, e)) :
    Tendsto
      (fun N : ℕ =>
        (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹))
      atTop (𝓝 0) := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by dsimp [r]; exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by dsimp [r]; exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hlcm_bound (N : ℕ) :
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) ≤
        r ^ N * φ ^ (∑ k ∈ Finset.range N, n k) *
          (φ ^ (∑ k ∈ Finset.range N, 2 * (E k).card) *
            r ^ (∑ k ∈ Finset.range N, (∑ e ∈ E k, e))) := by
    have hdvd := reciprocalLcm_fib_dvd_multiOverlap_product n E hepos hE0
      hpair hediv heprev N
    have hquotpos (k : ℕ) :
        0 < Nat.fib (n k) / multiOverlapFactor E k := by
      apply Nat.div_pos
      · exact Nat.le_of_dvd (Nat.fib_pos.mpr (hpos k))
          (multiOverlapFactor_dvd_fib n E hpair hediv k)
      · exact Finset.prod_pos fun e he => Nat.fib_pos.mpr (hepos k e he)
    have hnat : reciprocalLcm (fun k => Nat.fib (n k)) N ≤
        ∏ k ∈ Finset.range N, Nat.fib (n k) / multiOverlapFactor E k :=
      Nat.le_of_dvd (Finset.prod_pos fun k hk => hquotpos k) hdvd
    calc
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) ≤
          (∏ k ∈ Finset.range N,
            Nat.fib (n k) / multiOverlapFactor E k : ℕ) := by exact_mod_cast hnat
      _ = ∏ k ∈ Finset.range N,
          ((Nat.fib (n k) / multiOverlapFactor E k : ℕ) : ℝ) := by push_cast; rfl
      _ ≤ ∏ k ∈ Finset.range N,
          (r * φ ^ (n k) *
            (φ ^ (2 * (E k).card) * r ^ (∑ e ∈ E k, e))) := by
              apply Finset.prod_le_prod
              · intro k hk
                positivity
              · intro k hk
                simpa [r] using fib_div_multiOverlap_le_geometric
                  n E hpos hepos hpair hediv k
      _ = r ^ N * φ ^ (∑ k ∈ Finset.range N, n k) *
          (φ ^ (∑ k ∈ Finset.range N, 2 * (E k).card) *
            r ^ (∑ k ∈ Finset.range N, (∑ e ∈ E k, e))) := by
              repeat' rw [Finset.prod_mul_distrib]
              rw [Finset.prod_const, Finset.card_range,
                Finset.prod_pow_eq_pow_sum, Finset.prod_pow_eq_pow_sum,
                Finset.prod_pow_eq_pow_sum]
  have hbound (N : ℕ) :
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤
        φ ^ 4 * r ^ N := by
    have htail := (summable_and_tsum_shift_le n hpos hmono N).2
    have hcancel := golden_pow_mul_inv_pow_le
      ((∑ k ∈ Finset.range N, n k) +
        ∑ k ∈ Finset.range N, 2 * (E k).card)
      (n N + ∑ k ∈ Finset.range N, (∑ e ∈ E k, e)) 0 (by
        simpa using hbudget N)
    calc
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤
          (r ^ N * φ ^ (∑ k ∈ Finset.range N, n k) *
            (φ ^ (∑ k ∈ Finset.range N, 2 * (E k).card) *
              r ^ (∑ k ∈ Finset.range N, (∑ e ∈ E k, e)))) *
            ((φ ^ 2 * r ^ (n N)) * φ ^ 2) := by
              gcongr
              exact hlcm_bound N
      _ = φ ^ 4 * r ^ N *
          (φ ^ ((∑ k ∈ Finset.range N, n k) +
            ∑ k ∈ Finset.range N, 2 * (E k).card) *
            r ^ (n N + ∑ k ∈ Finset.range N, (∑ e ∈ E k, e))) := by
              rw [pow_add, pow_add]
              ring
      _ ≤ φ ^ 4 * r ^ N * r ^ 0 := by
              exact mul_le_mul_of_nonneg_left
                (by simpa [r] using hcancel) (by positivity)
      _ = φ ^ 4 * r ^ N := by simp
  have hnonneg (N : ℕ) :
      0 ≤ (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) := by positivity
  have hmajor : Tendsto (fun N : ℕ => φ ^ 4 * r ^ N) atTop (𝓝 0) := by
    simpa using tendsto_const_nhds.mul
      (tendsto_pow_atTop_nhds_zero_of_lt_one hr0 hr1)
  exact squeeze_zero hnonneg hbound hmajor

/-- Multi-factor overlap budget implies irrationality. -/
theorem irrational_reciprocal_fib_of_multiOverlap_budget
    (n : ℕ → ℕ) (E : ℕ → Finset ℕ)
    (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hepos : ∀ k e, e ∈ E k → 0 < e) (hE0 : E 0 = ∅)
    (hpair : ∀ k,
      (↑(E k) : Set ℕ).Pairwise
        (Function.onFun IsCoprime fun e => Nat.fib e))
    (hediv : ∀ k e, e ∈ E k → e ∣ n k)
    (heprev : ∀ k e, e ∈ E k → 0 < k → ∃ i < k, e ∣ n i)
    (hbudget : ∀ N,
      (∑ k ∈ Finset.range N, n k) +
          (∑ k ∈ Finset.range N, 2 * (E k).card) ≤
        n N + ∑ k ∈ Finset.range N, (∑ e ∈ E k, e)) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  apply irrational_tsum_reciprocals_of_lcm_tail_zero
    (d := fun k => Nat.fib (n k))
  · exact fun k => Nat.fib_pos.mpr (hpos k)
  · simpa using (summable_and_tsum_shift_le n hpos hmono 0).1
  · exact tendsto_fib_lcm_tail_zero_of_multiOverlap_budget n E hpos hmono
      hepos hE0 hpair hediv heprev hbudget

end Research

/-!
# Reusing the lcm of two overlapping Fibonacci factors
-/

namespace Research

open Filter Topology
open Real goldenRatio
open scoped BigOperators

/-- Common factor obtained from two reusable index divisors. -/
def twoOverlapFactor (e f : ℕ → ℕ) (k : ℕ) : ℕ :=
  Nat.lcm (Nat.fib (e k)) (Nat.fib (f k))

/-- The two-factor overlap divides the new Fibonacci denominator. -/
theorem twoOverlapFactor_dvd_fib
    (n e f : ℕ → ℕ) (hediv : ∀ k, e k ∣ n k)
    (hfdiv : ∀ k, f k ∣ n k) (k : ℕ) :
    twoOverlapFactor e f k ∣ Nat.fib (n k) := by
  apply Nat.lcm_dvd
  · exact Nat.fib_dvd _ _ (hediv k)
  · exact Nat.fib_dvd _ _ (hfdiv k)

/-- Except at the initial position, both factors being represented earlier
puts their lcm in the preceding selected-Fibonacci lcm. -/
theorem twoOverlapFactor_dvd_previous_lcm
    (n e f : ℕ → ℕ) (he0 : e 0 = 1) (hf0 : f 0 = 1)
    (heprev : ∀ k, 0 < k → ∃ i < k, e k ∣ n i)
    (hfprev : ∀ k, 0 < k → ∃ i < k, f k ∣ n i) (k : ℕ) :
    twoOverlapFactor e f k ∣ reciprocalLcm (fun i => Nat.fib (n i)) k := by
  by_cases hk : k = 0
  · subst k
    simp [twoOverlapFactor, he0, hf0, reciprocalLcm]
  · apply Nat.lcm_dvd
    · obtain ⟨i, hi, hd⟩ := heprev k (Nat.pos_of_ne_zero hk)
      exact (Nat.fib_dvd _ _ hd).trans (Finset.dvd_lcm (Finset.mem_range.mpr hi))
    · obtain ⟨i, hi, hd⟩ := hfprev k (Nat.pos_of_ne_zero hk)
      exact (Nat.fib_dvd _ _ hd).trans (Finset.dvd_lcm (Finset.mem_range.mpr hi))

/-- Exact finite lcm bound using both reusable factors simultaneously. -/
theorem reciprocalLcm_fib_dvd_twoOverlap_product
    (n e f : ℕ → ℕ) (hepos : ∀ k, 0 < e k) (hfpos : ∀ k, 0 < f k)
    (he0 : e 0 = 1) (hf0 : f 0 = 1)
    (hediv : ∀ k, e k ∣ n k) (hfdiv : ∀ k, f k ∣ n k)
    (heprev : ∀ k, 0 < k → ∃ i < k, e k ∣ n i)
    (hfprev : ∀ k, 0 < k → ∃ i < k, f k ∣ n i) :
    ∀ N, reciprocalLcm (fun k => Nat.fib (n k)) N ∣
      ∏ k ∈ Finset.range N, Nat.fib (n k) / twoOverlapFactor e f k := by
  apply reciprocalLcm_dvd_commonFactor_product
  · intro k
    exact Nat.lcm_pos (Nat.fib_pos.mpr (hepos k)) (Nat.fib_pos.mpr (hfpos k))
  · exact twoOverlapFactor_dvd_fib n e f hediv hfdiv
  · exact twoOverlapFactor_dvd_previous_lcm n e f he0 hf0 heprev hfprev

/-- The inverse two-factor lcm has exponent cost governed by
`e+f-gcd(e,f)`. -/
theorem inv_twoOverlapFactor_le_geometric
    (e f : ℕ) (he : 0 < e) (hf : 0 < f) :
    (twoOverlapFactor (fun _ => e) (fun _ => f) 0 : ℝ)⁻¹ ≤
      φ ^ 3 * (φ⁻¹) ^ (e + f - Nat.gcd e f) := by
  let H := Nat.lcm (Nat.fib e) (Nat.fib f)
  have heF : (0 : ℝ) < Nat.fib e := by exact_mod_cast Nat.fib_pos.mpr he
  have hfF : (0 : ℝ) < Nat.fib f := by exact_mod_cast Nat.fib_pos.mpr hf
  have hgpos : 0 < Nat.gcd e f := Nat.gcd_pos_of_pos_left _ he
  have hgF : (0 : ℝ) < Nat.fib (Nat.gcd e f) := by
    exact_mod_cast Nat.fib_pos.mpr hgpos
  have hprodNat : Nat.fib (Nat.gcd e f) * H = Nat.fib e * Nat.fib f := by
    dsimp [H]
    rw [Nat.fib_gcd]
    exact Nat.gcd_mul_lcm _ _
  have hprod : (Nat.fib (Nat.gcd e f) : ℝ) * H =
      (Nat.fib e : ℝ) * Nat.fib f := by exact_mod_cast hprodNat
  have hH : (0 : ℝ) < H := by
    exact_mod_cast Nat.lcm_pos (Nat.fib_pos.mpr he) (Nat.fib_pos.mpr hf)
  have hident : (H : ℝ)⁻¹ =
      (Nat.fib (Nat.gcd e f) : ℝ) *
        (Nat.fib e : ℝ)⁻¹ * (Nat.fib f : ℝ)⁻¹ := by
    field_simp [ne_of_gt hH, ne_of_gt heF, ne_of_gt hfF]
    nlinarith [hprod]
  have hgUpper : (Nat.fib (Nat.gcd e f) : ℝ) ≤
      φ⁻¹ * φ ^ (Nat.gcd e f) := by
    have h := goldenRatio_mul_fib_le_pow (Nat.gcd e f)
    rw [← div_eq_inv_mul]
    exact (le_div_iff₀ Real.goldenRatio_pos).2 (by simpa [mul_comm] using h)
  have heInv := inv_fib_le_golden_geometric e he
  have hfInv := inv_fib_le_golden_geometric f hf
  rw [show twoOverlapFactor (fun _ => e) (fun _ => f) 0 = H by rfl, hident]
  calc
    (Nat.fib (Nat.gcd e f) : ℝ) * (Nat.fib e : ℝ)⁻¹ *
        (Nat.fib f : ℝ)⁻¹ ≤
      (φ⁻¹ * φ ^ (Nat.gcd e f)) *
        (φ ^ 2 * (φ⁻¹) ^ e) * (φ ^ 2 * (φ⁻¹) ^ f) := by gcongr
    _ = φ ^ 3 * (φ⁻¹) ^ (e + f - Nat.gcd e f) := by
      have hge : Nat.gcd e f ≤ e := Nat.gcd_le_left f he
      have hgf : Nat.gcd e f ≤ f := Nat.gcd_le_right e hf
      have hsum : e + f = Nat.gcd e f + (e + f - Nat.gcd e f) := by omega
      have hpow : φ ^ (Nat.gcd e f) * (φ⁻¹) ^ e * (φ⁻¹) ^ f =
          (φ⁻¹) ^ (e + f - Nat.gcd e f) := by
        calc
          φ ^ (Nat.gcd e f) * (φ⁻¹) ^ e * (φ⁻¹) ^ f =
              φ ^ (Nat.gcd e f) * (φ⁻¹) ^ (e + f) := by
                rw [mul_assoc, ← pow_add]
          _ = φ ^ (Nat.gcd e f) *
              (φ⁻¹) ^ (Nat.gcd e f + (e + f - Nat.gcd e f)) := by
                congr 2
          _ = (φ * φ⁻¹) ^ (Nat.gcd e f) *
              (φ⁻¹) ^ (e + f - Nat.gcd e f) := by
                rw [pow_add, mul_pow]
                ring
          _ = (φ⁻¹) ^ (e + f - Nat.gcd e f) := by
                rw [mul_inv_cancel₀ Real.goldenRatio_ne_zero, one_pow, one_mul]
      calc
        (φ⁻¹ * φ ^ (Nat.gcd e f)) *
            (φ ^ 2 * (φ⁻¹) ^ e) * (φ ^ 2 * (φ⁻¹) ^ f) =
            φ ^ 3 *
              (φ ^ (Nat.gcd e f) * (φ⁻¹) ^ e * (φ⁻¹) ^ f) := by
                field_simp [Real.goldenRatio_ne_zero]
        _ = φ ^ 3 * (φ⁻¹) ^ (e + f - Nat.gcd e f) := by rw [hpow]

/-- Quotient estimate after reusing the two-factor lcm. -/
theorem fib_div_twoOverlap_le_geometric
    (n e f : ℕ) (_hn : 0 < n) (he : 0 < e) (hf : 0 < f)
    (hed : e ∣ n) (hfd : f ∣ n) :
    ((Nat.fib n / Nat.lcm (Nat.fib e) (Nat.fib f) : ℕ) : ℝ) ≤
      φ ^ 2 * φ ^ n * (φ⁻¹) ^ (e + f - Nat.gcd e f) := by
  have hdiv : Nat.lcm (Nat.fib e) (Nat.fib f) ∣ Nat.fib n :=
    Nat.lcm_dvd (Nat.fib_dvd _ _ hed) (Nat.fib_dvd _ _ hfd)
  have hHpos := Nat.lcm_pos (Nat.fib_pos.mpr he) (Nat.fib_pos.mpr hf)
  have hH0 : (Nat.lcm (Nat.fib e) (Nat.fib f) : ℝ) ≠ 0 := by
    exact_mod_cast (Nat.ne_of_gt hHpos)
  rw [Nat.cast_div hdiv hH0, div_eq_mul_inv]
  have hfn : (Nat.fib n : ℝ) ≤ φ⁻¹ * φ ^ n := by
    have h := goldenRatio_mul_fib_le_pow n
    rw [← div_eq_inv_mul]
    exact (le_div_iff₀ Real.goldenRatio_pos).2 (by simpa [mul_comm] using h)
  have hinv : (Nat.lcm (Nat.fib e) (Nat.fib f) : ℝ)⁻¹ ≤
      φ ^ 3 * (φ⁻¹) ^ (e + f - Nat.gcd e f) := by
    simpa [twoOverlapFactor] using inv_twoOverlapFactor_le_geometric e f he hf
  calc
    (Nat.fib n : ℝ) * (Nat.lcm (Nat.fib e) (Nat.fib f) : ℝ)⁻¹ ≤
        (φ⁻¹ * φ ^ n) *
          (φ ^ 3 * (φ⁻¹) ^ (e + f - Nat.gcd e f)) := by gcongr
    _ = φ ^ 2 * φ ^ n * (φ⁻¹) ^ (e + f - Nat.gcd e f) := by
      field_simp [Real.goldenRatio_ne_zero]

/-- Two-overlap cumulative budget implies irrationality. -/
theorem irrational_reciprocal_fib_of_twoOverlap_budget
    (n e f : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (hepos : ∀ k, 0 < e k) (hfpos : ∀ k, 0 < f k)
    (he0 : e 0 = 1) (hf0 : f 0 = 1)
    (hediv : ∀ k, e k ∣ n k) (hfdiv : ∀ k, f k ∣ n k)
    (heprev : ∀ k, 0 < k → ∃ i < k, e k ∣ n i)
    (hfprev : ∀ k, 0 < k → ∃ i < k, f k ∣ n i)
    (hbudget : ∀ N,
      (∑ k ∈ Finset.range N, n k) + 3 * N ≤
        n N + ∑ k ∈ Finset.range N,
          (e k + f k - Nat.gcd (e k) (f k))) :
    Irrational (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by dsimp [r]; exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by dsimp [r]; exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hlcm (N : ℕ) :
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) ≤
        φ ^ (2 * N) * φ ^ (∑ k ∈ Finset.range N, n k) *
          r ^ (∑ k ∈ Finset.range N,
            (e k + f k - Nat.gcd (e k) (f k))) := by
    have hdvd := reciprocalLcm_fib_dvd_twoOverlap_product n e f hepos hfpos
      he0 hf0 hediv hfdiv heprev hfprev N
    have hqpos (k : ℕ) :
        0 < Nat.fib (n k) / twoOverlapFactor e f k := by
      apply Nat.div_pos
      · exact Nat.le_of_dvd (Nat.fib_pos.mpr (hpos k))
          (twoOverlapFactor_dvd_fib n e f hediv hfdiv k)
      · exact Nat.lcm_pos (Nat.fib_pos.mpr (hepos k)) (Nat.fib_pos.mpr (hfpos k))
    have hnat : reciprocalLcm (fun k => Nat.fib (n k)) N ≤
        ∏ k ∈ Finset.range N, Nat.fib (n k) / twoOverlapFactor e f k :=
      Nat.le_of_dvd (Finset.prod_pos fun k hk => hqpos k) hdvd
    calc
      (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) ≤
          (∏ k ∈ Finset.range N,
            Nat.fib (n k) / twoOverlapFactor e f k : ℕ) := by exact_mod_cast hnat
      _ = ∏ k ∈ Finset.range N,
          ((Nat.fib (n k) / twoOverlapFactor e f k : ℕ) : ℝ) := by push_cast; rfl
      _ ≤ ∏ k ∈ Finset.range N,
          (φ ^ 2 * φ ^ (n k) *
            r ^ (e k + f k - Nat.gcd (e k) (f k))) := by
              apply Finset.prod_le_prod
              · intro k hk
                positivity
              · intro k hk
                simpa [twoOverlapFactor, r] using fib_div_twoOverlap_le_geometric
                  (n k) (e k) (f k) (hpos k) (hepos k) (hfpos k)
                    (hediv k) (hfdiv k)
      _ = φ ^ (2 * N) * φ ^ (∑ k ∈ Finset.range N, n k) *
          r ^ (∑ k ∈ Finset.range N,
            (e k + f k - Nat.gcd (e k) (f k))) := by
              repeat' rw [Finset.prod_mul_distrib]
              rw [Finset.prod_const, Finset.card_range,
                Finset.prod_pow_eq_pow_sum, Finset.prod_pow_eq_pow_sum]
              rw [← pow_mul]
  have hlim : Tendsto
      (fun N : ℕ =>
        (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹))
      atTop (𝓝 0) := by
    have hbound (N : ℕ) :
        (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
            (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤
          φ ^ 4 * r ^ N := by
      have htail := (summable_and_tsum_shift_le n hpos hmono N).2
      have hcancel := golden_pow_mul_inv_pow_le
        ((∑ k ∈ Finset.range N, n k) + 2 * N)
        (n N + ∑ k ∈ Finset.range N,
          (e k + f k - Nat.gcd (e k) (f k))) N (by
            have hb := hbudget N
            omega)
      calc
        (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
            (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) ≤
            (φ ^ (2 * N) * φ ^ (∑ k ∈ Finset.range N, n k) *
              r ^ (∑ k ∈ Finset.range N,
                (e k + f k - Nat.gcd (e k) (f k)))) *
              ((φ ^ 2 * r ^ (n N)) * φ ^ 2) := by
                gcongr
                exact hlcm N
        _ = φ ^ 4 *
            (φ ^ ((∑ k ∈ Finset.range N, n k) + 2 * N) *
              r ^ (n N + ∑ k ∈ Finset.range N,
                (e k + f k - Nat.gcd (e k) (f k)))) := by
                rw [pow_add, pow_add]
                ring
        _ ≤ φ ^ 4 * r ^ N := by
                exact mul_le_mul_of_nonneg_left
                  (by simpa [r] using hcancel) (by positivity)
    have hnonneg (N : ℕ) :
        0 ≤ (reciprocalLcm (fun k => Nat.fib (n k)) N : ℝ) *
          (∑' j : ℕ, (Nat.fib (n (N + j)) : ℝ)⁻¹) := by positivity
    have hmajor : Tendsto (fun N : ℕ => φ ^ 4 * r ^ N) atTop (𝓝 0) := by
      simpa using tendsto_const_nhds.mul
        (tendsto_pow_atTop_nhds_zero_of_lt_one hr0 hr1)
    exact squeeze_zero hnonneg hbound hmajor
  exact irrational_tsum_reciprocals_of_lcm_tail_zero
    (fun k => Nat.fib (n k)) (fun k => Nat.fib_pos.mpr (hpos k))
    (by simpa using (summable_and_tsum_shift_le n hpos hmono 0).1) hlim

end Research

/-!
# Exact Lambert expansion of a reciprocal Fibonacci number
-/

namespace Research

open Filter Topology
open Real goldenRatio
open scoped BigOperators

/-- Exact signed `φ`-power expansion of one reciprocal Fibonacci number. -/
theorem hasSum_inv_fib_lambert (n : ℕ) (hn : 0 < n) :
    HasSum
      (fun j : ℕ =>
        √5 * ((-1 : ℝ) ^ (n * j) *
          (φ⁻¹) ^ ((2 * j + 1) * n)))
      (Nat.fib n : ℝ)⁻¹ := by
  let r : ℝ := φ⁻¹
  let q : ℝ := (-1 : ℝ) ^ n * r ^ (2 * n)
  have hr0 : 0 ≤ r := by dsimp [r]; exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by dsimp [r]; exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hrabs : |r| < 1 := by simpa [abs_of_nonneg hr0] using hr1
  have hqabs : |q| < 1 := by
    dsimp [q]
    rw [abs_mul, abs_pow, abs_neg, abs_one, one_pow, one_mul,
      abs_pow, abs_of_nonneg hr0]
    exact pow_lt_one₀ hr0 hr1 (by omega)
  have hgeom := (hasSum_geometric_of_abs_lt_one hqabs).const_smul (√5 * r ^ n)
  have hseries :
      HasSum (fun j : ℕ =>
        √5 * ((-1 : ℝ) ^ (n * j) * r ^ ((2 * j + 1) * n)))
        ((√5 * r ^ n) * (1 - q)⁻¹) := by
    convert hgeom using 1
    · ext j
      dsimp [q]
      rw [mul_pow, ← pow_mul, ← pow_mul]
      ring_nf
    · rfl
  have hpsi : ψ = -r := by
    dsimp [r]
    linarith [Real.inv_goldenRatio]
  have hpsi_pow : ψ ^ n = (-1 : ℝ) ^ n * r ^ n := by
    rw [hpsi, neg_pow]
  have hunit : φ ^ n * r ^ n = 1 := by
    dsimp [r]
    rw [inv_pow, mul_inv_cancel₀ (pow_ne_zero _ Real.goldenRatio_ne_zero)]
  have hqne : 1 - q ≠ 0 := by
    have habsne : |q| ≠ 1 := ne_of_lt hqabs
    intro h
    have hq : q = 1 := (sub_eq_zero.mp h).symm
    exact habsne (by rw [hq, abs_one])
  have hsqrt : √5 ≠ 0 := by positivity
  have hden : 1 - ((-1 : ℝ) ^ n * r ^ (2 * n)) ≠ 0 := by
    simpa [q] using hqne
  have hrr : r ^ n * r ^ n = r ^ (2 * n) := by
    rw [← pow_add]
    congr 1
    omega
  have hvalue : ((√5 * r ^ n) * (1 - q)⁻¹) = (Nat.fib n : ℝ)⁻¹ := by
    symm
    apply inv_eq_of_mul_eq_one_right
    rw [Real.coe_fib_eq, hpsi_pow]
    dsimp [q]
    field_simp [hden, hsqrt]
    rw [mul_sub, show r ^ n * φ ^ n = 1 by simpa [mul_comm] using hunit,
      show r ^ n * ((-1 : ℝ) ^ n * r ^ n) =
        (-1 : ℝ) ^ n * r ^ (2 * n) by rw [← hrr]; ring]
  rw [hvalue] at hseries
  simpa [r] using hseries

/-- Residue-class description of the coefficient contributed by `1/F_n` in
its exact Lambert expansion.  It has period dividing `4n`. -/
def fibLambertCoeff (n m : ℕ) : ℤ :=
  if Even n then
    if m % (2 * n) = n then 1 else 0
  else
    if m % (4 * n) = n then 1
    else if m % (4 * n) = 3 * n then -1 else 0

/-- Every individual reciprocal-Fibonacci coefficient pattern is periodic with
period `4n`. -/
theorem fibLambertCoeff_add_four_mul (n m : ℕ) :
    fibLambertCoeff n (m + 4 * n) = fibLambertCoeff n m := by
  have h4 : (m + 4 * n) % (4 * n) = m % (4 * n) := by simp
  have h2 : (m + 4 * n) % (2 * n) = m % (2 * n) := by
    rw [show 4 * n = 2 * (2 * n) by omega]
    simp
  unfold fibLambertCoeff
  rw [h2, h4]

/-- The coefficient contributed by one summand is always `-1`, `0`, or `1`. -/
theorem abs_fibLambertCoeff_le_one (n m : ℕ) :
    |fibLambertCoeff n m| ≤ 1 := by
  unfold fibLambertCoeff
  split_ifs <;> norm_num

end Research

/-!
# Finite selected Lambert coefficient blocks
-/

namespace Research

open scoped BigOperators

/-- Coefficient contributed by the first `K` selected indices. -/
def prefixFibLambertCoeff (n : ℕ → ℕ) (K m : ℕ) : ℤ :=
  ∑ k ∈ Finset.range K, fibLambertCoeff (n k) m

/-- Iterating the basic period preserves a single contribution under any
multiple of `4n`. -/
theorem fibLambertCoeff_add_period_mul (n m t : ℕ) :
    fibLambertCoeff n (m + t * (4 * n)) = fibLambertCoeff n m := by
  induction t with
  | zero => simp
  | succ t ih =>
      rw [show m + (t + 1) * (4 * n) =
        (m + t * (4 * n)) + 4 * n by ring,
        fibLambertCoeff_add_four_mul, ih]

/-- A common multiple of all first-`K` coefficient periods shifts their total
coefficient block identically. -/
theorem prefixFibLambertCoeff_add_commonPeriod
    (n : ℕ → ℕ) (K X : ℕ)
    (hperiod : ∀ k < K, 4 * n k ∣ X) (m : ℕ) :
    prefixFibLambertCoeff n K (m + X) = prefixFibLambertCoeff n K m := by
  unfold prefixFibLambertCoeff
  apply Finset.sum_congr rfl
  intro k hk
  obtain ⟨t, ht⟩ := hperiod k (Finset.mem_range.mp hk)
  subst X
  simpa [mul_comm] using fibLambertCoeff_add_period_mul (n k) m t

/-- The absolute size of a prefix coefficient is at most the number of selected
summands used to form it. -/
theorem abs_prefixFibLambertCoeff_le (n : ℕ → ℕ) (K m : ℕ) :
    |prefixFibLambertCoeff n K m| ≤ (K : ℤ) := by
  calc
    |prefixFibLambertCoeff n K m| ≤
        ∑ k ∈ Finset.range K, |fibLambertCoeff (n k) m| := by
          exact Finset.abs_sum_le_sum_abs _ _
    _ ≤ ∑ _k ∈ Finset.range K, (1 : ℤ) := by
          apply Finset.sum_le_sum
          intro k hk
          exact abs_fibLambertCoeff_le_one (n k) m
    _ = (K : ℤ) := by simp

end Research

/-!
# The finite full Lambert coefficient at a fixed exponent
-/

namespace Research

open scoped BigOperators

/-- A nonzero contribution at exponent `m` can only come from an index at most
`m`. -/
theorem fibLambertCoeff_index_le_of_ne_zero
    (n m : ℕ) (_hn : 0 < n) (h : fibLambertCoeff n m ≠ 0) :
    n ≤ m := by
  unfold fibLambertCoeff at h
  split_ifs at h with he h₂ h₄ h₄' <;> try contradiction
  · have hm := Nat.mod_le m (2 * n)
    omega
  · have hm := Nat.mod_le m (4 * n)
    omega
  · have hm := Nat.mod_le m (4 * n)
    omega

/-- Positive strict index sequences dominate their position by at least one. -/
theorem position_add_one_le_index
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n) (k : ℕ) :
    k + 1 ≤ n k := by
  have h := hmono.add_le_nat k 0
  have h0 := hpos 0
  simp only [add_zero] at h
  omega

/-- Terms whose sequence position is at least the exponent contribute zero. -/
theorem fibLambertCoeff_eq_zero_of_exponent_le_position
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    {m k : ℕ} (hmk : m ≤ k) :
    fibLambertCoeff (n k) m = 0 := by
  by_contra hne
  have hidx := fibLambertCoeff_index_le_of_ne_zero (n k) m (hpos k) hne
  have hposition := position_add_one_le_index n hpos hmono k
  omega

/-- The full coefficient at exponent `m`; only the first `m` sequence
positions can contribute. -/
def selectedFibLambertCoeff (n : ℕ → ℕ) (m : ℕ) : ℤ :=
  ∑ k ∈ Finset.range m, fibLambertCoeff (n k) m

/-- Any larger finite cutoff computes the same full coefficient. -/
theorem prefixFibLambertCoeff_eq_selected
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    {m K : ℕ} (hmK : m ≤ K) :
    prefixFibLambertCoeff n K m = selectedFibLambertCoeff n m := by
  rw [prefixFibLambertCoeff, selectedFibLambertCoeff]
  rw [← Finset.sum_subset (Finset.range_mono hmK)]
  intro k hkK hkm
  have hmk : m ≤ k := by
    simpa only [Finset.mem_range, not_lt] using hkm
  exact fibLambertCoeff_eq_zero_of_exponent_le_position n hpos hmono hmk

/-- Linear absolute bound for the full coefficient. -/
theorem abs_selectedFibLambertCoeff_le
    (n : ℕ → ℕ) (m : ℕ) :
    |selectedFibLambertCoeff n m| ≤ (m : ℤ) := by
  simpa [selectedFibLambertCoeff, prefixFibLambertCoeff] using
    abs_prefixFibLambertCoeff_le n m m

/-- Under a common-period shift, the prefix contribution to the two full
coefficients agrees exactly; all discrepancy comes from later positions. -/
theorem selectedFibLambertCoeff_shift_prefix_cancel
    (n : ℕ → ℕ) (K X m : ℕ)
    (hperiod : ∀ k < K, 4 * n k ∣ X) :
    prefixFibLambertCoeff n K (m + X) = prefixFibLambertCoeff n K m :=
  prefixFibLambertCoeff_add_commonPeriod n K X hperiod m

end Research

/-!
# Elementary quadratic norm gate in `ℤ[φ]`
-/

namespace Research

open Real goldenRatio

/-- A nontrivial integral linear form in the golden ratio is nonzero. -/
theorem int_add_mul_goldenRatio_ne_zero (A B : ℤ)
    (hAB : A ≠ 0 ∨ B ≠ 0) :
    (A : ℝ) + (B : ℝ) * φ ≠ 0 := by
  by_cases hB : B = 0
  · subst B
    simp only [Int.cast_zero, zero_mul, add_zero]
    exact_mod_cast hAB.resolve_right (by simp)
  · intro h
    have hrat := (irrational_iff_ne_rational φ).mp Real.goldenRatio_irrational
      (-A) B hB
    have hB0 : (B : ℝ) ≠ 0 := by exact_mod_cast hB
    apply hrat
    apply (eq_div_iff hB0).2
    push_cast
    linarith

/-- The same nonvanishing statement at the conjugate embedding. -/
theorem int_add_mul_goldenConj_ne_zero (A B : ℤ)
    (hAB : A ≠ 0 ∨ B ≠ 0) :
    (A : ℝ) + (B : ℝ) * ψ ≠ 0 := by
  by_cases hB : B = 0
  · subst B
    simp only [Int.cast_zero, zero_mul, add_zero]
    exact_mod_cast hAB.resolve_right (by simp)
  · intro h
    have hrat := (irrational_iff_ne_rational ψ).mp Real.goldenConj_irrational
      (-A) B hB
    have hB0 : (B : ℝ) ≠ 0 := by exact_mod_cast hB
    apply hrat
    apply (eq_div_iff hB0).2
    push_cast
    linarith

/-- Explicit norm formula in the quadratic order `ℤ[φ]`. -/
theorem golden_integer_norm_eq (A B : ℤ) :
    ((A : ℝ) + (B : ℝ) * φ) * ((A : ℝ) + (B : ℝ) * ψ) =
      ((A * A + A * B - B * B : ℤ) : ℝ) := by
  calc
    ((A : ℝ) + (B : ℝ) * φ) * ((A : ℝ) + (B : ℝ) * ψ) =
        (A : ℝ) ^ 2 + (A : ℝ) * B * (φ + ψ) +
          (B : ℝ) ^ 2 * (φ * ψ) := by ring
    _ = ((A * A + A * B - B * B : ℤ) : ℝ) := by
      rw [Real.goldenRatio_add_goldenConj,
        Real.goldenRatio_mul_goldenConj]
      push_cast
      ring

/-- A nonzero element of `ℤ[φ]` has archimedean product at least one.  This is
the elementary degree-two algebraic-norm lower bound used by the planned block
argument. -/
theorem one_le_abs_golden_mul_abs_conj (A B : ℤ)
    (hAB : A ≠ 0 ∨ B ≠ 0) :
    (1 : ℝ) ≤
      |(A : ℝ) + (B : ℝ) * φ| * |(A : ℝ) + (B : ℝ) * ψ| := by
  have hφ := int_add_mul_goldenRatio_ne_zero A B hAB
  have hψ := int_add_mul_goldenConj_ne_zero A B hAB
  have hnorm : A * A + A * B - B * B ≠ 0 := by
    intro h
    have hprod := golden_integer_norm_eq A B
    rw [h, Int.cast_zero] at hprod
    exact mul_ne_zero hφ hψ hprod
  have hone : (1 : ℝ) ≤ |((A * A + A * B - B * B : ℤ) : ℝ)| := by
    exact_mod_cast Int.one_le_abs hnorm
  rw [← golden_integer_norm_eq, abs_mul] at hone
  exact hone

/-- Scaled form: if `q>0`, a nonzero element of `(1/q)ℤ[φ]` has the product of
its two real embeddings at least `q⁻²`. -/
theorem inv_sq_le_abs_scaled_golden_mul_abs_conj
    (A B : ℤ) (q : ℕ) (hq : 0 < q) (hAB : A ≠ 0 ∨ B ≠ 0) :
    ((q : ℝ)⁻¹) ^ 2 ≤
      |((A : ℝ) + (B : ℝ) * φ) / q| *
        |((A : ℝ) + (B : ℝ) * ψ) / q| := by
  have hbase := one_le_abs_golden_mul_abs_conj A B hAB
  have hqR : (0 : ℝ) < q := by exact_mod_cast hq
  rw [abs_div, abs_div, abs_of_pos hqR]
  have hq0 : (q : ℝ) ≠ 0 := ne_of_gt hqR
  calc
    ((q : ℝ)⁻¹) ^ 2 ≤
        (|(A : ℝ) + (B : ℝ) * φ| * |(A : ℝ) + (B : ℝ) * ψ|) *
          ((q : ℝ)⁻¹) ^ 2 := by
            simpa only [one_mul] using
              mul_le_mul_of_nonneg_right hbase (sq_nonneg ((q : ℝ)⁻¹))
    _ = |(A : ℝ) + (B : ℝ) * φ| / q *
        (|(A : ℝ) + (B : ℝ) * ψ| / q) := by
          field_simp

end Research

/-!
# Summing the collected Lambert coefficient series
-/

namespace Research

open Filter Topology
open Real goldenRatio
open scoped BigOperators

set_option maxHeartbeats 800000

private theorem even_coefficient_period_sum
    (n : ℕ) (hn : 0 < n) (he : Even n) (j : ℕ) (r : ℝ) :
    (∑ x : Fin (2 * n),
      (fibLambertCoeff n (j * (2 * n) + x) : ℝ) *
        r ^ (j * (2 * n) + x)) =
      r ^ (j * (2 * n) + n) := by
  have hnlt : n < 2 * n := by omega
  let y : Fin (2 * n) := ⟨n, hnlt⟩
  have hmod (x : Fin (2 * n)) :
      (j * (2 * n) + (x : ℕ)) % (2 * n) = x :=
    Nat.mul_add_mod_of_lt x.isLt
  have hcond (x : Fin (2 * n)) : ((x : ℕ) = n) ↔ x = y := by
    simp [y, Fin.ext_iff]
  simp only [fibLambertCoeff, if_pos he]
  simp_rw [hmod, hcond]
  simp only [Int.cast_ite, Int.cast_one, Int.cast_zero, ite_mul, one_mul, zero_mul]
  rw [Fintype.sum_ite_eq' y]

private theorem odd_coefficient_period_sum
    (n : ℕ) (hn : 0 < n) (ho : ¬ Even n) (j : ℕ) (r : ℝ) :
    (∑ x : Fin (4 * n),
      (fibLambertCoeff n (j * (4 * n) + x) : ℝ) *
        r ^ (j * (4 * n) + x)) =
      r ^ (j * (4 * n) + n) - r ^ (j * (4 * n) + 3 * n) := by
  have hnlt : n < 4 * n := by omega
  have h3nlt : 3 * n < 4 * n := by omega
  let y : Fin (4 * n) := ⟨n, hnlt⟩
  let z : Fin (4 * n) := ⟨3 * n, h3nlt⟩
  have hmod (x : Fin (4 * n)) :
      (j * (4 * n) + (x : ℕ)) % (4 * n) = x :=
    Nat.mul_add_mod_of_lt x.isLt
  have hcond (x : Fin (4 * n)) : ((x : ℕ) = n) ↔ x = y := by
    simp [y, Fin.ext_iff]
  have hcond3 (x : Fin (4 * n)) : ((x : ℕ) = 3 * n) ↔ x = z := by
    simp [z, Fin.ext_iff]
  simp only [fibLambertCoeff, if_neg ho]
  simp_rw [hmod, hcond, hcond3]
  simp only [Int.cast_ite, Int.cast_one, Int.cast_zero, Int.cast_neg, ite_mul,
    one_mul, zero_mul, neg_mul]
  have hyz : y ≠ z := by
    intro h
    have hv := congrArg Fin.val h
    dsimp [y, z] at hv
    omega
  calc
    (∑ x, if x = y then r ^ (j * (4 * n) + (x : ℕ))
      else if x = z then -r ^ (j * (4 * n) + (x : ℕ)) else 0) =
        (∑ x, if x = y then r ^ (j * (4 * n) + (x : ℕ)) else 0) +
        (∑ x, if x = z then -r ^ (j * (4 * n) + (x : ℕ)) else 0) := by
          rw [← Finset.sum_add_distrib]
          apply Finset.sum_congr rfl
          intro x hx
          by_cases hxy : x = y
          · simp [hxy, hyz]
          · by_cases hxz : x = z <;> simp [hxy, hxz, Ne.symm hyz]
    _ = r ^ (j * (4 * n) + n) - r ^ (j * (4 * n) + 3 * n) := by
      rw [Fintype.sum_ite_eq' y, Fintype.sum_ite_eq' z]
      rfl

/-- The residue-class coefficient series for one reciprocal Fibonacci summand
is absolutely summable. -/
theorem summable_fibLambertCoeff_mul_invPhi_pow (n : ℕ) :
    Summable (fun m : ℕ =>
      (fibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by
    dsimp [r]
    exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  change Summable (fun m : ℕ =>
    (fibLambertCoeff n m : ℝ) * r ^ m)
  have hgeom : Summable (fun m : ℕ => r ^ m) :=
    summable_geometric_of_norm_lt_one (by
      simpa [Real.norm_eq_abs, abs_of_nonneg hr0] using hr1)
  apply Summable.of_norm_bounded hgeom
  intro m
  have hc : |(fibLambertCoeff n m : ℝ)| ≤ 1 := by
    exact_mod_cast abs_fibLambertCoeff_le_one n m
  rw [Real.norm_eq_abs, abs_mul, abs_pow, abs_of_nonneg hr0]
  simpa [r] using mul_le_mul_of_nonneg_right hc (pow_nonneg hr0 m)

/-- Closed form of the coefficient generating series for one selected index. -/
theorem hasSum_fibLambertCoeff_mul_invPhi_pow
    (n : ℕ) (hn : 0 < n) :
    HasSum (fun m : ℕ =>
      (fibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m)
      ((φ⁻¹) ^ n *
        (1 - (-1 : ℝ) ^ n * (φ⁻¹) ^ (2 * n))⁻¹) := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by
    dsimp [r]
    exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hf : Summable (fun m : ℕ =>
      (fibLambertCoeff n m : ℝ) * r ^ m) := by
    simpa [r] using summable_fibLambertCoeff_mul_invPhi_pow n
  by_cases he : Even n
  · letI : NeZero (2 * n) := ⟨by omega⟩
    have hprod : HasSum
        (fun p : ℕ × Fin (2 * n) =>
          (fibLambertCoeff n (p.1 * (2 * n) + p.2) : ℝ) *
            r ^ (p.1 * (2 * n) + p.2))
        (∑' m : ℕ, (fibLambertCoeff n m : ℝ) * r ^ m) := by
      exact (Nat.divModEquiv (2 * n)).symm.hasSum_iff.mpr hf.hasSum
    have hrows : HasSum (fun j : ℕ => r ^ (j * (2 * n) + n))
        (∑' m : ℕ, (fibLambertCoeff n m : ℝ) * r ^ m) := by
      apply hprod.prod_fiberwise
      intro j
      convert hasSum_fintype (fun x : Fin (2 * n) =>
        (fibLambertCoeff n (j * (2 * n) + x) : ℝ) *
          r ^ (j * (2 * n) + x)) using 1
      exact (even_coefficient_period_sum n hn he j r).symm
    have hgeom : HasSum (fun j : ℕ => r ^ (j * (2 * n) + n))
        (r ^ n * (1 - r ^ (2 * n))⁻¹) := by
      have hg := (hasSum_geometric_of_abs_lt_one
        (show |r ^ (2 * n)| < 1 by
          rw [abs_pow, abs_of_nonneg hr0]
          exact pow_lt_one₀ hr0 hr1 (by omega))).mul_left (r ^ n)
      simpa only [← pow_mul, ← pow_add, Nat.mul_comm, Nat.add_comm] using hg
    have hv := hrows.unique hgeom
    rw [Even.neg_one_pow he, one_mul]
    rw [← hv]
    simpa [r] using hf.hasSum
  · have ho : Odd n := Nat.not_even_iff_odd.mp he
    letI : NeZero (4 * n) := ⟨by omega⟩
    have hprod : HasSum
        (fun p : ℕ × Fin (4 * n) =>
          (fibLambertCoeff n (p.1 * (4 * n) + p.2) : ℝ) *
            r ^ (p.1 * (4 * n) + p.2))
        (∑' m : ℕ, (fibLambertCoeff n m : ℝ) * r ^ m) := by
      exact (Nat.divModEquiv (4 * n)).symm.hasSum_iff.mpr hf.hasSum
    have hrows : HasSum
        (fun j : ℕ => r ^ (j * (4 * n) + n) -
          r ^ (j * (4 * n) + 3 * n))
        (∑' m : ℕ, (fibLambertCoeff n m : ℝ) * r ^ m) := by
      apply hprod.prod_fiberwise
      intro j
      convert hasSum_fintype (fun x : Fin (4 * n) =>
        (fibLambertCoeff n (j * (4 * n) + x) : ℝ) *
          r ^ (j * (4 * n) + x)) using 1
      exact (odd_coefficient_period_sum n hn he j r).symm
    have hgeom : HasSum
        (fun j : ℕ => r ^ (j * (4 * n) + n) -
          r ^ (j * (4 * n) + 3 * n))
        ((r ^ n - r ^ (3 * n)) * (1 - r ^ (4 * n))⁻¹) := by
      have hg := (hasSum_geometric_of_abs_lt_one
        (show |r ^ (4 * n)| < 1 by
          rw [abs_pow, abs_of_nonneg hr0]
          exact pow_lt_one₀ hr0 hr1 (by omega))).mul_left
            (r ^ n - r ^ (3 * n))
      simpa only [sub_mul, ← pow_mul, ← pow_add, Nat.mul_comm,
        Nat.add_comm] using hg
    have hv := hrows.unique hgeom
    have h2lt : r ^ (2 * n) < 1 := pow_lt_one₀ hr0 hr1 (by omega)
    have hplus : 1 + r ^ (2 * n) ≠ 0 := by positivity
    have hminus : 1 - r ^ (4 * n) ≠ 0 := by
      have : r ^ (4 * n) < 1 := pow_lt_one₀ hr0 hr1 (by omega)
      linarith
    rw [Odd.neg_one_pow ho, neg_mul, sub_neg_eq_add, one_mul]
    change HasSum (fun m : ℕ =>
      (fibLambertCoeff n m : ℝ) * r ^ m)
      (r ^ n * (1 + r ^ (2 * n))⁻¹)
    have hclosed :
        (r ^ n - r ^ (3 * n)) * (1 - r ^ (4 * n))⁻¹ =
          r ^ n * (1 + r ^ (2 * n))⁻¹ := by
      field_simp [hplus, hminus]
      rw [show r ^ (3 * n) = r ^ n * r ^ (2 * n) by
        rw [← pow_add]
        congr 1
        omega,
        show r ^ (4 * n) = r ^ (2 * n) * r ^ (2 * n) by
          rw [← pow_add]
          congr 1
          omega]
      ring
    rw [← hclosed, ← hv]
    exact hf.hasSum

/-- The collected coefficient series sums to exactly `1/(√5 F_n)`. -/
theorem hasSum_fibLambertCoeff_eq_inv_sqrtFive_mul_inv_fib
    (n : ℕ) (hn : 0 < n) :
    HasSum (fun m : ℕ =>
      (fibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m)
      ((√5)⁻¹ * (Nat.fib n : ℝ)⁻¹) := by
  let r : ℝ := φ⁻¹
  let q : ℝ := (-1 : ℝ) ^ n * r ^ (2 * n)
  have hcoeff := hasSum_fibLambertCoeff_mul_invPhi_pow n hn
  have hpsi : ψ = -r := by
    dsimp [r]
    linarith [Real.inv_goldenRatio]
  have hpsi_pow : ψ ^ n = (-1 : ℝ) ^ n * r ^ n := by
    rw [hpsi, neg_pow]
  have hunit : φ ^ n * r ^ n = 1 := by
    dsimp [r]
    rw [inv_pow, mul_inv_cancel₀ (pow_ne_zero _ Real.goldenRatio_ne_zero)]
  have hr0 : 0 ≤ r := by
    dsimp [r]
    exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hqabs : |q| < 1 := by
    dsimp [q]
    rw [abs_mul, abs_pow, abs_neg, abs_one, one_pow, one_mul,
      abs_pow, abs_of_nonneg hr0]
    exact pow_lt_one₀ hr0 hr1 (by omega)
  have hqne : 1 - q ≠ 0 := by
    have habsne : |q| ≠ 1 := ne_of_lt hqabs
    intro h
    have hq : q = 1 := (sub_eq_zero.mp h).symm
    exact habsne (by rw [hq, abs_one])
  have hsqrt : √5 ≠ 0 := by positivity
  have hden : 1 - ((-1 : ℝ) ^ n * r ^ (2 * n)) ≠ 0 := by
    simpa [q] using hqne
  have hrr : r ^ n * r ^ n = r ^ (2 * n) := by
    rw [← pow_add]
    congr 1
    omega
  have hvalue :
      √5 * (r ^ n * (1 - (-1 : ℝ) ^ n * r ^ (2 * n))⁻¹) =
        (Nat.fib n : ℝ)⁻¹ := by
    symm
    apply inv_eq_of_mul_eq_one_right
    rw [Real.coe_fib_eq, hpsi_pow]
    field_simp [hden, hsqrt]
    rw [mul_sub, show r ^ n * φ ^ n = 1 by
      simpa [mul_comm] using hunit,
      show r ^ n * ((-1 : ℝ) ^ n * r ^ n) =
        (-1 : ℝ) ^ n * r ^ (2 * n) by rw [← hrr]; ring]
  have hclosed :
      r ^ n * (1 - (-1 : ℝ) ^ n * r ^ (2 * n))⁻¹ =
        (√5)⁻¹ * (Nat.fib n : ℝ)⁻¹ := by
    rw [← hvalue]
    field_simp
  change HasSum (fun m : ℕ =>
    (fibLambertCoeff n m : ℝ) * r ^ m)
    (r ^ n * (1 - (-1 : ℝ) ^ n * r ^ (2 * n))⁻¹) at hcoeff
  rw [hclosed] at hcoeff
  simpa [r] using hcoeff

end Research

/-!
# The globally collected Lambert coefficient series
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

set_option maxHeartbeats 800000

private theorem summable_double_fibLambertCoeff
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n) :
    Summable (Function.uncurry fun k m : ℕ =>
      (fibLambertCoeff (n k) m : ℝ) * (φ⁻¹) ^ m) := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by
    dsimp [r]
    exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  let g : ℕ × ℕ → ℝ := fun p => if p.2 < p.1 then r ^ p.1 else 0
  have hg : Summable g := by
    have hg0 : ∀ p, 0 ≤ g p := by
      intro p
      dsimp [g]
      split_ifs <;> positivity
    rw [summable_prod_of_nonneg hg0]
    constructor
    · intro m
      apply summable_of_ne_finset_zero (s := Finset.range m)
      intro k hk
      simp only [Finset.mem_range, not_lt] at hk
      simp [g, hk]
    · have hrow : (fun m : ℕ => ∑' k : ℕ, g (m, k)) =
          (fun m : ℕ => (m : ℝ) * r ^ m) := by
        funext m
        rw [tsum_eq_sum (s := Finset.range m)]
        · calc
            (∑ k ∈ Finset.range m, g (m, k)) =
                ∑ _k ∈ Finset.range m, r ^ m := by
                  apply Finset.sum_congr rfl
                  intro k hk
                  simp [g, Finset.mem_range.mp hk]
            _ = (m : ℝ) * r ^ m := by simp
        · intro k hk
          simp only [Finset.mem_range, not_lt] at hk
          simp [g, hk]
      rw [hrow]
      simpa only [pow_one] using
        (summable_pow_mul_geometric_of_norm_lt_one (R := ℝ) 1
          (by simpa [Real.norm_eq_abs, abs_of_nonneg hr0] using hr1))
  have hswap : Summable (fun p : ℕ × ℕ =>
      (fibLambertCoeff (n p.2) p.1 : ℝ) * r ^ p.1) := by
    apply Summable.of_norm_bounded hg
    intro p
    by_cases hkm : p.2 < p.1
    · have hc : |(fibLambertCoeff (n p.2) p.1 : ℝ)| ≤ 1 := by
        exact_mod_cast abs_fibLambertCoeff_le_one (n p.2) p.1
      rw [Real.norm_eq_abs, abs_mul, abs_pow, abs_of_nonneg hr0]
      simp only [g, if_pos hkm]
      simpa using mul_le_mul_of_nonneg_right hc (pow_nonneg hr0 p.1)
    · have hmk : p.1 ≤ p.2 := by omega
      have hz := fibLambertCoeff_eq_zero_of_exponent_le_position
        n hpos hmono hmk
      simp [hz, g, hkm]
  have horig : Summable (fun p : ℕ × ℕ =>
      (fibLambertCoeff (n p.1) p.2 : ℝ) * r ^ p.2) := by
    exact ((Equiv.prodComm ℕ ℕ).summable_iff).mp (by
      simpa [Function.comp_def] using hswap)
  change Summable (fun p : ℕ × ℕ =>
    (fibLambertCoeff (n p.1) p.2 : ℝ) * (φ⁻¹) ^ p.2)
  simpa [r] using horig

private theorem tsum_over_positions_eq_selected
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (m : ℕ) :
    (∑' k : ℕ,
      (fibLambertCoeff (n k) m : ℝ) * (φ⁻¹) ^ m) =
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m := by
  rw [tsum_eq_sum (s := Finset.range m)]
  · rw [selectedFibLambertCoeff]
    push_cast
    rw [Finset.sum_mul]
  · intro k hk
    have hmk : m ≤ k := by
      simpa only [Finset.mem_range, not_lt] using hk
    rw [fibLambertCoeff_eq_zero_of_exponent_le_position n hpos hmono hmk]
    simp

/-- Exact global collection identity.  The sum of the full integer
coefficients at powers of `φ⁻¹` is `1/√5` times the original reciprocal
Fibonacci series. -/
theorem hasSum_selectedFibLambertCoeff
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n) :
    HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m)
      ((√5)⁻¹ * ∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) := by
  have hd := summable_double_fibLambertCoeff n hpos hmono
  have hcomm := hd.tsum_comm
  have hleft :
      (∑' m : ℕ, ∑' k : ℕ,
        (fibLambertCoeff (n k) m : ℝ) * (φ⁻¹) ^ m) =
      ∑' m : ℕ,
        (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m := by
    apply tsum_congr
    exact tsum_over_positions_eq_selected n hpos hmono
  have hright :
      (∑' k : ℕ, ∑' m : ℕ,
        (fibLambertCoeff (n k) m : ℝ) * (φ⁻¹) ^ m) =
      (√5)⁻¹ * ∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹ := by
    calc
      (∑' k : ℕ, ∑' m : ℕ,
        (fibLambertCoeff (n k) m : ℝ) * (φ⁻¹) ^ m) =
          ∑' k : ℕ, (√5)⁻¹ * (Nat.fib (n k) : ℝ)⁻¹ := by
            apply tsum_congr
            intro k
            exact (hasSum_fibLambertCoeff_eq_inv_sqrtFive_mul_inv_fib
              (n k) (hpos k)).tsum_eq
      _ = (√5)⁻¹ * ∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹ := tsum_mul_left
  have hsum :
      (∑' m : ℕ,
        (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) =
      (√5)⁻¹ * ∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹ := by
    rw [← hleft, hcomm, hright]
  have hsummable : Summable (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) := by
    have hdswap : Summable (fun p : ℕ × ℕ =>
        (fibLambertCoeff (n p.2) p.1 : ℝ) * (φ⁻¹) ^ p.1) := by
      change Summable ((Function.uncurry fun k m : ℕ =>
        (fibLambertCoeff (n k) m : ℝ) * (φ⁻¹) ^ m) ∘
          (Equiv.prodComm ℕ ℕ))
      exact ((Equiv.prodComm ℕ ℕ).summable_iff).mpr hd
    have hp : Summable (fun m : ℕ => ∑' k : ℕ,
        (fibLambertCoeff (n k) m : ℝ) * (φ⁻¹) ^ m) := hdswap.prod
    convert hp using 1
    funext m
    exact (tsum_over_positions_eq_selected n hpos hmono m).symm
  rw [← hsum]
  exact hsummable.hasSum

end Research

/-!
# Fixed quadratic lattice for normalized rational tails
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- Membership in the scaled quadratic lattice `(1/q) ℤ[φ]`. -/
def InScaledGoldenLattice (q : ℕ) (x : ℝ) : Prop :=
  ∃ A B : ℤ, x = ((A : ℝ) + (B : ℝ) * φ) / (q : ℝ)

/-- The scaled golden lattice is closed under addition. -/
theorem InScaledGoldenLattice.add {q : ℕ} (hq : 0 < q) {x y : ℝ}
    (hx : InScaledGoldenLattice q x) (hy : InScaledGoldenLattice q y) :
    InScaledGoldenLattice q (x + y) := by
  obtain ⟨A, B, rfl⟩ := hx
  obtain ⟨C, D, rfl⟩ := hy
  refine ⟨A + C, B + D, ?_⟩
  have hq0 : (q : ℝ) ≠ 0 := by exact_mod_cast ne_of_gt hq
  push_cast
  field_simp
  ring

/-- The scaled golden lattice is closed under negation. -/
theorem InScaledGoldenLattice.neg {q : ℕ} {x : ℝ}
    (hx : InScaledGoldenLattice q x) :
    InScaledGoldenLattice q (-x) := by
  obtain ⟨A, B, rfl⟩ := hx
  refine ⟨-A, -B, ?_⟩
  push_cast
  ring

/-- The scaled golden lattice is closed under subtraction. -/
theorem InScaledGoldenLattice.sub {q : ℕ} (hq : 0 < q) {x y : ℝ}
    (hx : InScaledGoldenLattice q x) (hy : InScaledGoldenLattice q y) :
    InScaledGoldenLattice q (x - y) := by
  rw [sub_eq_add_neg]
  exact hx.add hq hy.neg

/-- Multiplication by an integer preserves the denominator. -/
theorem InScaledGoldenLattice.int_mul {q : ℕ} {x : ℝ}
    (C : ℤ) (hx : InScaledGoldenLattice q x) :
    InScaledGoldenLattice q ((C : ℝ) * x) := by
  obtain ⟨A, B, rfl⟩ := hx
  refine ⟨C * A, C * B, ?_⟩
  push_cast
  ring

/-- Multiplication by any nonnegative power of `φ` preserves the scaled
lattice. -/
theorem InScaledGoldenLattice.goldenRatio_pow_mul {q : ℕ} (_hq : 0 < q)
    {x : ℝ} (hx : InScaledGoldenLattice q x) (p : ℕ) :
    InScaledGoldenLattice q (φ ^ p * x) := by
  induction p with
  | zero => simpa using hx
  | succ p ih =>
      obtain ⟨A, B, hAB⟩ := ih
      refine ⟨B, A + B, ?_⟩
      rw [show φ ^ (p + 1) * x = φ * (φ ^ p * x) by
        rw [pow_succ]
        ring, hAB]
      have hnum :
          φ * ((A : ℝ) + (B : ℝ) * φ) =
            (B : ℝ) + ((A + B : ℤ) : ℝ) * φ := by
        push_cast
        rw [show φ * ((A : ℝ) + (B : ℝ) * φ) =
          (A : ℝ) * φ + (B : ℝ) * φ ^ 2 by ring,
          Real.goldenRatio_sq]
        ring
      rw [← mul_div_assoc, hnum]

/-- Every power of `φ` is an algebraic integer in `ℤ[φ]`. -/
theorem goldenRatio_pow_mem_lattice (p : ℕ) :
    InScaledGoldenLattice 1 (φ ^ p) := by
  have hone : InScaledGoldenLattice 1 (1 : ℝ) := by
    exact ⟨1, 0, by norm_num⟩
  simpa using hone.goldenRatio_pow_mul (by omega) p

/-- An integral golden-lattice element can be viewed with any positive
specified denominator. -/
theorem InScaledGoldenLattice.change_one_to_denominator
    {q : ℕ} (hq : 0 < q) {x : ℝ}
    (hx : InScaledGoldenLattice 1 x) :
    InScaledGoldenLattice q x := by
  obtain ⟨A, B, hAB⟩ := hx
  refine ⟨(q : ℤ) * A, (q : ℤ) * B, ?_⟩
  rw [hAB]
  have hq0 : (q : ℝ) ≠ 0 := by exact_mod_cast ne_of_gt hq
  push_cast
  field_simp

/-- Every integer multiple of every nonnegative power of `φ` belongs to a
chosen positive scaled lattice. -/
theorem int_mul_goldenRatio_pow_mem_scaled
    (q : ℕ) (hq : 0 < q) (C : ℤ) (p : ℕ) :
    InScaledGoldenLattice q ((C : ℝ) * φ ^ p) := by
  exact (goldenRatio_pow_mem_lattice p).int_mul C |>.change_one_to_denominator hq

/-- A finite sum of elements with one common positive denominator remains in
the same scaled lattice. -/
theorem finset_sum_mem_scaledGoldenLattice
    {ι : Type*} {q : ℕ} (hq : 0 < q) (s : Finset ι) (f : ι → ℝ)
    (hf : ∀ i ∈ s, InScaledGoldenLattice q (f i)) :
    InScaledGoldenLattice q (∑ i ∈ s, f i) := by
  classical
  induction s using Finset.induction_on with
  | empty =>
      exact ⟨0, 0, by simp⟩
  | @insert a s ha ih =>
      rw [Finset.sum_insert ha]
      exact (hf a (Finset.mem_insert_self a s)).add hq
        (ih fun i hi => hf i (Finset.mem_insert_of_mem hi))

/-- Rationality of the original sum puts its `1/√5` multiple in the fixed
lattice with denominator `5b`. -/
theorem inv_sqrtFive_mul_rational_mem_scaled
    (a : ℤ) (b : ℕ) (hb : 0 < b) :
    InScaledGoldenLattice (5 * b)
      ((√5)⁻¹ * ((a : ℝ) / (b : ℝ))) := by
  refine ⟨-a, 2 * a, ?_⟩
  have hs : √(5 : ℝ) ≠ 0 := by positivity
  have hb0 : (b : ℝ) ≠ 0 := by exact_mod_cast ne_of_gt hb
  rw [show φ = (1 + √5) / 2 by rfl]
  push_cast
  field_simp
  rw [show (-1 : ℝ) + (1 + √5) = √5 by ring,
    show √5 * (a : ℝ) * √5 = (a : ℝ) * √5 ^ 2 by ring,
    Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 5)]

/-- Algebraic normalized prefix residual at cut `N`. -/
noncomputable def normalizedCoefficientResidual (C : ℕ → ℤ) (T : ℝ) (N : ℕ) : ℝ :=
  φ ^ N * T -
    ∑ m ∈ Finset.range N, (C m : ℝ) * φ ^ (N - m)

/-- If `T=S/√5` and `S=a/b`, every normalized prefix residual lies in one
fixed lattice `(1/(5b))ℤ[φ]`, independently of the cut. -/
theorem normalizedCoefficientResidual_mem_fixed_lattice
    (C : ℕ → ℤ) (a : ℤ) (b N : ℕ) (hb : 0 < b) :
    InScaledGoldenLattice (5 * b)
      (normalizedCoefficientResidual C
        ((√5)⁻¹ * ((a : ℝ) / (b : ℝ))) N) := by
  have hq : 0 < 5 * b := by omega
  apply InScaledGoldenLattice.sub hq
  · exact (inv_sqrtFive_mul_rational_mem_scaled a b hb).goldenRatio_pow_mul hq N
  · apply finset_sum_mem_scaledGoldenLattice hq
    intro m hm
    exact int_mul_goldenRatio_pow_mem_scaled (5 * b) hq (C m) (N - m)

end Research

/-!
# Analytic normalized coefficient tails
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- The normalized coefficient tail beginning at exponent `N`. -/
noncomputable def coefficientTail (C : ℕ → ℤ) (N : ℕ) : ℝ :=
  ∑' t : ℕ, (C (N + t) : ℝ) * (φ⁻¹) ^ t

private theorem goldenRatio_pow_mul_inv_pow_add (N t : ℕ) :
    φ ^ N * (φ⁻¹) ^ (t + N) = (φ⁻¹) ^ t := by
  rw [pow_add]
  have hu : φ ^ N * (φ⁻¹) ^ N = 1 := by
    rw [inv_pow, mul_inv_cancel₀ (pow_ne_zero _ Real.goldenRatio_ne_zero)]
  rw [show φ ^ N * ((φ⁻¹) ^ t * (φ⁻¹) ^ N) =
    (φ⁻¹) ^ t * (φ ^ N * (φ⁻¹) ^ N) by ring, hu, mul_one]

private theorem goldenRatio_pow_mul_inv_pow_of_le
    {N m : ℕ} (hmN : m ≤ N) :
    φ ^ N * (φ⁻¹) ^ m = φ ^ (N - m) := by
  rw [inv_pow, pow_sub₀ φ Real.goldenRatio_ne_zero hmN]

/-- Summability of the original coefficient series implies summability of every
normalized tail. -/
theorem summable_coefficientTail
    (C : ℕ → ℤ)
    (hsum : Summable (fun m : ℕ => (C m : ℝ) * (φ⁻¹) ^ m))
    (N : ℕ) :
    Summable (fun t : ℕ => (C (N + t) : ℝ) * (φ⁻¹) ^ t) := by
  have hshift : Summable (fun t : ℕ =>
      (C (t + N) : ℝ) * (φ⁻¹) ^ (t + N)) :=
    (summable_nat_add_iff N).mpr hsum
  have hmul := hshift.mul_left (φ ^ N)
  apply hmul.congr
  intro t
  rw [Nat.add_comm t N]
  rw [show φ ^ N * ((C (N + t) : ℝ) * (φ⁻¹) ^ (N + t)) =
    (C (N + t) : ℝ) * (φ ^ N * (φ⁻¹) ^ (t + N)) by
      rw [Nat.add_comm N t]
      ring,
    goldenRatio_pow_mul_inv_pow_add]

/-- The algebraic prefix residual of F-024 equals the analytic normalized
infinite tail whenever the coefficient series has sum `T`. -/
theorem normalizedCoefficientResidual_eq_coefficientTail
    (C : ℕ → ℤ) (T : ℝ)
    (hsum : HasSum (fun m : ℕ => (C m : ℝ) * (φ⁻¹) ^ m) T)
    (N : ℕ) :
    normalizedCoefficientResidual C T N = coefficientTail C N := by
  have hs := hsum.summable
  have hdecomp := hs.sum_add_tsum_nat_add N
  rw [hsum.tsum_eq] at hdecomp
  have hprefix :
      φ ^ N * (∑ m ∈ Finset.range N,
        (C m : ℝ) * (φ⁻¹) ^ m) =
      ∑ m ∈ Finset.range N, (C m : ℝ) * φ ^ (N - m) := by
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intro m hm
    have hmN : m ≤ N := (Finset.mem_range.mp hm).le
    rw [show φ ^ N * ((C m : ℝ) * (φ⁻¹) ^ m) =
      (C m : ℝ) * (φ ^ N * (φ⁻¹) ^ m) by ring,
      goldenRatio_pow_mul_inv_pow_of_le hmN]
  have htail :
      φ ^ N * (∑' t : ℕ,
        (C (t + N) : ℝ) * (φ⁻¹) ^ (t + N)) =
      coefficientTail C N := by
    rw [← tsum_mul_left]
    apply tsum_congr
    intro t
    rw [Nat.add_comm t N]
    rw [show φ ^ N * ((C (N + t) : ℝ) * (φ⁻¹) ^ (N + t)) =
      (C (N + t) : ℝ) * (φ ^ N * (φ⁻¹) ^ (t + N)) by
        rw [Nat.add_comm N t]
        ring,
      goldenRatio_pow_mul_inv_pow_add]
  unfold normalizedCoefficientResidual
  rw [← hprefix, ← htail]
  have hmuldecomp := congrArg (fun x : ℝ => φ ^ N * x) hdecomp
  rw [mul_add] at hmuldecomp
  linarith

/-- A normalized tail splits into a finite length-`L` block and a rescaled
later tail. -/
theorem coefficientTail_eq_block_add
    (C : ℕ → ℤ)
    (hsum : Summable (fun m : ℕ => (C m : ℝ) * (φ⁻¹) ^ m))
    (N L : ℕ) :
    coefficientTail C N =
      (∑ t ∈ Finset.range L, (C (N + t) : ℝ) * (φ⁻¹) ^ t) +
        (φ⁻¹) ^ L * coefficientTail C (N + L) := by
  have htailSum := summable_coefficientTail C hsum N
  have hdecomp := htailSum.sum_add_tsum_nat_add L
  unfold coefficientTail
  rw [← hdecomp]
  congr 1
  rw [← tsum_mul_left]
  apply tsum_congr
  intro t
  rw [show N + (t + L) = N + L + t by omega, pow_add]
  ring

/-- A linear coefficient bound gives an explicit linear bound for every
normalized tail. -/
theorem abs_coefficientTail_le
    (C : ℕ → ℤ) (hC : ∀ m, |C m| ≤ (m : ℤ)) (N : ℕ) :
    |coefficientTail C N| ≤
      (N : ℝ) * (1 - φ⁻¹)⁻¹ + φ⁻¹ / (1 - φ⁻¹) ^ 2 := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by
    dsimp [r]
    exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hrabs : |r| < 1 := by simpa [abs_of_nonneg hr0] using hr1
  let g : ℕ → ℝ := fun t => (N + t : ℕ) * r ^ t
  have hgeom : Summable (fun t : ℕ => r ^ t) :=
    summable_geometric_of_abs_lt_one hrabs
  have hlin : Summable (fun t : ℕ => (t : ℝ) * r ^ t) := by
    simpa only [pow_one] using
      (summable_pow_mul_geometric_of_norm_lt_one (R := ℝ) 1
        (by simpa [Real.norm_eq_abs] using hrabs))
  have hconst : Summable (fun t : ℕ => (N : ℝ) * r ^ t) :=
    hgeom.mul_left (N : ℝ)
  have hg : Summable g := by
    apply (hconst.add hlin).congr
    intro t
    dsimp [g]
    push_cast
    ring
  have hterm : ∀ t : ℕ,
      ‖(C (N + t) : ℝ) * r ^ t‖ ≤ g t := by
    intro t
    have hc : |(C (N + t) : ℝ)| ≤ (N + t : ℕ) := by
      exact_mod_cast hC (N + t)
    rw [Real.norm_eq_abs, abs_mul, abs_pow, abs_of_nonneg hr0]
    exact mul_le_mul_of_nonneg_right hc (pow_nonneg hr0 t)
  have hf : Summable (fun t : ℕ => (C (N + t) : ℝ) * r ^ t) :=
    Summable.of_norm_bounded hg hterm
  have hnorm := norm_tsum_le_tsum_norm hf.norm
  have hle := hf.norm.tsum_le_tsum hterm hg
  have hgvalue :
      (∑' t : ℕ, g t) =
        (N : ℝ) * (1 - r)⁻¹ + r / (1 - r) ^ 2 := by
    calc
      (∑' t : ℕ, g t) =
          ∑' t : ℕ, ((N : ℝ) * r ^ t + (t : ℝ) * r ^ t) := by
            apply tsum_congr
            intro t
            dsimp [g]
            push_cast
            ring
      _ = (∑' t : ℕ, (N : ℝ) * r ^ t) +
          ∑' t : ℕ, (t : ℝ) * r ^ t := hconst.tsum_add hlin
      _ = (N : ℝ) * (1 - r)⁻¹ + r / (1 - r) ^ 2 := by
        rw [tsum_mul_left, tsum_geometric_of_abs_lt_one hrabs,
          tsum_coe_mul_geometric_of_norm_lt_one
            (by simpa [Real.norm_eq_abs] using hrabs)]
  have hfinal := hnorm.trans hle
  rw [hgvalue] at hfinal
  change |∑' t : ℕ, (C (N + t) : ℝ) * r ^ t| ≤
    (N : ℝ) * (1 - r)⁻¹ + r / (1 - r) ^ 2
  rw [← Real.norm_eq_abs]
  exact hfinal

/-- Two identical length-`L` coefficient blocks force their normalized-tail
difference to acquire the factor `φ⁻ᴸ`. -/
theorem coefficientTail_sub_eq_pow_mul_of_block_eq
    (C : ℕ → ℤ)
    (hsum : Summable (fun m : ℕ => (C m : ℝ) * (φ⁻¹) ^ m))
    (N M L : ℕ)
    (hblock : ∀ t < L, C (N + t) = C (M + t)) :
    coefficientTail C N - coefficientTail C M =
      (φ⁻¹) ^ L *
        (coefficientTail C (N + L) - coefficientTail C (M + L)) := by
  rw [coefficientTail_eq_block_add C hsum N L,
    coefficientTail_eq_block_add C hsum M L]
  have hfinite :
      (∑ t ∈ Finset.range L, (C (N + t) : ℝ) * (φ⁻¹) ^ t) =
      ∑ t ∈ Finset.range L, (C (M + t) : ℝ) * (φ⁻¹) ^ t := by
    apply Finset.sum_congr rfl
    intro t ht
    rw [hblock t (Finset.mem_range.mp ht)]
  rw [hfinite]
  ring

end Research

/-!
# Conjugate normalized tails and the paired lattice
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- Two real numbers represented by the two embeddings of one element of
`(1/q)ℤ[φ]`. -/
def InScaledGoldenPair (q : ℕ) (x y : ℝ) : Prop :=
  ∃ A B : ℤ,
    x = ((A : ℝ) + (B : ℝ) * φ) / (q : ℝ) ∧
    y = ((A : ℝ) + (B : ℝ) * ψ) / (q : ℝ)

/-- Paired lattice closure under addition. -/
theorem InScaledGoldenPair.add {q : ℕ} (hq : 0 < q)
    {x y x' y' : ℝ} (h : InScaledGoldenPair q x y)
    (h' : InScaledGoldenPair q x' y') :
    InScaledGoldenPair q (x + x') (y + y') := by
  obtain ⟨A, B, hx, hy⟩ := h
  obtain ⟨C, D, hx', hy'⟩ := h'
  refine ⟨A + C, B + D, ?_, ?_⟩
  · rw [hx, hx']
    push_cast
    field_simp
    ring
  · rw [hy, hy']
    push_cast
    field_simp
    ring

/-- Paired lattice closure under negation. -/
theorem InScaledGoldenPair.neg {q : ℕ} {x y : ℝ}
    (h : InScaledGoldenPair q x y) :
    InScaledGoldenPair q (-x) (-y) := by
  obtain ⟨A, B, hx, hy⟩ := h
  refine ⟨-A, -B, ?_, ?_⟩
  · rw [hx]
    push_cast
    ring
  · rw [hy]
    push_cast
    ring

/-- Paired lattice closure under subtraction. -/
theorem InScaledGoldenPair.sub {q : ℕ} (hq : 0 < q)
    {x y x' y' : ℝ} (h : InScaledGoldenPair q x y)
    (h' : InScaledGoldenPair q x' y') :
    InScaledGoldenPair q (x - x') (y - y') := by
  rw [sub_eq_add_neg, sub_eq_add_neg]
  exact h.add hq h'.neg

/-- Paired lattice closure under integer scaling. -/
theorem InScaledGoldenPair.int_mul {q : ℕ} (C : ℤ) {x y : ℝ}
    (h : InScaledGoldenPair q x y) :
    InScaledGoldenPair q ((C : ℝ) * x) ((C : ℝ) * y) := by
  obtain ⟨A, B, hx, hy⟩ := h
  refine ⟨C * A, C * B, ?_, ?_⟩
  · rw [hx]
    push_cast
    ring
  · rw [hy]
    push_cast
    ring

/-- Simultaneous multiplication by corresponding powers in the two embeddings
preserves the paired lattice. -/
theorem InScaledGoldenPair.powers_mul {q : ℕ}
    {x y : ℝ} (h : InScaledGoldenPair q x y) (p : ℕ) :
    InScaledGoldenPair q (φ ^ p * x) (ψ ^ p * y) := by
  induction p with
  | zero => simpa using h
  | succ p ih =>
      obtain ⟨A, B, hx, hy⟩ := ih
      refine ⟨B, A + B, ?_, ?_⟩
      · rw [show φ ^ (p + 1) * x = φ * (φ ^ p * x) by
          rw [pow_succ]
          ring, hx]
        rw [← mul_div_assoc]
        congr 1
        push_cast
        rw [show φ * ((A : ℝ) + (B : ℝ) * φ) =
          (A : ℝ) * φ + (B : ℝ) * φ ^ 2 by ring,
          Real.goldenRatio_sq]
        ring
      · rw [show ψ ^ (p + 1) * y = ψ * (ψ ^ p * y) by
          rw [pow_succ]
          ring, hy]
        rw [← mul_div_assoc]
        congr 1
        push_cast
        rw [show ψ * ((A : ℝ) + (B : ℝ) * ψ) =
          (A : ℝ) * ψ + (B : ℝ) * ψ ^ 2 by ring,
          Real.goldenConj_sq]
        ring

/-- Paired algebraic-integer powers. -/
theorem golden_powers_mem_pair (p : ℕ) :
    InScaledGoldenPair 1 (φ ^ p) (ψ ^ p) := by
  have hone : InScaledGoldenPair 1 (1 : ℝ) (1 : ℝ) := by
    exact ⟨1, 0, by norm_num, by norm_num⟩
  simpa using hone.powers_mul p

/-- Change an integral paired element to a specified positive denominator. -/
theorem InScaledGoldenPair.change_one_to_denominator
    {q : ℕ} (hq : 0 < q) {x y : ℝ}
    (h : InScaledGoldenPair 1 x y) :
    InScaledGoldenPair q x y := by
  obtain ⟨A, B, hx, hy⟩ := h
  refine ⟨(q : ℤ) * A, (q : ℤ) * B, ?_, ?_⟩
  · rw [hx]
    push_cast
    field_simp
  · rw [hy]
    push_cast
    field_simp

/-- Paired integer multiples of corresponding powers. -/
theorem int_mul_golden_powers_mem_pair
    (q : ℕ) (hq : 0 < q) (C : ℤ) (p : ℕ) :
    InScaledGoldenPair q ((C : ℝ) * φ ^ p) ((C : ℝ) * ψ ^ p) := by
  exact (golden_powers_mem_pair p).int_mul C |>.change_one_to_denominator hq

/-- Finite sums preserve a paired denominator. -/
theorem finset_sum_mem_scaledGoldenPair
    {ι : Type*} {q : ℕ} (hq : 0 < q) (s : Finset ι)
    (f g : ι → ℝ) (hfg : ∀ i ∈ s, InScaledGoldenPair q (f i) (g i)) :
    InScaledGoldenPair q (∑ i ∈ s, f i) (∑ i ∈ s, g i) := by
  classical
  induction s using Finset.induction_on with
  | empty => exact ⟨0, 0, by simp, by simp⟩
  | @insert a s ha ih =>
      rw [Finset.sum_insert ha, Finset.sum_insert ha]
      exact (hfg a (Finset.mem_insert_self a s)).add hq
        (ih fun i hi => hfg i (Finset.mem_insert_of_mem hi))

/-- The two embeddings of `(a/b)/√5` are opposite and form one paired lattice
element with denominator `5b`. -/
theorem rational_inv_sqrtFive_mem_pair
    (a : ℤ) (b : ℕ) (hb : 0 < b) :
    InScaledGoldenPair (5 * b)
      ((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))
      (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) := by
  refine ⟨-a, 2 * a, ?_, ?_⟩
  · have hs : √(5 : ℝ) ≠ 0 := by positivity
    have hb0 : (b : ℝ) ≠ 0 := by exact_mod_cast ne_of_gt hb
    rw [show φ = (1 + √5) / 2 by rfl]
    push_cast
    field_simp
    rw [show (-1 : ℝ) + (1 + √5) = √5 by ring,
      show √5 * (a : ℝ) * √5 = (a : ℝ) * √5 ^ 2 by ring,
      Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 5)]
  · have hs : √(5 : ℝ) ≠ 0 := by positivity
    have hb0 : (b : ℝ) ≠ 0 := by exact_mod_cast ne_of_gt hb
    rw [show ψ = (1 - √5) / 2 by rfl]
    push_cast
    field_simp
    rw [show (-1 : ℝ) + (1 - √5) = -√5 by ring,
      show √5 * (a : ℝ) * (-√5) = -(a : ℝ) * √5 ^ 2 by ring,
      Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 5)]
    ring

/-- Conjugate algebraic prefix residual at a cut. -/
noncomputable def conjugateCoefficientResidual (C : ℕ → ℤ)
    (Tconj : ℝ) (N : ℕ) : ℝ :=
  ψ ^ N * Tconj -
    ∑ m ∈ Finset.range N, (C m : ℝ) * ψ ^ (N - m)

/-- Under `S=a/b`, the principal and conjugate normalized residuals are the two
embeddings of one element of the fixed lattice `(1/(5b))ℤ[φ]`. -/
theorem normalized_and_conjugate_residual_mem_pair
    (C : ℕ → ℤ) (a : ℤ) (b N : ℕ) (hb : 0 < b) :
    InScaledGoldenPair (5 * b)
      (normalizedCoefficientResidual C
        ((√5)⁻¹ * ((a : ℝ) / (b : ℝ))) N)
      (conjugateCoefficientResidual C
        (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) N) := by
  have hq : 0 < 5 * b := by omega
  apply InScaledGoldenPair.sub hq
  · exact (rational_inv_sqrtFive_mem_pair a b hb).powers_mul N
  · apply finset_sum_mem_scaledGoldenPair hq
    intro m hm
    exact int_mul_golden_powers_mem_pair (5 * b) hq (C m) (N - m)

/-- Paired norm lower bound in directly usable form. -/
theorem InScaledGoldenPair.norm_lower {q : ℕ} (hq : 0 < q)
    {x y : ℝ} (h : InScaledGoldenPair q x y) (hx : x ≠ 0) :
    ((q : ℝ)⁻¹) ^ 2 ≤ |x| * |y| := by
  obtain ⟨A, B, hxAB, hyAB⟩ := h
  have hAB : A ≠ 0 ∨ B ≠ 0 := by
    by_contra hz
    simp only [not_or, not_not] at hz
    rcases hz with ⟨rfl, rfl⟩
    simp at hxAB
    exact hx hxAB
  rw [hxAB, hyAB]
  exact inv_sq_le_abs_scaled_golden_mul_abs_conj A B q hq hAB

end Research

/-!
# Fully explicit matched-block norm contradiction gate
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

noncomputable def tailLinearBound (N : ℕ) : ℝ :=
  (N : ℝ) * (1 - φ⁻¹)⁻¹ + φ⁻¹ / (1 - φ⁻¹) ^ 2

noncomputable def conjugateQuadraticBound (Tconj : ℝ) (N : ℕ) : ℝ :=
  |Tconj| + (N : ℝ) ^ 2

/-- A coarse quadratic bound for the explicit conjugate residual. -/
theorem abs_conjugateCoefficientResidual_le
    (C : ℕ → ℤ) (hC : ∀ m, |C m| ≤ (m : ℤ))
    (Tconj : ℝ) (N : ℕ) :
    |conjugateCoefficientResidual C Tconj N| ≤
      conjugateQuadraticBound Tconj N := by
  have hψabs0 : 0 ≤ |ψ| := abs_nonneg _
  have hψabs1 : |ψ| ≤ 1 := by
    rw [abs_of_neg Real.goldenConj_neg]
    linarith [Real.neg_one_lt_goldenConj]
  have hpow : ∀ p : ℕ, |ψ| ^ p ≤ 1 := fun p =>
    pow_le_one₀ hψabs0 hψabs1
  have hfirst : |ψ ^ N * Tconj| ≤ |Tconj| := by
    rw [abs_mul, abs_pow]
    simpa only [one_mul] using
      mul_le_mul_of_nonneg_right (hpow N) (abs_nonneg Tconj)
  have hterm : ∀ m ∈ Finset.range N,
      |(C m : ℝ) * ψ ^ (N - m)| ≤ (N : ℝ) := by
    intro m hm
    have hmN : m ≤ N := (Finset.mem_range.mp hm).le
    have hc : |(C m : ℝ)| ≤ (m : ℝ) := by
      exact_mod_cast hC m
    rw [abs_mul, abs_pow]
    calc
      |(C m : ℝ)| * |ψ| ^ (N - m) ≤ (m : ℝ) * 1 :=
        mul_le_mul hc (hpow (N - m)) (pow_nonneg hψabs0 _) (by positivity)
      _ ≤ (N : ℝ) := by
        simpa using (show (m : ℝ) ≤ (N : ℝ) by exact_mod_cast hmN)
  have hprefix :
      |∑ m ∈ Finset.range N, (C m : ℝ) * ψ ^ (N - m)| ≤
        (N : ℝ) ^ 2 := by
    calc
      |∑ m ∈ Finset.range N, (C m : ℝ) * ψ ^ (N - m)| ≤
          ∑ m ∈ Finset.range N, |(C m : ℝ) * ψ ^ (N - m)| :=
        Finset.abs_sum_le_sum_abs _ _
      _ ≤ ∑ _m ∈ Finset.range N, (N : ℝ) := by
        apply Finset.sum_le_sum
        exact hterm
      _ = (N : ℝ) ^ 2 := by
        simp
        ring
  unfold conjugateCoefficientResidual conjugateQuadraticBound
  exact (abs_sub _ _).trans (add_le_add hfirst hprefix)

/-- Equal coefficient blocks make the principal tail difference exponentially
small, with a completely explicit endpoint bound. -/
theorem abs_coefficientTail_sub_le_of_block_eq
    (C : ℕ → ℤ) (hC : ∀ m, |C m| ≤ (m : ℤ))
    (hsum : Summable (fun m : ℕ => (C m : ℝ) * (φ⁻¹) ^ m))
    (N M L : ℕ) (hblock : ∀ t < L, C (N + t) = C (M + t)) :
    |coefficientTail C N - coefficientTail C M| ≤
      (φ⁻¹) ^ L *
        (tailLinearBound (N + L) + tailLinearBound (M + L)) := by
  rw [coefficientTail_sub_eq_pow_mul_of_block_eq C hsum N M L hblock,
    abs_mul, abs_pow, abs_of_nonneg (inv_nonneg.mpr Real.goldenRatio_pos.le)]
  apply mul_le_mul_of_nonneg_left _ (pow_nonneg (inv_nonneg.mpr Real.goldenRatio_pos.le) _)
  exact (abs_sub _ _).trans <| add_le_add
    (abs_coefficientTail_le C hC (N + L))
    (abs_coefficientTail_le C hC (M + L))

/-- The two conjugate residuals have a quadratic difference bound. -/
theorem abs_conjugateResidual_sub_le
    (C : ℕ → ℤ) (hC : ∀ m, |C m| ≤ (m : ℤ))
    (Tconj : ℝ) (N M : ℕ) :
    |conjugateCoefficientResidual C Tconj N -
      conjugateCoefficientResidual C Tconj M| ≤
      conjugateQuadraticBound Tconj N +
        conjugateQuadraticBound Tconj M := by
  exact (abs_sub _ _).trans <| add_le_add
    (abs_conjugateCoefficientResidual_le C hC Tconj N)
    (abs_conjugateCoefficientResidual_le C hC Tconj M)

/-- **Matched-block contradiction gate.**  Under the rationality identity for
the coefficient sum, a nonzero repeated block cannot be long enough to make
the displayed explicit product smaller than the fixed norm lower bound. -/
theorem matched_block_norm_obstruction
    (C : ℕ → ℤ) (hC : ∀ m, |C m| ≤ (m : ℤ))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hsum : HasSum (fun m : ℕ => (C m : ℝ) * (φ⁻¹) ^ m)
      ((√5)⁻¹ * ((a : ℝ) / (b : ℝ))))
    (N M L : ℕ)
    (hblock : ∀ t < L, C (N + t) = C (M + t))
    (hne : coefficientTail C N ≠ coefficientTail C M)
    (hsmall :
      (φ⁻¹) ^ L *
          (tailLinearBound (N + L) + tailLinearBound (M + L)) *
        (conjugateQuadraticBound
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) N +
          conjugateQuadraticBound
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) M) <
      (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  let T : ℝ := (√5)⁻¹ * ((a : ℝ) / (b : ℝ))
  let Tc : ℝ := -T
  let x : ℝ := coefficientTail C N - coefficientTail C M
  let y : ℝ := conjugateCoefficientResidual C Tc N -
    conjugateCoefficientResidual C Tc M
  have hpairN := normalized_and_conjugate_residual_mem_pair C a b N hb
  have hpairM := normalized_and_conjugate_residual_mem_pair C a b M hb
  have hresN := normalizedCoefficientResidual_eq_coefficientTail C T hsum N
  have hresM := normalizedCoefficientResidual_eq_coefficientTail C T hsum M
  have hpair : InScaledGoldenPair (5 * b) x y := by
    dsimp [x, y, Tc]
    rw [← hresN, ← hresM]
    exact hpairN.sub (by omega) hpairM
  have hx : x ≠ 0 := sub_ne_zero.mpr hne
  have hlower := hpair.norm_lower (by omega) hx
  have hxupper : |x| ≤
      (φ⁻¹) ^ L *
        (tailLinearBound (N + L) + tailLinearBound (M + L)) := by
    exact abs_coefficientTail_sub_le_of_block_eq C hC hsum.summable
      N M L hblock
  have hyupper : |y| ≤
      conjugateQuadraticBound Tc N + conjugateQuadraticBound Tc M := by
    exact abs_conjugateResidual_sub_le C hC Tc N M
  have hpnonneg : 0 ≤
      (φ⁻¹) ^ L *
        (tailLinearBound (N + L) + tailLinearBound (M + L)) :=
    (abs_nonneg x).trans hxupper
  have hproduct : |x| * |y| ≤
      ((φ⁻¹) ^ L *
        (tailLinearBound (N + L) + tailLinearBound (M + L))) *
      (conjugateQuadraticBound Tc N + conjugateQuadraticBound Tc M) := by
    exact mul_le_mul hxupper hyupper (abs_nonneg _) hpnonneg
  dsimp [Tc, T] at hproduct
  exact (not_lt_of_ge (hlower.trans hproduct)) hsmall

end Research

/-!
# Coefficient bounds by the index counting function
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- Selected sequence positions whose index is at most the exponent `m`. -/
def activeIndexPositions (n : ℕ → ℕ) (m : ℕ) : Finset ℕ :=
  (Finset.range m).filter fun k => n k ≤ m

/-- Number of selected indices not exceeding `m`. -/
def selectedIndexCount (n : ℕ → ℕ) (m : ℕ) : ℕ :=
  (activeIndexPositions n m).card

/-- The active-position sets are monotone in the exponent. -/
theorem activeIndexPositions_mono
    (n : ℕ → ℕ) {a b : ℕ} (hab : a ≤ b) :
    activeIndexPositions n a ⊆ activeIndexPositions n b := by
  intro k hk
  simp only [activeIndexPositions, Finset.mem_filter, Finset.mem_range] at hk ⊢
  exact ⟨lt_of_lt_of_le hk.1 hab, hk.2.trans hab⟩

/-- The selected-index counting function is monotone. -/
theorem selectedIndexCount_mono
    (n : ℕ → ℕ) {a b : ℕ} (hab : a ≤ b) :
    selectedIndexCount n a ≤ selectedIndexCount n b :=
  Finset.card_le_card (activeIndexPositions_mono n hab)

/-- Raising the exponent threshold by one introduces at most one new selected
index, because the selected indices are distinct. -/
theorem selectedIndexCount_succ_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n) (m : ℕ) :
    selectedIndexCount n (m + 1) ≤ selectedIndexCount n m + 1 := by
  let S := activeIndexPositions n m
  let T := activeIndexPositions n (m + 1)
  have hST : S ⊆ T := activeIndexPositions_mono n (by omega)
  have hdiff : (T \ S).card ≤ 1 := by
    rw [Finset.card_le_one]
    intro i hi j hj
    have hiT := (Finset.mem_sdiff.mp hi).1
    have hiS := (Finset.mem_sdiff.mp hi).2
    have hjT := (Finset.mem_sdiff.mp hj).1
    have hjS := (Finset.mem_sdiff.mp hj).2
    have hiData : i < m + 1 ∧ n i ≤ m + 1 := by
      simpa [T, activeIndexPositions] using hiT
    have hjData : j < m + 1 ∧ n j ≤ m + 1 := by
      simpa [T, activeIndexPositions] using hjT
    have hni : n i = m + 1 := by
      by_contra hne
      have hle : n i ≤ m := by omega
      have hipos := position_add_one_le_index n hpos hmono i
      have hiMem : i ∈ S := by
        simp only [S, activeIndexPositions, Finset.mem_filter, Finset.mem_range]
        exact ⟨by omega, hle⟩
      exact hiS hiMem
    have hnj : n j = m + 1 := by
      by_contra hne
      have hle : n j ≤ m := by omega
      have hjpos := position_add_one_le_index n hpos hmono j
      have hjMem : j ∈ S := by
        simp only [S, activeIndexPositions, Finset.mem_filter, Finset.mem_range]
        exact ⟨by omega, hle⟩
      exact hjS hjMem
    exact hmono.injective (hni.trans hnj.symm)
  have hunion := Finset.card_union_le (T \ S) S
  rw [Finset.sdiff_union_of_subset hST] at hunion
  change T.card ≤ S.card + 1
  omega

/-- Over an interval of length `t`, the counting function rises by at most
`t`. -/
theorem selectedIndexCount_add_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (N t : ℕ) :
    selectedIndexCount n (N + t) ≤ selectedIndexCount n N + t := by
  induction t with
  | zero => simp
  | succ t ih =>
      have hs := selectedIndexCount_succ_le n hpos hmono (N + t)
      rw [show N + (t + 1) = N + t + 1 by omega]
      omega

/-- The exact Lambert coefficient is bounded by the number of selected indices
not exceeding its exponent. -/
theorem abs_selectedFibLambertCoeff_le_indexCount
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (m : ℕ) :
    |selectedFibLambertCoeff n m| ≤ (selectedIndexCount n m : ℤ) := by
  rw [selectedFibLambertCoeff]
  calc
    |∑ k ∈ Finset.range m, fibLambertCoeff (n k) m| ≤
        ∑ k ∈ Finset.range m, |fibLambertCoeff (n k) m| :=
      Finset.abs_sum_le_sum_abs _ _
    _ ≤ ∑ k ∈ Finset.range m,
        if n k ≤ m then (1 : ℤ) else 0 := by
      apply Finset.sum_le_sum
      intro k hk
      by_cases hkm : n k ≤ m
      · simp only [if_pos hkm]
        exact abs_fibLambertCoeff_le_one (n k) m
      · have hz : fibLambertCoeff (n k) m = 0 := by
          by_contra hne
          exact hkm (fibLambertCoeff_index_le_of_ne_zero
            (n k) m (hpos k) hne)
        simp [hkm, hz]
    _ = (selectedIndexCount n m : ℤ) := by
      rw [selectedIndexCount, activeIndexPositions]
      simp

end Research

/-!
# Logarithmic-scale tail bounds through the index counting function
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

noncomputable def indexCountTailBound (n : ℕ → ℕ) (N : ℕ) : ℝ :=
  (selectedIndexCount n N : ℝ) * (1 - φ⁻¹)⁻¹ +
    φ⁻¹ / (1 - φ⁻¹) ^ 2

noncomputable def indexCountConjugateBound
    (n : ℕ → ℕ) (Tconj : ℝ) (N : ℕ) : ℝ :=
  |Tconj| + (selectedIndexCount n N : ℝ) * (1 - φ⁻¹)⁻¹

/-- The principal normalized tail is controlled by the number of selected
indices below its cut, rather than by the cut itself. -/
theorem abs_selected_coefficientTail_le_indexCount
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n) (N : ℕ) :
    |coefficientTail (selectedFibLambertCoeff n) N| ≤
      indexCountTailBound n N := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by
    dsimp [r]
    exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hrabs : |r| < 1 := by simpa [abs_of_nonneg hr0] using hr1
  let A : ℕ := selectedIndexCount n N
  let g : ℕ → ℝ := fun t => (A + t : ℕ) * r ^ t
  have hgeom : Summable (fun t : ℕ => r ^ t) :=
    summable_geometric_of_abs_lt_one hrabs
  have hlin : Summable (fun t : ℕ => (t : ℝ) * r ^ t) := by
    simpa only [pow_one] using
      (summable_pow_mul_geometric_of_norm_lt_one (R := ℝ) 1
        (by simpa [Real.norm_eq_abs] using hrabs))
  have hconst : Summable (fun t : ℕ => (A : ℝ) * r ^ t) :=
    hgeom.mul_left (A : ℝ)
  have hg : Summable g := by
    apply (hconst.add hlin).congr
    intro t
    dsimp [g]
    push_cast
    ring
  have hterm : ∀ t : ℕ,
      ‖(selectedFibLambertCoeff n (N + t) : ℝ) * r ^ t‖ ≤ g t := by
    intro t
    have hcZ := abs_selectedFibLambertCoeff_le_indexCount n hpos (N + t)
    have hcount := selectedIndexCount_add_le n hpos hmono N t
    have hc : |(selectedFibLambertCoeff n (N + t) : ℝ)| ≤ (A + t : ℕ) := by
      have hcR : |(selectedFibLambertCoeff n (N + t) : ℝ)| ≤
          (selectedIndexCount n (N + t) : ℝ) := by exact_mod_cast hcZ
      exact hcR.trans (by exact_mod_cast hcount)
    rw [Real.norm_eq_abs, abs_mul, abs_pow, abs_of_nonneg hr0]
    exact mul_le_mul_of_nonneg_right hc (pow_nonneg hr0 t)
  have hf : Summable (fun t : ℕ =>
      (selectedFibLambertCoeff n (N + t) : ℝ) * r ^ t) :=
    Summable.of_norm_bounded hg hterm
  have hnorm := norm_tsum_le_tsum_norm hf.norm
  have hle := hf.norm.tsum_le_tsum hterm hg
  have hgvalue :
      (∑' t : ℕ, g t) =
        (A : ℝ) * (1 - r)⁻¹ + r / (1 - r) ^ 2 := by
    calc
      (∑' t : ℕ, g t) =
          ∑' t : ℕ, ((A : ℝ) * r ^ t + (t : ℝ) * r ^ t) := by
            apply tsum_congr
            intro t
            dsimp [g]
            push_cast
            ring
      _ = (∑' t : ℕ, (A : ℝ) * r ^ t) +
          ∑' t : ℕ, (t : ℝ) * r ^ t := hconst.tsum_add hlin
      _ = (A : ℝ) * (1 - r)⁻¹ + r / (1 - r) ^ 2 := by
        rw [tsum_mul_left, tsum_geometric_of_abs_lt_one hrabs,
          tsum_coe_mul_geometric_of_norm_lt_one
            (by simpa [Real.norm_eq_abs] using hrabs)]
  have hfinal := hnorm.trans hle
  rw [hgvalue] at hfinal
  change |∑' t : ℕ,
    (selectedFibLambertCoeff n (N + t) : ℝ) * r ^ t| ≤
      (A : ℝ) * (1 - r)⁻¹ + r / (1 - r) ^ 2
  rw [← Real.norm_eq_abs]
  exact hfinal

/-- A finite reverse geometric sum in powers of the golden conjugate is bounded
by the full geometric series. -/
private theorem sum_abs_goldenConj_pow_sub_le (N : ℕ) :
    (∑ m ∈ Finset.range N, |ψ| ^ (N - m)) ≤
      (1 - φ⁻¹)⁻¹ := by
  let r : ℝ := φ⁻¹
  have hr0 : 0 ≤ r := by
    dsimp [r]
    exact (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hrabs : |r| < 1 := by simpa [abs_of_nonneg hr0] using hr1
  have hψ : |ψ| = r := by
    dsimp [r]
    rw [Real.inv_goldenRatio, abs_of_neg Real.goldenConj_neg]
  rw [hψ]
  calc
    (∑ m ∈ Finset.range N, r ^ (N - m)) =
        ∑ j ∈ Finset.range N, r ^ (j + 1) := by
      rw [← Finset.sum_range_reflect (fun j => r ^ (j + 1)) N]
      apply Finset.sum_congr rfl
      intro m hm
      congr 1
      have hmN := Finset.mem_range.mp hm
      omega
    _ ≤ ∑ j ∈ Finset.range N, r ^ j := by
      apply Finset.sum_le_sum
      intro j hj
      exact pow_le_pow_of_le_one hr0 hr1.le (by omega)
    _ ≤ ∑' j : ℕ, r ^ j := by
      exact (summable_geometric_of_abs_lt_one hrabs).sum_le_tsum
        (Finset.range N) (fun _ _ => pow_nonneg hr0 _)
    _ = (1 - φ⁻¹)⁻¹ := by
      simpa [r] using tsum_geometric_of_abs_lt_one hrabs

/-- The explicit conjugate residual has the same index-count scale. -/
theorem abs_selected_conjugateResidual_le_indexCount
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (_hmono : StrictMono n)
    (Tconj : ℝ) (N : ℕ) :
    |conjugateCoefficientResidual (selectedFibLambertCoeff n) Tconj N| ≤
      indexCountConjugateBound n Tconj N := by
  let A : ℕ := selectedIndexCount n N
  have hψabs1 : |ψ| ≤ 1 := by
    rw [abs_of_neg Real.goldenConj_neg]
    linarith [Real.neg_one_lt_goldenConj]
  have hfirst : |ψ ^ N * Tconj| ≤ |Tconj| := by
    rw [abs_mul, abs_pow]
    simpa only [one_mul] using mul_le_mul_of_nonneg_right
      (pow_le_one₀ (abs_nonneg _) hψabs1) (abs_nonneg Tconj)
  have hterm : ∀ m ∈ Finset.range N,
      |(selectedFibLambertCoeff n m : ℝ) * ψ ^ (N - m)| ≤
        (A : ℝ) * |ψ| ^ (N - m) := by
    intro m hm
    have hcZ := abs_selectedFibLambertCoeff_le_indexCount n hpos m
    have hcount := selectedIndexCount_mono n (Finset.mem_range.mp hm).le
    have hc : |(selectedFibLambertCoeff n m : ℝ)| ≤ (A : ℝ) := by
      have hcR : |(selectedFibLambertCoeff n m : ℝ)| ≤
          (selectedIndexCount n m : ℝ) := by exact_mod_cast hcZ
      exact hcR.trans (by exact_mod_cast hcount)
    rw [abs_mul, abs_pow]
    exact mul_le_mul_of_nonneg_right hc (pow_nonneg (abs_nonneg _) _)
  have hprefix :
      |∑ m ∈ Finset.range N,
        (selectedFibLambertCoeff n m : ℝ) * ψ ^ (N - m)| ≤
      (A : ℝ) * (1 - φ⁻¹)⁻¹ := by
    calc
      |∑ m ∈ Finset.range N,
        (selectedFibLambertCoeff n m : ℝ) * ψ ^ (N - m)| ≤
          ∑ m ∈ Finset.range N,
            |(selectedFibLambertCoeff n m : ℝ) * ψ ^ (N - m)| :=
        Finset.abs_sum_le_sum_abs _ _
      _ ≤ ∑ m ∈ Finset.range N, (A : ℝ) * |ψ| ^ (N - m) := by
        apply Finset.sum_le_sum
        exact hterm
      _ = (A : ℝ) * ∑ m ∈ Finset.range N, |ψ| ^ (N - m) := by
        rw [Finset.mul_sum]
      _ ≤ (A : ℝ) * (1 - φ⁻¹)⁻¹ := by
        exact mul_le_mul_of_nonneg_left (sum_abs_goldenConj_pow_sub_le N)
          (by positivity)
  unfold conjugateCoefficientResidual indexCountConjugateBound
  exact (abs_sub _ _).trans (add_le_add hfirst hprefix)

end Research

/-!
# Matched-block norm gate with index-count bounds
-/

namespace Research

open Real goldenRatio

/-- Equal coefficient blocks give an exponentially small principal difference,
now with the sharp index-count endpoint bounds. -/
theorem abs_selectedTail_sub_le_indexCount_of_block_eq
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (N M L : ℕ)
    (hblock : ∀ t < L,
      selectedFibLambertCoeff n (N + t) =
        selectedFibLambertCoeff n (M + t)) :
    |coefficientTail (selectedFibLambertCoeff n) N -
      coefficientTail (selectedFibLambertCoeff n) M| ≤
      (φ⁻¹) ^ L *
        (indexCountTailBound n (N + L) +
          indexCountTailBound n (M + L)) := by
  have hsum := (hasSum_selectedFibLambertCoeff n hpos hmono).summable
  rw [coefficientTail_sub_eq_pow_mul_of_block_eq
      (selectedFibLambertCoeff n) hsum N M L hblock,
    abs_mul, abs_pow, abs_of_nonneg (inv_nonneg.mpr Real.goldenRatio_pos.le)]
  apply mul_le_mul_of_nonneg_left _
    (pow_nonneg (inv_nonneg.mpr Real.goldenRatio_pos.le) _)
  exact (abs_sub _ _).trans <| add_le_add
    (abs_selected_coefficientTail_le_indexCount n hpos hmono (N + L))
    (abs_selected_coefficientTail_le_indexCount n hpos hmono (M + L))

/-- The paired conjugate difference has the corresponding index-count bound. -/
theorem abs_selectedConjugateResidual_sub_le_indexCount
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (Tconj : ℝ) (N M : ℕ) :
    |conjugateCoefficientResidual (selectedFibLambertCoeff n) Tconj N -
      conjugateCoefficientResidual (selectedFibLambertCoeff n) Tconj M| ≤
      indexCountConjugateBound n Tconj N +
        indexCountConjugateBound n Tconj M := by
  exact (abs_sub _ _).trans <| add_le_add
    (abs_selected_conjugateResidual_le_indexCount n hpos hmono Tconj N)
    (abs_selected_conjugateResidual_le_indexCount n hpos hmono Tconj M)

/-- **Index-count matched-block obstruction.**  If the original
reciprocal-Fibonacci sum were `a/b`, no unequal pair of normalized tails could
be preceded by an equal coefficient block satisfying the displayed sharp
numerical inequality. -/
theorem selected_matched_block_indexCount_obstruction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (N M L : ℕ)
    (hblock : ∀ t < L,
      selectedFibLambertCoeff n (N + t) =
        selectedFibLambertCoeff n (M + t))
    (hne : coefficientTail (selectedFibLambertCoeff n) N ≠
      coefficientTail (selectedFibLambertCoeff n) M)
    (hsmall :
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (M + L)) *
        (indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) N +
          indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) M) <
      (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  let C := selectedFibLambertCoeff n
  let T : ℝ := (√5)⁻¹ * ((a : ℝ) / (b : ℝ))
  let Tc : ℝ := -T
  let x : ℝ := coefficientTail C N - coefficientTail C M
  let y : ℝ := conjugateCoefficientResidual C Tc N -
    conjugateCoefficientResidual C Tc M
  have hsum := hasSum_selectedFibLambertCoeff n hpos hmono
  rw [hrat] at hsum
  have hpairN := normalized_and_conjugate_residual_mem_pair C a b N hb
  have hpairM := normalized_and_conjugate_residual_mem_pair C a b M hb
  have hresN := normalizedCoefficientResidual_eq_coefficientTail C T hsum N
  have hresM := normalizedCoefficientResidual_eq_coefficientTail C T hsum M
  have hpair : InScaledGoldenPair (5 * b) x y := by
    dsimp [x, y, Tc]
    rw [← hresN, ← hresM]
    exact hpairN.sub (by omega) hpairM
  have hx : x ≠ 0 := sub_ne_zero.mpr hne
  have hlower := hpair.norm_lower (by omega) hx
  have hxupper : |x| ≤
      (φ⁻¹) ^ L *
        (indexCountTailBound n (N + L) +
          indexCountTailBound n (M + L)) := by
    exact abs_selectedTail_sub_le_indexCount_of_block_eq
      n hpos hmono N M L hblock
  have hyupper : |y| ≤
      indexCountConjugateBound n Tc N +
        indexCountConjugateBound n Tc M := by
    exact abs_selectedConjugateResidual_sub_le_indexCount
      n hpos hmono Tc N M
  have hpnonneg : 0 ≤
      (φ⁻¹) ^ L *
        (indexCountTailBound n (N + L) +
          indexCountTailBound n (M + L)) :=
    (abs_nonneg x).trans hxupper
  have hproduct : |x| * |y| ≤
      ((φ⁻¹) ^ L *
        (indexCountTailBound n (N + L) +
          indexCountTailBound n (M + L))) *
      (indexCountConjugateBound n Tc N +
        indexCountConjugateBound n Tc M) := by
    exact mul_le_mul hxupper hyupper (abs_nonneg _) hpnonneg
  dsimp [Tc, T] at hproduct
  exact (not_lt_of_ge (hlower.trans hproduct)) hsmall

end Research

/-!
# Explicit counting bounds from the multiplicative ratio gap
-/

namespace Research

/-- The counting function evaluated at a selected index has its exact expected
value. -/
theorem selectedIndexCount_at_index
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n) (K : ℕ) :
    selectedIndexCount n (n K) = K + 1 := by
  have hKpos := position_add_one_le_index n hpos hmono K
  have heq : activeIndexPositions n (n K) = Finset.range (K + 1) := by
    ext k
    simp only [activeIndexPositions, Finset.mem_filter, Finset.mem_range]
    constructor
    · intro hk
      have hle : k ≤ K := by
        by_contra hnot
        have hlt : K < k := by omega
        exact (not_lt_of_ge hk.2) (hmono hlt)
      omega
    · intro hk
      have hle : k ≤ K := by omega
      exact ⟨by omega, hmono.monotone hle⟩
  rw [selectedIndexCount, heq, Finset.card_range]

/-- Below the `K`-th selected index, at most `K` selected indices occur. -/
theorem selectedIndexCount_lt_index
    (n : ℕ → ℕ) (_hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    {x K : ℕ} (hx : x < n K) :
    selectedIndexCount n x ≤ K := by
  have hsubset : activeIndexPositions n x ⊆ Finset.range K := by
    intro k hk
    simp only [activeIndexPositions, Finset.mem_filter, Finset.mem_range] at hk
    simp only [Finset.mem_range]
    by_contra hnot
    have hKk : K ≤ k := by omega
    have hindex : n K ≤ n k := hmono.monotone hKk
    omega
  simpa [selectedIndexCount] using Finset.card_le_card hsubset

/-- Iterating a real multiplicative ratio gap gives geometric growth of the
selected indices. -/
theorem ratio_gap_geometric_growth
    (n : ℕ → ℕ) (c : ℝ) (hc : 0 ≤ c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1)) (K : ℕ) :
    c ^ K * (n 0 : ℝ) ≤ n K := by
  induction K with
  | zero => simp
  | succ K ih =>
      calc
        c ^ (K + 1) * (n 0 : ℝ) = c * (c ^ K * (n 0 : ℝ)) := by
          rw [pow_succ]
          ring
        _ ≤ c * (n K : ℝ) := by
          gcongr
        _ ≤ n (K + 1) := hratio K

/-- Explicit inverse-geometric certificate for the counting function: whenever
`x` lies below the geometric lower bound for `n_K`, at most `K` indices can be
active at `x`. -/
theorem selectedIndexCount_le_of_lt_geometric
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 0 ≤ c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    {x K : ℕ} (hx : (x : ℝ) < c ^ K * (n 0 : ℝ)) :
    selectedIndexCount n x ≤ K := by
  have hgrowth := ratio_gap_geometric_growth n c hc hratio K
  have hxindex : x < n K := by exact_mod_cast hx.trans_le hgrowth
  exact selectedIndexCount_lt_index n hpos hmono hxindex

end Research

/-!
# Certifying tail nonvanishing from an isolated coefficient mismatch
-/

namespace Research

open Real goldenRatio

/-- A nonzero coefficient mismatch followed by a sufficiently long equal block
forces the two normalized tails to be different. -/
theorem selected_coefficientTail_ne_of_isolated_mismatch
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (N M L J : ℕ)
    (hmismatch : selectedFibLambertCoeff n (N + L) ≠
      selectedFibLambertCoeff n (M + L))
    (hpost : ∀ t < J,
      selectedFibLambertCoeff n (N + L + 1 + t) =
        selectedFibLambertCoeff n (M + L + 1 + t))
    (hsmallPost :
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (M + L + 1 + J)) < 1) :
    coefficientTail (selectedFibLambertCoeff n) (N + L) ≠
      coefficientTail (selectedFibLambertCoeff n) (M + L) := by
  let C := selectedFibLambertCoeff n
  have hsum := (hasSum_selectedFibLambertCoeff n hpos hmono).summable
  have hsplitN := coefficientTail_eq_block_add C hsum (N + L) 1
  have hsplitM := coefficientTail_eq_block_add C hsum (M + L) 1
  simp only [Finset.sum_range_succ, Finset.sum_range_zero, zero_add,
    pow_zero, mul_one, pow_one] at hsplitN hsplitM
  have hpostFactor := coefficientTail_sub_eq_pow_mul_of_block_eq C hsum
    (N + L + 1) (M + L + 1) J hpost
  have hformula :
      coefficientTail C (N + L) - coefficientTail C (M + L) =
        ((C (N + L) - C (M + L) : ℤ) : ℝ) +
          (φ⁻¹) ^ (J + 1) *
            (coefficientTail C (N + L + 1 + J) -
              coefficientTail C (M + L + 1 + J)) := by
    rw [hsplitN, hsplitM]
    simp only [add_zero]
    push_cast
    calc
      (C (N + L) : ℝ) + φ⁻¹ * coefficientTail C (N + L + 1) -
          ((C (M + L) : ℝ) + φ⁻¹ * coefficientTail C (M + L + 1)) =
        ((C (N + L) : ℝ) - (C (M + L) : ℝ)) +
          φ⁻¹ * (coefficientTail C (N + L + 1) -
            coefficientTail C (M + L + 1)) := by ring
      _ = ((C (N + L) : ℝ) - (C (M + L) : ℝ)) +
          (φ⁻¹) ^ (J + 1) *
            (coefficientTail C (N + L + 1 + J) -
              coefficientTail C (M + L + 1 + J)) := by
        rw [hpostFactor, pow_succ]
        ring
  have hlater :
      |coefficientTail C (N + L + 1 + J) -
        coefficientTail C (M + L + 1 + J)| ≤
        indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (M + L + 1 + J) := by
    exact (abs_sub _ _).trans <| add_le_add
      (abs_selected_coefficientTail_le_indexCount n hpos hmono
        (N + L + 1 + J))
      (abs_selected_coefficientTail_le_indexCount n hpos hmono
        (M + L + 1 + J))
  have hr0 : 0 ≤ φ⁻¹ := inv_nonneg.mpr Real.goldenRatio_pos.le
  have hrem :
      |(φ⁻¹) ^ (J + 1) *
        (coefficientTail C (N + L + 1 + J) -
          coefficientTail C (M + L + 1 + J))| < 1 := by
    rw [abs_mul, abs_pow, abs_of_nonneg hr0]
    exact (mul_le_mul_of_nonneg_left hlater (pow_nonneg hr0 _)).trans_lt hsmallPost
  have hdZ : C (N + L) - C (M + L) ≠ 0 := sub_ne_zero.mpr hmismatch
  have hdLower : (1 : ℝ) ≤ |((C (N + L) - C (M + L) : ℤ) : ℝ)| := by
    exact_mod_cast Int.one_le_abs hdZ
  intro heq
  have hzero : coefficientTail C (N + L) - coefficientTail C (M + L) = 0 :=
    sub_eq_zero.mpr heq
  rw [hzero] at hformula
  have habsEq :
      |((C (N + L) - C (M + L) : ℤ) : ℝ)| =
      |(φ⁻¹) ^ (J + 1) *
        (coefficientTail C (N + L + 1 + J) -
          coefficientTail C (M + L + 1 + J))| := by
    rw [← abs_neg]
    congr 1
    linarith
  rw [habsEq] at hdLower
  exact (not_lt_of_ge hdLower) hrem

/-- Adding an equal block before an isolated mismatch transfers the certified
nonvanishing back to the start of that block. -/
theorem selected_coefficientTail_ne_of_sandwiched_mismatch
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (N M L J : ℕ)
    (hpre : ∀ t < L,
      selectedFibLambertCoeff n (N + t) =
        selectedFibLambertCoeff n (M + t))
    (hmismatch : selectedFibLambertCoeff n (N + L) ≠
      selectedFibLambertCoeff n (M + L))
    (hpost : ∀ t < J,
      selectedFibLambertCoeff n (N + L + 1 + t) =
        selectedFibLambertCoeff n (M + L + 1 + t))
    (hsmallPost :
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (M + L + 1 + J)) < 1) :
    coefficientTail (selectedFibLambertCoeff n) N ≠
      coefficientTail (selectedFibLambertCoeff n) M := by
  have hsum := (hasSum_selectedFibLambertCoeff n hpos hmono).summable
  have hfactor := coefficientTail_sub_eq_pow_mul_of_block_eq
    (selectedFibLambertCoeff n) hsum N M L hpre
  have hlater := selected_coefficientTail_ne_of_isolated_mismatch
    n hpos hmono N M L J hmismatch hpost hsmallPost
  intro heq
  have hz : coefficientTail (selectedFibLambertCoeff n) N -
      coefficientTail (selectedFibLambertCoeff n) M = 0 := sub_eq_zero.mpr heq
  rw [hz] at hfactor
  have hpne : (φ⁻¹ : ℝ) ^ L ≠ 0 :=
    pow_ne_zero _ (inv_ne_zero Real.goldenRatio_ne_zero)
  exact hlater (sub_eq_zero.mp
    (mul_eq_zero.mp hfactor.symm |>.resolve_left hpne))

/-- **Sandwiched-mismatch irrationality gate.**  A long equal block, one
mismatch, and a second long equal block provide both the small principal value
and its certified nonvanishing, so the sharp norm obstruction applies. -/
theorem selected_sandwiched_mismatch_obstruction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (N M L J : ℕ)
    (hpre : ∀ t < L,
      selectedFibLambertCoeff n (N + t) =
        selectedFibLambertCoeff n (M + t))
    (hmismatch : selectedFibLambertCoeff n (N + L) ≠
      selectedFibLambertCoeff n (M + L))
    (hpost : ∀ t < J,
      selectedFibLambertCoeff n (N + L + 1 + t) =
        selectedFibLambertCoeff n (M + L + 1 + t))
    (hsmallPost :
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (M + L + 1 + J)) < 1)
    (hsmallPre :
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (M + L)) *
        (indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) N +
          indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) M) <
      (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  apply selected_matched_block_indexCount_obstruction
    n hpos hmono a b hb hrat N M L hpre
  · exact selected_coefficientTail_ne_of_sandwiched_mismatch
      n hpos hmono N M L J hpre hmismatch hpost hsmallPost
  · exact hsmallPre

end Research

/-!
# Componentwise certificates for coefficient blocks
-/

namespace Research

open scoped BigOperators

/-- Every nonzero individual Lambert coefficient occurs at a multiple of its
selected index. -/
theorem index_dvd_of_fibLambertCoeff_ne_zero
    (n m : ℕ) (h : fibLambertCoeff n m ≠ 0) :
    n ∣ m := by
  unfold fibLambertCoeff at h
  split_ifs at h with he h₂ h₄ h₄' <;> try contradiction
  · have hd : n ∣ 2 * n := ⟨2, by ring⟩
    have hm := Nat.mod_mod_of_dvd m hd
    rw [h₂, Nat.mod_self] at hm
    exact Nat.dvd_of_mod_eq_zero hm.symm
  · have hd : n ∣ 4 * n := ⟨4, by ring⟩
    have hm := Nat.mod_mod_of_dvd m hd
    rw [h₄, Nat.mod_self] at hm
    exact Nat.dvd_of_mod_eq_zero hm.symm
  · have hd : n ∣ 4 * n := ⟨4, by ring⟩
    have hm := Nat.mod_mod_of_dvd m hd
    rw [h₄'] at hm
    have hz : 3 * n % n = 0 := by simp
    rw [hz] at hm
    exact Nat.dvd_of_mod_eq_zero hm.symm

/-- Avoiding divisibility is enough to force an individual contribution to
vanish. -/
theorem fibLambertCoeff_eq_zero_of_not_dvd
    (n m : ℕ) (hndvd : ¬ n ∣ m) :
    fibLambertCoeff n m = 0 := by
  by_contra hne
  exact hndvd (index_dvd_of_fibLambertCoeff_ne_zero n m hne)

/-- Equality of every individual selected contribution implies equality of the
full collected coefficients. -/
theorem selectedFibLambertCoeff_eq_of_all_components_eq
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    {a b : ℕ}
    (hcomp : ∀ k, fibLambertCoeff (n k) a = fibLambertCoeff (n k) b) :
    selectedFibLambertCoeff n a = selectedFibLambertCoeff n b := by
  let Q := max a b
  have haQ : a ≤ Q := le_max_left _ _
  have hbQ : b ≤ Q := le_max_right _ _
  rw [← prefixFibLambertCoeff_eq_selected n hpos hmono haQ,
    ← prefixFibLambertCoeff_eq_selected n hpos hmono hbQ]
  unfold prefixFibLambertCoeff
  apply Finset.sum_congr rfl
  intro k hk
  exact hcomp k

/-- If exactly one individual contribution changes, then the full collected
coefficient changes. -/
theorem selectedFibLambertCoeff_ne_of_one_component_ne
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    {a b K : ℕ}
    (hK : fibLambertCoeff (n K) a ≠ fibLambertCoeff (n K) b)
    (hother : ∀ k, k ≠ K →
      fibLambertCoeff (n k) a = fibLambertCoeff (n k) b) :
    selectedFibLambertCoeff n a ≠ selectedFibLambertCoeff n b := by
  let Q := max (max a b) (K + 1)
  have haQ : a ≤ Q := le_trans (le_max_left _ _) (le_max_left _ _)
  have hbQ : b ≤ Q := le_trans (le_max_right _ _) (le_max_left _ _)
  have hKQ : K < Q := lt_of_lt_of_le (by omega) (le_max_right _ _)
  rw [← prefixFibLambertCoeff_eq_selected n hpos hmono haQ,
    ← prefixFibLambertCoeff_eq_selected n hpos hmono hbQ]
  unfold prefixFibLambertCoeff
  intro hsum
  have hmem : K ∈ Finset.range Q := Finset.mem_range.mpr hKQ
  have hrest :
      (∑ k ∈ (Finset.range Q).erase K, fibLambertCoeff (n k) a) =
      ∑ k ∈ (Finset.range Q).erase K, fibLambertCoeff (n k) b := by
    apply Finset.sum_congr rfl
    intro k hk
    exact hother k (Finset.ne_of_mem_erase hk)
  have haSplit := Finset.sum_erase_add (Finset.range Q)
    (fun k => fibLambertCoeff (n k) a) hmem
  have hbSplit := Finset.sum_erase_add (Finset.range Q)
    (fun k => fibLambertCoeff (n k) b) hmem
  apply hK
  omega

/-- A common prefix period plus divisibility avoidance for every later index
certifies equality of two full coefficients. -/
theorem selectedFibLambertCoeff_eq_of_prefix_period_and_avoidance
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K X a : ℕ) (hperiod : ∀ k < K, 4 * n k ∣ X)
    (havoidLeft : ∀ k, K ≤ k → ¬ n k ∣ a)
    (havoidRight : ∀ k, K ≤ k → ¬ n k ∣ a + X) :
    selectedFibLambertCoeff n (a + X) = selectedFibLambertCoeff n a := by
  apply selectedFibLambertCoeff_eq_of_all_components_eq n hpos hmono
  intro k
  by_cases hk : k < K
  · obtain ⟨t, ht⟩ := hperiod k hk
    subst X
    simpa [mul_comm] using fibLambertCoeff_add_period_mul (n k) a t
  · have hk' : K ≤ k := by omega
    rw [fibLambertCoeff_eq_zero_of_not_dvd _ _ (havoidRight k hk'),
      fibLambertCoeff_eq_zero_of_not_dvd _ _ (havoidLeft k hk')]

/-- At one target component, prefix periodicity and avoidance of every strictly
later component certify a genuine full-coefficient mismatch. -/
theorem selectedFibLambertCoeff_ne_of_target_and_later_avoidance
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K X a : ℕ) (hperiod : ∀ k < K, 4 * n k ∣ X)
    (htarget : fibLambertCoeff (n K) (a + X) ≠
      fibLambertCoeff (n K) a)
    (havoidLeft : ∀ k, K < k → ¬ n k ∣ a)
    (havoidRight : ∀ k, K < k → ¬ n k ∣ a + X) :
    selectedFibLambertCoeff n (a + X) ≠
      selectedFibLambertCoeff n a := by
  apply selectedFibLambertCoeff_ne_of_one_component_ne n hpos hmono htarget
  intro k hkK
  by_cases hk : k < K
  · obtain ⟨t, ht⟩ := hperiod k hk
    subst X
    simpa [mul_comm] using fibLambertCoeff_add_period_mul (n k) a t
  · have hKk : K < k := by omega
    rw [fibLambertCoeff_eq_zero_of_not_dvd _ _ (havoidRight k hKk),
      fibLambertCoeff_eq_zero_of_not_dvd _ _ (havoidLeft k hKk)]

end Research

/-!
# Counting divisibility events along an arithmetic progression
-/

namespace Research

/-- Solutions of one linear divisibility condition among `R` consecutive
progression parameters occupy at most one residue class modulo
`q / gcd(q,p)`. -/
theorem card_filter_dvd_add_mul_le
    (a p q R : ℕ) (hq : 0 < q) :
    ((Finset.range R).filter fun t => q ∣ a + p * t).card ≤
      R / (q / q.gcd p) + 1 := by
  let S := (Finset.range R).filter fun t => q ∣ a + p * t
  let Q := q / q.gcd p
  have hQ : 0 < Q := Nat.div_pos (Nat.gcd_le_left p hq)
    (Nat.gcd_pos_of_pos_left p hq)
  have hinj : Set.InjOn (fun t : ℕ => t / Q) (S : Set ℕ) := by
    intro x hx y hy hdiv
    have hxData : x < R ∧ q ∣ a + p * x := by
      simpa [S] using hx
    have hyData : y < R ∧ q ∣ a + p * y := by
      simpa [S] using hy
    have hxmod : a + p * x ≡ 0 [MOD q] :=
      Nat.modEq_zero_iff_dvd.mpr hxData.2
    have hymod : a + p * y ≡ 0 [MOD q] :=
      Nat.modEq_zero_iff_dvd.mpr hyData.2
    have hadd : a + p * x ≡ a + p * y [MOD q] := hxmod.trans hymod.symm
    have hmul : p * x ≡ p * y [MOD q] :=
      (Nat.ModEq.refl a).add_left_cancel hadd
    have hxy : x ≡ y [MOD Q] := by
      simpa [Q, Nat.gcd_comm] using
        (Nat.ModEq.cancel_left_div_gcd hq hmul)
    have hrem : x % Q = y % Q := hxy
    change x / Q = y / Q at hdiv
    calc
      x = x % Q + Q * (x / Q) := (Nat.mod_add_div x Q).symm
      _ = y % Q + Q * (y / Q) := by rw [hrem, hdiv]
      _ = y := Nat.mod_add_div y Q
  have himage : Finset.image (fun t : ℕ => t / Q) S ⊆
      Finset.range (R / Q + 1) := by
    intro z hz
    obtain ⟨t, htS, rfl⟩ := Finset.mem_image.mp hz
    have htR : t < R := by
      have := (Finset.mem_filter.mp htS).1
      exact Finset.mem_range.mp this
    apply Finset.mem_range.mpr
    exact Nat.lt_succ_of_le (Nat.div_le_div_right (Nat.le_of_lt htR))
  have hcardImage : (Finset.image (fun t : ℕ => t / Q) S).card = S.card :=
    Finset.card_image_iff.mpr hinj
  rw [← hcardImage]
  simpa [Q] using Finset.card_le_card himage

/-- A union of finitely many linear divisibility conditions is bounded by the
sum of the individual residue-class bounds. -/
theorem card_biUnion_filter_dvd_add_mul_le
    (I : Finset ℕ) (a p : ℕ) (q : ℕ → ℕ) (R : ℕ)
    (hq : ∀ i ∈ I, 0 < q i) :
    (I.biUnion fun i =>
      (Finset.range R).filter fun t => q i ∣ a + p * t).card ≤
      ∑ i ∈ I, (R / (q i / (q i).gcd p) + 1) := by
  calc
    (I.biUnion fun i =>
      (Finset.range R).filter fun t => q i ∣ a + p * t).card ≤
        ∑ i ∈ I,
          ((Finset.range R).filter fun t => q i ∣ a + p * t).card :=
      Finset.card_biUnion_le
    _ ≤ ∑ i ∈ I, (R / (q i / (q i).gcd p) + 1) := by
      apply Finset.sum_le_sum
      intro i hi
      exact card_filter_dvd_add_mul_le a p (q i) R (hq i hi)

end Research

/-!
# Finite union-bound sieve for progression candidates
-/

namespace Research

/-- Gcd-sensitive union bound with a separate affine offset for each bad
condition. -/
theorem card_biUnion_filter_varying_dvd_add_mul_le
    {ι : Type*} (I : Finset ι) (a q : ι → ℕ) (p R : ℕ)
    (hq : ∀ i ∈ I, 0 < q i) :
    (I.biUnion fun i =>
      (Finset.range R).filter fun t => q i ∣ a i + p * t).card ≤
      ∑ i ∈ I, (R / (q i / (q i).gcd p) + 1) := by
  classical
  calc
    (I.biUnion fun i =>
      (Finset.range R).filter fun t => q i ∣ a i + p * t).card ≤
        ∑ i ∈ I,
          ((Finset.range R).filter fun t => q i ∣ a i + p * t).card :=
      Finset.card_biUnion_le
    _ ≤ ∑ i ∈ I, (R / (q i / (q i).gcd p) + 1) := by
      apply Finset.sum_le_sum
      intro i hi
      exact card_filter_dvd_add_mul_le (a i) p (q i) R (hq i hi)

/-- If the sum of the individual congruence-count bounds is below the number of
candidates, some progression parameter avoids every divisibility condition. -/
theorem exists_avoiding_linear_divisibility
    {ι : Type*} (I : Finset ι) (a q : ι → ℕ) (p R : ℕ)
    (hq : ∀ i ∈ I, 0 < q i)
    (hbudget :
      (∑ i ∈ I, (R / (q i / (q i).gcd p) + 1)) < R) :
    ∃ t < R, ∀ i ∈ I, ¬ q i ∣ a i + p * t := by
  classical
  let bad : Finset ℕ := I.biUnion fun i =>
    (Finset.range R).filter fun t => q i ∣ a i + p * t
  have hbad : bad.card < R :=
    (card_biUnion_filter_varying_dvd_add_mul_le I a q p R hq).trans_lt hbudget
  have hnsubset : ¬ Finset.range R ⊆ bad := by
    intro hsub
    have hc : R ≤ bad.card := by
      simpa using Finset.card_le_card hsub
    exact (not_le_of_gt hbad) hc
  obtain ⟨t, htR, htbad⟩ := Finset.not_subset.mp hnsubset
  refine ⟨t, Finset.mem_range.mp htR, ?_⟩
  intro i hi hdiv
  apply htbad
  apply Finset.mem_biUnion.mpr
  refine ⟨i, hi, ?_⟩
  exact Finset.mem_filter.mpr ⟨htR, hdiv⟩

end Research

/-!
# Instantiating the progression sieve on two coefficient windows
-/

namespace Research

/-- Finite positions strictly after `K` but before a cutoff `H`. -/
def laterPositionRange (K H : ℕ) : Finset ℕ :=
  (Finset.range H).filter fun j => K < j

/-- The finite family indexing a later position, a window offset, and one of
the two shifted windows. -/
def twoWindowConditions (K H W : ℕ) : Finset ((ℕ × ℕ) × Bool) :=
  ((laterPositionRange K H).product (Finset.range W)).product Finset.univ

/-- A finite condition's affine offset: the right-hand window receives the
additional shift `X`. -/
def twoWindowOffset (A X : ℕ) (u : (ℕ × ℕ) × Bool) : ℕ :=
  A + u.1.2 + if u.2 then X else 0

/-- The modulus attached to a two-window condition. -/
def twoWindowModulus (n : ℕ → ℕ) (u : (ℕ × ℕ) × Bool) : ℕ :=
  n u.1.1

/-- Exact finite union-bound budget for the two-window sieve. -/
def twoWindowSieveBudget
    (n : ℕ → ℕ) (K H W p R : ℕ) : ℕ :=
  ∑ u ∈ twoWindowConditions K H W,
    (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1)

/-- If the exact F-034 budget is below `R` and the cutoff index lies beyond all
candidate windows, one candidate progression parameter avoids divisibility by
every selected index strictly after the target `K`, in both windows and at
every offset. -/
theorem exists_two_windows_avoiding_all_later_indices
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H W A X p R : ℕ) (hA : 0 < A) (_hKH : K < H)
    (hbudget : twoWindowSieveBudget n K H W p R < R)
    (hcut : A + p * R + X + W < n H) :
    ∃ t < R, ∀ j, K < j → ∀ s < W,
      (¬ n j ∣ A + p * t + s) ∧
      (¬ n j ∣ A + p * t + s + X) := by
  classical
  let I := twoWindowConditions K H W
  let a := twoWindowOffset A X
  let q := twoWindowModulus n
  have hq : ∀ u ∈ I, 0 < q u := by
    intro u hu
    exact hpos u.1.1
  have hbudget' :
      (∑ u ∈ I, (R / (q u / (q u).gcd p) + 1)) < R := by
    simpa [I, a, q, twoWindowSieveBudget] using hbudget
  obtain ⟨t, htR, hav⟩ :=
    exists_avoiding_linear_divisibility I a q p R hq hbudget'
  refine ⟨t, htR, ?_⟩
  intro j hKj s hsW
  by_cases hjH : j < H
  · have hjI : j ∈ laterPositionRange K H := by
      simp [laterPositionRange, hjH, hKj]
    have hsI : s ∈ Finset.range W := Finset.mem_range.mpr hsW
    have hleft := hav ((j, s), false) (by
      simp [I, twoWindowConditions, hjI, hsI])
    have hright := hav ((j, s), true) (by
      simp [I, twoWindowConditions, hjI, hsI])
    dsimp [a, q, twoWindowOffset, twoWindowModulus] at hleft hright
    constructor
    · simpa [add_assoc, add_comm, add_left_comm] using hleft
    · simpa [add_assoc, add_comm, add_left_comm] using hright
  · have hHj : H ≤ j := by omega
    have hnHj : n H ≤ n j := hmono.monotone hHj
    have hleftPos : 0 < A + p * t + s := by omega
    have hrightPos : 0 < A + p * t + s + X := by omega
    have hpt : p * t ≤ p * R :=
      Nat.mul_le_mul_left p (Nat.le_of_lt htR)
    have hleftLt : A + p * t + s < n H := by
      omega
    have hrightLt : A + p * t + s + X < n H := by
      omega
    constructor
    · intro hdvd
      have hle := Nat.le_of_dvd hleftPos hdvd
      omega
    · intro hdvd
      have hle := Nat.le_of_dvd hrightPos hdvd
      omega

end Research

/-!
# From a two-window sieve to a full sandwiched coefficient mismatch
-/

namespace Research

/-- The target component's isolated residue pattern and the exact two-window
sieve budget produce a genuine sandwiched mismatch in the full collected
coefficient word. -/
theorem exists_sandwiched_mismatch_of_twoWindowSieve
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H L J A X R : ℕ) (hA : 0 < A) (hKH : K < H)
    (hperiod : ∀ k < K, 4 * n k ∣ X)
    (htargetPre : ∀ s < L,
      fibLambertCoeff (n K) (A + s + X) =
        fibLambertCoeff (n K) (A + s))
    (htarget : fibLambertCoeff (n K) (A + L + X) ≠
      fibLambertCoeff (n K) (A + L))
    (htargetPost : ∀ s < J,
      fibLambertCoeff (n K) (A + L + 1 + s + X) =
        fibLambertCoeff (n K) (A + L + 1 + s))
    (hbudget :
      twoWindowSieveBudget n K H (L + 1 + J) (4 * n K) R < R)
    (hcut : A + (4 * n K) * R + X + (L + 1 + J) < n H) :
    ∃ t < R,
      let N := A + (4 * n K) * t
      (∀ s < L,
        selectedFibLambertCoeff n (N + s + X) =
          selectedFibLambertCoeff n (N + s)) ∧
      selectedFibLambertCoeff n (N + L + X) ≠
        selectedFibLambertCoeff n (N + L) ∧
      (∀ s < J,
        selectedFibLambertCoeff n (N + L + 1 + s + X) =
          selectedFibLambertCoeff n (N + L + 1 + s)) := by
  obtain ⟨t, htR, hav⟩ :=
    exists_two_windows_avoiding_all_later_indices n hpos hmono
      K H (L + 1 + J) A X (4 * n K) R hA hKH hbudget hcut
  let N := A + (4 * n K) * t
  have htransport (u : ℕ) :
      fibLambertCoeff (n K) (N + u) = fibLambertCoeff (n K) (A + u) := by
    have hp := fibLambertCoeff_add_period_mul (n K) (A + u) t
    simpa [N, add_assoc, add_comm, add_left_comm, mul_comm] using hp
  have htransportX (u : ℕ) :
      fibLambertCoeff (n K) (N + u + X) =
        fibLambertCoeff (n K) (A + u + X) := by
    have hp := fibLambertCoeff_add_period_mul (n K) (A + u + X) t
    simpa [N, add_assoc, add_comm, add_left_comm, mul_comm] using hp
  have hprefix (k : ℕ) (hk : k < K) (u : ℕ) :
      fibLambertCoeff (n k) (N + u + X) =
        fibLambertCoeff (n k) (N + u) := by
    obtain ⟨v, hv⟩ := hperiod k hk
    subst X
    simpa [mul_comm] using
      fibLambertCoeff_add_period_mul (n k) (N + u) v
  have hlaterZero (k : ℕ) (hk : K < k) (u : ℕ)
      (hu : u < L + 1 + J) :
      fibLambertCoeff (n k) (N + u + X) = 0 ∧
        fibLambertCoeff (n k) (N + u) = 0 := by
    have ha := hav k hk u hu
    constructor
    · exact fibLambertCoeff_eq_zero_of_not_dvd _ _ ha.2
    · exact fibLambertCoeff_eq_zero_of_not_dvd _ _ ha.1
  refine ⟨t, htR, ?_, ?_, ?_⟩
  · intro s hs
    apply selectedFibLambertCoeff_eq_of_all_components_eq n hpos hmono
    intro k
    by_cases hk₁ : k < K
    · exact hprefix k hk₁ s
    · by_cases hk₂ : k = K
      · subst k
        rw [htransportX s, htransport s]
        exact htargetPre s hs
      · have hKk : K < k := by omega
        have hz := hlaterZero k hKk s (by omega)
        rw [hz.1, hz.2]
  · apply selectedFibLambertCoeff_ne_of_one_component_ne n hpos hmono
    · rw [htransportX L, htransport L]
      exact htarget
    · intro k hkK
      by_cases hk : k < K
      · exact hprefix k hk L
      · have hKk : K < k := by omega
        have hz := hlaterZero k hKk L (by omega)
        rw [hz.1, hz.2]
  · intro s hs
    let u := L + 1 + s
    have hcore : selectedFibLambertCoeff n (N + u + X) =
        selectedFibLambertCoeff n (N + u) := by
      apply selectedFibLambertCoeff_eq_of_all_components_eq n hpos hmono
      intro k
      by_cases hk₁ : k < K
      · exact hprefix k hk₁ u
      · by_cases hk₂ : k = K
        · subst k
          rw [htransportX u, htransport u]
          simpa [u, add_assoc] using htargetPost s hs
        · have hKk : K < k := by omega
          have hz := hlaterZero k hKk u (by dsimp [u]; omega)
          rw [hz.1, hz.2]
    simpa [N, u, add_assoc] using hcore

end Research

/-!
# Simplifying the exact two-window sieve budget
-/

namespace Research

/-- The progression count can equivalently be written with the gcd in the
numerator. -/
theorem div_div_gcd_eq_mul_div (R q p : ℕ) (hq : 0 < q) :
    R / (q / q.gcd p) = (R * q.gcd p) / q := by
  have hg : 0 < q.gcd p := Nat.gcd_pos_of_pos_left p hq
  have hfactor : q / q.gcd p * q.gcd p = q :=
    Nat.div_mul_cancel (Nat.gcd_dvd_left q p)
  symm
  calc
    (R * q.gcd p) / q =
        (R * q.gcd p) / (q / q.gcd p * q.gcd p) := by rw [hfactor]
    _ = R / (q / q.gcd p) :=
      Nat.mul_div_mul_right (m := q.gcd p) R (q / q.gcd p) hg

/-- The exact budget is simply `2W` times the sum of the one-modulus bounds,
because the same bound occurs at every offset on both sides. -/
theorem twoWindowSieveBudget_eq
    (n : ℕ → ℕ) (K H W p R : ℕ) :
    twoWindowSieveBudget n K H W p R =
      2 * W *
        ∑ j ∈ laterPositionRange K H,
          (R / (n j / (n j).gcd p) + 1) := by
  simp [twoWindowSieveBudget, twoWindowConditions, twoWindowModulus,
    Finset.sum_product]
  rw [Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro j hj
  ring

/-- Gcd-numerator form of the exact two-window budget. -/
theorem twoWindowSieveBudget_eq_gcdNumerator
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K H W p R : ℕ) :
    twoWindowSieveBudget n K H W p R =
      2 * W *
        ∑ j ∈ laterPositionRange K H,
          ((R * (n j).gcd p) / n j + 1) := by
  rw [twoWindowSieveBudget_eq]
  apply congrArg (fun z : ℕ => 2 * W * z)
  apply Finset.sum_congr rfl
  intro j hj
  rw [div_div_gcd_eq_mul_div R (n j) p (hpos j)]

end Research

/-!
# Isolating one target coefficient by a shift residue
-/

namespace Research

/-- Nonzero support of an individual contribution lies in the single residue
class `n` modulo `2n`, for both parity cases. -/
theorem mod_two_mul_eq_of_fibLambertCoeff_ne_zero
    (n m : ℕ) (hn : 0 < n) (h : fibLambertCoeff n m ≠ 0) :
    m % (2 * n) = n := by
  unfold fibLambertCoeff at h
  split_ifs at h with he h₂ h₄ h₄' <;> try contradiction
  · exact h₂
  · have hd : 2 * n ∣ 4 * n := ⟨2, by ring⟩
    have hm := Nat.mod_mod_of_dvd m hd
    rw [h₄, Nat.mod_eq_of_lt (by omega : n < 2 * n)] at hm
    exact hm.symm
  · have hd : 2 * n ∣ 4 * n := ⟨2, by ring⟩
    have hm := Nat.mod_mod_of_dvd m hd
    rw [h₄'] at hm
    have h3 : 3 * n % (2 * n) = n := by
      rw [show 3 * n = 2 * n + n by ring]
      simp [Nat.mod_eq_of_lt (by omega : n < 2 * n)]
    rw [h3] at hm
    exact hm.symm

/-- A residue different from `n` modulo `2n` certifies zero contribution. -/
theorem fibLambertCoeff_eq_zero_of_mod_two_mul_ne
    (n m : ℕ) (hn : 0 < n) (hmod : m % (2 * n) ≠ n) :
    fibLambertCoeff n m = 0 := by
  by_contra hne
  exact hmod (mod_two_mul_eq_of_fibLambertCoeff_ne_zero n m hn hne)

/-- The target contribution at its basic support exponent is `+1`. -/
theorem fibLambertCoeff_self (n : ℕ) (hn : 0 < n) :
    fibLambertCoeff n n = 1 := by
  unfold fibLambertCoeff
  by_cases he : Even n
  · rw [if_pos he, if_pos]
    exact Nat.mod_eq_of_lt (by omega)
  · rw [if_neg he, if_pos]
    exact Nat.mod_eq_of_lt (by omega)

/-- Reduction of a shifted exponent to a small representative, with the only
two possible lifts of the target residue excluded. -/
private theorem add_shift_mod_two_mul_ne
    (n m X r : ℕ) (hn : 0 < n) (hm : m < 2 * n)
    (hr : r = X % (2 * n))
    (hne₁ : m + r ≠ n) (hne₃ : m + r ≠ 3 * n) :
    (m + X) % (2 * n) ≠ n := by
  have hreduce : (m + X) % (2 * n) = (m + r) % (2 * n) := by
    rw [Nat.add_mod, Nat.mod_eq_of_lt hm, ← hr]
  rw [hreduce]
  by_cases hsmall : m + r < 2 * n
  · rw [Nat.mod_eq_of_lt hsmall]
    exact hne₁
  · rw [Nat.mod_eq_sub_mod (by omega)]
    have hlt : m + r - 2 * n < 2 * n := by
      have hrlt : r < 2 * n := by
        rw [hr]
        exact Nat.mod_lt X (by omega)
      omega
    rw [Nat.mod_eq_of_lt hlt]
    intro heq
    apply hne₃
    omega

/-- If the shift residue `r=X mod 2n` lies beyond the `L` positions to the
left and the `J` positions to the right, the target component has exactly one
mismatch, at exponent `n`, between two equal zero blocks. -/
theorem target_component_sandwiched_pattern
    (n L J X r : ℕ) (hn : 0 < n) (hL : L < n) (hJ : J < n)
    (hr : r = X % (2 * n)) (hrLeft : L < r)
    (hrRight : r + J < 2 * n) :
    let A := n - L
    (∀ s < L,
      fibLambertCoeff n (A + s + X) = fibLambertCoeff n (A + s)) ∧
    fibLambertCoeff n (A + L + X) ≠ fibLambertCoeff n (A + L) ∧
    (∀ s < J,
      fibLambertCoeff n (A + L + 1 + s + X) =
        fibLambertCoeff n (A + L + 1 + s)) := by
  let A := n - L
  have hA : A + L = n := by dsimp [A]; omega
  refine ⟨?_, ?_, ?_⟩
  · intro s hs
    have hm : A + s < 2 * n := by dsimp [A]; omega
    have hbase : (A + s) % (2 * n) ≠ n := by
      rw [Nat.mod_eq_of_lt hm]
      dsimp [A]
      omega
    have hshift : (A + s + X) % (2 * n) ≠ n := by
      apply add_shift_mod_two_mul_ne n (A + s) X r hn hm hr
      · dsimp [A]
        omega
      · have hrlt : r < 2 * n := by rw [hr]; exact Nat.mod_lt X (by omega)
        dsimp [A]
        omega
    rw [fibLambertCoeff_eq_zero_of_mod_two_mul_ne n _ hn hshift,
      fibLambertCoeff_eq_zero_of_mod_two_mul_ne n _ hn hbase]
  · rw [hA, fibLambertCoeff_self n hn]
    have hm : n < 2 * n := by omega
    have hshift : (n + X) % (2 * n) ≠ n := by
      apply add_shift_mod_two_mul_ne n n X r hn hm hr
      · omega
      · have hrlt : r < 2 * n := by rw [hr]; exact Nat.mod_lt X (by omega)
        omega
    rw [fibLambertCoeff_eq_zero_of_mod_two_mul_ne n _ hn hshift]
    norm_num
  · intro s hs
    have hm : A + L + 1 + s < 2 * n := by rw [hA]; omega
    have hbase : (A + L + 1 + s) % (2 * n) ≠ n := by
      rw [Nat.mod_eq_of_lt hm, hA]
      omega
    have hshift : (A + L + 1 + s + X) % (2 * n) ≠ n := by
      apply add_shift_mod_two_mul_ne n (A + L + 1 + s) X r hn hm hr
      · rw [hA]
        omega
      · rw [hA]
        omega
    rw [fibLambertCoeff_eq_zero_of_mod_two_mul_ne n _ hn hshift,
      fibLambertCoeff_eq_zero_of_mod_two_mul_ne n _ hn hbase]

end Research

/-!
# Selecting a middle residue from a nontrivial cyclic subgroup
-/

namespace Research

/-- If `d` does not divide `P`, some multiple of `P` has residue between the
one-third and two-thirds marks modulo `d`. -/
theorem exists_mul_mod_between_thirds
    (P d : ℕ) (hd : 0 < d) (hndvd : ¬ d ∣ P) :
    ∃ u r : ℕ,
      r = (P * u) % d ∧ 3 * r ≥ d ∧ 3 * r ≤ 2 * d := by
  let g := d.gcd P
  let q := d / g
  let P' := P / g
  have hg : 0 < g := Nat.gcd_pos_of_pos_left P hd
  have hgD : g ∣ d := Nat.gcd_dvd_left d P
  have hgP : g ∣ P := Nat.gcd_dvd_right d P
  have hdFactor : g * q = d := by
    dsimp [q]
    exact Nat.mul_div_cancel' hgD
  have hPFactor : g * P' = P := by
    dsimp [P']
    exact Nat.mul_div_cancel' hgP
  have hqpos : 0 < q := by
    dsimp [q]
    exact Nat.div_pos (Nat.gcd_le_left P hd) hg
  have hq : 2 ≤ q := by
    by_contra hnot
    have hq1 : q = 1 := by omega
    have hgd : g = d := by
      rw [hq1, mul_one] at hdFactor
      exact hdFactor
    apply hndvd
    rw [← hgd]
    exact hgP
  have hcop : P'.Coprime q := by
    have hc := Nat.coprime_div_gcd_div_gcd (m := d) (n := P) hg
    exact hc.symm
  let k := q / 2
  have hklt : k < q := by
    dsimp [k]
    omega
  obtain ⟨u, huq, hu⟩ :=
    Nat.exists_mul_mod_eq_of_coprime k hcop (Nat.ne_of_gt hqpos)
  have hkmod : k % q = k := Nat.mod_eq_of_lt hklt
  rw [hkmod] at hu
  let r := g * k
  refine ⟨u, r, ?_, ?_, ?_⟩
  · dsimp [r]
    rw [← hPFactor, ← hdFactor, mul_assoc, Nat.mul_mod_mul_left, hu]
  · dsimp [r, k]
    nlinarith [show q ≤ 3 * (q / 2) by omega]
  · dsimp [r, k]
    nlinarith [show 3 * (q / 2) ≤ 2 * q by omega]

/-- For windows shorter than one third of `2n`, a multiplier of any prefix
period not divisible by `2n` gives the separated residue required by F-038. -/
theorem exists_multiplier_for_target_isolation
    (P n L J : ℕ) (hn : 0 < n) (hndvd : ¬ 2 * n ∣ P)
    (hL : 3 * L < 2 * n) (hJ : 3 * J < 2 * n) :
    ∃ u r : ℕ,
      r = (P * u) % (2 * n) ∧ L < r ∧ r + J < 2 * n := by
  obtain ⟨u, r, hr, hrLower, hrUpper⟩ :=
    exists_mul_mod_between_thirds P (2 * n) (by omega) hndvd
  refine ⟨u, r, hr, ?_, ?_⟩
  · nlinarith
  · nlinarith

end Research

/-!
# Complete conditional irrationality theorem from explicit sieve certificates
-/

namespace Research

open Real goldenRatio

/-- All finite arithmetic certificates (prefix periods, target pattern, exact
sieve budget, cutoff, and uniform norm inequalities) compose to contradict a
hypothetical rational value of the reciprocal-Fibonacci sum. -/
theorem sieved_sandwiched_mismatch_rationality_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (K H L J A X R : ℕ) (hA : 0 < A) (hKH : K < H)
    (hperiod : ∀ k < K, 4 * n k ∣ X)
    (htargetPre : ∀ s < L,
      fibLambertCoeff (n K) (A + s + X) =
        fibLambertCoeff (n K) (A + s))
    (htarget : fibLambertCoeff (n K) (A + L + X) ≠
      fibLambertCoeff (n K) (A + L))
    (htargetPost : ∀ s < J,
      fibLambertCoeff (n K) (A + L + 1 + s + X) =
        fibLambertCoeff (n K) (A + L + 1 + s))
    (hbudget :
      twoWindowSieveBudget n K H (L + 1 + J) (4 * n K) R < R)
    (hcut : A + (4 * n K) * R + X + (L + 1 + J) < n H)
    (hsmallPost : ∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (N + X + L + 1 + J)) < 1)
    (hsmallPre : ∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (N + X + L)) *
        (indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) N +
          indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) (N + X)) <
      (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  obtain ⟨t, htR, hpre, hmis, hpost⟩ :=
    exists_sandwiched_mismatch_of_twoWindowSieve n hpos hmono
      K H L J A X R hA hKH hperiod htargetPre htarget htargetPost
      hbudget hcut
  apply selected_sandwiched_mismatch_obstruction
    n hpos hmono a b hb hrat
      (A + (4 * n K) * t) (A + (4 * n K) * t + X) L J
  · intro s hs
    simpa [add_assoc, add_comm, add_left_comm] using (hpre s hs).symm
  · simpa [add_assoc, add_comm, add_left_comm] using (ne_comm.mp hmis)
  · intro s hs
    simpa [add_assoc, add_comm, add_left_comm] using (hpost s hs).symm
  · simpa [add_assoc, add_comm, add_left_comm] using hsmallPost t htR
  · simpa [add_assoc, add_comm, add_left_comm] using hsmallPre t htR

end Research

/-!
# Removing insoluble congruences from the two-window sieve
-/

namespace Research

/-- Solvability of `q ∣ a + pt` forces the standard gcd compatibility. -/
theorem gcd_dvd_offset_of_dvd_add_mul
    (a p q t : ℕ) (h : q ∣ a + p * t) :
    q.gcd p ∣ a := by
  have hsum : q.gcd p ∣ a + p * t :=
    dvd_trans (Nat.gcd_dvd_left q p) h
  have hpt : q.gcd p ∣ p * t :=
    dvd_mul_of_dvd_left (Nat.gcd_dvd_right q p) t
  exact (Nat.dvd_add_iff_left hpt).mpr hsum

/-- Sieve only the congruence conditions that are actually soluble. -/
theorem exists_avoiding_linear_divisibility_compatible
    {ι : Type*} (I : Finset ι) (a q : ι → ℕ) (p R : ℕ)
    (hq : ∀ i ∈ I, 0 < q i)
    (hbudget :
      (∑ i ∈ I.filter (fun i => (q i).gcd p ∣ a i),
        (R / (q i / (q i).gcd p) + 1)) < R) :
    ∃ t < R, ∀ i ∈ I, ¬ q i ∣ a i + p * t := by
  classical
  let I' := I.filter fun i => (q i).gcd p ∣ a i
  have hq' : ∀ i ∈ I', 0 < q i := by
    intro i hi
    exact hq i (Finset.mem_filter.mp hi).1
  have hbudget' :
      (∑ i ∈ I', (R / (q i / (q i).gcd p) + 1)) < R := by
    simpa [I'] using hbudget
  obtain ⟨t, ht, hav⟩ :=
    exists_avoiding_linear_divisibility I' a q p R hq' hbudget'
  refine ⟨t, ht, ?_⟩
  intro i hi
  by_cases hcompat : (q i).gcd p ∣ a i
  · exact hav i (by simp [I', hi, hcompat])
  · intro hdvd
    exact hcompat (gcd_dvd_offset_of_dvd_add_mul (a i) p (q i) t hdvd)

/-- Soluble conditions among the finite two-window family. -/
def compatibleTwoWindowConditions
    (n : ℕ → ℕ) (K H W A X p : ℕ) : Finset ((ℕ × ℕ) × Bool) :=
  (twoWindowConditions K H W).filter fun u =>
    (twoWindowModulus n u).gcd p ∣ twoWindowOffset A X u

/-- Exact two-window budget after deleting every insoluble congruence. -/
def compatibleTwoWindowSieveBudget
    (n : ℕ → ℕ) (K H W A X p R : ℕ) : ℕ :=
  ∑ u ∈ compatibleTwoWindowConditions n K H W A X p,
    (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1)

/-- The compatible budget is never larger than F-035's unfiltered budget. -/
theorem compatibleTwoWindowSieveBudget_le
    (n : ℕ → ℕ) (K H W A X p R : ℕ) :
    compatibleTwoWindowSieveBudget n K H W A X p R ≤
      twoWindowSieveBudget n K H W p R := by
  unfold compatibleTwoWindowSieveBudget compatibleTwoWindowConditions
  unfold twoWindowSieveBudget
  exact Finset.sum_le_sum_of_subset (Finset.filter_subset _ _)

/-- Improved two-window sieve using only gcd-compatible conditions. -/
theorem exists_two_windows_avoiding_all_later_indices_compatible
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H W A X p R : ℕ) (hA : 0 < A) (_hKH : K < H)
    (hbudget : compatibleTwoWindowSieveBudget n K H W A X p R < R)
    (hcut : A + p * R + X + W < n H) :
    ∃ t < R, ∀ j, K < j → ∀ s < W,
      (¬ n j ∣ A + p * t + s) ∧
      (¬ n j ∣ A + p * t + s + X) := by
  classical
  let I := twoWindowConditions K H W
  let a := twoWindowOffset A X
  let q := twoWindowModulus n
  have hq : ∀ u ∈ I, 0 < q u := by
    intro u hu
    exact hpos u.1.1
  have hbudget' :
      (∑ u ∈ I.filter (fun u => (q u).gcd p ∣ a u),
        (R / (q u / (q u).gcd p) + 1)) < R := by
    simpa [I, a, q, compatibleTwoWindowSieveBudget,
      compatibleTwoWindowConditions] using hbudget
  obtain ⟨t, htR, hav⟩ :=
    exists_avoiding_linear_divisibility_compatible I a q p R hq hbudget'
  refine ⟨t, htR, ?_⟩
  intro j hKj s hsW
  by_cases hjH : j < H
  · have hjI : j ∈ laterPositionRange K H := by
      simp [laterPositionRange, hjH, hKj]
    have hsI : s ∈ Finset.range W := Finset.mem_range.mpr hsW
    have hleft := hav ((j, s), false) (by
      simp [I, twoWindowConditions, hjI, hsI])
    have hright := hav ((j, s), true) (by
      simp [I, twoWindowConditions, hjI, hsI])
    dsimp [a, q, twoWindowOffset, twoWindowModulus] at hleft hright
    constructor
    · simpa [add_assoc, add_comm, add_left_comm] using hleft
    · simpa [add_assoc, add_comm, add_left_comm] using hright
  · have hHj : H ≤ j := by omega
    have hnHj : n H ≤ n j := hmono.monotone hHj
    have hleftPos : 0 < A + p * t + s := by omega
    have hrightPos : 0 < A + p * t + s + X := by omega
    have hpt : p * t ≤ p * R :=
      Nat.mul_le_mul_left p (Nat.le_of_lt htR)
    have hleftLt : A + p * t + s < n H := by omega
    have hrightLt : A + p * t + s + X < n H := by omega
    constructor
    · intro hdvd
      have hle := Nat.le_of_dvd hleftPos hdvd
      omega
    · intro hdvd
      have hle := Nat.le_of_dvd hrightPos hdvd
      omega

end Research

/-!
# Minimal parity-sensitive periods of individual coefficient patterns
-/

namespace Research

/-- A parity-sensitive period: `2n` for even indices and `4n` for odd ones. -/
def fibLambertPeriod (n : ℕ) : ℕ :=
  if Even n then 2 * n else 4 * n

/-- Shifting by the parity-sensitive period fixes one contribution. -/
theorem fibLambertCoeff_add_period (n m : ℕ) :
    fibLambertCoeff n (m + fibLambertPeriod n) = fibLambertCoeff n m := by
  by_cases he : Even n
  · simp [fibLambertPeriod, fibLambertCoeff, he]
  · simpa [fibLambertPeriod, he] using fibLambertCoeff_add_four_mul n m

/-- Any multiple of the parity-sensitive period fixes one contribution. -/
theorem fibLambertCoeff_add_period_mul_minimal (n m t : ℕ) :
    fibLambertCoeff n (m + t * fibLambertPeriod n) =
      fibLambertCoeff n m := by
  induction t with
  | zero => simp
  | succ t ih =>
      rw [show m + (t + 1) * fibLambertPeriod n =
        (m + t * fibLambertPeriod n) + fibLambertPeriod n by ring,
        fibLambertCoeff_add_period, ih]

/-- Common multiples of all parity-sensitive prefix periods fix every prefix
component. -/
theorem prefix_component_eq_of_minimal_period
    (n : ℕ → ℕ) (K X : ℕ)
    (hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ X)
    {a : ℕ} (k : ℕ) (hk : k < K) :
    fibLambertCoeff (n k) (a + X) = fibLambertCoeff (n k) a := by
  obtain ⟨t, ht⟩ := hperiod k hk
  subst X
  simpa [mul_comm] using
    fibLambertCoeff_add_period_mul_minimal (n k) a t

end Research

/-!
# Minimal-period sieve to a full sandwiched coefficient mismatch
-/

namespace Research

/-- The target component's isolated residue pattern and the exact two-window
sieve budget produce a genuine sandwiched mismatch in the full collected
coefficient word. -/
theorem exists_sandwiched_mismatch_of_minimalPeriod_twoWindowSieve
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H L J A X R : ℕ) (hA : 0 < A) (hKH : K < H)
    (hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ X)
    (htargetPre : ∀ s < L,
      fibLambertCoeff (n K) (A + s + X) =
        fibLambertCoeff (n K) (A + s))
    (htarget : fibLambertCoeff (n K) (A + L + X) ≠
      fibLambertCoeff (n K) (A + L))
    (htargetPost : ∀ s < J,
      fibLambertCoeff (n K) (A + L + 1 + s + X) =
        fibLambertCoeff (n K) (A + L + 1 + s))
    (hbudget :
      twoWindowSieveBudget n K H (L + 1 + J) (4 * n K) R < R)
    (hcut : A + (4 * n K) * R + X + (L + 1 + J) < n H) :
    ∃ t < R,
      let N := A + (4 * n K) * t
      (∀ s < L,
        selectedFibLambertCoeff n (N + s + X) =
          selectedFibLambertCoeff n (N + s)) ∧
      selectedFibLambertCoeff n (N + L + X) ≠
        selectedFibLambertCoeff n (N + L) ∧
      (∀ s < J,
        selectedFibLambertCoeff n (N + L + 1 + s + X) =
          selectedFibLambertCoeff n (N + L + 1 + s)) := by
  obtain ⟨t, htR, hav⟩ :=
    exists_two_windows_avoiding_all_later_indices n hpos hmono
      K H (L + 1 + J) A X (4 * n K) R hA hKH hbudget hcut
  let N := A + (4 * n K) * t
  have htransport (u : ℕ) :
      fibLambertCoeff (n K) (N + u) = fibLambertCoeff (n K) (A + u) := by
    have hp := fibLambertCoeff_add_period_mul (n K) (A + u) t
    simpa [N, add_assoc, add_comm, add_left_comm, mul_comm] using hp
  have htransportX (u : ℕ) :
      fibLambertCoeff (n K) (N + u + X) =
        fibLambertCoeff (n K) (A + u + X) := by
    have hp := fibLambertCoeff_add_period_mul (n K) (A + u + X) t
    simpa [N, add_assoc, add_comm, add_left_comm, mul_comm] using hp
  have hprefix (k : ℕ) (hk : k < K) (u : ℕ) :
      fibLambertCoeff (n k) (N + u + X) =
        fibLambertCoeff (n k) (N + u) := by
    exact prefix_component_eq_of_minimal_period n K X hperiod k hk
  have hlaterZero (k : ℕ) (hk : K < k) (u : ℕ)
      (hu : u < L + 1 + J) :
      fibLambertCoeff (n k) (N + u + X) = 0 ∧
        fibLambertCoeff (n k) (N + u) = 0 := by
    have ha := hav k hk u hu
    constructor
    · exact fibLambertCoeff_eq_zero_of_not_dvd _ _ ha.2
    · exact fibLambertCoeff_eq_zero_of_not_dvd _ _ ha.1
  refine ⟨t, htR, ?_, ?_, ?_⟩
  · intro s hs
    apply selectedFibLambertCoeff_eq_of_all_components_eq n hpos hmono
    intro k
    by_cases hk₁ : k < K
    · exact hprefix k hk₁ s
    · by_cases hk₂ : k = K
      · subst k
        rw [htransportX s, htransport s]
        exact htargetPre s hs
      · have hKk : K < k := by omega
        have hz := hlaterZero k hKk s (by omega)
        rw [hz.1, hz.2]
  · apply selectedFibLambertCoeff_ne_of_one_component_ne n hpos hmono
    · rw [htransportX L, htransport L]
      exact htarget
    · intro k hkK
      by_cases hk : k < K
      · exact hprefix k hk L
      · have hKk : K < k := by omega
        have hz := hlaterZero k hKk L (by omega)
        rw [hz.1, hz.2]
  · intro s hs
    let u := L + 1 + s
    have hcore : selectedFibLambertCoeff n (N + u + X) =
        selectedFibLambertCoeff n (N + u) := by
      apply selectedFibLambertCoeff_eq_of_all_components_eq n hpos hmono
      intro k
      by_cases hk₁ : k < K
      · exact hprefix k hk₁ u
      · by_cases hk₂ : k = K
        · subst k
          rw [htransportX u, htransport u]
          simpa [u, add_assoc] using htargetPost s hs
        · have hKk : K < k := by omega
          have hz := hlaterZero k hKk u (by dsimp [u]; omega)
          rw [hz.1, hz.2]
    simpa [N, u, add_assoc] using hcore

end Research

/-!
# Deterministic half-period mismatches at period-absorbing targets
-/

namespace Research

/-- A minimal-period prefix, one target pattern, and direct divisibility
avoidance suffice for a full sandwiched mismatch; no progression sieve is
needed. -/
theorem sandwiched_mismatch_of_minimalPeriod_and_avoidance
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K L J A X : ℕ)
    (hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ X)
    (htargetPre : ∀ s < L,
      fibLambertCoeff (n K) (A + s + X) =
        fibLambertCoeff (n K) (A + s))
    (htarget : fibLambertCoeff (n K) (A + L + X) ≠
      fibLambertCoeff (n K) (A + L))
    (htargetPost : ∀ s < J,
      fibLambertCoeff (n K) (A + L + 1 + s + X) =
        fibLambertCoeff (n K) (A + L + 1 + s))
    (havoid : ∀ k, K < k → ∀ u < L + 1 + J,
      (¬ n k ∣ A + u) ∧ (¬ n k ∣ A + u + X)) :
    (∀ s < L,
      selectedFibLambertCoeff n (A + s + X) =
        selectedFibLambertCoeff n (A + s)) ∧
    selectedFibLambertCoeff n (A + L + X) ≠
      selectedFibLambertCoeff n (A + L) ∧
    (∀ s < J,
      selectedFibLambertCoeff n (A + L + 1 + s + X) =
        selectedFibLambertCoeff n (A + L + 1 + s)) := by
  have hprefix (k : ℕ) (hk : k < K) (u : ℕ) :
      fibLambertCoeff (n k) (A + u + X) =
        fibLambertCoeff (n k) (A + u) := by
    exact prefix_component_eq_of_minimal_period n K X hperiod k hk
  have hlaterZero (k : ℕ) (hk : K < k) (u : ℕ)
      (hu : u < L + 1 + J) :
      fibLambertCoeff (n k) (A + u + X) = 0 ∧
        fibLambertCoeff (n k) (A + u) = 0 := by
    have ha := havoid k hk u hu
    constructor
    · exact fibLambertCoeff_eq_zero_of_not_dvd _ _ ha.2
    · exact fibLambertCoeff_eq_zero_of_not_dvd _ _ ha.1
  refine ⟨?_, ?_, ?_⟩
  · intro s hs
    apply selectedFibLambertCoeff_eq_of_all_components_eq n hpos hmono
    intro k
    by_cases hk₁ : k < K
    · exact hprefix k hk₁ s
    · by_cases hk₂ : k = K
      · subst k
        exact htargetPre s hs
      · have hKk : K < k := by omega
        have hz := hlaterZero k hKk s (by omega)
        rw [hz.1, hz.2]
  · apply selectedFibLambertCoeff_ne_of_one_component_ne n hpos hmono htarget
    intro k hkK
    by_cases hk : k < K
    · exact hprefix k hk L
    · have hKk : K < k := by omega
      have hz := hlaterZero k hKk L (by omega)
      rw [hz.1, hz.2]
  · intro s hs
    let u := L + 1 + s
    have hcore : selectedFibLambertCoeff n (A + u + X) =
        selectedFibLambertCoeff n (A + u) := by
      apply selectedFibLambertCoeff_eq_of_all_components_eq n hpos hmono
      intro k
      by_cases hk₁ : k < K
      · exact hprefix k hk₁ u
      · by_cases hk₂ : k = K
        · subst k
          simpa [u, add_assoc] using htargetPost s hs
        · have hKk : K < k := by omega
          have hz := hlaterZero k hKk u (by dsimp [u]; omega)
          rw [hz.1, hz.2]
    simpa [u, add_assoc] using hcore

/-- Around the two centers `n_K` and `2n_K`, every strictly later selected
index is automatically absent as a divisor if the next selected index lies
past the short unshifted window and no selected index itself lies in the
shifted window.  A proper divisor of a positive integer is at most half of it. -/
theorem later_avoids_periodAbsorbing_windows
    (n : ℕ → ℕ) (_hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K L J : ℕ) (hL : L < n K)
    (hnext : n K + J < n (K + 1))
    (hnoTerm : ∀ k, K < k → ∀ u < L + 1 + J,
      n k ≠ (n K - L + u) + n K) :
    ∀ k, K < k → ∀ u < L + 1 + J,
      (¬ n k ∣ n K - L + u) ∧
      (¬ n k ∣ n K - L + u + n K) := by
  intro k hKk u hu
  have hK1k : K + 1 ≤ k := by omega
  have hnnext : n (K + 1) ≤ n k := hmono.monotone hK1k
  have huBound : u ≤ L + J := by omega
  have hbasePos : 0 < n K - L + u := by omega
  have hbaseLt : n K - L + u < n (K + 1) := by omega
  constructor
  · intro hdvd
    have hle := Nat.le_of_dvd hbasePos hdvd
    omega
  · intro hdvd
    let m := n K - L + u + n K
    have hmPos : 0 < m := by dsimp [m]; omega
    have hnkm : n k ≤ m := Nat.le_of_dvd hmPos hdvd
    have hne : n k ≠ m := by
      exact hnoTerm k hKk u hu
    obtain ⟨q, hq⟩ := hdvd
    have hqTwo : 2 ≤ q := by
      by_contra hnot
      have hqle : q ≤ 1 := by omega
      interval_cases q
      · simp_all
      · subst m
        simp_all
    have htwonk : 2 * n k ≤ m := by
      subst m
      nlinarith
    have hmUpper : m ≤ 2 * n K + J := by
      dsimp [m]
      omega
    have htwoNext : 2 * n (K + 1) ≤ 2 * n k := by omega
    omega

/-- If a target absorbs every sharp prefix period and there is a short gap
around its double, then shifting by exactly `n_K` creates a full isolated
coefficient mismatch. -/
theorem periodAbsorbing_sandwiched_mismatch
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K L J : ℕ) (hL : L < n K) (hJ : J < n K)
    (hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ n K)
    (hnext : n K + J < n (K + 1))
    (hnoTerm : ∀ k, K < k → ∀ u < L + 1 + J,
      n k ≠ (n K - L + u) + n K) :
    let A := n K - L
    (∀ s < L,
      selectedFibLambertCoeff n (A + s + n K) =
        selectedFibLambertCoeff n (A + s)) ∧
    selectedFibLambertCoeff n (A + L + n K) ≠
      selectedFibLambertCoeff n (A + L) ∧
    (∀ s < J,
      selectedFibLambertCoeff n (A + L + 1 + s + n K) =
        selectedFibLambertCoeff n (A + L + 1 + s)) := by
  let A := n K - L
  have hn : 0 < n K := hpos K
  have hr : n K = n K % (2 * n K) := by
    rw [Nat.mod_eq_of_lt (by omega)]
  have ht := target_component_sandwiched_pattern
    (n K) L J (n K) (n K) hn hL hJ hr hL (by omega)
  dsimp only at ht
  exact sandwiched_mismatch_of_minimalPeriod_and_avoidance
    n hpos hmono K L J A (n K) hperiod ht.1 ht.2.1 ht.2.2
    (later_avoids_periodAbsorbing_windows
      n hpos hmono K L J hL hnext hnoTerm)

/-- Complete rationality contradiction for a period-absorbing target with
a short selected-index gap around its double. -/
theorem periodAbsorbing_rationality_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (K L J : ℕ) (hL : L < n K) (hJ : J < n K)
    (hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ n K)
    (hnext : n K + J < n (K + 1))
    (hnoTerm : ∀ k, K < k → ∀ u < L + 1 + J,
      n k ≠ (n K - L + u) + n K)
    (hsmallPost :
      (Real.goldenRatio⁻¹) ^ (J + 1) *
        (indexCountTailBound n (n K + 1 + J) +
          indexCountTailBound n (2 * n K + 1 + J)) < 1)
    (hsmallPre :
      (Real.goldenRatio⁻¹) ^ L *
          (indexCountTailBound n (n K) +
            indexCountTailBound n (2 * n K)) *
        (indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) (n K - L) +
          indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ))))
              (n K - L + n K)) <
      (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  let A := n K - L
  have hpat := periodAbsorbing_sandwiched_mismatch
    n hpos hmono K L J hL hJ hperiod hnext hnoTerm
  dsimp only at hpat
  have hbase : A + L = n K := by dsimp [A]; omega
  have hshift : A + n K + L = 2 * n K := by dsimp [A]; omega
  have hbasePost : A + L + 1 + J = n K + 1 + J := by omega
  have hshiftPost : A + n K + L + 1 + J = 2 * n K + 1 + J := by omega
  apply selected_sandwiched_mismatch_obstruction
    n hpos hmono a b hb hrat (A + n K) A L J
  · intro t ht
    simpa [add_assoc, add_comm, add_left_comm] using hpat.1 t ht
  · simpa [add_assoc, add_comm, add_left_comm] using hpat.2.1
  · intro t ht
    simpa [add_assoc, add_comm, add_left_comm] using hpat.2.2 t ht
  · rw [hshiftPost, hbasePost]
    simpa [add_comm] using hsmallPost
  · rw [hshift, hbase]
    simpa [add_comm] using hsmallPre

end Research

/-!
# Isolating targets whose sharp period is new
-/

namespace Research

/-- For an odd index, translation by `2n` negates its signed coefficient
pattern. -/
theorem fibLambertCoeff_add_two_mul_of_odd
    (n m : ℕ) (hnodd : ¬ Even n) :
    fibLambertCoeff n (m + 2 * n) = -fibLambertCoeff n m := by
  have hn : 0 < n := by
    by_contra hz
    have : n = 0 := Nat.eq_zero_of_not_pos hz
    subst n
    exact hnodd (by simp)
  have hmod : (m + 2 * n) % (4 * n) =
      (m % (4 * n) + 2 * n) % (4 * n) := by
    rw [Nat.add_mod]
    simp
  unfold fibLambertCoeff
  rw [if_neg hnodd, if_neg hnodd, hmod]
  have hm : m % (4 * n) < 4 * n := Nat.mod_lt _ (by omega)
  by_cases h₁ : m % (4 * n) = n
  · have hcalc : (n + 2 * n) % (4 * n) = 3 * n := by
      rw [show n + 2 * n = 3 * n by ring,
        Nat.mod_eq_of_lt (by omega)]
    have hne : 3 * n ≠ n := by omega
    rw [h₁, hcalc]
    simp [hne]
  · by_cases h₃ : m % (4 * n) = 3 * n
    · have hnlt : n < 4 * n := by nlinarith
      have hcalc : (3 * n + 2 * n) % (4 * n) = n := by
        rw [show 3 * n + 2 * n = 4 * n + n by ring,
          Nat.add_mod_left, Nat.mod_eq_of_lt hnlt]
      have hne : 3 * n ≠ n := by omega
      rw [h₃, hcalc]
      simp [hne]
    · have hshift₁ : (m % (4 * n) + 2 * n) % (4 * n) ≠ n := by
        intro heq
        by_cases hsmall : m % (4 * n) + 2 * n < 4 * n
        · rw [Nat.mod_eq_of_lt hsmall] at heq
          omega
        · rw [Nat.mod_eq_sub_mod (by omega)] at heq
          have hlt : m % (4 * n) + 2 * n - 4 * n < 4 * n := by omega
          rw [Nat.mod_eq_of_lt hlt] at heq
          omega
      have hshift₃ : (m % (4 * n) + 2 * n) % (4 * n) ≠ 3 * n := by
        intro heq
        by_cases hsmall : m % (4 * n) + 2 * n < 4 * n
        · rw [Nat.mod_eq_of_lt hsmall] at heq
          omega
        · rw [Nat.mod_eq_sub_mod (by omega)] at heq
          have hlt : m % (4 * n) + 2 * n - 4 * n < 4 * n := by omega
          rw [Nat.mod_eq_of_lt hlt] at heq
          omega
      have hshift₁' : (m + 2 * n) % (4 * n) ≠ n := by
        rw [hmod]
        exact hshift₁
      have hshift₃' : (m + 2 * n) % (4 * n) ≠ 3 * n := by
        rw [hmod]
        exact hshift₃
      simp [h₁, h₃, hshift₁', hshift₃']

/-- If an odd target is shifted by the nontrivial half of its sharp
`4n` period, it has an isolated sign-changing mismatch, while the neighboring
coefficients remain zero. -/
theorem odd_target_halfPeriod_sandwiched_pattern
    (n L J X : ℕ) (hn : 0 < n) (hnodd : ¬ Even n)
    (hL : L < n) (hJ : J < n)
    (hhalf : X % (4 * n) = 2 * n) :
    let A := n - L
    (∀ s < L,
      fibLambertCoeff n (A + s + X) = fibLambertCoeff n (A + s)) ∧
    fibLambertCoeff n (A + L + X) ≠ fibLambertCoeff n (A + L) ∧
    (∀ s < J,
      fibLambertCoeff n (A + L + 1 + s + X) =
        fibLambertCoeff n (A + L + 1 + s)) := by
  let A := n - L
  have hfour : 0 < 4 * n := by omega
  have hdecomp : 2 * n + 4 * n * (X / (4 * n)) = X := by
    rw [← hhalf]
    exact Nat.mod_add_div X (4 * n)
  have hneg (m : ℕ) : fibLambertCoeff n (m + X) = -fibLambertCoeff n m := by
    have hper := fibLambertCoeff_add_period_mul
      n (m + 2 * n) (X / (4 * n))
    rw [fibLambertCoeff_add_two_mul_of_odd n m hnodd] at hper
    have hx : m + X = m + (2 * n + 4 * n * (X / (4 * n))) :=
      congrArg (fun z => m + z) hdecomp.symm
    calc
      fibLambertCoeff n (m + X) =
          fibLambertCoeff n (m + (2 * n + 4 * n * (X / (4 * n)))) := by
            rw [hx]
      _ = fibLambertCoeff n
          ((m + 2 * n) + (X / (4 * n)) * (4 * n)) := by
            congr 1
            ring
      _ = -fibLambertCoeff n m := hper
  have hAL : A + L = n := by dsimp [A]; omega
  refine ⟨?_, ?_, ?_⟩
  · intro s hs
    have hm : A + s < 2 * n := by dsimp [A]; omega
    have hmod : (A + s) % (2 * n) ≠ n := by
      rw [Nat.mod_eq_of_lt hm]
      dsimp [A]
      omega
    have hz := fibLambertCoeff_eq_zero_of_mod_two_mul_ne n (A + s) hn hmod
    rw [hneg, hz, neg_zero]
  · rw [hAL, fibLambertCoeff_self n hn, hneg,
      fibLambertCoeff_self n hn]
    norm_num
  · intro s hs
    have hm : A + L + 1 + s < 2 * n := by rw [hAL]; omega
    have hmod : (A + L + 1 + s) % (2 * n) ≠ n := by
      rw [Nat.mod_eq_of_lt hm, hAL]
      omega
    have hz := fibLambertCoeff_eq_zero_of_mod_two_mul_ne
      n (A + L + 1 + s) hn hmod
    rw [hneg, hz, neg_zero]

/-- Every genuinely new sharp component period yields a prefix-period multiple
with an isolated target mismatch.  For even targets, and for odd targets whose
support period `2n` is new, use F-039.  The only remaining case is an odd target
with old `2n` but new `4n`; the prefix period itself is then exactly the
sign-changing half-period modulo `4n`. -/
theorem exists_sharpPeriod_target_sandwiched_pattern
    (P n L J : ℕ) (hn : 0 < n)
    (hnew : ¬ fibLambertPeriod n ∣ P)
    (hL : 3 * L < 2 * n) (hJ : 3 * J < 2 * n) :
    ∃ X : ℕ, P ∣ X ∧
      let A := n - L
      (∀ s < L,
        fibLambertCoeff n (A + s + X) = fibLambertCoeff n (A + s)) ∧
      fibLambertCoeff n (A + L + X) ≠ fibLambertCoeff n (A + L) ∧
      (∀ s < J,
        fibLambertCoeff n (A + L + 1 + s + X) =
          fibLambertCoeff n (A + L + 1 + s)) := by
  by_cases he : Even n
  · have hnewTwo : ¬ 2 * n ∣ P := by
      simpa [fibLambertPeriod, he] using hnew
    obtain ⟨u, r, hr, hrL, hrJ⟩ :=
      exists_multiplier_for_target_isolation P n L J hn hnewTwo hL hJ
    let X := P * u
    refine ⟨X, ⟨u, rfl⟩, ?_⟩
    have hLn : L < n := by nlinarith
    have hJn : J < n := by nlinarith
    exact target_component_sandwiched_pattern
      n L J X r hn hLn hJn hr hrL hrJ
  · by_cases hnewTwo : ¬ 2 * n ∣ P
    · obtain ⟨u, r, hr, hrL, hrJ⟩ :=
        exists_multiplier_for_target_isolation P n L J hn hnewTwo hL hJ
      let X := P * u
      refine ⟨X, ⟨u, rfl⟩, ?_⟩
      have hLn : L < n := by nlinarith
      have hJn : J < n := by nlinarith
      exact target_component_sandwiched_pattern
        n L J X r hn hLn hJn hr hrL hrJ
    · have htwo : 2 * n ∣ P := not_not.mp hnewTwo
      have hnewFour : ¬ 4 * n ∣ P := by
        simpa [fibLambertPeriod, he] using hnew
      obtain ⟨q, hP⟩ := htwo
      have hqmod : q % 2 = 1 := by
        rcases Nat.mod_two_eq_zero_or_one q with hq | hq
        · exfalso
          apply hnewFour
          rw [Nat.dvd_iff_mod_eq_zero, hP,
            show 4 * n = (2 * n) * 2 by ring,
            Nat.mul_mod_mul_left, hq]
          simp
        · exact hq
      have hhalf : P % (4 * n) = 2 * n := by
        rw [hP, show 4 * n = (2 * n) * 2 by ring,
          Nat.mul_mod_mul_left, hqmod]
        simp
      refine ⟨P, dvd_rfl, ?_⟩
      exact odd_target_halfPeriod_sandwiched_pattern
        n L J P hn he (by nlinarith) (by nlinarith) hhalf

end Research

/-!
# Infinitely many genuinely new sharp periods
-/

namespace Research

/-- Lcm of all sharp component periods before position `K`. -/
def sharpPrefixPeriod (n : ℕ → ℕ) : ℕ → ℕ
  | 0 => 1
  | K + 1 => Nat.lcm (sharpPrefixPeriod n K) (fibLambertPeriod (n K))

/-- Every earlier sharp period divides the prefix lcm. -/
theorem fibLambertPeriod_dvd_sharpPrefixPeriod
    (n : ℕ → ℕ) {k K : ℕ} (hk : k < K) :
    fibLambertPeriod (n k) ∣ sharpPrefixPeriod n K := by
  induction K with
  | zero => omega
  | succ K ih =>
      simp only [sharpPrefixPeriod]
      by_cases h : k = K
      · subst k
        exact Nat.dvd_lcm_right _ _
      · exact dvd_trans (ih (by omega)) (Nat.dvd_lcm_left _ _)

/-- Prefix sharp periods are positive for a positive index sequence. -/
theorem sharpPrefixPeriod_pos
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) :
    ∀ K, 0 < sharpPrefixPeriod n K := by
  intro K
  induction K with
  | zero => simp [sharpPrefixPeriod]
  | succ K ih =>
      simp only [sharpPrefixPeriod]
      apply Nat.lcm_pos ih
      unfold fibLambertPeriod
      split <;> nlinarith [hpos K]

/-- If every sharp period after a cut already divides the preceding prefix
lcm, then that lcm is constant from the cut onward. -/
theorem sharpPrefixPeriod_eventually_constant_of_absorbed
    (n : ℕ → ℕ) (B : ℕ)
    (habsorb : ∀ K, B < K →
      fibLambertPeriod (n K) ∣ sharpPrefixPeriod n K) :
    ∀ t, sharpPrefixPeriod n (B + 1 + t) =
      sharpPrefixPeriod n (B + 1) := by
  intro t
  induction t with
  | zero => simp
  | succ t ih =>
      rw [show B + 1 + (t + 1) = (B + 1 + t) + 1 by omega,
        sharpPrefixPeriod,
        Nat.lcm_eq_left (habsorb (B + 1 + t) (by omega))]
      exact ih

/-- Because a positive strict index sequence is unbounded whereas an eventually
absorbed prefix lcm would be constant, genuinely new sharp periods occur beyond
every position. -/
theorem exists_new_sharpPeriod_after
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (B : ℕ) :
    ∃ K, B < K ∧
      ¬ fibLambertPeriod (n K) ∣ sharpPrefixPeriod n K := by
  by_contra hnone
  push Not at hnone
  have hconst := sharpPrefixPeriod_eventually_constant_of_absorbed n B hnone
  let P := sharpPrefixPeriod n (B + 1)
  let K := B + 1 + (P + 1)
  have hBK : B < K := by dsimp [K]; omega
  have habs : fibLambertPeriod (n K) ∣ sharpPrefixPeriod n K := hnone K hBK
  have hPK : sharpPrefixPeriod n K = P := by
    dsimp [K, P]
    exact hconst (P + 1)
  have hPpos : 0 < P := sharpPrefixPeriod_pos n hpos (B + 1)
  have hperiodLe : fibLambertPeriod (n K) ≤ P := by
    rw [← hPK]
    exact Nat.le_of_dvd (sharpPrefixPeriod_pos n hpos K) habs
  have hKn : K ≤ n K := hmono.le_apply
  have hPKidx : P < K := by dsimp [K]; omega
  have hnP : P < n K := lt_of_lt_of_le hPKidx hKn
  have htwo : 2 * n K ≤ fibLambertPeriod (n K) := by
    unfold fibLambertPeriod
    split <;> omega
  omega

end Research

/-!
# Complete irrationality gate with sharp periods and compatible conditions
-/

namespace Research

open Real goldenRatio

/-- F-040 with both later improvements: sharp parity-sensitive prefix periods
and deletion of every gcd-incompatible sieve condition. -/
theorem compatible_sandwiched_mismatch_rationality_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (K H L J A X R : ℕ) (hA : 0 < A) (hKH : K < H)
    (hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ X)
    (htargetPre : ∀ s < L,
      fibLambertCoeff (n K) (A + s + X) =
        fibLambertCoeff (n K) (A + s))
    (htarget : fibLambertCoeff (n K) (A + L + X) ≠
      fibLambertCoeff (n K) (A + L))
    (htargetPost : ∀ s < J,
      fibLambertCoeff (n K) (A + L + 1 + s + X) =
        fibLambertCoeff (n K) (A + L + 1 + s))
    (hbudget : compatibleTwoWindowSieveBudget n K H (L + 1 + J)
      A X (4 * n K) R < R)
    (hcut : A + (4 * n K) * R + X + (L + 1 + J) < n H)
    (hsmallPost : ∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (N + X + L + 1 + J)) < 1)
    (hsmallPre : ∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (N + X + L)) *
        (indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) N +
          indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) (N + X)) <
      (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  obtain ⟨t, htR, hav⟩ :=
    exists_two_windows_avoiding_all_later_indices_compatible
      n hpos hmono K H (L + 1 + J) A X (4 * n K) R
      hA hKH hbudget hcut
  let N := A + (4 * n K) * t
  have htransport (u : ℕ) :
      fibLambertCoeff (n K) (N + u) = fibLambertCoeff (n K) (A + u) := by
    have hp := fibLambertCoeff_add_period_mul (n K) (A + u) t
    simpa [N, add_assoc, add_comm, add_left_comm, mul_comm] using hp
  have htransportX (u : ℕ) :
      fibLambertCoeff (n K) (N + u + X) =
        fibLambertCoeff (n K) (A + u + X) := by
    have hp := fibLambertCoeff_add_period_mul (n K) (A + u + X) t
    simpa [N, add_assoc, add_comm, add_left_comm, mul_comm] using hp
  have htargetPreN : ∀ s < L,
      fibLambertCoeff (n K) (N + s + X) =
        fibLambertCoeff (n K) (N + s) := by
    intro s hs
    rw [htransportX, htransport]
    exact htargetPre s hs
  have htargetN : fibLambertCoeff (n K) (N + L + X) ≠
      fibLambertCoeff (n K) (N + L) := by
    rw [htransportX, htransport]
    exact htarget
  have htargetPostN : ∀ s < J,
      fibLambertCoeff (n K) (N + L + 1 + s + X) =
        fibLambertCoeff (n K) (N + L + 1 + s) := by
    intro s hs
    have hx := htransportX (L + 1 + s)
    have hxbase := htransport (L + 1 + s)
    calc
      fibLambertCoeff (n K) (N + L + 1 + s + X) =
          fibLambertCoeff (n K) (A + L + 1 + s + X) := by
            simpa [add_assoc] using hx
      _ = fibLambertCoeff (n K) (A + L + 1 + s) :=
        htargetPost s hs
      _ = fibLambertCoeff (n K) (N + L + 1 + s) := by
        simpa [add_assoc] using hxbase.symm
  have hpat := sandwiched_mismatch_of_minimalPeriod_and_avoidance
    n hpos hmono K L J N X hperiod htargetPreN htargetN htargetPostN hav
  apply selected_sandwiched_mismatch_obstruction
    n hpos hmono a b hb hrat N (N + X) L J
  · intro s hs
    simpa [add_assoc, add_comm, add_left_comm] using (hpat.1 s hs).symm
  · simpa [add_assoc, add_comm, add_left_comm] using (ne_comm.mp hpat.2.1)
  · intro s hs
    simpa [add_assoc, add_comm, add_left_comm] using (hpat.2.2 s hs).symm
  · simpa [N, add_assoc, add_comm, add_left_comm] using hsmallPost t htR
  · simpa [N, add_assoc, add_comm, add_left_comm] using hsmallPre t htR

end Research

/-!
# Geometry of gcd-compatible window offsets
-/

namespace Research

/-- A common divisor of two naturals divides their natural distance. -/
theorem dvd_natDist_of_dvd
    (d x y : ℕ) (hx : d ∣ x) (hy : d ∣ y) :
    d ∣ x.dist y := by
  rcases le_total x y with hxy | hyx
  · rw [Nat.dist_eq_sub_of_le hxy]
    exact Nat.dvd_sub hy hx
  · rw [Nat.dist_eq_sub_of_le_right hyx]
    exact Nat.dvd_sub hx hy

/-- General offset-geometry lemma.  Suppose `g=gcd(q,p)` is compatible at an
offset `s`, while a distinguished offset `s₀` becomes a multiple of `p` after
scaling by `z`.  Away from `s₀`, compatibility forces
`g ≤ z·dist(s,s₀)`. -/
theorem gcd_le_scaled_offset_distance
    (q p z A X s s₀ : ℕ) (_hq : 0 < q) (hz : 0 < z)
    (hcompat : q.gcd p ∣ A + s + X)
    (hspecial : p ∣ z * (A + s₀ + X)) :
    s = s₀ ∨ q.gcd p ≤ z * s.dist s₀ := by
  by_cases heq : s = s₀
  · exact Or.inl heq
  · right
    have hgCurrent : q.gcd p ∣ z * (A + s + X) :=
      dvd_mul_of_dvd_right hcompat z
    have hgSpecial : q.gcd p ∣ z * (A + s₀ + X) :=
      dvd_trans (Nat.gcd_dvd_right q p) hspecial
    have hd := dvd_natDist_of_dvd (q.gcd p)
      (z * (A + s + X)) (z * (A + s₀ + X)) hgCurrent hgSpecial
    have hdist :
        (z * (A + s + X)).dist (z * (A + s₀ + X)) =
          z * s.dist s₀ := by
      rw [Nat.dist_mul_left]
      congr 1
      rw [show A + s + X = (A + X) + s by omega,
        show A + s₀ + X = (A + X) + s₀ by omega,
        Nat.dist_add_add_left]
    rw [hdist] at hd
    exact Nat.le_of_dvd (mul_pos hz (Nat.dist_pos_of_ne heq)) hd

/-- In the unshifted window centered at `n`, every compatible gcd away from the
center is at most four times the offset distance. -/
theorem left_window_compatible_gcd_le
    (q n L s : ℕ) (hq : 0 < q) (hL : L ≤ n)
    (hcompat : q.gcd (4 * n) ∣ n - L + s) :
    s = L ∨ q.gcd (4 * n) ≤ 4 * s.dist L := by
  apply gcd_le_scaled_offset_distance q (4 * n) 4 (n - L) 0 s L hq
    (by norm_num) (by simpa using hcompat)
  have hcenter : n - L + L = n := by omega
  rw [hcenter]
  exact ⟨1, by ring⟩

/-- More generally, if twice a distinguished shifted-window exponent is a
multiple of `4n`, every compatible gcd away from that distinguished offset is
at most twice the offset distance. -/
theorem right_window_compatible_gcd_le
    (q n A X s s₀ : ℕ) (hq : 0 < q)
    (hcompat : q.gcd (4 * n) ∣ A + s + X)
    (hspecial : 4 * n ∣ 2 * (A + s₀ + X)) :
    s = s₀ ∨ q.gcd (4 * n) ≤ 2 * s.dist s₀ := by
  exact gcd_le_scaled_offset_distance q (4 * n) 2 A X s s₀
    hq (by norm_num) hcompat hspecial

/-- The scale-four variant always applies when the distinguished shifted
exponent itself is a multiple of `n`; this covers odd half-period sign flips. -/
theorem shifted_window_compatible_gcd_le_four
    (q n A X s s₀ : ℕ) (hq : 0 < q)
    (hcompat : q.gcd (4 * n) ∣ A + s + X)
    (hspecial : n ∣ A + s₀ + X) :
    s = s₀ ∨ q.gcd (4 * n) ≤ 4 * s.dist s₀ := by
  apply gcd_le_scaled_offset_distance q (4 * n) 4 A X s s₀ hq
    (by norm_num) hcompat
  obtain ⟨v, hv⟩ := hspecial
  rw [hv]
  exact ⟨v, by ring⟩

end Research

/-!
# Coherent reduced-modulus conditions at distinguished offsets
-/

namespace Research

/-- Cancel a common gcd factor and then a coprime cofactor. -/
theorem mul_mul_dvd_mul_mul_iff_right
    (g Q u x : ℕ) (hg : 0 < g) (hcop : Q.Coprime u) :
    g * Q ∣ g * (u * x) ↔ Q ∣ x := by
  rw [Nat.mul_dvd_mul_iff_left hg]
  exact hcop.dvd_mul_left

/-- At the unshifted center, after writing the later modulus as `gQ` and the
target as `gu`, all dependence on `g` disappears: the bad condition is exactly
`Q ∣ 4t+1`. -/
theorem left_center_divisibility_iff_reduced
    (q n g Q u t : ℕ) (hg : 0 < g)
    (hq : q = g * Q) (hn : n = g * u) (hcop : Q.Coprime u) :
    q ∣ n + (4 * n) * t ↔ Q ∣ 4 * t + 1 := by
  subst q
  subst n
  rw [show g * u + 4 * (g * u) * t = g * (u * (4 * t + 1)) by ring,
    mul_mul_dvd_mul_mul_iff_right g Q u (4 * t + 1) hg hcop]

/-- At a shifted distinguished exponent of the form `g u (v+1+2t)`, the bad
condition is exactly the second linear form `Q ∣ v+1+2t`. -/
theorem right_center_divisibility_iff_reduced
    (q g Q u v t : ℕ) (hg : 0 < g)
    (hq : q = g * Q) (hcop : Q.Coprime u) :
    q ∣ g * u * (v + 1 + 2 * t) ↔ Q ∣ v + 1 + 2 * t := by
  subst q
  rw [show g * u * (v + 1 + 2 * t) =
    g * (u * (v + 1 + 2 * t)) by ring,
    mul_mul_dvd_mul_mul_iff_right g Q u (v + 1 + 2 * t) hg hcop]

/-- Repeated later moduli with the same reduced quotient impose exactly the
same left-center residue class, regardless of their gcd factors. -/
theorem left_center_conditions_coincide
    (q₁ q₂ n g₁ g₂ Q u₁ u₂ t : ℕ)
    (hg₁ : 0 < g₁) (hg₂ : 0 < g₂)
    (hq₁ : q₁ = g₁ * Q) (hq₂ : q₂ = g₂ * Q)
    (hn₁ : n = g₁ * u₁) (hn₂ : n = g₂ * u₂)
    (hc₁ : Q.Coprime u₁) (hc₂ : Q.Coprime u₂) :
    q₁ ∣ n + (4 * n) * t ↔ q₂ ∣ n + (4 * n) * t := by
  rw [left_center_divisibility_iff_reduced q₁ n g₁ Q u₁ t
      hg₁ hq₁ hn₁ hc₁,
    left_center_divisibility_iff_reduced q₂ n g₂ Q u₂ t
      hg₂ hq₂ hn₂ hc₂]

/-- Repeated moduli with the same reduced quotient likewise impose the same
right-center class when their aligned exponents have the displayed factors. -/
theorem right_center_conditions_coincide
    (q₁ q₂ g₁ g₂ Q u₁ u₂ v t : ℕ)
    (hg₁ : 0 < g₁) (hg₂ : 0 < g₂)
    (hq₁ : q₁ = g₁ * Q) (hq₂ : q₂ = g₂ * Q)
    (hc₁ : Q.Coprime u₁) (hc₂ : Q.Coprime u₂) :
    (q₁ ∣ g₁ * u₁ * (v + 1 + 2 * t)) ↔
      q₂ ∣ g₂ * u₂ * (v + 1 + 2 * t) := by
  rw [right_center_divisibility_iff_reduced q₁ g₁ Q u₁ v t
      hg₁ hq₁ hc₁,
    right_center_divisibility_iff_reduced q₂ g₂ Q u₂ v t
      hg₂ hq₂ hc₂]

end Research

/-!
# Reciprocal-index tail bounds from a ratio gap
-/

namespace Research

/-- The geometric-growth estimate starting at an arbitrary selected position. -/
theorem ratio_gap_geometric_growth_from
    (n : ℕ → ℕ) (c : ℝ) (hc : 0 ≤ c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K r : ℕ) :
    c ^ r * (n K : ℝ) ≤ n (K + r) := by
  induction r with
  | zero => simp
  | succ r ih =>
      calc
        c ^ (r + 1) * (n K : ℝ) = c * (c ^ r * (n K : ℝ)) := by
          rw [pow_succ]
          ring
        _ ≤ c * (n (K + r) : ℝ) := by gcongr
        _ ≤ n (K + r + 1) := by
          simpa [add_assoc] using hratio (K + r)

/-- A ratio gap makes the tail of reciprocal selected indices summable, with an
explicit shifted geometric majorant. -/
theorem summable_inv_indices_from
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K : ℕ) :
    Summable (fun r : ℕ => ((n (K + 1 + r) : ℝ)⁻¹)) := by
  let ρ : ℝ := c⁻¹
  have hcpos : 0 < c := lt_trans (by norm_num) hc
  have hρpos : 0 < ρ := inv_pos.mpr hcpos
  have hρlt : ρ < 1 := by
    dsimp [ρ]
    exact (inv_lt_one₀ hcpos).2 hc
  have hρnorm : ‖ρ‖ < 1 := by simpa [Real.norm_eq_abs, abs_of_pos hρpos]
  have hgeom : Summable (fun r : ℕ => ρ ^ r) :=
    summable_geometric_of_norm_lt_one hρnorm
  have hmajor : Summable
      (fun r : ℕ => ρ ^ (r + 1) * (n K : ℝ)⁻¹) := by
    have h := (hgeom.mul_left ρ).mul_right (n K : ℝ)⁻¹
    simpa [pow_succ, mul_assoc, mul_comm, mul_left_comm] using h
  apply hmajor.of_nonneg_of_le
  · intro r
    positivity
  · intro r
    have hgrowth := ratio_gap_geometric_growth_from n c hcpos.le hratio K (r + 1)
    have hdenpos : 0 < c ^ (r + 1) * (n K : ℝ) :=
      mul_pos (pow_pos (lt_trans (by norm_num) hc) _) (by exact_mod_cast hpos K)
    have hinv : ((n (K + (r + 1)) : ℝ)⁻¹) ≤
        (c ^ (r + 1) * (n K : ℝ))⁻¹ :=
      inv_anti₀ hdenpos hgrowth
    calc
      (n (K + 1 + r) : ℝ)⁻¹ = (n (K + (r + 1)) : ℝ)⁻¹ := by
        rw [show K + 1 + r = K + (r + 1) by omega]
      _ ≤ (c ^ (r + 1) * (n K : ℝ))⁻¹ := hinv
      _ = ρ ^ (r + 1) * (n K : ℝ)⁻¹ := by
        simp [ρ, mul_inv_rev, inv_pow, mul_comm]

/-- Explicit reciprocal-index tail bound. -/
theorem tsum_inv_indices_from_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K : ℕ) :
    (∑' r : ℕ, ((n (K + 1 + r) : ℝ)⁻¹)) ≤
      c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹ := by
  let ρ : ℝ := c⁻¹
  have hcpos : 0 < c := lt_trans (by norm_num) hc
  have hρpos : 0 < ρ := inv_pos.mpr hcpos
  have hρlt : ρ < 1 := by
    dsimp [ρ]
    exact (inv_lt_one₀ hcpos).2 hc
  have hρnorm : ‖ρ‖ < 1 := by simpa [Real.norm_eq_abs, abs_of_pos hρpos]
  have hgeom : Summable (fun r : ℕ => ρ ^ r) :=
    summable_geometric_of_norm_lt_one hρnorm
  have hmajor : Summable
      (fun r : ℕ => ρ ^ (r + 1) * (n K : ℝ)⁻¹) := by
    have h := (hgeom.mul_left ρ).mul_right (n K : ℝ)⁻¹
    simpa [pow_succ, mul_assoc, mul_comm, mul_left_comm] using h
  have hterm (r : ℕ) : (n (K + 1 + r) : ℝ)⁻¹ ≤
      ρ ^ (r + 1) * (n K : ℝ)⁻¹ := by
    have hgrowth := ratio_gap_geometric_growth_from n c hcpos.le hratio K (r + 1)
    have hdenpos : 0 < c ^ (r + 1) * (n K : ℝ) :=
      mul_pos (pow_pos (lt_trans (by norm_num) hc) _) (by exact_mod_cast hpos K)
    calc
      (n (K + 1 + r) : ℝ)⁻¹ = (n (K + (r + 1)) : ℝ)⁻¹ := by
        rw [show K + 1 + r = K + (r + 1) by omega]
      _ ≤ (c ^ (r + 1) * (n K : ℝ))⁻¹ := inv_anti₀ hdenpos hgrowth
      _ = ρ ^ (r + 1) * (n K : ℝ)⁻¹ := by
        simp [ρ, mul_inv_rev, inv_pow, mul_comm]
  have hsum := summable_inv_indices_from n hpos c hc hratio K
  calc
    (∑' r : ℕ, (n (K + 1 + r) : ℝ)⁻¹) ≤
        ∑' r : ℕ, ρ ^ (r + 1) * (n K : ℝ)⁻¹ :=
      hsum.tsum_le_tsum hterm hmajor
    _ = ρ * (1 - ρ)⁻¹ * (n K : ℝ)⁻¹ := by
      rw [show (fun r : ℕ => ρ ^ (r + 1) * (n K : ℝ)⁻¹) =
          (fun r : ℕ => (ρ * ρ ^ r) * (n K : ℝ)⁻¹) by
            funext r
            rw [pow_succ']]
      rw [tsum_mul_right, tsum_mul_left,
        tsum_geometric_of_norm_lt_one hρnorm]
    _ = c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹ := rfl

end Research

/-!
# A two-stage sieve protecting candidates that avoid coherent center classes
-/

namespace Research

/-- Candidate parameters below `R` that avoid every condition in `C`.  Unlike
the off-center conditions, these center conditions are retained exactly rather
than union-bounded. -/
def protectedCandidates
    {ι : Type*} (C : Finset ι) (a q : ι → ℕ) (p R : ℕ) : Finset ℕ :=
  (Finset.range R).filter fun t => ∀ i ∈ C, ¬ q i ∣ a i + p * t

/-- A two-stage finite sieve.  First retain *exactly* all parameters avoiding a
possibly highly correlated center family `C`.  If the ordinary union bound for
the remaining family `O` is smaller than the number retained, one retained
parameter avoids every condition in both families. -/
theorem exists_avoiding_with_protected_centers
    {ι : Type*} (C O : Finset ι) (a q : ι → ℕ) (p R : ℕ)
    (hq : ∀ i ∈ O, 0 < q i)
    (hbudget :
      (∑ i ∈ O, (R / (q i / (q i).gcd p) + 1)) <
        (protectedCandidates C a q p R).card) :
    ∃ t < R,
      (∀ i ∈ C, ¬ q i ∣ a i + p * t) ∧
      (∀ i ∈ O, ¬ q i ∣ a i + p * t) := by
  classical
  let T := protectedCandidates C a q p R
  let badO : Finset ℕ := O.biUnion fun i =>
    (Finset.range R).filter fun t => q i ∣ a i + p * t
  have hbadO : badO.card < T.card :=
    (card_biUnion_filter_varying_dvd_add_mul_le O a q p R hq).trans_lt hbudget
  have hnsubset : ¬ T ⊆ badO := by
    intro hsub
    have hc := Finset.card_le_card hsub
    exact (not_le_of_gt hbadO) hc
  obtain ⟨t, htT, htbad⟩ := Finset.not_subset.mp hnsubset
  have htData := Finset.mem_filter.mp htT
  refine ⟨t, Finset.mem_range.mp htData.1, htData.2, ?_⟩
  intro i hi hdiv
  apply htbad
  apply Finset.mem_biUnion.mpr
  refine ⟨i, hi, ?_⟩
  exact Finset.mem_filter.mpr ⟨htData.1, hdiv⟩

/-- If the center conditions have only `D` distinct reduced classes, replacing
repeated copies by one representative leaves `protectedCandidates` unchanged.
This extensional helper makes F-048's duplicate collapse directly usable. -/
theorem protectedCandidates_congr
    {ι κ : Type*} (C : Finset ι) (D : Finset κ)
    (a : ι → ℕ) (q : ι → ℕ) (a' : κ → ℕ) (q' : κ → ℕ)
    (p R : ℕ)
    (hclasses : ∀ t < R,
      (∀ i ∈ C, ¬ q i ∣ a i + p * t) ↔
      (∀ j ∈ D, ¬ q' j ∣ a' j + p * t)) :
    protectedCandidates C a q p R =
      protectedCandidates D a' q' p R := by
  ext t
  simp only [protectedCandidates, Finset.mem_filter, Finset.mem_range]
  by_cases ht : t < R
  · simp [ht, hclasses t ht]
  · simp [ht]

end Research

/-!
# CRT avoidance of the two coherent center linear forms
-/

namespace Research

/-- With an invertible progression step modulo `q`, one affine divisibility
class occupies at most one residue among `0,…,q-1`. -/
theorem card_affine_bad_residues_le_one
    (a p q : ℕ) (_hq : 0 < q) (hcop : q.gcd p = 1) :
    ((Finset.range q).filter fun t => q ∣ a + p * t).card ≤ 1 := by
  rw [Finset.card_le_one]
  intro x hx y hy
  have hxData := Finset.mem_filter.mp hx
  have hyData := Finset.mem_filter.mp hy
  have hxmod : a + p * x ≡ 0 [MOD q] :=
    Nat.modEq_zero_iff_dvd.mpr hxData.2
  have hymod : a + p * y ≡ 0 [MOD q] :=
    Nat.modEq_zero_iff_dvd.mpr hyData.2
  have hadd : a + p * x ≡ a + p * y [MOD q] := hxmod.trans hymod.symm
  have hmul : p * x ≡ p * y [MOD q] :=
    (Nat.ModEq.refl a).add_left_cancel hadd
  have hxy : x ≡ y [MOD q] := Nat.ModEq.cancel_left_of_coprime hcop hmul
  exact hxy.eq_of_lt_of_lt (Finset.mem_range.mp hxData.1)
    (Finset.mem_range.mp hyData.1)

/-- Modulo every odd `q≥3`, some residue avoids both coherent center forms
`4t+1` and `v+1+2t`. -/
theorem exists_residue_avoiding_two_center_forms
    (q v : ℕ) (hq : 3 ≤ q) (hodd : q.gcd 2 = 1) :
    ∃ r < q, (¬ q ∣ 4 * r + 1) ∧ (¬ q ∣ v + 1 + 2 * r) := by
  classical
  let B₁ := (Finset.range q).filter fun r => q ∣ 1 + 4 * r
  let B₂ := (Finset.range q).filter fun r => q ∣ v + 1 + 2 * r
  have hcop4 : q.gcd 4 = 1 := by
    have hc2 : q.Coprime 2 := hodd
    simpa using (hc2.mul_right hc2).gcd_eq_one
  have hB₁ : B₁.card ≤ 1 := by
    dsimp [B₁]
    exact card_affine_bad_residues_le_one 1 4 q (by omega) hcop4
  have hB₂ : B₂.card ≤ 1 := by
    dsimp [B₂]
    exact card_affine_bad_residues_le_one (v + 1) 2 q (by omega) hodd
  have hUnion : (B₁ ∪ B₂).card < q := by
    calc
      (B₁ ∪ B₂).card ≤ B₁.card + B₂.card := Finset.card_union_le _ _
      _ ≤ 2 := by omega
      _ < q := by omega
  have hnsubset : ¬ Finset.range q ⊆ B₁ ∪ B₂ := by
    intro hsub
    have hc := Finset.card_le_card hsub
    simp only [Finset.card_range] at hc
    omega
  obtain ⟨r, hrange, hrbad⟩ := Finset.not_subset.mp hnsubset
  have hr₁ : ¬ q ∣ 4 * r + 1 := by
    intro hd
    apply hrbad
    apply Finset.mem_union_left B₂
    exact Finset.mem_filter.mpr ⟨hrange, by simpa [add_comm] using hd⟩
  have hr₂ : ¬ q ∣ v + 1 + 2 * r := by
    intro hd
    apply hrbad
    apply Finset.mem_union_right B₁
    exact Finset.mem_filter.mpr ⟨hrange, hd⟩
  exact ⟨r, Finset.mem_range.mp hrange, hr₁, hr₂⟩

/-- Abstract CRT assembly: safe local residues for pairwise-coprime moduli give
one integer simultaneously avoiding both center forms. -/
theorem exists_avoiding_two_center_forms_of_local
    {ι : Type*} (S : Finset ι) (m r : ι → ℕ) (v : ℕ)
    (hm : ∀ i ∈ S, m i ≠ 0)
    (hpair : Set.Pairwise S (fun i j => Nat.Coprime (m i) (m j)))
    (hsafe : ∀ i ∈ S,
      (¬ m i ∣ 4 * r i + 1) ∧ (¬ m i ∣ v + 1 + 2 * r i)) :
    ∃ t : ℕ, ∀ i ∈ S,
      (¬ m i ∣ 4 * t + 1) ∧ (¬ m i ∣ v + 1 + 2 * t) := by
  classical
  let z := Nat.chineseRemainderOfFinset r m S hm hpair
  refine ⟨z, ?_⟩
  intro i hi
  have hz : z ≡ r i [MOD m i] := z.property i hi
  have hlin₁ : 4 * z + 1 ≡ 4 * r i + 1 [MOD m i] :=
    (hz.mul_left 4).add_right 1
  have hlin₂ : v + 1 + 2 * z ≡ v + 1 + 2 * r i [MOD m i] := by
    exact (Nat.ModEq.refl (v + 1)).add (hz.mul_left 2)
  constructor
  · intro hd
    exact (hsafe i hi).1 ((hlin₁.dvd_iff dvd_rfl).mp hd)
  · intro hd
    exact (hsafe i hi).2 ((hlin₂.dvd_iff dvd_rfl).mp hd)

/-- Pairwise-coprime odd moduli at least three can never cover all parameters
with the two coherent center classes. -/
theorem exists_avoiding_two_center_forms_of_odd_coprime
    {ι : Type*} (S : Finset ι) (m : ι → ℕ) (v : ℕ)
    (hm3 : ∀ i ∈ S, 3 ≤ m i)
    (hodd : ∀ i ∈ S, (m i).gcd 2 = 1)
    (hpair : Set.Pairwise S (fun i j => Nat.Coprime (m i) (m j))) :
    ∃ t : ℕ, ∀ i ∈ S,
      (¬ m i ∣ 4 * t + 1) ∧ (¬ m i ∣ v + 1 + 2 * t) := by
  classical
  let T : Finset {i // i ∈ S} := Finset.univ
  choose r hrlt hr₁ hr₂ using fun i : {i // i ∈ S} =>
    exists_residue_avoiding_two_center_forms (m i) v
      (hm3 i i.property) (hodd i i.property)
  have hpairT : Set.Pairwise T
      (fun i j : {i // i ∈ S} => Nat.Coprime (m i) (m j)) := by
    intro i _ j _ hij
    exact hpair i.property j.property (fun h => hij (Subtype.ext h))
  obtain ⟨t, ht⟩ := exists_avoiding_two_center_forms_of_local
    T (fun i : {i // i ∈ S} => m i) r v
    (fun i _ => Nat.ne_of_gt (lt_of_lt_of_le (by norm_num) (hm3 i i.property)))
    hpairT (fun i _ => ⟨hr₁ i, hr₂ i⟩)
  refine ⟨t, ?_⟩
  intro i hi
  exact ht ⟨i, hi⟩ (by simp [T])

end Research

/-!
# Target isolation with an even quotient of the support period
-/

namespace Research

/-- If `2n` does not divide `P`, one can choose F-039's target-isolating
multiple so that its quotient by `2n` is even.  Equivalently, select a multiple
of `P` in the lower middle sixth-to-third arc modulo `4n`. -/
theorem exists_multiplier_for_target_isolation_even_quotient
    (P n L J : ℕ) (hn : 0 < n) (hndvd : ¬ 2 * n ∣ P)
    (hL : 3 * L < 2 * n) (hJ : 3 * J < 2 * n) :
    ∃ X r v : ℕ,
      P ∣ X ∧ X = r + (2 * n) * v ∧ Even v ∧
      L < r ∧ r + J < 2 * n := by
  let d := 2 * n
  let M := 2 * d
  let g := M.gcd P
  let q := M / g
  let P' := P / g
  have hd : 0 < d := by dsimp [d]; omega
  have hM : 0 < M := by dsimp [M]; omega
  have hg : 0 < g := Nat.gcd_pos_of_pos_left P hM
  have hgM : g ∣ M := Nat.gcd_dvd_left M P
  have hgP : g ∣ P := Nat.gcd_dvd_right M P
  have hMFactor : g * q = M := by
    dsimp [q]
    exact Nat.mul_div_cancel' hgM
  have hPFactor : g * P' = P := by
    dsimp [P']
    exact Nat.mul_div_cancel' hgP
  have hqpos : 0 < q := by
    dsimp [q]
    exact Nat.div_pos (Nat.gcd_le_left P hM) hg
  have hq : 3 ≤ q := by
    by_contra hnot
    have hq12 : q = 1 ∨ q = 2 := by omega
    rcases hq12 with hq1 | hq2
    · have hgM' : g = M := by
        rw [hq1, mul_one] at hMFactor
        exact hMFactor
      apply hndvd
      have hdM : d ∣ M := ⟨2, by dsimp [M]; ring⟩
      exact dvd_trans (by simpa [hgM'] using hdM) hgP
    · have hgd : g = d := by
        rw [hq2] at hMFactor
        dsimp [M] at hMFactor
        omega
      apply hndvd
      change d ∣ P
      rw [← hgd]
      exact hgP
  have hcop : P'.Coprime q := by
    have hc := Nat.coprime_div_gcd_div_gcd (m := M) (n := P) hg
    exact hc.symm
  let k := (q + 5) / 6
  have hkpos : 0 < k := by dsimp [k]; omega
  have hklt : k < q := by dsimp [k]; omega
  obtain ⟨u, huq, hu⟩ :=
    Nat.exists_mul_mod_eq_of_coprime k hcop (Nat.ne_of_gt hqpos)
  have hkmod : k % q = k := Nat.mod_eq_of_lt hklt
  rw [hkmod] at hu
  let r := g * k
  let X := P * u
  have hrmod : r = X % M := by
    dsimp [r, X]
    rw [← hPFactor, ← hMFactor, mul_assoc, Nat.mul_mod_mul_left, hu]
  have hkLower : q ≤ 6 * k := by dsimp [k]; omega
  have hkUpper : 3 * k ≤ q := by dsimp [k]; omega
  have hrLower : d ≤ 3 * r := by
    have hmul : 2 * d ≤ 6 * (g * k) := by
      calc
        2 * d = M := by rfl
        _ = g * q := hMFactor.symm
        _ ≤ g * (6 * k) := Nat.mul_le_mul_left g hkLower
        _ = 6 * (g * k) := by ring
    dsimp [r]
    omega
  have hrUpper : 3 * r ≤ 2 * d := by
    have hmul : 3 * (g * k) ≤ 2 * d := by
      calc
        3 * (g * k) = g * (3 * k) := by ring
        _ ≤ g * q := Nat.mul_le_mul_left g hkUpper
        _ = M := hMFactor
        _ = 2 * d := by rfl
    simpa [r] using hmul
  have hrlt : r < d := by omega
  let w := X / M
  let v := X / d
  have hdecomp : X = r + d * (w * 2) := by
    have hx := Nat.mod_add_div X M
    rw [← hrmod] at hx
    calc
      X = r + M * (X / M) := hx.symm
      _ = r + d * (w * 2) := by dsimp [M, w]; ring
  have hv : v = w * 2 := by
    dsimp [v]
    rw [hdecomp, Nat.add_mul_div_left r (w * 2) hd,
      Nat.div_eq_of_lt hrlt]
    simp
  refine ⟨X, r, v, ⟨u, rfl⟩, ?_, ?_, ?_, ?_⟩
  · rw [hdecomp, hv]
  · rw [hv]
    exact ⟨w, by ring⟩
  · omega
  · omega

/-- The even-quotient selection directly supplies F-038's isolated target
component pattern. -/
theorem exists_evenQuotient_target_sandwiched_pattern
    (P n L J : ℕ) (hn : 0 < n) (hndvd : ¬ 2 * n ∣ P)
    (hL : 3 * L < 2 * n) (hJ : 3 * J < 2 * n) :
    ∃ X r v : ℕ,
      P ∣ X ∧ X = r + (2 * n) * v ∧ Even v ∧
      let A := n - L
      (∀ s < L,
        fibLambertCoeff n (A + s + X) = fibLambertCoeff n (A + s)) ∧
      fibLambertCoeff n (A + L + X) ≠ fibLambertCoeff n (A + L) ∧
      (∀ s < J,
        fibLambertCoeff n (A + L + 1 + s + X) =
          fibLambertCoeff n (A + L + 1 + s)) := by
  obtain ⟨X, r, v, hPX, hX, hv, hrL, hrJ⟩ :=
    exists_multiplier_for_target_isolation_even_quotient
      P n L J hn hndvd hL hJ
  refine ⟨X, r, v, hPX, hX, hv, ?_⟩
  have hrlt : r < 2 * n := by omega
  have hrmod : r = X % (2 * n) := by
    rw [hX, Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt hrlt]
  exact target_component_sandwiched_pattern n L J X r hn
    (by nlinarith) (by nlinarith) hrmod hrL hrJ

end Research

/-!
# Parity classification of aligned right-center reduced moduli
-/

namespace Research

/-- A divisor common to `4n` and `2nM`, with `M` odd, already divides `2n`. -/
theorem dvd_two_mul_of_dvd_four_mul_and_two_mul_odd
    (g n M : ℕ) (hM : Odd M)
    (hfour : g ∣ 4 * n) (htwo : g ∣ 2 * n * M) :
    g ∣ 2 * n := by
  have hgcd : g ∣ (4 * n).gcd (2 * n * M) := Nat.dvd_gcd hfour htwo
  have hcop : Nat.Coprime 2 M := Nat.coprime_two_left.mpr hM
  have heq : (4 * n).gcd (2 * n * M) = 2 * n := by
    rw [show 4 * n = (2 * n) * 2 by ring,
      Nat.gcd_mul_left, hcop.gcd_eq_one, mul_one]
  rwa [heq] at hgcd

/-- For a later index `q`, put `g=gcd(q,4n)` and `Q=q/g`.  If its aligned
right-center condition is compatible with an odd cofactor `M`, then `Q` is odd.
If `Q=1` and `q>n`, the later index is exactly `2n`. -/
theorem right_center_reduced_odd_and_eq_one
    (q n M : ℕ) (hq : 0 < q) (hn : 0 < n) (hnq : n < q)
    (hM : Odd M) (hcompat : q.gcd (4 * n) ∣ 2 * n * M) :
    Odd (q / q.gcd (4 * n)) ∧
      (q / q.gcd (4 * n) = 1 → q = 2 * n) := by
  let g := q.gcd (4 * n)
  let Q := q / g
  have hg : 0 < g := Nat.gcd_pos_of_pos_left (4 * n) hq
  have hgq : g ∣ q := Nat.gcd_dvd_left q (4 * n)
  have hgp : g ∣ 4 * n := Nat.gcd_dvd_right q (4 * n)
  have hg2n : g ∣ 2 * n :=
    dvd_two_mul_of_dvd_four_mul_and_two_mul_odd g n M hM hgp hcompat
  have hqFactor : g * Q = q := by
    dsimp [Q]
    exact Nat.mul_div_cancel' hgq
  have hcopFull : Q.Coprime ((4 * n) / g) :=
    Nat.coprime_div_gcd_div_gcd hg
  have htwoFactor : 2 * ((2 * n) / g) = (4 * n) / g := by
    rw [show 4 * n = 2 * (2 * n) by ring,
      Nat.mul_div_assoc 2 hg2n]
  have htwoDvd : 2 ∣ (4 * n) / g := by
    rw [← htwoFactor]
    exact dvd_mul_right 2 ((2 * n) / g)
  have hcopTwo : Q.Coprime 2 :=
    hcopFull.of_dvd_right htwoDvd
  refine ⟨Nat.coprime_two_right.mp hcopTwo, ?_⟩
  intro hQ
  have hQ' : Q = 1 := by simpa [Q, g] using hQ
  have hqg : q = g := by
    rw [← hqFactor, hQ', mul_one]
  have hq2n : q ∣ 2 * n := by simpa [hqg] using hg2n
  obtain ⟨k, hk⟩ := hq2n
  have hkpos : 0 < k := by
    by_contra hk0
    have : k = 0 := Nat.eq_zero_of_not_pos hk0
    subst k
    simp at hk
    omega
  have hk1 : k = 1 := by
    by_contra hne
    have hk2 : 2 ≤ k := by omega
    have hle : 2 * q ≤ 2 * n := by
      rw [hk]
      nlinarith
    omega
  rw [hk1, mul_one] at hk
  exact hk.symm

/-- At the unshifted center, every compatible reduced quotient of a
strictly later index is odd and at least three. -/
theorem left_center_reduced_odd_ge_three
    (q n : ℕ) (hq : 0 < q) (hn : 0 < n) (hnq : n < q)
    (hcompat : q.gcd (4 * n) ∣ n) :
    Odd (q / q.gcd (4 * n)) ∧ 3 ≤ q / q.gcd (4 * n) := by
  let g := q.gcd (4 * n)
  let Q := q / g
  have hg : 0 < g := Nat.gcd_pos_of_pos_left (4 * n) hq
  have hgq : g ∣ q := Nat.gcd_dvd_left q (4 * n)
  have hgn : g ∣ n := by simpa [g] using hcompat
  have hqFactor : g * Q = q := by
    dsimp [Q]
    exact Nat.mul_div_cancel' hgq
  have hcopFull : Q.Coprime ((4 * n) / g) :=
    Nat.coprime_div_gcd_div_gcd hg
  have hfourFactor : 4 * (n / g) = (4 * n) / g := by
    rw [Nat.mul_div_assoc 4 hgn]
  have htwoDvd : 2 ∣ (4 * n) / g := by
    rw [← hfourFactor]
    exact ⟨2 * (n / g), by ring⟩
  have hoddQ : Odd Q := Nat.coprime_two_right.mp
    (hcopFull.of_dvd_right htwoDvd)
  have hQne : Q ≠ 1 := by
    intro hQ
    have hqg : q = g := by rw [← hqFactor, hQ, mul_one]
    have hqn : q ∣ n := by simpa [hqg] using hgn
    have hle := Nat.le_of_dvd hn hqn
    omega
  refine ⟨by simpa [Q, g] using hoddQ, ?_⟩
  have hQpos : 0 < Q := Nat.pos_of_ne_zero (by
    intro hQ0
    rw [hQ0, mul_zero] at hqFactor
    omega)
  have hQtwo : 2 ≤ Q := by omega
  have hQnotTwo : Q ≠ 2 := by
    intro hQ2
    rcases hoddQ with ⟨z, hz⟩
    omega
  have : 3 ≤ Q := by omega
  simpa [Q, g] using this

end Research

/-!
# Finite dyadic chains in Lambert-coefficient coordinates
-/

namespace Research

/-- Coefficient contributed by the first `R` levels of the dyadic chain rooted
at `n`. -/
def dyadicChainCoeff (n R m : ℕ) : ℤ :=
  ∑ j ∈ Finset.range R, fibLambertCoeff (n * 2 ^ j) m

/-- At its root exponent, every non-root level of a positive dyadic chain
vanishes, so a nonempty finite chain contributes exactly one. -/
theorem dyadicChainCoeff_at_root
    (n R : ℕ) (hn : 0 < n) (hR : 0 < R) :
    dyadicChainCoeff n R n = 1 := by
  unfold dyadicChainCoeff
  rw [Finset.sum_eq_single 0]
  · simpa using fibLambertCoeff_self n hn
  · intro j hj hj0
    apply fibLambertCoeff_eq_zero_of_not_dvd
    intro hdvd
    have hle := Nat.le_of_dvd hn hdvd
    have hpow : 2 ≤ 2 ^ j := Nat.one_lt_two_pow hj0
    nlinarith
  · intro hnot
    exfalso
    apply hnot
    simp [hR]

/-- At the first omitted dyadic level, every included component has even
quotient and hence vanishes. -/
theorem dyadicChainCoeff_at_first_omitted
    (n R : ℕ) (hn : 0 < n) :
    dyadicChainCoeff n R (n * 2 ^ R) = 0 := by
  unfold dyadicChainCoeff
  apply Finset.sum_eq_zero
  intro j hj
  have hjR : j < R := Finset.mem_range.mp hj
  have hindex : 0 < n * 2 ^ j := mul_pos hn (pow_pos (by norm_num) _)
  have hdvd : 2 * (n * 2 ^ j) ∣ n * 2 ^ R := by
    have hp : 2 ^ (j + 1) ∣ 2 ^ R := Nat.pow_dvd_pow 2 (by omega)
    have hm := Nat.mul_dvd_mul_left n hp
    simpa [pow_succ, mul_assoc, mul_comm, mul_left_comm] using hm
  apply fibLambertCoeff_eq_zero_of_mod_two_mul_ne
    (n * 2 ^ j) (n * 2 ^ R) hindex
  rw [Nat.mod_eq_zero_of_dvd hdvd]
  omega

/-- A finite nonempty dyadic chain therefore creates an exact coefficient
mismatch between its root and its first missing level. -/
theorem dyadicChainCoeff_root_ne_first_omitted
    (n R : ℕ) (hn : 0 < n) (hR : 0 < R) :
    dyadicChainCoeff n R n ≠ dyadicChainCoeff n R (n * 2 ^ R) := by
  rw [dyadicChainCoeff_at_root n R hn hR,
    dyadicChainCoeff_at_first_omitted n R hn]
  norm_num

/-- If the root does not divide an exponent, every dyadic-chain component
vanishes there. -/
theorem dyadicChainCoeff_eq_zero_of_not_dvd
    (n R m : ℕ) (hndvd : ¬ n ∣ m) :
    dyadicChainCoeff n R m = 0 := by
  unfold dyadicChainCoeff
  apply Finset.sum_eq_zero
  intro j _
  apply fibLambertCoeff_eq_zero_of_not_dvd
  intro hdvd
  apply hndvd
  exact dvd_trans (dvd_mul_right n (2 ^ j)) hdvd

/-- A finite dyadic chain has an exact sandwiched mismatch between its root and
first omitted level, with arbitrary neighboring windows shorter than the root. -/
theorem dyadicChainCoeff_sandwiched_pattern
    (n R L J : ℕ) (hn : 0 < n) (hR : 0 < R)
    (hL : L < n) (hJ : J < n) :
    let A := n - L
    let X := (2 ^ R - 1) * n
    (∀ s < L, dyadicChainCoeff n R (A + s + X) =
      dyadicChainCoeff n R (A + s)) ∧
    dyadicChainCoeff n R (A + L + X) ≠
      dyadicChainCoeff n R (A + L) ∧
    (∀ s < J, dyadicChainCoeff n R (A + L + 1 + s + X) =
      dyadicChainCoeff n R (A + L + 1 + s)) := by
  let A := n - L
  let X := (2 ^ R - 1) * n
  let E := n * 2 ^ R
  have hpow : 1 ≤ 2 ^ R := Nat.one_le_two_pow
  have hAL : A + L = n := by dsimp [A]; omega
  have hcenter : n + X = E := by
    have hpEq : 2 ^ R = (2 ^ R - 1) + 1 := by omega
    dsimp [X, E]
    calc
      n + (2 ^ R - 1) * n = ((2 ^ R - 1) + 1) * n := by ring
      _ = 2 ^ R * n := by rw [← hpEq]
      _ = n * 2 ^ R := by ring
  have hnE : n ∣ E := dvd_mul_right n (2 ^ R)
  refine ⟨?_, ?_, ?_⟩
  · intro s hs
    have hbasePos : 0 < A + s := by dsimp [A]; omega
    have hbaseLt : A + s < n := by dsimp [A]; omega
    have hbaseN : ¬ n ∣ A + s := by
      intro hdvd
      have hle := Nat.le_of_dvd hbasePos hdvd
      omega
    have hshiftLt : A + s + X < E := by
      rw [← hcenter]
      dsimp [A]
      omega
    have hshiftPos : 0 < A + s + X := by omega
    have hshiftN : ¬ n ∣ A + s + X := by
      intro hdvd
      have hdiff : n ∣ E - (A + s + X) := Nat.dvd_sub hnE hdvd
      have heq : E - (A + s + X) = L - s := by
        rw [← hcenter]
        dsimp [A]
        omega
      rw [heq] at hdiff
      have hdiffPos : 0 < L - s := by omega
      have hle := Nat.le_of_dvd hdiffPos hdiff
      omega
    rw [dyadicChainCoeff_eq_zero_of_not_dvd n R _ hshiftN,
      dyadicChainCoeff_eq_zero_of_not_dvd n R _ hbaseN]
  · rw [hAL, hcenter, dyadicChainCoeff_at_root n R hn hR,
      dyadicChainCoeff_at_first_omitted n R hn]
    norm_num
  · intro s hs
    have hdPos : 0 < 1 + s := by omega
    have hdLt : 1 + s < n := by omega
    have hbaseN : ¬ n ∣ A + L + 1 + s := by
      rw [hAL]
      intro hdvd
      have hdvd' : n ∣ n + (1 + s) := by simpa [add_assoc] using hdvd
      have hsum : n ∣ (n + (1 + s)) - n :=
        Nat.dvd_sub hdvd' (dvd_refl n)
      have heq : (n + (1 + s)) - n = 1 + s := by omega
      rw [heq] at hsum
      have hle := Nat.le_of_dvd hdPos hsum
      omega
    have hshiftN : ¬ n ∣ A + L + 1 + s + X := by
      rw [hAL]
      intro hdvd
      have hrewrite : n + 1 + s + X = E + (1 + s) := by
        rw [← hcenter]
        omega
      rw [hrewrite] at hdvd
      have hsum : n ∣ (E + (1 + s)) - E := Nat.dvd_sub hdvd hnE
      have heq : (E + (1 + s)) - E = 1 + s := by omega
      rw [heq] at hsum
      have hle := Nat.le_of_dvd hdPos hsum
      omega
    rw [dyadicChainCoeff_eq_zero_of_not_dvd n R _ hshiftN,
      dyadicChainCoeff_eq_zero_of_not_dvd n R _ hbaseN]

end Research

/-!
# Quantitative local density of coherent-center safe residues
-/

namespace Research

/-- Safe residues for the two coherent center forms modulo `q`. -/
def centerSafeResidues (q v : ℕ) : Finset ℕ :=
  (Finset.range q).filter fun t =>
    (¬ q ∣ 4 * t + 1) ∧ (¬ q ∣ v + 1 + 2 * t)

/-- For an odd modulus, the two affine classes remove at most two residues:
`centerSafeResidues` has codimension at most two in the full residue system. -/
theorem card_centerSafeResidues_add_two_ge
    (q v : ℕ) (hq : 0 < q) (hodd : q.gcd 2 = 1) :
    q ≤ (centerSafeResidues q v).card + 2 := by
  classical
  let B₁ := (Finset.range q).filter fun t => q ∣ 1 + 4 * t
  let B₂ := (Finset.range q).filter fun t => q ∣ v + 1 + 2 * t
  let B := (Finset.range q).filter fun t =>
    q ∣ 4 * t + 1 ∨ q ∣ v + 1 + 2 * t
  have hcop4 : q.gcd 4 = 1 := by
    have hc2 : q.Coprime 2 := hodd
    simpa using (hc2.mul_right hc2).gcd_eq_one
  have hB₁ : B₁.card ≤ 1 := by
    dsimp [B₁]
    exact card_affine_bad_residues_le_one 1 4 q hq hcop4
  have hB₂ : B₂.card ≤ 1 := by
    dsimp [B₂]
    exact card_affine_bad_residues_le_one (v + 1) 2 q hq hodd
  have hBunion : B = B₁ ∪ B₂ := by
    dsimp [B, B₁, B₂]
    rw [← Finset.filter_or]
    apply Finset.filter_congr
    intro t _
    simp [add_comm]
  have hB : B.card ≤ 2 := by
    rw [hBunion]
    calc
      (B₁ ∪ B₂).card ≤ B₁.card + B₂.card := Finset.card_union_le _ _
      _ ≤ 2 := by omega
  have hpartition := Finset.card_filter_add_card_filter_not
    (s := Finset.range q)
    (fun t => q ∣ 4 * t + 1 ∨ q ∣ v + 1 + 2 * t)
  have hsafe :
      ((Finset.range q).filter fun t =>
        ¬(q ∣ 4 * t + 1 ∨ q ∣ v + 1 + 2 * t)) =
        centerSafeResidues q v := by
    ext t
    simp [centerSafeResidues]
  have hpart : B.card + (centerSafeResidues q v).card = q := by
    rw [← hsafe]
    simpa [B] using hpartition
  omega

/-- In particular an odd modulus `q≥3` has at least `q-2` safe residues. -/
theorem sub_two_le_card_centerSafeResidues
    (q v : ℕ) (hq : 3 ≤ q) (hodd : q.gcd 2 = 1) :
    q - 2 ≤ (centerSafeResidues q v).card := by
  have h := card_centerSafeResidues_add_two_ge q v (by omega) hodd
  omega

end Research

/-!
# Polynomial lower bound for products of local safe densities
-/

namespace Research

open scoped BigOperators

/-- Numerator obtained by multiplying the local lower bounds `pᵢ-2`. -/
def centerDensityNumerator (p : ℕ → ℕ) (r : ℕ) : ℕ :=
  ∏ i ∈ Finset.range r, (p i - 2)

/-- Product of the corresponding moduli. -/
def centerDensityDenominator (p : ℕ → ℕ) (r : ℕ) : ℕ :=
  ∏ i ∈ Finset.range r, p i

/-- Distinct increasing moduli at least three have a polynomial, rather than
exponential, product-density lower bound.  The only input needed here is the
rank bound `pᵢ≥i+3`:

`2 ∏pᵢ ≤ (r+1)(r+2) ∏(pᵢ-2)`.
-/
theorem two_mul_centerDensityDenominator_le
    (p : ℕ → ℕ) (r : ℕ)
    (hrank : ∀ i < r, i + 3 ≤ p i) :
    2 * centerDensityDenominator p r ≤
      (r + 1) * (r + 2) * centerDensityNumerator p r := by
  induction r with
  | zero => simp [centerDensityDenominator, centerDensityNumerator]
  | succ r ih =>
      have hp : r + 3 ≤ p r := hrank r (by omega)
      have hrank' : ∀ i < r, i + 3 ≤ p i := by
        intro i hi
        exact hrank i (by omega)
      have hprev := ih hrank'
      have hfactor : (r + 1) * p r ≤ (r + 3) * (p r - 2) := by
        obtain ⟨d, hd⟩ := Nat.exists_eq_add_of_le hp
        rw [hd]
        have hsub : r + 3 + d - 2 = r + 1 + d := by omega
        rw [hsub]
        nlinarith
      unfold centerDensityDenominator centerDensityNumerator
      simp only [Finset.prod_range_succ]
      calc
        2 * ((∏ i ∈ Finset.range r, p i) * p r) =
            (2 * (∏ i ∈ Finset.range r, p i)) * p r := by ring
        _ ≤ ((r + 1) * (r + 2) *
              (∏ i ∈ Finset.range r, (p i - 2))) * p r :=
          Nat.mul_le_mul_right (p r) hprev
        _ = (r + 2) * (∏ i ∈ Finset.range r, (p i - 2)) *
              ((r + 1) * p r) := by ring
        _ ≤ (r + 2) * (∏ i ∈ Finset.range r, (p i - 2)) *
              ((r + 3) * (p r - 2)) :=
          Nat.mul_le_mul_left _ hfactor
        _ = (r + 2) * (r + 3) *
              ((∏ i ∈ Finset.range r, (p i - 2)) * (p r - 2)) := by ring

/-- Real-valued form: the product of `(pᵢ-2)/pᵢ` is at least
`2/((r+1)(r+2))`. -/
theorem centerDensity_product_lower_real
    (p : ℕ → ℕ) (r : ℕ)
    (hrank : ∀ i < r, i + 3 ≤ p i) :
    (2 : ℝ) / ((r + 1) * (r + 2) : ℕ) ≤
      (centerDensityNumerator p r : ℝ) /
        (centerDensityDenominator p r : ℕ) := by
  have hdenPos : 0 < centerDensityDenominator p r := by
    unfold centerDensityDenominator
    apply Finset.prod_pos
    intro i hi
    exact lt_of_lt_of_le (by omega : 0 < i + 3)
      (hrank i (Finset.mem_range.mp hi))
  have hcoefPos : 0 < (r + 1) * (r + 2) := by positivity
  have h := two_mul_centerDensityDenominator_le p r hrank
  rw [div_le_div_iff₀ (by exact_mod_cast hcoefPos) (by exact_mod_cast hdenPos)]
  exact_mod_cast (by
    simpa [mul_assoc, mul_comm, mul_left_comm] using h)

end Research

/-!
# Cardinality of a full CRT-protected center period
-/

namespace Research

open scoped BigOperators

/-- Parameters in one full CRT period that avoid both coherent forms modulo
every modulus `p i`. -/
def globalCenterSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (v : ℕ) : Finset ℕ :=
  (Finset.range (∏ i, p i)).filter fun t =>
    ∀ i, (¬ p i ∣ 4 * t + 1) ∧ (¬ p i ∣ v + 1 + 2 * t)

/-- The Cartesian product of local safe residue sets injects into the global
safe residues in one CRT period.  Therefore the global safe cardinality is at
least the product of all local safe cardinalities. -/
theorem prod_card_centerSafeResidues_le_global
    {r : ℕ} (p : Fin r → ℕ) (v : ℕ)
    (hp : ∀ i, 0 < p i)
    (hpair : ∀ i j, i ≠ j → (p i).Coprime (p j)) :
    (∏ i, (centerSafeResidues (p i) v).card) ≤
      (globalCenterSafeResidues p v).card := by
  classical
  let S : Finset (Fin r) := Finset.univ
  have hpne : ∀ i ∈ S, p i ≠ 0 := by
    intro i _
    exact Nat.ne_of_gt (hp i)
  have hpairS : Set.Pairwise S (fun i j => (p i).Coprime (p j)) := by
    intro i _ j _ hij
    exact hpair i j hij
  let α := ∀ i : Fin r, {x // x ∈ centerSafeResidues (p i) v}
  let crt (x : α) : ℕ :=
    Nat.chineseRemainderOfFinset (fun i => (x i : ℕ)) p S hpne hpairS
  have hcrt_lt (x : α) : crt x < ∏ i, p i := by
    have h := Nat.chineseRemainderOfFinset_lt_prod
      (fun i => (x i : ℕ)) p hpne hpairS
    simpa [crt, S] using h
  have hcrt_safe (x : α) (i : Fin r) :
      (¬ p i ∣ 4 * crt x + 1) ∧
      (¬ p i ∣ v + 1 + 2 * crt x) := by
    have hz : crt x ≡ (x i : ℕ) [MOD p i] := by
      exact (Nat.chineseRemainderOfFinset
        (fun j => (x j : ℕ)) p S hpne hpairS).property i (by simp [S])
    have hx := Finset.mem_filter.mp (x i).property
    have hlin₁ : 4 * crt x + 1 ≡ 4 * (x i : ℕ) + 1 [MOD p i] :=
      (hz.mul_left 4).add_right 1
    have hlin₂ : v + 1 + 2 * crt x ≡
        v + 1 + 2 * (x i : ℕ) [MOD p i] :=
      (Nat.ModEq.refl (v + 1)).add (hz.mul_left 2)
    constructor
    · intro hd
      exact hx.2.1 ((hlin₁.dvd_iff dvd_rfl).mp hd)
    · intro hd
      exact hx.2.2 ((hlin₂.dvd_iff dvd_rfl).mp hd)
  let f : α → {t // t ∈ globalCenterSafeResidues p v} := fun x =>
    ⟨crt x, Finset.mem_filter.mpr
      ⟨Finset.mem_range.mpr (hcrt_lt x), fun i => hcrt_safe x i⟩⟩
  have hf : Function.Injective f := by
    intro x y hxy
    funext i
    apply Subtype.ext
    have hzx : (crt x) ≡ (x i : ℕ) [MOD p i] :=
      (Nat.chineseRemainderOfFinset
        (fun j => (x j : ℕ)) p S hpne hpairS).property i (by simp [S])
    have hzy : (crt y) ≡ (y i : ℕ) [MOD p i] :=
      (Nat.chineseRemainderOfFinset
        (fun j => (y j : ℕ)) p S hpne hpairS).property i (by simp [S])
    have hcrt : crt x = crt y := congrArg Subtype.val hxy
    have hmod : (x i : ℕ) ≡ (y i : ℕ) [MOD p i] := by
      exact hzx.symm.trans (by simpa [hcrt] using hzy)
    have hxlt : (x i : ℕ) < p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp (x i).property).1
    have hylt : (y i : ℕ) < p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp (y i).property).1
    exact hmod.eq_of_lt_of_lt hxlt hylt
  have hcard := Fintype.card_le_of_injective f hf
  simpa [α, Fintype.card_pi, globalCenterSafeResidues] using hcard

/-- Combining the CRT injection with F-056: for odd pairwise-coprime moduli,
the global protected cardinality is at least `∏(pᵢ-2)`. -/
theorem prod_sub_two_le_globalCenterSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (v : ℕ)
    (hp3 : ∀ i, 3 ≤ p i)
    (hodd : ∀ i, (p i).gcd 2 = 1)
    (hpair : ∀ i j, i ≠ j → (p i).Coprime (p j)) :
    (∏ i, (p i - 2)) ≤ (globalCenterSafeResidues p v).card := by
  calc
    (∏ i, (p i - 2)) ≤ ∏ i, (centerSafeResidues (p i) v).card := by
      apply Finset.prod_le_prod
      · intro i hi
        exact Nat.zero_le _
      · intro i hi
        exact sub_two_le_card_centerSafeResidues (p i) v (hp3 i) (hodd i)
    _ ≤ (globalCenterSafeResidues p v).card :=
      prod_card_centerSafeResidues_le_global p v
        (fun i => lt_of_lt_of_le (by norm_num) (hp3 i)) hpair

end Research

/-!
# Odd prime-factor cover of all reduced center moduli
-/

namespace Research

/-- One canonical prime factor for each reduced center modulus. -/
def centerPrimeFactors (Q : Finset ℕ) : Finset ℕ :=
  Q.image Nat.minFac

/-- Every canonical factor really divides one of the covered moduli. -/
theorem mem_centerPrimeFactors_iff
    (Q : Finset ℕ) (p : ℕ) :
    p ∈ centerPrimeFactors Q ↔ ∃ q ∈ Q, q.minFac = p := by
  simp [centerPrimeFactors]

/-- Canonical factors of odd moduli at least three are distinct odd primes at
least three. -/
theorem centerPrimeFactors_prime_odd_ge_three
    (Q : Finset ℕ)
    (hQ3 : ∀ q ∈ Q, 3 ≤ q)
    (hQodd : ∀ q ∈ Q, Odd q) :
    ∀ p ∈ centerPrimeFactors Q,
      p.Prime ∧ Odd p ∧ 3 ≤ p := by
  intro p hp
  obtain ⟨q, hqQ, hqp⟩ := mem_centerPrimeFactors_iff Q p |>.mp hp
  subst p
  have hq3 := hQ3 q hqQ
  have hqne : q ≠ 1 := by omega
  have hpprime : q.minFac.Prime := Nat.minFac_prime hqne
  have hpne2 : q.minFac ≠ 2 := by
    intro heq
    have htwo : 2 ∣ q := by simpa [← heq] using Nat.minFac_dvd q
    have heven : Even q := even_iff_two_dvd.mpr htwo
    exact (Nat.not_even_iff_odd.mpr (hQodd q hqQ)) heven
  have hpodd : Odd q.minFac := by
    exact Nat.coprime_two_right.mp
      ((Nat.coprime_primes hpprime Nat.prime_two).mpr hpne2)
  exact ⟨hpprime, hpodd, by
    have := hpprime.two_le
    omega⟩

/-- Distinct canonical prime factors are pairwise coprime. -/
theorem centerPrimeFactors_pairwise_coprime
    (Q : Finset ℕ)
    (hQ3 : ∀ q ∈ Q, 3 ≤ q) :
    Set.Pairwise (centerPrimeFactors Q) Nat.Coprime := by
  intro p hp q hq hpq
  obtain ⟨a, haQ, hap⟩ := mem_centerPrimeFactors_iff Q p |>.mp hp
  obtain ⟨b, hbQ, hbq⟩ := mem_centerPrimeFactors_iff Q q |>.mp hq
  have hpa : p.Prime := by
    rw [← hap]
    exact Nat.minFac_prime (by have := hQ3 a haQ; omega)
  have hqb : q.Prime := by
    rw [← hbq]
    exact Nat.minFac_prime (by have := hQ3 b hbQ; omega)
  exact (Nat.coprime_primes hpa hqb).mpr hpq

/-- Avoiding both forms modulo the canonical prime factors automatically avoids
both forms modulo every covered reduced modulus. -/
theorem avoid_centerPrimeFactors_implies_avoid_moduli
    (Q : Finset ℕ) (v t : ℕ)
    (hQ3 : ∀ q ∈ Q, 3 ≤ q)
    (hsafe : ∀ p ∈ centerPrimeFactors Q,
      (¬ p ∣ 4 * t + 1) ∧ (¬ p ∣ v + 1 + 2 * t)) :
    ∀ q ∈ Q,
      (¬ q ∣ 4 * t + 1) ∧ (¬ q ∣ v + 1 + 2 * t) := by
  intro q hq
  have hqne : q ≠ 1 := by have := hQ3 q hq; omega
  have hpMem : q.minFac ∈ centerPrimeFactors Q := by
    apply (mem_centerPrimeFactors_iff Q q.minFac).mpr
    exact ⟨q, hq, rfl⟩
  have hs := hsafe q.minFac hpMem
  constructor
  · intro hd
    exact hs.1 (dvd_trans (Nat.minFac_dvd q) hd)
  · intro hd
    exact hs.2 (dvd_trans (Nat.minFac_dvd q) hd)

end Research

/-!
# Adding union-bounded conditions to an exactly protected family
-/

namespace Research

/-- Adding a second family `D` to exact protected conditions can reduce the
protected cardinality by at most F-033's union bound for `D`. -/
theorem protectedCandidates_card_le_card_union_add_budget
    {ι : Type*} [DecidableEq ι] (C D : Finset ι) (a q : ι → ℕ) (p R : ℕ)
    (hq : ∀ i ∈ D, 0 < q i) :
    (protectedCandidates C a q p R).card ≤
      (protectedCandidates (C ∪ D) a q p R).card +
        ∑ i ∈ D, (R / (q i / (q i).gcd p) + 1) := by
  classical
  let T := protectedCandidates C a q p R
  let U := protectedCandidates (C ∪ D) a q p R
  let badD : Finset ℕ := D.biUnion fun i =>
    (Finset.range R).filter fun t => q i ∣ a i + p * t
  have hgood : T \ badD ⊆ U := by
    intro t ht
    have htData := Finset.mem_sdiff.mp ht
    have htC := Finset.mem_filter.mp htData.1
    apply Finset.mem_filter.mpr
    refine ⟨htC.1, ?_⟩
    intro i hi
    rcases Finset.mem_union.mp hi with hiC | hiD
    · exact htC.2 i hiC
    · intro hdiv
      apply htData.2
      apply Finset.mem_biUnion.mpr
      exact ⟨i, hiD, Finset.mem_filter.mpr ⟨htC.1, hdiv⟩⟩
  have hcardGood : (T \ badD).card ≤ U.card := Finset.card_le_card hgood
  have hsplit : T.card ≤ (T \ badD).card + badD.card := by
    calc
      T.card = (T \ badD).card + (T ∩ badD).card :=
        (Finset.card_sdiff_add_card_inter T badD).symm
      _ ≤ (T \ badD).card + badD.card := by
        gcongr
        exact Finset.inter_subset_right
  have hbad := card_biUnion_filter_varying_dvd_add_mul_le D a q p R hq
  calc
    (protectedCandidates C a q p R).card = T.card := rfl
    _ ≤ (T \ badD).card + badD.card := hsplit
    _ ≤ U.card + badD.card := Nat.add_le_add_right hcardGood _
    _ ≤ U.card + ∑ i ∈ D, (R / (q i / (q i).gcd p) + 1) :=
      Nat.add_le_add_left hbad _
    _ = (protectedCandidates (C ∪ D) a q p R).card +
        ∑ i ∈ D, (R / (q i / (q i).gcd p) + 1) := rfl

/-- Rearranged lower-bound form. -/
theorem protectedCandidates_card_union_lower
    {ι : Type*} [DecidableEq ι] (C D : Finset ι) (a q : ι → ℕ) (p R B : ℕ)
    (hq : ∀ i ∈ D, 0 < q i)
    (hbase : B ≤ (protectedCandidates C a q p R).card) :
    B ≤ (protectedCandidates (C ∪ D) a q p R).card +
      ∑ i ∈ D, (R / (q i / (q i).gcd p) + 1) := by
  exact hbase.trans
    (protectedCandidates_card_le_card_union_add_budget C D a q p R hq)

end Research

/-!
# Uniformly bounded local completion clusters
-/

namespace Research

/-- A ratio gap bounds how many subsequent selected positions can remain below
a fixed multiple of a target. -/
theorem ratio_cluster_position_lt
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c D : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (B K r : ℕ) (hDB : D < c ^ B)
    (hupper : (n (K + r) : ℝ) ≤ D * n K) :
    r < B := by
  by_contra hnot
  have hBr : B ≤ r := by omega
  have hpow : c ^ B ≤ c ^ r := pow_le_pow_right₀ hc.le hBr
  have hnpos : 0 < (n K : ℝ) := by exact_mod_cast hpos K
  have hgrowth := ratio_gap_geometric_growth_from n c
    (lt_trans (by norm_num) hc).le hratio K r
  have hlow : c ^ B * (n K : ℝ) ≤ n (K + r) := by
    exact (mul_le_mul_of_nonneg_right hpow hnpos.le).trans hgrowth
  have : c ^ B * (n K : ℝ) ≤ D * n K := hlow.trans hupper
  nlinarith

/-- Specialization to the `4n_K` completion window relevant to the coefficient
sieve.  Any `B` with `4<c^B` bounds its number of subsequent positions. -/
theorem four_mul_cluster_position_lt
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (B K r : ℕ) (hB : (4 : ℝ) < c ^ B)
    (hupper : n (K + r) ≤ 4 * n K) :
    r < B := by
  apply ratio_cluster_position_lt n hpos c 4 hc hratio B K r hB
  exact_mod_cast hupper

end Research

/-!
# Treating a finite completion cluster as one distinguished coefficient block
-/

namespace Research

open scoped BigOperators

/-- Coefficient contribution of selected positions in `[K,H)`. -/
def selectedPositionBlockCoeff
    (n : ℕ → ℕ) (K H m : ℕ) : ℤ :=
  ∑ k ∈ Finset.Ico K H, fibLambertCoeff (n k) m

/-- Equality of the aggregate block and equality of every outside component
imply equality of the full collected coefficient. -/
theorem selectedFibLambertCoeff_eq_of_block_eq
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H a b : ℕ)
    (hblock : selectedPositionBlockCoeff n K H a =
      selectedPositionBlockCoeff n K H b)
    (hout : ∀ k, ¬(K ≤ k ∧ k < H) →
      fibLambertCoeff (n k) a = fibLambertCoeff (n k) b) :
    selectedFibLambertCoeff n a = selectedFibLambertCoeff n b := by
  let Q := max (max a b) H
  let B := Finset.Ico K H
  have haQ : a ≤ Q := le_trans (le_max_left _ _) (le_max_left _ _)
  have hbQ : b ≤ Q := le_trans (le_max_right _ _) (le_max_left _ _)
  have hHQ : H ≤ Q := le_max_right _ _
  have hBsub : B ⊆ Finset.range Q := by
    intro k hk
    have hk' := Finset.mem_Ico.mp hk
    exact Finset.mem_range.mpr (lt_of_lt_of_le hk'.2 hHQ)
  rw [← prefixFibLambertCoeff_eq_selected n hpos hmono haQ,
    ← prefixFibLambertCoeff_eq_selected n hpos hmono hbQ]
  unfold prefixFibLambertCoeff
  have houtsum :
      (∑ k ∈ Finset.range Q \ B, fibLambertCoeff (n k) a) =
        ∑ k ∈ Finset.range Q \ B, fibLambertCoeff (n k) b := by
    apply Finset.sum_congr rfl
    intro k hk
    apply hout k
    simpa [B] using (Finset.mem_sdiff.mp hk).2
  have hsplitA := Finset.sum_sdiff (f := fun k => fibLambertCoeff (n k) a) hBsub
  have hsplitB := Finset.sum_sdiff (f := fun k => fibLambertCoeff (n k) b) hBsub
  have hblock' :
      (∑ k ∈ B, fibLambertCoeff (n k) a) =
        ∑ k ∈ B, fibLambertCoeff (n k) b := by
    simpa [B, selectedPositionBlockCoeff] using hblock
  omega

/-- If the aggregate block changes while every outside component agrees, then
the full collected coefficient changes. -/
theorem selectedFibLambertCoeff_ne_of_block_ne
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H a b : ℕ)
    (hblock : selectedPositionBlockCoeff n K H a ≠
      selectedPositionBlockCoeff n K H b)
    (hout : ∀ k, ¬(K ≤ k ∧ k < H) →
      fibLambertCoeff (n k) a = fibLambertCoeff (n k) b) :
    selectedFibLambertCoeff n a ≠ selectedFibLambertCoeff n b := by
  intro heq
  apply hblock
  let Q := max (max a b) H
  let B := Finset.Ico K H
  have haQ : a ≤ Q := le_trans (le_max_left _ _) (le_max_left _ _)
  have hbQ : b ≤ Q := le_trans (le_max_right _ _) (le_max_left _ _)
  have hHQ : H ≤ Q := le_max_right _ _
  have hBsub : B ⊆ Finset.range Q := by
    intro k hk
    have hk' := Finset.mem_Ico.mp hk
    exact Finset.mem_range.mpr (lt_of_lt_of_le hk'.2 hHQ)
  have heq' : prefixFibLambertCoeff n Q a = prefixFibLambertCoeff n Q b := by
    rw [prefixFibLambertCoeff_eq_selected n hpos hmono haQ,
      prefixFibLambertCoeff_eq_selected n hpos hmono hbQ]
    exact heq
  unfold prefixFibLambertCoeff at heq'
  have houtsum :
      (∑ k ∈ Finset.range Q \ B, fibLambertCoeff (n k) a) =
        ∑ k ∈ Finset.range Q \ B, fibLambertCoeff (n k) b := by
    apply Finset.sum_congr rfl
    intro k hk
    apply hout k
    simpa [B] using (Finset.mem_sdiff.mp hk).2
  have hsplitA := Finset.sum_sdiff (f := fun k => fibLambertCoeff (n k) a) hBsub
  have hsplitB := Finset.sum_sdiff (f := fun k => fibLambertCoeff (n k) b) hBsub
  change (∑ k ∈ B, fibLambertCoeff (n k) a) =
    ∑ k ∈ B, fibLambertCoeff (n k) b
  omega

/-- A position block that is exactly a dyadic chain has the dyadic-chain
coefficient from F-055. -/
theorem selectedPositionBlockCoeff_eq_dyadicChainCoeff
    (n : ℕ → ℕ) (K R root m : ℕ)
    (hchain : ∀ j < R, n (K + j) = root * 2 ^ j) :
    selectedPositionBlockCoeff n K (K + R) m =
      dyadicChainCoeff root R m := by
  unfold selectedPositionBlockCoeff dyadicChainCoeff
  rw [Finset.sum_Ico_eq_sum_range]
  simp only [Nat.add_sub_cancel_left]
  apply Finset.sum_congr rfl
  intro j hj
  rw [hchain j (Finset.mem_range.mp hj)]

/-- A finite consecutive dyadic selected block can replace the single target
in the full-word sandwich bridge. -/
theorem dyadicPositionBlock_sandwiched_mismatch
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K R L J : ℕ) (hR : 0 < R) (hL : L < n K) (hJ : J < n K)
    (hchain : ∀ j < R, n (K + j) = n K * 2 ^ j)
    (hperiod : ∀ k < K,
      fibLambertPeriod (n k) ∣ (2 ^ R - 1) * n K)
    (havoid : ∀ k, K + R ≤ k → ∀ u < L + 1 + J,
      (¬ n k ∣ n K - L + u) ∧
      (¬ n k ∣ n K - L + u + (2 ^ R - 1) * n K)) :
    let A := n K - L
    let X := (2 ^ R - 1) * n K
    (∀ s < L,
      selectedFibLambertCoeff n (A + s + X) =
        selectedFibLambertCoeff n (A + s)) ∧
    selectedFibLambertCoeff n (A + L + X) ≠
      selectedFibLambertCoeff n (A + L) ∧
    (∀ s < J,
      selectedFibLambertCoeff n (A + L + 1 + s + X) =
        selectedFibLambertCoeff n (A + L + 1 + s)) := by
  let A := n K - L
  let X := (2 ^ R - 1) * n K
  have hpat := dyadicChainCoeff_sandwiched_pattern
    (n K) R L J (hpos K) hR hL hJ
  dsimp only at hpat
  have houtEq (u : ℕ) (hu : u < L + 1 + J) (k : ℕ)
      (hk : ¬(K ≤ k ∧ k < K + R)) :
      fibLambertCoeff (n k) (A + u + X) =
        fibLambertCoeff (n k) (A + u) := by
    by_cases hkK : k < K
    · exact prefix_component_eq_of_minimal_period n K X hperiod k hkK
    · have hkLater : K + R ≤ k := by omega
      have ha := havoid k hkLater u hu
      rw [fibLambertCoeff_eq_zero_of_not_dvd _ _ ha.2,
        fibLambertCoeff_eq_zero_of_not_dvd _ _ ha.1]
  refine ⟨?_, ?_, ?_⟩
  · intro s hs
    apply selectedFibLambertCoeff_eq_of_block_eq n hpos hmono K (K + R)
    · rw [selectedPositionBlockCoeff_eq_dyadicChainCoeff n K R (n K)
          (A + s + X) hchain,
        selectedPositionBlockCoeff_eq_dyadicChainCoeff n K R (n K)
          (A + s) hchain]
      exact hpat.1 s hs
    · exact houtEq s (by omega)
  · apply selectedFibLambertCoeff_ne_of_block_ne n hpos hmono K (K + R)
    · rw [selectedPositionBlockCoeff_eq_dyadicChainCoeff n K R (n K)
          (A + L + X) hchain,
        selectedPositionBlockCoeff_eq_dyadicChainCoeff n K R (n K)
          (A + L) hchain]
      exact hpat.2.1
    · exact houtEq L (by omega)
  · intro s hs
    let u := L + 1 + s
    apply selectedFibLambertCoeff_eq_of_block_eq n hpos hmono K (K + R)
    · have hcore : selectedPositionBlockCoeff n K (K + R) (A + u + X) =
          selectedPositionBlockCoeff n K (K + R) (A + u) := by
        rw [selectedPositionBlockCoeff_eq_dyadicChainCoeff n K R (n K)
            (A + u + X) hchain,
          selectedPositionBlockCoeff_eq_dyadicChainCoeff n K R (n K)
            (A + u) hchain]
        simpa [u, add_assoc] using hpat.2.2 s hs
      simpa [A, X, u, add_assoc] using hcore
    · intro k hk
      simpa [u, add_assoc] using houtEq u (by dsimp [u]; omega) k hk

end Research

/-!
# Polynomial safe-density bound for an unordered finite set
-/

namespace Research

open scoped BigOperators

/-- Unordered Finset form of F-057.  Any finite set of distinct naturals at
least three satisfies the same polynomial product-density bound. -/
theorem two_mul_prod_le_card_factor_mul_prod_sub_two
    (S : Finset ℕ) (hmin : ∀ p ∈ S, 3 ≤ p) :
    2 * (∏ p ∈ S, p) ≤
      (S.card + 1) * (S.card + 2) * (∏ p ∈ S, (p - 2)) := by
  classical
  have main : ∀ k : ℕ, ∀ T : Finset ℕ, T.card = k →
      (∀ p ∈ T, 3 ≤ p) →
      2 * (∏ p ∈ T, p) ≤
        (T.card + 1) * (T.card + 2) * (∏ p ∈ T, (p - 2)) := by
    intro k
    induction k using Nat.strong_induction_on with
    | h k ih =>
        intro T hcard hTmin
        by_cases hT : T.Nonempty
        · let m := T.max' hT
          let U := T.erase m
          have hmT : m ∈ T := Finset.max'_mem T hT
          have hUcard : U.card = k - 1 := by
            dsimp [U]
            rw [Finset.card_erase_of_mem hmT, hcard]
          have hkpos : 0 < k := by
            rw [← hcard]
            exact Finset.card_pos.mpr hT
          have hUcardlt : U.card < k := by omega
          have hUmin : ∀ p ∈ U, 3 ≤ p := by
            intro p hp
            exact hTmin p (Finset.mem_of_mem_erase hp)
          have hIH := ih U.card hUcardlt U rfl hUmin
          have hUsub : U ⊆ Finset.Ico 3 m := by
            intro p hp
            have hpT := Finset.mem_of_mem_erase hp
            have hpmle : p ≤ m := Finset.le_max' T p hpT
            have hpne : p ≠ m := Finset.ne_of_mem_erase hp
            exact Finset.mem_Ico.mpr ⟨hTmin p hpT, lt_of_le_of_ne hpmle hpne⟩
          have hUbound : U.card ≤ m - 3 := by
            have hc := Finset.card_le_card hUsub
            simpa using hc
          have hm3 : 3 ≤ m := hTmin m hmT
          have hmrank : U.card + 3 ≤ m := by omega
          have hfactor : (U.card + 1) * m ≤
              (U.card + 3) * (m - 2) := by
            obtain ⟨d, hd⟩ := Nat.exists_eq_add_of_le hmrank
            rw [hd]
            have hsub : U.card + 3 + d - 2 = U.card + 1 + d := by omega
            rw [hsub]
            nlinarith
          have hprod : (∏ p ∈ T, p) = (∏ p ∈ U, p) * m := by
            symm
            exact Finset.prod_erase_mul T (fun p => p) hmT
          have hprodSub : (∏ p ∈ T, (p - 2)) =
              (∏ p ∈ U, (p - 2)) * (m - 2) := by
            symm
            exact Finset.prod_erase_mul T (fun p => p - 2) hmT
          rw [hprod, hprodSub]
          have hkcard : T.card = U.card + 1 := by omega
          rw [hkcard]
          calc
            2 * ((∏ p ∈ U, p) * m) =
                (2 * (∏ p ∈ U, p)) * m := by ring
            _ ≤ ((U.card + 1) * (U.card + 2) *
                  (∏ p ∈ U, (p - 2))) * m :=
              Nat.mul_le_mul_right m hIH
            _ = (U.card + 2) * (∏ p ∈ U, (p - 2)) *
                  ((U.card + 1) * m) := by ring
            _ ≤ (U.card + 2) * (∏ p ∈ U, (p - 2)) *
                  ((U.card + 3) * (m - 2)) :=
              Nat.mul_le_mul_left _ hfactor
            _ = (U.card + 1 + 1) * (U.card + 1 + 2) *
                  ((∏ p ∈ U, (p - 2)) * (m - 2)) := by ring
        · have hEmpty : T = ∅ := Finset.not_nonempty_iff_eq_empty.mp hT
          subst T
          norm_num
  exact main S.card S rfl hmin

/-- Real ratio form for an unordered finite set. -/
theorem finset_safeDensity_product_lower_real
    (S : Finset ℕ) (hmin : ∀ p ∈ S, 3 ≤ p) :
    (2 : ℝ) / ((S.card + 1) * (S.card + 2) : ℕ) ≤
      ((∏ p ∈ S, (p - 2) : ℕ) : ℝ) / ((∏ p ∈ S, p : ℕ) : ℝ) := by
  have hden : 0 < ∏ p ∈ S, p := by
    apply Finset.prod_pos
    intro p hp
    have := hmin p hp
    omega
  have hc : 0 < (S.card + 1) * (S.card + 2) := by positivity
  rw [div_le_div_iff₀ (by exact_mod_cast hc) (by exact_mod_cast hden)]
  exact_mod_cast (by
    simpa [mul_assoc, mul_comm, mul_left_comm] using
      two_mul_prod_le_card_factor_mul_prod_sub_two S hmin)

end Research

/-!
# Polynomial protected cardinality for an unordered prime family
-/

namespace Research

open scoped BigOperators

/-- Enumerate an unordered finite family of odd primes and combine F-058 with
F-063.  In one CRT product period `M`, at least
`2M/((r+1)(r+2))` parameters avoid both center forms. -/
theorem exists_prime_enumeration_with_global_safe_bound
    (S : Finset ℕ) (v : ℕ)
    (hprime : ∀ p ∈ S, p.Prime)
    (hodd : ∀ p ∈ S, Odd p) :
    ∃ p : Fin S.card → ℕ,
      (∏ i, p i) = ∏ q ∈ S, q ∧
      (∀ i, 3 ≤ p i) ∧
      (∀ i, (p i).gcd 2 = 1) ∧
      (∀ i j, i ≠ j → (p i).Coprime (p j)) ∧
      2 * (∏ i, p i) ≤
        (S.card + 1) * (S.card + 2) *
          (globalCenterSafeResidues p v).card := by
  classical
  let e : Fin S.card ≃ {x // x ∈ S} :=
    (Fin.castOrderIso (Fintype.card_coe S).symm).toEquiv.trans
      (Fintype.equivFin {x // x ∈ S}).symm
  let p : Fin S.card → ℕ := fun i => (e i : ℕ)
  have hpMem (i : Fin S.card) : p i ∈ S := (e i).property
  have hpPrime (i : Fin S.card) : (p i).Prime := hprime (p i) (hpMem i)
  have hpOdd (i : Fin S.card) : Odd (p i) := hodd (p i) (hpMem i)
  have hp3 (i : Fin S.card) : 3 ≤ p i := by
    have h2 := (hpPrime i).two_le
    have hne : p i ≠ 2 := by
      intro heq
      have heven : Even (p i) := by rw [heq]; norm_num
      exact (Nat.not_even_iff_odd.mpr (hpOdd i)) heven
    omega
  have hpPair : ∀ i j, i ≠ j → (p i).Coprime (p j) := by
    intro i j hij
    apply (Nat.coprime_primes (hpPrime i) (hpPrime j)).mpr
    intro hpij
    apply hij
    exact e.injective (Subtype.ext hpij)
  have hprod : (∏ i, p i) = ∏ q ∈ S, q := by
    calc
      (∏ i, p i) = ∏ x : {x // x ∈ S}, (x : ℕ) :=
        Equiv.prod_comp e (fun x : {x // x ∈ S} => (x : ℕ))
      _ = ∏ q ∈ S, q := Finset.prod_coe_sort S (fun q => q)
  have hprodSub : (∏ i, (p i - 2)) = ∏ q ∈ S, (q - 2) := by
    calc
      (∏ i, (p i - 2)) = ∏ x : {x // x ∈ S}, ((x : ℕ) - 2) :=
        Equiv.prod_comp e (fun x : {x // x ∈ S} => ((x : ℕ) - 2))
      _ = ∏ q ∈ S, (q - 2) := Finset.prod_coe_sort S (fun q => q - 2)
  have hglobal : (∏ i, (p i - 2)) ≤
      (globalCenterSafeResidues p v).card :=
    prod_sub_two_le_globalCenterSafeResidues p v hp3
      (fun i => Nat.coprime_two_right.mpr (hpOdd i) |>.gcd_eq_one) hpPair
  have hS3 : ∀ q ∈ S, 3 ≤ q := by
    intro q hq
    have hq2 := (hprime q hq).two_le
    have hqne : q ≠ 2 := by
      intro heq
      have heven : Even q := by rw [heq]; norm_num
      exact (Nat.not_even_iff_odd.mpr (hodd q hq)) heven
    omega
  have hdensity := two_mul_prod_le_card_factor_mul_prod_sub_two S hS3
  refine ⟨p, hprod, hp3, ?_, hpPair, ?_⟩
  · intro i
    exact (Nat.coprime_two_right.mpr (hpOdd i)).gcd_eq_one
  · calc
      2 * (∏ i, p i) = 2 * (∏ q ∈ S, q) := by rw [hprod]
      _ ≤ (S.card + 1) * (S.card + 2) * (∏ q ∈ S, (q - 2)) :=
        hdensity
      _ = (S.card + 1) * (S.card + 2) * (∏ i, (p i - 2)) := by
        rw [hprodSub]
      _ ≤ (S.card + 1) * (S.card + 2) *
          (globalCenterSafeResidues p v).card :=
        Nat.mul_le_mul_left _ hglobal

end Research

namespace Research

/-- The same enumeration, exposing that it is onto the original prime
`Finset`; this is useful when transporting local safety back to named center
moduli. -/
theorem exists_prime_enumeration_with_global_safe_bound_onto
    (S : Finset ℕ) (v : ℕ)
    (hprime : ∀ p ∈ S, p.Prime)
    (hodd : ∀ p ∈ S, Odd p) :
    ∃ p : Fin S.card → ℕ,
      (∏ i, p i) = ∏ q ∈ S, q ∧
      (∀ i, (p i).Prime) ∧
      (∀ i, 3 ≤ p i) ∧
      (∀ i, (p i).gcd 2 = 1) ∧
      (∀ i j, i ≠ j → (p i).Coprime (p j)) ∧
      (∀ q ∈ S, ∃ i, p i = q) ∧
      2 * (∏ i, p i) ≤
        (S.card + 1) * (S.card + 2) *
          (globalCenterSafeResidues p v).card := by
  classical
  let e : Fin S.card ≃ {x // x ∈ S} :=
    (Fin.castOrderIso (Fintype.card_coe S).symm).toEquiv.trans
      (Fintype.equivFin {x // x ∈ S}).symm
  let p : Fin S.card → ℕ := fun i => (e i : ℕ)
  have hpMem (i : Fin S.card) : p i ∈ S := (e i).property
  have hpPrime (i : Fin S.card) : (p i).Prime := hprime (p i) (hpMem i)
  have hpOdd (i : Fin S.card) : Odd (p i) := hodd (p i) (hpMem i)
  have hp3 (i : Fin S.card) : 3 ≤ p i := by
    have h2 := (hpPrime i).two_le
    have hne : p i ≠ 2 := by
      intro heq
      have heven : Even (p i) := by rw [heq]; norm_num
      exact (Nat.not_even_iff_odd.mpr (hpOdd i)) heven
    omega
  have hpPair : ∀ i j, i ≠ j → (p i).Coprime (p j) := by
    intro i j hij
    apply (Nat.coprime_primes (hpPrime i) (hpPrime j)).mpr
    intro hpij
    apply hij
    exact e.injective (Subtype.ext hpij)
  have hprod : (∏ i, p i) = ∏ q ∈ S, q := by
    calc
      (∏ i, p i) = ∏ x : {x // x ∈ S}, (x : ℕ) :=
        Equiv.prod_comp e (fun x : {x // x ∈ S} => (x : ℕ))
      _ = ∏ q ∈ S, q := Finset.prod_coe_sort S (fun q => q)
  have hprodSub : (∏ i, (p i - 2)) = ∏ q ∈ S, (q - 2) := by
    calc
      (∏ i, (p i - 2)) = ∏ x : {x // x ∈ S}, ((x : ℕ) - 2) :=
        Equiv.prod_comp e (fun x : {x // x ∈ S} => ((x : ℕ) - 2))
      _ = ∏ q ∈ S, (q - 2) := Finset.prod_coe_sort S (fun q => q - 2)
  have hglobal : (∏ i, (p i - 2)) ≤
      (globalCenterSafeResidues p v).card :=
    prod_sub_two_le_globalCenterSafeResidues p v hp3
      (fun i => Nat.coprime_two_right.mpr (hpOdd i) |>.gcd_eq_one) hpPair
  have hS3 : ∀ q ∈ S, 3 ≤ q := by
    intro q hq
    have hq2 := (hprime q hq).two_le
    have hqne : q ≠ 2 := by
      intro heq
      have heven : Even q := by rw [heq]; norm_num
      exact (Nat.not_even_iff_odd.mpr (hodd q hq)) heven
    omega
  have hdensity := two_mul_prod_le_card_factor_mul_prod_sub_two S hS3
  have honto : ∀ q ∈ S, ∃ i, p i = q := by
    intro q hq
    obtain ⟨i, hi⟩ := e.surjective ⟨q, hq⟩
    exact ⟨i, congrArg Subtype.val hi⟩
  refine ⟨p, hprod, hpPrime, hp3, ?_, hpPair, honto, ?_⟩
  · intro i
    exact (Nat.coprime_two_right.mpr (hpOdd i)).gcd_eq_one
  · calc
      2 * (∏ i, p i) = 2 * (∏ q ∈ S, q) := by rw [hprod]
      _ ≤ (S.card + 1) * (S.card + 2) * (∏ q ∈ S, (q - 2)) :=
        hdensity
      _ = (S.card + 1) * (S.card + 2) * (∏ i, (p i - 2)) := by
        rw [hprodSub]
      _ ≤ (S.card + 1) * (S.card + 2) *
          (globalCenterSafeResidues p v).card :=
        Nat.mul_le_mul_left _ hglobal


end Research


/-!
# Bridge from coherent center forms to protected candidates
-/

namespace Research

open scoped BigOperators

/-- A finite family of divisibility conditions, each implied by one of the two
coherent center forms modulo a covered odd modulus, retains polynomially many
candidates in one canonical-prime CRT period. -/
theorem exists_period_with_polynomially_many_protected_centers
    {ι : Type*} [DecidableEq ι]
    (Q : Finset ℕ) (C : Finset ι) (side : ι → Bool)
    (a qmod : ι → ℕ) (step v : ℕ)
    (hQ3 : ∀ q ∈ Q, 3 ≤ q)
    (hQodd : ∀ q ∈ Q, Odd q)
    (hcover : ∀ u ∈ C, ∃ q ∈ Q, ∀ t,
      qmod u ∣ a u + step * t →
        if side u then q ∣ v + 1 + 2 * t else q ∣ 4 * t + 1) :
    let S := centerPrimeFactors Q
    ∃ R : ℕ, 0 < R ∧
      2 * R ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C a qmod step R).card := by
  classical
  let S := centerPrimeFactors Q
  have hSdata := centerPrimeFactors_prime_odd_ge_three Q hQ3 hQodd
  have hSprime : ∀ p ∈ S, p.Prime := fun p hp => (hSdata p hp).1
  have hSodd : ∀ p ∈ S, Odd p := fun p hp => (hSdata p hp).2.1
  obtain ⟨p, hprod, hpPrime, hp3, hpTwo, hpPair, hEnumCovers,
      hsafeBound⟩ :=
    exists_prime_enumeration_with_global_safe_bound_onto
      S v hSprime hSodd
  let R := ∏ i, p i
  have hRpos : 0 < R := by
    dsimp [R]
    apply Finset.prod_pos
    intro i hi
    exact lt_of_lt_of_le (by norm_num) (hp3 i)
  have hsubset : globalCenterSafeResidues p v ⊆
      protectedCandidates C a qmod step R := by
    intro t htSafe
    have htData := Finset.mem_filter.mp htSafe
    apply Finset.mem_filter.mpr
    refine ⟨by simpa [R] using htData.1, ?_⟩
    intro u huC hbad
    obtain ⟨q, hqQ, himp⟩ := hcover u huC
    have hform := himp t hbad
    have hqne : q ≠ 1 := by have := hQ3 q hqQ; omega
    let z := q.minFac
    have hzS : z ∈ S := by
      apply (mem_centerPrimeFactors_iff Q z).mpr
      exact ⟨q, hqQ, rfl⟩
    obtain ⟨i, hpi⟩ := hEnumCovers z hzS
    have hsafeI := htData.2 i
    have hzDvd : z ∣ q := Nat.minFac_dvd q
    split at hform
    · exact hsafeI.2 (by simpa [hpi] using dvd_trans hzDvd hform)
    · exact hsafeI.1 (by simpa [hpi] using dvd_trans hzDvd hform)
  refine ⟨R, hRpos, ?_⟩
  have hcard := Finset.card_le_card hsubset
  calc
    2 * R = 2 * (∏ i, p i) := rfl
    _ ≤ (S.card + 1) * (S.card + 2) *
        (globalCenterSafeResidues p v).card := hsafeBound
    _ ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C a qmod step R).card :=
      Nat.mul_le_mul_left _ hcard

/-- Repeat one full global-safe CRT period `T` times. -/
def replicatedGlobalCenterSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (v T : ℕ) : Finset ℕ :=
  ((Finset.range T).product (globalCenterSafeResidues p v)).image fun z =>
    z.2 + (∏ i, p i) * z.1

lemma card_replicatedGlobalCenterSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (v T : ℕ)
    (hM : 0 < ∏ i, p i) :
    (replicatedGlobalCenterSafeResidues p v T).card =
      T * (globalCenterSafeResidues p v).card := by
  classical
  unfold replicatedGlobalCenterSafeResidues
  rw [Finset.card_image_of_injOn]
  · simp
  · intro z hz w hw hzw
    have hzlt : z.2 < ∏ i, p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp
        (Finset.mem_product.mp hz).2).1
    have hwlt : w.2 < ∏ i, p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp
        (Finset.mem_product.mp hw).2).1
    have hrem := congrArg (fun x => x % (∏ i, p i)) hzw
    simp only [Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt hzlt,
      Nat.mod_eq_of_lt hwlt] at hrem
    have hblock : z.1 = w.1 := by
      change z.2 + (∏ i, p i) * z.1 =
        w.2 + (∏ i, p i) * w.1 at hzw
      rw [hrem] at hzw
      exact Nat.mul_left_cancel hM (Nat.add_left_cancel hzw)
    cases z
    cases w
    simp_all

/-- Scaled strengthening of `exists_period_with_polynomially_many_protected_centers`:
the same protected density is available in every positive number of full CRT
periods, so endpoint costs can be made negligible. -/
theorem exists_period_with_scaled_polynomially_many_protected_centers
    {ι : Type*} [DecidableEq ι]
    (Q : Finset ℕ) (C : Finset ι) (side : ι → Bool)
    (a qmod : ι → ℕ) (step v : ℕ)
    (hQ3 : ∀ q ∈ Q, 3 ≤ q)
    (hQodd : ∀ q ∈ Q, Odd q)
    (hcover : ∀ u ∈ C, ∃ q ∈ Q, ∀ t,
      qmod u ∣ a u + step * t →
        if side u then q ∣ v + 1 + 2 * t else q ∣ 4 * t + 1) :
    let S := centerPrimeFactors Q
    ∃ M : ℕ, 0 < M ∧ ∀ T : ℕ,
      2 * (T * M) ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C a qmod step (T * M)).card := by
  classical
  let S := centerPrimeFactors Q
  have hSdata := centerPrimeFactors_prime_odd_ge_three Q hQ3 hQodd
  have hSprime : ∀ z ∈ S, z.Prime := fun z hz => (hSdata z hz).1
  have hSodd : ∀ z ∈ S, Odd z := fun z hz => (hSdata z hz).2.1
  obtain ⟨p, hprod, hpPrime, hp3, hpTwo, hpPair, hEnumCovers,
      hsafeBound⟩ :=
    exists_prime_enumeration_with_global_safe_bound_onto
      S v hSprime hSodd
  let M := ∏ i, p i
  have hMpos : 0 < M := by
    dsimp [M]
    apply Finset.prod_pos
    intro i hi
    exact lt_of_lt_of_le (by norm_num) (hp3 i)
  refine ⟨M, hMpos, ?_⟩
  intro T
  have hsubset : replicatedGlobalCenterSafeResidues p v T ⊆
      protectedCandidates C a qmod step (T * M) := by
    intro t htRep
    obtain ⟨z, hzProd, rfl⟩ := Finset.mem_image.mp htRep
    have hzT := Finset.mem_range.mp (Finset.mem_product.mp hzProd).1
    have hzSafe := (Finset.mem_product.mp hzProd).2
    have hzData := Finset.mem_filter.mp hzSafe
    apply Finset.mem_filter.mpr
    refine ⟨Finset.mem_range.mpr ?_, ?_⟩
    · have hzlt := Finset.mem_range.mp hzData.1
      dsimp [M]
      nlinarith
    · intro u huC hbad
      obtain ⟨q, hqQ, himp⟩ := hcover u huC
      have hform := himp (z.2 + M * z.1) hbad
      have hqne : q ≠ 1 := by have := hQ3 q hqQ; omega
      let prime := q.minFac
      have hprimeS : prime ∈ S := by
        apply (mem_centerPrimeFactors_iff Q prime).mpr
        exact ⟨q, hqQ, rfl⟩
      obtain ⟨i, hpi⟩ := hEnumCovers prime hprimeS
      have hsafeI := hzData.2 i
      have hpM : p i ∣ M := by
        dsimp [M]
        exact Finset.dvd_prod_of_mem p (by simp)
      have hformReduceLeft : p i ∣ 4 * z.2 + 1 ↔
          p i ∣ 4 * (z.2 + M * z.1) + 1 := by
        have hd : p i ∣ 4 * M * z.1 := by
          simpa [mul_comm, mul_left_comm, mul_assoc] using
            dvd_mul_of_dvd_left (dvd_mul_of_dvd_left hpM 4) z.1
        rw [show 4 * (z.2 + M * z.1) + 1 =
          4 * M * z.1 + (4 * z.2 + 1) by ring]
        exact Nat.dvd_add_iff_right hd
      have hformReduceRight : p i ∣ v + 1 + 2 * z.2 ↔
          p i ∣ v + 1 + 2 * (z.2 + M * z.1) := by
        have hd : p i ∣ 2 * M * z.1 := by
          simpa [mul_comm, mul_left_comm, mul_assoc] using
            dvd_mul_of_dvd_left (dvd_mul_of_dvd_left hpM 2) z.1
        rw [show v + 1 + 2 * (z.2 + M * z.1) =
          2 * M * z.1 + (v + 1 + 2 * z.2) by ring]
        exact Nat.dvd_add_iff_right hd
      have hprimeDvd : prime ∣ q := Nat.minFac_dvd q
      split at hform
      · apply hsafeI.2
        rw [hformReduceRight]
        simpa [hpi] using dvd_trans hprimeDvd hform
      · apply hsafeI.1
        rw [hformReduceLeft]
        simpa [hpi] using dvd_trans hprimeDvd hform
  have hcard := Finset.card_le_card hsubset
  have hrepCard := card_replicatedGlobalCenterSafeResidues p v T hMpos
  have hbaseScaled := Nat.mul_le_mul_left T hsafeBound
  calc
    2 * (T * M) = T * (2 * (∏ i, p i)) := by dsimp [M]; ring
    _ ≤ T * ((S.card + 1) * (S.card + 2) *
        (globalCenterSafeResidues p v).card) := hbaseScaled
    _ = (S.card + 1) * (S.card + 2) *
        (replicatedGlobalCenterSafeResidues p v T).card := by
      rw [hrepCard]
      ring
    _ ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C a qmod step (T * M)).card :=
      Nat.mul_le_mul_left _ hcard

end Research

/-!
# Actual coherent centers for a near-half target shift
-/

namespace Research

/-- The two compatible conditions at the unshifted and shifted aligned center
offsets. -/
def nearHalfCenterConditions
    (n : ℕ → ℕ) (K H W A X p L sR : ℕ) :
    Finset ((ℕ × ℕ) × Bool) :=
  (compatibleTwoWindowConditions n K H W A X p).filter fun u =>
    (u.2 = false ∧ u.1.2 = L) ∨ (u.2 = true ∧ u.1.2 = sR)

/-- The remaining compatible conditions after removing the two centers. -/
def nearHalfOffCenterConditions
    (n : ℕ → ℕ) (K H W A X p L sR : ℕ) :
    Finset ((ℕ × ℕ) × Bool) :=
  compatibleTwoWindowConditions n K H W A X p \
    (nearHalfCenterConditions n K H W A X p L sR)

/-- Reduced moduli represented among the two aligned center families. -/
def nearHalfCenterReducedModuli
    (n : ℕ → ℕ) (K H W A X p L sR : ℕ) : Finset ℕ :=
  (nearHalfCenterConditions n K H W A X p L sR).image fun u =>
    twoWindowModulus n u / (twoWindowModulus n u).gcd p

lemma coprime_reduced_modulus_factor
    (q p d : ℕ) (hq : 0 < q) (hd : q.gcd p ∣ d) (hdp : d ∣ p) :
    (q / q.gcd p).Coprime (d / q.gcd p) := by
  let g := q.gcd p
  have hg : 0 < g := Nat.gcd_pos_of_pos_left p hq
  have hcop : (q / g).Coprime (p / g) :=
    Nat.coprime_div_gcd_div_gcd hg
  apply hcop.of_dvd_right
  apply (Nat.dvd_div_iff_mul_dvd (Nat.gcd_dvd_right q p)).mpr
  rw [Nat.mul_div_cancel' hd]
  exact hdp

/-- If the near-half shift puts both aligned offsets inside the windows and no
later condition is the exact double `2n_K`, the actual center family satisfies
F-080's polynomial protected-count conclusion. -/
theorem exists_scaled_polynomially_many_nearHalf_center_candidates
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H L J X r v : ℕ) (_hKH : K < H)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (_hsRWindow : n K + L - r < L + 1 + J)
    (hnoDouble : ∀ j, K < j → j < H → n j ≠ 2 * n K) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C := nearHalfCenterConditions n K H W A X p L sR
    let Q := nearHalfCenterReducedModuli n K H W A X p L sR
    let S := centerPrimeFactors Q
    ∃ M : ℕ, 0 < M ∧ ∀ T : ℕ,
      2 * (T * M) ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p (T * M)).card := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C := nearHalfCenterConditions n K H W A X p L sR
  let Q := nearHalfCenterReducedModuli n K H W A X p L sR
  have hn := hpos K
  have hcenterLeft : A + L = n K := by dsimp [A]; omega
  have hvOdd : Odd (v + 1) := by
    obtain ⟨z, hz⟩ := hv
    exact ⟨z, by omega⟩
  have hcenterRight : A + sR + X = 2 * n K * (v + 1) := by
    have hAr : A + L = n K := hcenterLeft
    have hsrr : sR + r = n K + L := by dsimp [sR]; omega
    rw [hX]
    calc
      A + sR + (r + 2 * n K * v) =
          2 * n K + 2 * n K * v := by omega
      _ = 2 * n K * (v + 1) := by ring
  have hQdata : ∀ q ∈ Q, Odd q ∧ 3 ≤ q := by
    intro q hqQ
    obtain ⟨u, huC, rfl⟩ := Finset.mem_image.mp hqQ
    have huCompat := (Finset.mem_filter.mp huC).1
    have huCenter := (Finset.mem_filter.mp huC).2
    have huBase := (Finset.mem_filter.mp huCompat).1
    have huComp := (Finset.mem_filter.mp huCompat).2
    have huPair := Finset.mem_product.mp (Finset.mem_product.mp huBase).1
    have hjData := Finset.mem_filter.mp huPair.1
    have hjH := Finset.mem_range.mp hjData.1
    have hKj := hjData.2
    have hnj := hpos u.1.1
    have hnlt : n K < n u.1.1 := hmono hKj
    rcases huCenter with hleft | hright
    · have hside : u.2 = false := hleft.1
      have hoff : u.1.2 = L := hleft.2
      have hcompLeft : (n u.1.1).gcd (4 * n K) ∣ n K := by
        simpa [twoWindowModulus, twoWindowOffset, p, A,
          hside, hoff, hcenterLeft] using huComp
      exact left_center_reduced_odd_ge_three
        (n u.1.1) (n K) hnj hn hnlt hcompLeft
    · have hside : u.2 = true := hright.1
      have hoff : u.1.2 = sR := hright.2
      have hcompRight : (n u.1.1).gcd (4 * n K) ∣
          2 * n K * (v + 1) := by
        simpa [twoWindowModulus, twoWindowOffset, p, A,
          sR, hside, hoff, hcenterRight] using huComp
      have hd := right_center_reduced_odd_and_eq_one
        (n u.1.1) (n K) (v + 1) hnj hn hnlt hvOdd hcompRight
      refine ⟨hd.1, ?_⟩
      have hqpos : 0 < n u.1.1 / (n u.1.1).gcd (4 * n K) := hd.1.pos
      have hqne : n u.1.1 / (n u.1.1).gcd (4 * n K) ≠ 1 := by
        intro heq
        have heqDouble := hd.2 heq
        exact hnoDouble u.1.1 hKj hjH heqDouble
      have hqneTwo : n u.1.1 / (n u.1.1).gcd (4 * n K) ≠ 2 := by
        intro heq
        obtain ⟨z, hz⟩ := hd.1
        omega
      change 3 ≤ n u.1.1 / (n u.1.1).gcd (4 * n K)
      omega
  apply exists_period_with_scaled_polynomially_many_protected_centers
    Q C (fun u => u.2) (twoWindowOffset A X) (twoWindowModulus n)
      p v
  · exact fun q hq => (hQdata q hq).2
  · exact fun q hq => (hQdata q hq).1
  · intro u huC
    let q0 := twoWindowModulus n u /
      (twoWindowModulus n u).gcd p
    refine ⟨q0, ?_, ?_⟩
    · apply Finset.mem_image.mpr
      exact ⟨u, huC, rfl⟩
    · intro t hbad
      have huCompat := (Finset.mem_filter.mp huC).1
      have huCenter := (Finset.mem_filter.mp huC).2
      have huComp := (Finset.mem_filter.mp huCompat).2
      let g := (n u.1.1).gcd (4 * n K)
      have hg : 0 < g := Nat.gcd_pos_of_pos_left (4 * n K) (hpos u.1.1)
      have hqFactor : n u.1.1 = g * q0 := by
        dsimp [g, q0, p]
        exact (Nat.mul_div_cancel' (Nat.gcd_dvd_left _ _)).symm
      rcases huCenter with hleft | hright
      · have hside : u.2 = false := hleft.1
        have hoff : u.1.2 = L := hleft.2
        have hgN : g ∣ n K := by
          simpa [g, p, twoWindowModulus, twoWindowOffset,
            A, hside, hoff, hcenterLeft] using huComp
        let u0 := n K / g
        have hnFactor : n K = g * u0 := by
          dsimp [u0]
          exact (Nat.mul_div_cancel' hgN).symm
        have hcop : q0.Coprime u0 := by
          dsimp [q0, u0, g, p]
          exact coprime_reduced_modulus_factor
            (n u.1.1) (4 * n K) (n K) (hpos u.1.1)
              hgN (by exact ⟨4, by ring⟩)
        simp only [hside, Bool.false_eq_true, ↓reduceIte]
        apply (left_center_divisibility_iff_reduced
          (n u.1.1) (n K) g q0 u0 t hg hqFactor hnFactor hcop).mp
        simpa [twoWindowModulus, twoWindowOffset, p, A,
          hside, hoff, hcenterLeft] using hbad
      · have hside : u.2 = true := hright.1
        have hoff : u.1.2 = sR := hright.2
        have hgAligned : g ∣ 2 * n K * (v + 1) := by
          simpa [g, p, twoWindowModulus, twoWindowOffset,
            A, sR, hside, hoff, hcenterRight] using huComp
        have hgTwo : g ∣ 2 * n K :=
          dvd_two_mul_of_dvd_four_mul_and_two_mul_odd
            g (n K) (v + 1) hvOdd
            (by dsimp [g]; exact Nat.gcd_dvd_right _ _) hgAligned
        let u0 := (2 * n K) / g
        have htwoFactor : 2 * n K = g * u0 := by
          dsimp [u0]
          exact (Nat.mul_div_cancel' hgTwo).symm
        have hcop : q0.Coprime u0 := by
          dsimp [q0, u0, g, p]
          exact coprime_reduced_modulus_factor
            (n u.1.1) (4 * n K) (2 * n K) (hpos u.1.1)
              hgTwo (by exact ⟨2, by ring⟩)
        simp only [hside, ite_true]
        apply (right_center_divisibility_iff_reduced
          (n u.1.1) g q0 u0 v t hg hqFactor hcop).mp
        have haligned : A + u.1.2 + X + p * t =
            g * u0 * (v + 1 + 2 * t) := by
          rw [hoff, hcenterRight, ← htwoFactor]
          dsimp [p]
          ring
        simpa [twoWindowModulus, twoWindowOffset, hside, haligned]
          using hbad

/-- One-period corollary of the scaled center theorem. -/
theorem exists_polynomially_many_nearHalf_center_candidates
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H L J X r v : ℕ) (hKH : K < H)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDouble : ∀ j, K < j → j < H → n j ≠ 2 * n K) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C := nearHalfCenterConditions n K H W A X p L sR
    let Q := nearHalfCenterReducedModuli n K H W A X p L sR
    let S := centerPrimeFactors Q
    ∃ R : ℕ, 0 < R ∧
      2 * R ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
  obtain ⟨M, hM, hscaled⟩ :=
    exists_scaled_polynomially_many_nearHalf_center_candidates
      n hpos hmono K H L J X r v hKH hL hX hv hrUpper
        hsRWindow hnoDouble
  refine ⟨M, hM, ?_⟩
  simpa using hscaled 1

/-- Once both aligned centers are removed, every remaining compatible gcd is
at most `4W`; consequently its complete union budget has an explicit
reciprocal-index upper bound. -/
theorem nearHalf_offCenter_budget_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K H L J X r v R : ℕ) (hL : L < n K)
    (hX : X = r + (2 * n K) * v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let O := nearHalfOffCenterConditions n K H W A X p L sR
    (∑ u ∈ O, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1)) ≤
      2 * W * ∑ j ∈ laterPositionRange K H,
        ((R * (4 * W)) / n j + 1) := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C := nearHalfCenterConditions n K H W A X p L sR
  let I := compatibleTwoWindowConditions n K H W A X p
  let O := nearHalfOffCenterConditions n K H W A X p L sR
  have hcenterLeft : A + L = n K := by dsimp [A]; omega
  have hcenterRight : A + sR + X = 2 * n K * (v + 1) := by
    have hsrr : sR + r = n K + L := by dsimp [sR]; omega
    rw [hX]
    calc
      A + sR + (r + 2 * n K * v) =
          2 * n K + 2 * n K * v := by
        dsimp [A]
        omega
      _ = 2 * n K * (v + 1) := by ring
  have hspecialRight : 4 * n K ∣ 2 * (A + sR + X) := by
    rw [hcenterRight]
    exact ⟨v + 1, by ring⟩
  have hOsub : O ⊆ twoWindowConditions K H W := by
    intro u hu
    have huI : u ∈ I := (Finset.mem_sdiff.mp hu).1
    exact (Finset.mem_filter.mp huI).1
  have hgcd : ∀ u ∈ O,
      (twoWindowModulus n u).gcd p ≤ 4 * W := by
    intro u huO
    have huData := Finset.mem_sdiff.mp huO
    have huI := huData.1
    have huNotC := huData.2
    have huBase := (Finset.mem_filter.mp huI).1
    have huComp := (Finset.mem_filter.mp huI).2
    have huInner := (Finset.mem_product.mp huBase).1
    have huPair := Finset.mem_product.mp huInner
    have hsW := Finset.mem_range.mp huPair.2
    by_cases hside : u.2 = false
    · have hcomp : (n u.1.1).gcd (4 * n K) ∣ n K - L + u.1.2 := by
        simpa [twoWindowModulus, twoWindowOffset, p, A, hside] using huComp
      have hne : u.1.2 ≠ L := by
        intro heq
        apply huNotC
        apply Finset.mem_filter.mpr
        exact ⟨huI, Or.inl ⟨hside, heq⟩⟩
      have hbound := (left_window_compatible_gcd_le
        (n u.1.1) (n K) L u.1.2 (hpos u.1.1) hL.le hcomp).resolve_left hne
      have hdist : u.1.2.dist L ≤ W := by
        have hLW : L < W := by dsimp [W]; omega
        rcases le_total u.1.2 L with hle | hge
        · rw [Nat.dist_eq_sub_of_le hle]
          omega
        · rw [Nat.dist_eq_sub_of_le_right hge]
          omega
      dsimp [twoWindowModulus, p]
      exact hbound.trans (Nat.mul_le_mul_left 4 hdist)
    · have hsideTrue : u.2 = true := Bool.eq_true_of_not_eq_false hside
      have hcomp : (n u.1.1).gcd (4 * n K) ∣
          A + u.1.2 + X := by
        simpa [twoWindowModulus, twoWindowOffset, p, hsideTrue] using huComp
      have hne : u.1.2 ≠ sR := by
        intro heq
        apply huNotC
        apply Finset.mem_filter.mpr
        exact ⟨huI, Or.inr ⟨hsideTrue, heq⟩⟩
      have hbound := (right_window_compatible_gcd_le
        (n u.1.1) (n K) A X u.1.2 sR (hpos u.1.1)
          hcomp hspecialRight).resolve_left hne
      have hdist : u.1.2.dist sR ≤ W := by
        rcases le_total u.1.2 sR with hle | hge
        · rw [Nat.dist_eq_sub_of_le hle]
          omega
        · rw [Nat.dist_eq_sub_of_le_right hge]
          omega
      dsimp [twoWindowModulus, p]
      exact hbound.trans <| calc
        2 * u.1.2.dist sR ≤ 2 * W := Nat.mul_le_mul_left 2 hdist
        _ ≤ 4 * W := by omega
  calc
    (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) =
        ∑ u ∈ O, ((R * (twoWindowModulus n u).gcd p) /
          twoWindowModulus n u + 1) := by
            apply Finset.sum_congr rfl
            intro u hu
            rw [div_div_gcd_eq_mul_div R (twoWindowModulus n u) p]
            exact hpos u.1.1
    _ ≤ ∑ u ∈ O, ((R * (4 * W)) / twoWindowModulus n u + 1) := by
      apply Finset.sum_le_sum
      intro u hu
      apply Nat.add_le_add_right
      apply Nat.div_le_div_right
      exact Nat.mul_le_mul_left R (hgcd u hu)
    _ ≤ ∑ u ∈ twoWindowConditions K H W,
        ((R * (4 * W)) / twoWindowModulus n u + 1) :=
      Finset.sum_le_sum_of_subset hOsub
    _ = 2 * W * ∑ j ∈ laterPositionRange K H,
        ((R * (4 * W)) / n j + 1) := by
      simp [twoWindowConditions, twoWindowModulus, Finset.sum_product]
      rw [Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro j hj
      ring

end Research

/-!
# Closing the protected/off-center budget by scaling the CRT period
-/

namespace Research

open scoped BigOperators

set_option maxHeartbeats 1200000

/-- If the reciprocal-index density term is below the polynomial protected
fraction, scaling the canonical CRT period eventually dominates all additive
endpoint costs. -/
theorem exists_nearHalf_protected_budget
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H L J X r v : ℕ) (hKH : K < H)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDouble : ∀ j, K < j → j < H → n j ≠ 2 * n K)
    (hdensity :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let sR := n K + L - r
      let Q := nearHalfCenterReducedModuli n K H W A X p L sR
      let S := centerPrimeFactors Q
      (4 : ℝ) * ((S.card + 1) * (S.card + 2) : ℕ) * W ^ 2 *
        (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) < 1) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C := nearHalfCenterConditions n K H W A X p L sR
    let O := nearHalfOffCenterConditions n K H W A X p L sR
    ∃ R : ℕ, 0 < R ∧
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C := nearHalfCenterConditions n K H W A X p L sR
  let O := nearHalfOffCenterConditions n K H W A X p L sR
  let Q := nearHalfCenterReducedModuli n K H W A X p L sR
  let S := centerPrimeFactors Q
  let D := (S.card + 1) * (S.card + 2)
  let Z := (laterPositionRange K H).card
  let sigma : ℝ := ∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)
  have hdensity' : (4 : ℝ) * D * W ^ 2 * sigma < 1 := by
    simpa [A, W, p, sR, Q, S, D, sigma] using hdensity
  obtain ⟨M, hM, hprotected⟩ :=
    exists_scaled_polynomially_many_nearHalf_center_candidates
      n hpos hmono K H L J X r v hKH hL hX hv hrUpper
        hsRWindow hnoDouble
  have hDpos : 0 < D := by dsimp [D]; positivity
  let delta : ℝ := 2 - 8 * D * W ^ 2 * sigma
  have hdelta : 0 < delta := by
    dsimp [delta]
    nlinarith
  have hden : 0 < delta * (M : ℝ) :=
    mul_pos hdelta (by exact_mod_cast hM)
  obtain ⟨T, hT⟩ := exists_nat_gt
    (((2 * D * W * Z : ℕ) : ℝ) / (delta * (M : ℝ)))
  have hTpos : 0 < T := by
    have hnonneg : 0 ≤ ((2 * D * W * Z : ℕ) : ℝ) /
        (delta * (M : ℝ)) := div_nonneg (by positivity) hden.le
    exact_mod_cast hnonneg.trans_lt hT
  let R := T * M
  have hRpos : 0 < R := mul_pos hTpos hM
  have hendpoint : ((2 * D * W * Z : ℕ) : ℝ) <
      delta * (R : ℝ) := by
    have hm := (div_lt_iff₀ hden).mp hT
    calc
      ((2 * D * W * Z : ℕ) : ℝ) <
          (T : ℝ) * (delta * (M : ℝ)) := hm
      _ = delta * (R : ℝ) := by
        dsimp [R]
        push_cast
        ring
  let B := ∑ u ∈ O, (R / (twoWindowModulus n u /
    (twoWindowModulus n u).gcd p) + 1)
  have hBnat : B ≤ 2 * W * ∑ j ∈ laterPositionRange K H,
      ((R * (4 * W)) / n j + 1) := by
    dsimp [B]
    exact nearHalf_offCenter_budget_le n hpos K H L J X r v R
      hL hX hrUpper hsRWindow
  have hterm (j : ℕ) (hj : j ∈ laterPositionRange K H) :
      ((((R * (4 * W)) / n j + 1 : ℕ) : ℝ)) ≤
        (R : ℝ) * (4 * W : ℕ) * (n j : ℝ)⁻¹ + 1 := by
    have hcast := Nat.cast_div_le (α := ℝ)
      (m := R * (4 * W)) (n := n j)
    push_cast at hcast ⊢
    have hnj : (n j : ℝ) ≠ 0 := by exact_mod_cast (hpos j).ne'
    rw [div_eq_mul_inv] at hcast
    nlinarith
  have hsumReal :
      ((∑ j ∈ laterPositionRange K H,
        ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) ≤
      (R : ℝ) * (4 * W : ℕ) * sigma + Z := by
    rw [Nat.cast_sum]
    calc
      (∑ j ∈ laterPositionRange K H,
          ((((R * (4 * W)) / n j + 1 : ℕ) : ℝ))) ≤
          ∑ j ∈ laterPositionRange K H,
            ((R : ℝ) * (4 * W : ℕ) * (n j : ℝ)⁻¹ + 1) := by
              apply Finset.sum_le_sum
              intro j hj
              exact hterm j hj
      _ = (R : ℝ) * (4 * W : ℕ) * sigma + Z := by
        rw [Finset.sum_add_distrib]
        simp [sigma, Z, Finset.mul_sum]
  have hBreal : (B : ℝ) ≤
      8 * (R : ℝ) * W ^ 2 * sigma + 2 * W * Z := by
    have hc : (B : ℝ) ≤
        ((2 * W * ∑ j ∈ laterPositionRange K H,
          ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) := by
      exact_mod_cast hBnat
    push_cast at hc
    calc
      (B : ℝ) ≤ (2 * W : ℕ) *
          ((∑ j ∈ laterPositionRange K H,
            ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) := by
        simpa using hc
      _ ≤ (2 * W : ℕ) *
          ((R : ℝ) * (4 * W : ℕ) * sigma + Z) := by
        gcongr
      _ = 8 * (R : ℝ) * W ^ 2 * sigma + 2 * W * Z := by
        push_cast
        ring
  have hDBreal : (D * B : ℕ) < 2 * R := by
    have hmain : (D : ℝ) * (B : ℝ) < 2 * (R : ℝ) := by
      have hscaled := mul_le_mul_of_nonneg_left hBreal
        (show (0 : ℝ) ≤ D by positivity)
      dsimp [delta] at hendpoint
      push_cast at hendpoint hscaled
      nlinarith
    exact_mod_cast hmain
  have hprot := hprotected T
  have hBcard : B < (protectedCandidates C (twoWindowOffset A X)
      (twoWindowModulus n) p R).card := by
    have hchain : D * B < D *
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
      calc
        D * B < 2 * R := hDBreal
        _ ≤ D * (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
            simpa [D, R, S, Q, C, A, W, p, sR] using hprot
    exact (Nat.mul_lt_mul_left hDpos).mp hchain
  exact ⟨R, hRpos, hBcard⟩

end Research

/-!
# Protect only an initial center cluster
-/

namespace Research

open scoped BigOperators

/-- All two-window conditions whose position lies in `[G,H)`. -/
def lateTwoWindowConditions (G H W : ℕ) :
    Finset ((ℕ × ℕ) × Bool) :=
  ((Finset.Ico G H).product (Finset.range W)).product Finset.univ

/-- Protecting centers only before `G` leaves the global off-center family plus
all conditions at positions `[G,H)`. -/
theorem partialCenter_offBudget_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K G H L J X r v R : ℕ) (_hKG : K < G) (_hGH : G ≤ H)
    (hL : L < n K) (hX : X = r + (2 * n K) * v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C0 := nearHalfCenterConditions n K G W A X p L sR
    let O := compatibleTwoWindowConditions n K H W A X p \ C0
    (∑ u ∈ O, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1)) ≤
      2 * W * ∑ j ∈ laterPositionRange K H,
        ((R * (4 * W)) / n j + 1) +
      2 * W * ∑ j ∈ Finset.Ico G H,
        ((R * (4 * n K)) / n j + 1) := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C0 := nearHalfCenterConditions n K G W A X p L sR
  let I := compatibleTwoWindowConditions n K H W A X p
  let O := I \ C0
  let Oall := nearHalfOffCenterConditions n K H W A X p L sR
  let Late := lateTwoWindowConditions G H W
  have hOsub : O ⊆ Oall ∪ Late := by
    intro u huO
    have huData := Finset.mem_sdiff.mp huO
    have huI := huData.1
    have huNotC0 := huData.2
    by_cases huCH : u ∈ nearHalfCenterConditions n K H W A X p L sR
    · apply Finset.mem_union.mpr
      right
      have huCompat := (Finset.mem_filter.mp huCH).1
      have huCenter := (Finset.mem_filter.mp huCH).2
      have huBase := (Finset.mem_filter.mp huCompat).1
      have huOuter := Finset.mem_product.mp huBase
      have huInner := Finset.mem_product.mp huOuter.1
      have hjRange := Finset.mem_filter.mp huInner.1
      have hjH := Finset.mem_range.mp hjRange.1
      have hKGj := hjRange.2
      have hGj : G ≤ u.1.1 := by
        by_contra hnot
        have hjG : u.1.1 < G := by omega
        apply huNotC0
        apply Finset.mem_filter.mpr
        refine ⟨?_, huCenter⟩
        apply Finset.mem_filter.mpr
        refine ⟨?_, (Finset.mem_filter.mp huCompat).2⟩
        simp [twoWindowConditions, laterPositionRange, hjG, hKGj,
          Finset.mem_range.mp huInner.2]
      simp [Late, lateTwoWindowConditions, hGj, hjH,
        Finset.mem_range.mp huInner.2]
    · apply Finset.mem_union.mpr
      left
      exact Finset.mem_sdiff.mpr ⟨huI, huCH⟩
  let cost : ((ℕ × ℕ) × Bool) → ℕ := fun u =>
    R / (twoWindowModulus n u / (twoWindowModulus n u).gcd p) + 1
  have hsplit : (∑ u ∈ O, cost u) ≤
      (∑ u ∈ Oall, cost u) + ∑ u ∈ Late, cost u := by
    calc
      (∑ u ∈ O, cost u) ≤ ∑ u ∈ Oall ∪ Late, cost u :=
        Finset.sum_le_sum_of_subset hOsub
      _ ≤ (∑ u ∈ Oall, cost u) + ∑ u ∈ Late, cost u := by
        have hu := Finset.sum_union_inter (s₁ := Oall) (s₂ := Late)
          (f := cost)
        omega
  have hoff := nearHalf_offCenter_budget_le
    n hpos K H L J X r v R hL hX hrUpper hsRWindow
  have hlate : (∑ u ∈ Late, cost u) ≤
      2 * W * ∑ j ∈ Finset.Ico G H,
        ((R * (4 * n K)) / n j + 1) := by
    have hgcd (u : (ℕ × ℕ) × Bool) :
        (twoWindowModulus n u).gcd p ≤ 4 * n K := by
      dsimp [p]
      exact Nat.gcd_le_right _ (mul_pos (by norm_num) (hpos K))
    calc
      (∑ u ∈ Late, cost u) =
          ∑ u ∈ Late, ((R * (twoWindowModulus n u).gcd p) /
            twoWindowModulus n u + 1) := by
              apply Finset.sum_congr rfl
              intro u hu
              dsimp [cost]
              rw [div_div_gcd_eq_mul_div R (twoWindowModulus n u) p]
              exact hpos u.1.1
      _ ≤ ∑ u ∈ Late, ((R * (4 * n K)) /
          twoWindowModulus n u + 1) := by
            apply Finset.sum_le_sum
            intro u hu
            apply Nat.add_le_add_right
            apply Nat.div_le_div_right
            exact Nat.mul_le_mul_left R (hgcd u)
      _ = 2 * W * ∑ j ∈ Finset.Ico G H,
          ((R * (4 * n K)) / n j + 1) := by
            simp [Late, lateTwoWindowConditions, twoWindowModulus,
              Finset.sum_product]
            rw [Finset.mul_sum]
            apply Finset.sum_congr rfl
            intro j hj
            ring
  dsimp [O, I, C0, cost] at hsplit ⊢
  exact hsplit.trans (Nat.add_le_add hoff hlate)

end Research

/-!
# Existence of a budget using only a finite initial center cluster
-/

namespace Research

open scoped BigOperators

set_option maxHeartbeats 1200000

lemma cast_sum_nat_div_add_one_le
    {α : Type*} (I : Finset α) (q : α → ℕ)
    (_hq : ∀ i ∈ I, 0 < q i) (A : ℕ) :
    ((∑ i ∈ I, (A / q i + 1) : ℕ) : ℝ) ≤
      (A : ℝ) * (∑ i ∈ I, ((q i : ℝ)⁻¹)) + I.card := by
  rw [Nat.cast_sum]
  calc
    (∑ i ∈ I, (((A / q i + 1 : ℕ) : ℝ))) ≤
        ∑ i ∈ I, ((A : ℝ) * (q i : ℝ)⁻¹ + 1) := by
          apply Finset.sum_le_sum
          intro i hi
          have hc := Nat.cast_div_le (α := ℝ) (m := A) (n := q i)
          push_cast at hc ⊢
          rw [div_eq_mul_inv] at hc
          linarith
    _ = (A : ℝ) * (∑ i ∈ I, ((q i : ℝ)⁻¹)) + I.card := by
      rw [Finset.sum_add_distrib]
      simp [Finset.mul_sum]

/-- Partial-center analogue of F-084. The initial center cluster controls the
CRT product, while all later centers are absorbed by a second reciprocal tail. -/
theorem exists_partialCenter_protected_budget
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K G H L J X r v : ℕ) (hKG : K < G) (hGH : G ≤ H)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDouble : ∀ j, K < j → j < G → n j ≠ 2 * n K)
    (hdensity :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let sR := n K + L - r
      let Q := nearHalfCenterReducedModuli n K G W A X p L sR
      let S := centerPrimeFactors Q
      let D := (S.card + 1) * (S.card + 2)
      (4 : ℝ) * D *
        (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
          W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) < 1) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C0 := nearHalfCenterConditions n K G W A X p L sR
    let O := compatibleTwoWindowConditions n K H W A X p \ C0
    ∃ R : ℕ, 0 < R ∧
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C0 := nearHalfCenterConditions n K G W A X p L sR
  let O := compatibleTwoWindowConditions n K H W A X p \ C0
  let Q := nearHalfCenterReducedModuli n K G W A X p L sR
  let S := centerPrimeFactors Q
  let D := (S.card + 1) * (S.card + 2)
  let Z₁ := (laterPositionRange K H).card
  let Z₂ := (Finset.Ico G H).card
  let sigma₁ : ℝ := ∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)
  let sigma₂ : ℝ := ∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)
  have hdensity' : (4 : ℝ) * D *
      (W ^ 2 * sigma₁ + W * n K * sigma₂) < 1 := by
    simpa [A, W, p, sR, Q, S, D, sigma₁, sigma₂] using hdensity
  obtain ⟨M, hM, hprotected⟩ :=
    exists_scaled_polynomially_many_nearHalf_center_candidates
      n hpos hmono K G L J X r v hKG hL hX hv hrUpper
        hsRWindow hnoDouble
  have hDpos : 0 < D := by dsimp [D]; positivity
  let delta : ℝ := 2 - 8 * D *
    (W ^ 2 * sigma₁ + W * n K * sigma₂)
  have hdelta : 0 < delta := by
    dsimp [delta]
    nlinarith
  have hden : 0 < delta * (M : ℝ) :=
    mul_pos hdelta (by exact_mod_cast hM)
  obtain ⟨T, hT⟩ := exists_nat_gt
    (((2 * D * W * (Z₁ + Z₂) : ℕ) : ℝ) /
      (delta * (M : ℝ)))
  have hTpos : 0 < T := by
    have hnonneg : 0 ≤ ((2 * D * W * (Z₁ + Z₂) : ℕ) : ℝ) /
        (delta * (M : ℝ)) := div_nonneg (by positivity) hden.le
    exact_mod_cast hnonneg.trans_lt hT
  let R := T * M
  have hRpos : 0 < R := mul_pos hTpos hM
  have hendpoint : ((2 * D * W * (Z₁ + Z₂) : ℕ) : ℝ) <
      delta * (R : ℝ) := by
    have hm := (div_lt_iff₀ hden).mp hT
    calc
      ((2 * D * W * (Z₁ + Z₂) : ℕ) : ℝ) <
          (T : ℝ) * (delta * (M : ℝ)) := hm
      _ = delta * (R : ℝ) := by
        dsimp [R]
        push_cast
        ring
  let B := ∑ u ∈ O, (R / (twoWindowModulus n u /
    (twoWindowModulus n u).gcd p) + 1)
  have hBnat : B ≤
      2 * W * ∑ j ∈ laterPositionRange K H,
        ((R * (4 * W)) / n j + 1) +
      2 * W * ∑ j ∈ Finset.Ico G H,
        ((R * (4 * n K)) / n j + 1) := by
    dsimp [B]
    exact partialCenter_offBudget_le n hpos K G H L J X r v R
      hKG hGH hL hX hrUpper hsRWindow
  have hsum₁ := cast_sum_nat_div_add_one_le
    (laterPositionRange K H) n (fun j hj => hpos j) (R * (4 * W))
  have hsum₂ := cast_sum_nat_div_add_one_le
    (Finset.Ico G H) n (fun j hj => hpos j) (R * (4 * n K))
  have hBreal : (B : ℝ) ≤
      8 * (R : ℝ) *
          (W ^ 2 * sigma₁ + W * n K * sigma₂) +
        2 * W * (Z₁ + Z₂) := by
    have hc : (B : ℝ) ≤
        ((2 * W * ∑ j ∈ laterPositionRange K H,
            ((R * (4 * W)) / n j + 1) +
          2 * W * ∑ j ∈ Finset.Ico G H,
            ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) := by
      exact_mod_cast hBnat
    push_cast at hc
    have hsum₁' :
        ((∑ j ∈ laterPositionRange K H,
          ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) ≤
          (R * (4 * W) : ℕ) * sigma₁ + Z₁ := by
      simpa [sigma₁, Z₁] using hsum₁
    have hsum₂' :
        ((∑ j ∈ Finset.Ico G H,
          ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) ≤
          (R * (4 * n K) : ℕ) * sigma₂ + Z₂ := by
      simpa [sigma₂, Z₂] using hsum₂
    have hs1 :
        ((∑ j ∈ laterPositionRange K H,
          ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) ≤
          (R : ℝ) * (4 * W : ℕ) * sigma₁ + Z₁ := by
      calc
        _ ≤ ((R * (4 * W) : ℕ) : ℝ) * sigma₁ + Z₁ := hsum₁'
        _ = (R : ℝ) * (4 * W : ℕ) * sigma₁ + Z₁ := by
          push_cast
          ring
    have hs2 :
        ((∑ j ∈ Finset.Ico G H,
          ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) ≤
          (R : ℝ) * (4 * n K : ℕ) * sigma₂ + Z₂ := by
      calc
        _ ≤ ((R * (4 * n K) : ℕ) : ℝ) * sigma₂ + Z₂ := hsum₂'
        _ = (R : ℝ) * (4 * n K : ℕ) * sigma₂ + Z₂ := by
          push_cast
          ring
    calc
      (B : ℝ) ≤
          (2 * W : ℕ) *
            ((∑ j ∈ laterPositionRange K H,
              ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) +
          (2 * W : ℕ) *
            ((∑ j ∈ Finset.Ico G H,
              ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) := by
        simpa using hc
      _ ≤ (2 * W : ℕ) *
            ((R : ℝ) * (4 * W : ℕ) * sigma₁ + Z₁) +
          (2 * W : ℕ) *
            ((R : ℝ) * (4 * n K : ℕ) * sigma₂ + Z₂) := by
        exact add_le_add
          (mul_le_mul_of_nonneg_left hs1 (by positivity))
          (mul_le_mul_of_nonneg_left hs2 (by positivity))
      _ = 8 * (R : ℝ) *
          (W ^ 2 * sigma₁ + W * n K * sigma₂) +
            2 * W * (Z₁ + Z₂) := by
        push_cast
        ring
  have hDBreal : (D * B : ℕ) < 2 * R := by
    have hmain : (D : ℝ) * (B : ℝ) < 2 * (R : ℝ) := by
      have hscaled := mul_le_mul_of_nonneg_left hBreal
        (show (0 : ℝ) ≤ D by positivity)
      dsimp [delta] at hendpoint
      push_cast at hendpoint hscaled
      nlinarith
    exact_mod_cast hmain
  have hprot := hprotected T
  have hBcard : B < (protectedCandidates C0 (twoWindowOffset A X)
      (twoWindowModulus n) p R).card := by
    have hchain : D * B < D *
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
      calc
        D * B < 2 * R := hDBreal
        _ ≤ D * (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
            simpa [D, R, S, Q, C0, A, W, p, sR] using hprot
    exact (Nat.mul_lt_mul_left hDpos).mp hchain
  exact ⟨R, hRpos, hBcard⟩

end Research

/-!
# Elementary cardinality bound for protected center primes
-/

namespace Research

/-- There are at most two aligned center conditions per later position. -/
theorem nearHalfCenterConditions_card_le
    (n : ℕ → ℕ) (K G W A X p L sR : ℕ) :
    (nearHalfCenterConditions n K G W A X p L sR).card ≤
      2 * (laterPositionRange K G).card := by
  classical
  let C := nearHalfCenterConditions n K G W A X p L sR
  let T := (laterPositionRange K G).product (Finset.univ : Finset Bool)
  let f : ((ℕ × ℕ) × Bool) → ℕ × Bool := fun u => (u.1.1, u.2)
  have hmap : Set.MapsTo f (C : Set ((ℕ × ℕ) × Bool)) (T : Set (ℕ × Bool)) := by
    intro u huC
    have huCompat := (Finset.mem_filter.mp huC).1
    have huBase := (Finset.mem_filter.mp huCompat).1
    have huOuter := Finset.mem_product.mp huBase
    have huInner := Finset.mem_product.mp huOuter.1
    exact Finset.mem_product.mpr ⟨huInner.1, by simp⟩
  have hinj : Set.InjOn f (C : Set ((ℕ × ℕ) × Bool)) := by
    intro u hu v hv huv
    have huCenter := (Finset.mem_filter.mp hu).2
    have hvCenter := (Finset.mem_filter.mp hv).2
    change (u.1.1, u.2) = (v.1.1, v.2) at huv
    have hj : u.1.1 = v.1.1 :=
      congrArg (fun z : ℕ × Bool => z.1) huv
    have hb : u.2 = v.2 :=
      congrArg (fun z : ℕ × Bool => z.2) huv
    have hs : u.1.2 = v.1.2 := by
      rcases huCenter with huL | huR
      · have huSide := huL.1
        have huOff := huL.2
        rcases hvCenter with hvL | hvR
        · omega
        · rw [huSide, hvR.1] at hb
          contradiction
      · have huSide := huR.1
        have huOff := huR.2
        rcases hvCenter with hvL | hvR
        · rw [huSide, hvL.1] at hb
          contradiction
        · omega
    apply Prod.ext
    · exact Prod.ext hj hs
    · exact hb
  have hc := Finset.card_le_card_of_injOn f hmap hinj
  dsimp [C, T] at hc ⊢
  simpa [mul_comm] using hc

/-- Canonical center primes inherit the same two-per-position bound. -/
theorem nearHalf_centerPrimeFactors_card_le
    (n : ℕ → ℕ) (K G W A X p L sR : ℕ) :
    (centerPrimeFactors
      (nearHalfCenterReducedModuli n K G W A X p L sR)).card ≤
      2 * (laterPositionRange K G).card := by
  calc
    (centerPrimeFactors
      (nearHalfCenterReducedModuli n K G W A X p L sR)).card ≤
        (nearHalfCenterReducedModuli n K G W A X p L sR).card :=
      Finset.card_image_le
    _ ≤ (nearHalfCenterConditions n K G W A X p L sR).card :=
      Finset.card_image_le
    _ ≤ 2 * (laterPositionRange K G).card :=
      nearHalfCenterConditions_card_le n K G W A X p L sR

/-- Crude position-only version. -/
theorem nearHalf_centerPrimeFactors_card_le_two_mul_G
    (n : ℕ → ℕ) (K G W A X p L sR : ℕ) :
    (centerPrimeFactors
      (nearHalfCenterReducedModuli n K G W A X p L sR)).card ≤ 2 * G := by
  refine (nearHalf_centerPrimeFactors_card_le n K G W A X p L sR).trans ?_
  apply Nat.mul_le_mul_left 2
  calc
    (laterPositionRange K G).card ≤ (Finset.range G).card :=
      Finset.card_le_card (Finset.filter_subset _ _)
    _ = G := Finset.card_range G

end Research

/-!
# Finite cutoff sums bounded by the geometric reciprocal-index tail
-/

namespace Research

open scoped BigOperators

lemma laterPositionRange_eq_Ico_succ (K H : ℕ) :
    laterPositionRange K H = Finset.Ico (K + 1) H := by
  ext j
  simp [laterPositionRange]
  omega

/-- Any finite later-position reciprocal sum is bounded by F-049's full
geometric tail. -/
theorem sum_laterPositionRange_inv_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K H : ℕ) :
    (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) ≤
      c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹ := by
  have hsummable := summable_inv_indices_from n hpos c hc hratio K
  have hfinite :
      (∑ r ∈ Finset.range (H - (K + 1)),
        ((n (K + 1 + r) : ℝ)⁻¹)) ≤
      ∑' r : ℕ, ((n (K + 1 + r) : ℝ)⁻¹) :=
    hsummable.sum_le_tsum _ (fun r hr => by positivity)
  calc
    (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) =
        ∑ r ∈ Finset.range (H - (K + 1)),
          ((n (K + 1 + r) : ℝ)⁻¹) := by
            rw [laterPositionRange_eq_Ico_succ,
              Finset.sum_Ico_eq_sum_range]
    _ ≤ ∑' r : ℕ, ((n (K + 1 + r) : ℝ)⁻¹) := hfinite
    _ ≤ c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹ :=
      tsum_inv_indices_from_le n hpos c hc hratio K

/-- The finite interval `[G,H)` is bounded by the tail based at `G-1`. -/
theorem sum_Ico_inv_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (G H : ℕ) (hG : 0 < G) :
    (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) ≤
      c⁻¹ * (1 - c⁻¹)⁻¹ * (n (G - 1) : ℝ)⁻¹ := by
  have hGs : G - 1 + 1 = G := by omega
  have h := sum_laterPositionRange_inv_le
    n hpos c hc hratio (G - 1) H
  rw [laterPositionRange_eq_Ico_succ, hGs] at h
  exact h

/-- A direct sufficient numerical condition for F-086, using only `G`, `W`,
and two geometric-tail endpoints. -/
theorem partialCenter_density_of_geometric_bounds
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K G H W A X p L sR : ℕ) (hG : 0 < G)
    (hbound :
      (4 : ℝ) * ((2 * G + 1) * (2 * G + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n (G - 1) : ℝ)⁻¹)) < 1) :
    let Q := nearHalfCenterReducedModuli n K G W A X p L sR
    let S := centerPrimeFactors Q
    let D := (S.card + 1) * (S.card + 2)
    (4 : ℝ) * D *
      (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) < 1 := by
  let Q := nearHalfCenterReducedModuli n K G W A X p L sR
  let S := centerPrimeFactors Q
  let D := (S.card + 1) * (S.card + 2)
  have hScard : S.card ≤ 2 * G := by
    exact nearHalf_centerPrimeFactors_card_le_two_mul_G
      n K G W A X p L sR
  have hD : D ≤ (2 * G + 1) * (2 * G + 2) := by
    dsimp [D]
    exact Nat.mul_le_mul (Nat.add_le_add_right hScard 1)
      (Nat.add_le_add_right hScard 2)
  have htail₁ := sum_laterPositionRange_inv_le
    n hpos c hc hratio K H
  have htail₂ := sum_Ico_inv_le n hpos c hc hratio G H hG
  have hnonneg₁ : 0 ≤
      (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) := by positivity
  have hnonneg₂ : 0 ≤
      (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) := by positivity
  have hinner :
      W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) ≤
      W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K *
          (c⁻¹ * (1 - c⁻¹)⁻¹ * (n (G - 1) : ℝ)⁻¹) := by
    gcongr
  have hDreal : (D : ℝ) ≤
      (((2 * G + 1) * (2 * G + 2) : ℕ) : ℝ) := by exact_mod_cast hD
  have hnonnegInner : 0 ≤
      W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) := by
    positivity
  calc
    (4 : ℝ) * D *
      (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) ≤
      4 * (((2 * G + 1) * (2 * G + 2) : ℕ) : ℝ) *
      (W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K *
          (c⁻¹ * (1 - c⁻¹)⁻¹ * (n (G - 1) : ℝ)⁻¹)) := by
      gcongr
    _ < 1 := hbound

end Research


/-!
# Size bound for the canonical center CRT period
-/

namespace Research

open scoped BigOperators

/-- Every canonical prime used to protect near-half centers before position `G`
is at most the last selected index before `G`. -/
theorem nearHalf_centerPrime_le_last
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K G W A X p L sR z : ℕ)
    (hz : z ∈ centerPrimeFactors
      (nearHalfCenterReducedModuli n K G W A X p L sR)) :
    z ≤ n (G - 1) := by
  obtain ⟨q, hqQ, hqz⟩ :=
    (mem_centerPrimeFactors_iff
      (nearHalfCenterReducedModuli n K G W A X p L sR) z).mp hz
  obtain ⟨u, huC, hqu⟩ := Finset.mem_image.mp hqQ
  rw [← hqz, ← hqu]
  have huCompat := (Finset.mem_filter.mp huC).1
  have huBase := (Finset.mem_filter.mp huCompat).1
  have huOuter := Finset.mem_product.mp huBase
  have huInner := Finset.mem_product.mp huOuter.1
  have huPos := Finset.mem_filter.mp huInner.1
  have hjG := Finset.mem_range.mp huPos.1
  have hqpos : 0 < n u.1.1 / (n u.1.1).gcd p := by
    apply Nat.div_pos
    · exact Nat.gcd_le_left p (hpos u.1.1)
    · exact Nat.gcd_pos_of_pos_left p (hpos u.1.1)
  have hmin := Nat.minFac_le hqpos
  have hdiv : n u.1.1 / (n u.1.1).gcd p ≤ n u.1.1 :=
    Nat.div_le_self _ _
  have hjLast : u.1.1 ≤ G - 1 := by omega
  exact hmin.trans (hdiv.trans (hmono.monotone hjLast))

/-- The canonical-prime CRT period protecting the near-half centers before
`G` is at most `n_(G-1)^(2G)`.  This crude but explicit bound is sufficient
for choosing a later cutoff, because the ratio gap gives exponential growth in
the position after `G`. -/
theorem nearHalf_centerPrime_product_le_last_pow
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K G W A X p L sR : ℕ) :
    let S := centerPrimeFactors
      (nearHalfCenterReducedModuli n K G W A X p L sR)
    (∏ z ∈ S, z) ≤ (n (G - 1)) ^ (2 * G) := by
  let S := centerPrimeFactors
    (nearHalfCenterReducedModuli n K G W A X p L sR)
  have hprod : (∏ z ∈ S, z) ≤ (n (G - 1)) ^ S.card := by
    apply Finset.prod_le_pow_card
    intro z hz
    exact nearHalf_centerPrime_le_last n hpos hmono
      K G W A X p L sR z hz
  have hcard : S.card ≤ 2 * G :=
    nearHalf_centerPrimeFactors_card_le_two_mul_G
      n K G W A X p L sR
  exact hprod.trans (pow_le_pow_right₀ (by
    have := hpos (G - 1)
    omega) hcard)

end Research

namespace Research

/-- Scaled strengthening of `exists_period_with_polynomially_many_protected_centers`:
the same protected density is available in every positive number of full CRT
periods, so endpoint costs can be made negligible. -/
theorem exists_exact_period_with_scaled_polynomially_many_protected_centers
    {ι : Type*} [DecidableEq ι]
    (Q : Finset ℕ) (C : Finset ι) (side : ι → Bool)
    (a qmod : ι → ℕ) (step v : ℕ)
    (hQ3 : ∀ q ∈ Q, 3 ≤ q)
    (hQodd : ∀ q ∈ Q, Odd q)
    (hcover : ∀ u ∈ C, ∃ q ∈ Q, ∀ t,
      qmod u ∣ a u + step * t →
        if side u then q ∣ v + 1 + 2 * t else q ∣ 4 * t + 1) :
    let S := centerPrimeFactors Q
    ∃ M : ℕ, 0 < M ∧ M = ∏ z ∈ S, z ∧ ∀ T : ℕ,
      2 * (T * M) ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C a qmod step (T * M)).card := by
  classical
  let S := centerPrimeFactors Q
  have hSdata := centerPrimeFactors_prime_odd_ge_three Q hQ3 hQodd
  have hSprime : ∀ z ∈ S, z.Prime := fun z hz => (hSdata z hz).1
  have hSodd : ∀ z ∈ S, Odd z := fun z hz => (hSdata z hz).2.1
  obtain ⟨p, hprod, hpPrime, hp3, hpTwo, hpPair, hEnumCovers,
      hsafeBound⟩ :=
    exists_prime_enumeration_with_global_safe_bound_onto
      S v hSprime hSodd
  let M := ∏ i, p i
  have hMpos : 0 < M := by
    dsimp [M]
    apply Finset.prod_pos
    intro i hi
    exact lt_of_lt_of_le (by norm_num) (hp3 i)
  refine ⟨M, hMpos, hprod, ?_⟩
  intro T
  have hsubset : replicatedGlobalCenterSafeResidues p v T ⊆
      protectedCandidates C a qmod step (T * M) := by
    intro t htRep
    obtain ⟨z, hzProd, rfl⟩ := Finset.mem_image.mp htRep
    have hzT := Finset.mem_range.mp (Finset.mem_product.mp hzProd).1
    have hzSafe := (Finset.mem_product.mp hzProd).2
    have hzData := Finset.mem_filter.mp hzSafe
    apply Finset.mem_filter.mpr
    refine ⟨Finset.mem_range.mpr ?_, ?_⟩
    · have hzlt := Finset.mem_range.mp hzData.1
      dsimp [M]
      nlinarith
    · intro u huC hbad
      obtain ⟨q, hqQ, himp⟩ := hcover u huC
      have hform := himp (z.2 + M * z.1) hbad
      have hqne : q ≠ 1 := by have := hQ3 q hqQ; omega
      let prime := q.minFac
      have hprimeS : prime ∈ S := by
        apply (mem_centerPrimeFactors_iff Q prime).mpr
        exact ⟨q, hqQ, rfl⟩
      obtain ⟨i, hpi⟩ := hEnumCovers prime hprimeS
      have hsafeI := hzData.2 i
      have hpM : p i ∣ M := by
        dsimp [M]
        exact Finset.dvd_prod_of_mem p (by simp)
      have hformReduceLeft : p i ∣ 4 * z.2 + 1 ↔
          p i ∣ 4 * (z.2 + M * z.1) + 1 := by
        have hd : p i ∣ 4 * M * z.1 := by
          simpa [mul_comm, mul_left_comm, mul_assoc] using
            dvd_mul_of_dvd_left (dvd_mul_of_dvd_left hpM 4) z.1
        rw [show 4 * (z.2 + M * z.1) + 1 =
          4 * M * z.1 + (4 * z.2 + 1) by ring]
        exact Nat.dvd_add_iff_right hd
      have hformReduceRight : p i ∣ v + 1 + 2 * z.2 ↔
          p i ∣ v + 1 + 2 * (z.2 + M * z.1) := by
        have hd : p i ∣ 2 * M * z.1 := by
          simpa [mul_comm, mul_left_comm, mul_assoc] using
            dvd_mul_of_dvd_left (dvd_mul_of_dvd_left hpM 2) z.1
        rw [show v + 1 + 2 * (z.2 + M * z.1) =
          2 * M * z.1 + (v + 1 + 2 * z.2) by ring]
        exact Nat.dvd_add_iff_right hd
      have hprimeDvd : prime ∣ q := Nat.minFac_dvd q
      split at hform
      · apply hsafeI.2
        rw [hformReduceRight]
        simpa [hpi] using dvd_trans hprimeDvd hform
      · apply hsafeI.1
        rw [hformReduceLeft]
        simpa [hpi] using dvd_trans hprimeDvd hform
  have hcard := Finset.card_le_card hsubset
  have hrepCard := card_replicatedGlobalCenterSafeResidues p v T hMpos
  have hbaseScaled := Nat.mul_le_mul_left T hsafeBound
  calc
    2 * (T * M) = T * (2 * (∏ i, p i)) := by dsimp [M]; ring
    _ ≤ T * ((S.card + 1) * (S.card + 2) *
        (globalCenterSafeResidues p v).card) := hbaseScaled
    _ = (S.card + 1) * (S.card + 2) *
        (replicatedGlobalCenterSafeResidues p v T).card := by
      rw [hrepCard]
      ring
    _ ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C a qmod step (T * M)).card :=
      Nat.mul_le_mul_left _ hcard


end Research

namespace Research

/-- If the near-half shift puts both aligned offsets inside the windows and no
later condition is the exact double `2n_K`, the actual center family satisfies
F-080's polynomial protected-count conclusion. -/
theorem exists_exact_scaled_polynomially_many_nearHalf_center_candidates
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H L J X r v : ℕ) (_hKH : K < H)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (_hsRWindow : n K + L - r < L + 1 + J)
    (hnoDouble : ∀ j, K < j → j < H → n j ≠ 2 * n K) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C := nearHalfCenterConditions n K H W A X p L sR
    let Q := nearHalfCenterReducedModuli n K H W A X p L sR
    let S := centerPrimeFactors Q
    ∃ M : ℕ, 0 < M ∧ M = ∏ z ∈ S, z ∧ ∀ T : ℕ,
      2 * (T * M) ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p (T * M)).card := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C := nearHalfCenterConditions n K H W A X p L sR
  let Q := nearHalfCenterReducedModuli n K H W A X p L sR
  have hn := hpos K
  have hcenterLeft : A + L = n K := by dsimp [A]; omega
  have hvOdd : Odd (v + 1) := by
    obtain ⟨z, hz⟩ := hv
    exact ⟨z, by omega⟩
  have hcenterRight : A + sR + X = 2 * n K * (v + 1) := by
    have hAr : A + L = n K := hcenterLeft
    have hsrr : sR + r = n K + L := by dsimp [sR]; omega
    rw [hX]
    calc
      A + sR + (r + 2 * n K * v) =
          2 * n K + 2 * n K * v := by omega
      _ = 2 * n K * (v + 1) := by ring
  have hQdata : ∀ q ∈ Q, Odd q ∧ 3 ≤ q := by
    intro q hqQ
    obtain ⟨u, huC, rfl⟩ := Finset.mem_image.mp hqQ
    have huCompat := (Finset.mem_filter.mp huC).1
    have huCenter := (Finset.mem_filter.mp huC).2
    have huBase := (Finset.mem_filter.mp huCompat).1
    have huComp := (Finset.mem_filter.mp huCompat).2
    have huPair := Finset.mem_product.mp (Finset.mem_product.mp huBase).1
    have hjData := Finset.mem_filter.mp huPair.1
    have hjH := Finset.mem_range.mp hjData.1
    have hKj := hjData.2
    have hnj := hpos u.1.1
    have hnlt : n K < n u.1.1 := hmono hKj
    rcases huCenter with hleft | hright
    · have hside : u.2 = false := hleft.1
      have hoff : u.1.2 = L := hleft.2
      have hcompLeft : (n u.1.1).gcd (4 * n K) ∣ n K := by
        simpa [twoWindowModulus, twoWindowOffset, p, A,
          hside, hoff, hcenterLeft] using huComp
      exact left_center_reduced_odd_ge_three
        (n u.1.1) (n K) hnj hn hnlt hcompLeft
    · have hside : u.2 = true := hright.1
      have hoff : u.1.2 = sR := hright.2
      have hcompRight : (n u.1.1).gcd (4 * n K) ∣
          2 * n K * (v + 1) := by
        simpa [twoWindowModulus, twoWindowOffset, p, A,
          sR, hside, hoff, hcenterRight] using huComp
      have hd := right_center_reduced_odd_and_eq_one
        (n u.1.1) (n K) (v + 1) hnj hn hnlt hvOdd hcompRight
      refine ⟨hd.1, ?_⟩
      have hqpos : 0 < n u.1.1 / (n u.1.1).gcd (4 * n K) := hd.1.pos
      have hqne : n u.1.1 / (n u.1.1).gcd (4 * n K) ≠ 1 := by
        intro heq
        have heqDouble := hd.2 heq
        exact hnoDouble u.1.1 hKj hjH heqDouble
      have hqneTwo : n u.1.1 / (n u.1.1).gcd (4 * n K) ≠ 2 := by
        intro heq
        obtain ⟨z, hz⟩ := hd.1
        omega
      change 3 ≤ n u.1.1 / (n u.1.1).gcd (4 * n K)
      omega
  apply exists_exact_period_with_scaled_polynomially_many_protected_centers
    Q C (fun u => u.2) (twoWindowOffset A X) (twoWindowModulus n)
      p v
  · exact fun q hq => (hQdata q hq).2
  · exact fun q hq => (hQdata q hq).1
  · intro u huC
    let q0 := twoWindowModulus n u /
      (twoWindowModulus n u).gcd p
    refine ⟨q0, ?_, ?_⟩
    · apply Finset.mem_image.mpr
      exact ⟨u, huC, rfl⟩
    · intro t hbad
      have huCompat := (Finset.mem_filter.mp huC).1
      have huCenter := (Finset.mem_filter.mp huC).2
      have huComp := (Finset.mem_filter.mp huCompat).2
      let g := (n u.1.1).gcd (4 * n K)
      have hg : 0 < g := Nat.gcd_pos_of_pos_left (4 * n K) (hpos u.1.1)
      have hqFactor : n u.1.1 = g * q0 := by
        dsimp [g, q0, p]
        exact (Nat.mul_div_cancel' (Nat.gcd_dvd_left _ _)).symm
      rcases huCenter with hleft | hright
      · have hside : u.2 = false := hleft.1
        have hoff : u.1.2 = L := hleft.2
        have hgN : g ∣ n K := by
          simpa [g, p, twoWindowModulus, twoWindowOffset,
            A, hside, hoff, hcenterLeft] using huComp
        let u0 := n K / g
        have hnFactor : n K = g * u0 := by
          dsimp [u0]
          exact (Nat.mul_div_cancel' hgN).symm
        have hcop : q0.Coprime u0 := by
          dsimp [q0, u0, g, p]
          exact coprime_reduced_modulus_factor
            (n u.1.1) (4 * n K) (n K) (hpos u.1.1)
              hgN (by exact ⟨4, by ring⟩)
        simp only [hside, Bool.false_eq_true, ↓reduceIte]
        apply (left_center_divisibility_iff_reduced
          (n u.1.1) (n K) g q0 u0 t hg hqFactor hnFactor hcop).mp
        simpa [twoWindowModulus, twoWindowOffset, p, A,
          hside, hoff, hcenterLeft] using hbad
      · have hside : u.2 = true := hright.1
        have hoff : u.1.2 = sR := hright.2
        have hgAligned : g ∣ 2 * n K * (v + 1) := by
          simpa [g, p, twoWindowModulus, twoWindowOffset,
            A, sR, hside, hoff, hcenterRight] using huComp
        have hgTwo : g ∣ 2 * n K :=
          dvd_two_mul_of_dvd_four_mul_and_two_mul_odd
            g (n K) (v + 1) hvOdd
            (by dsimp [g]; exact Nat.gcd_dvd_right _ _) hgAligned
        let u0 := (2 * n K) / g
        have htwoFactor : 2 * n K = g * u0 := by
          dsimp [u0]
          exact (Nat.mul_div_cancel' hgTwo).symm
        have hcop : q0.Coprime u0 := by
          dsimp [q0, u0, g, p]
          exact coprime_reduced_modulus_factor
            (n u.1.1) (4 * n K) (2 * n K) (hpos u.1.1)
              hgTwo (by exact ⟨2, by ring⟩)
        simp only [hside, ite_true]
        apply (right_center_divisibility_iff_reduced
          (n u.1.1) g q0 u0 v t hg hqFactor hcop).mp
        have haligned : A + u.1.2 + X + p * t =
            g * u0 * (v + 1 + 2 * t) := by
          rw [hoff, hcenterRight, ← htwoFactor]
          dsimp [p]
          ring
        simpa [twoWindowModulus, twoWindowOffset, hside, haligned]
          using hbad


end Research


/-!
# A bounded range for the partial-center protected sieve
-/

namespace Research

open scoped BigOperators

set_option maxHeartbeats 1200000

/-- A strengthened, quantitative version of F-086.  With the slightly stronger
margin `8 D Z < 1`, the protected range can be chosen no larger than the base
CRT period plus the explicit additive endpoint cost.  Exposing this upper bound
is what permits a later lacunary cutoff to dominate the entire search window. -/
theorem exists_bounded_partialCenter_protected_budget
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K G H L J X r v : ℕ) (hKG : K < G) (hGH : G ≤ H)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDouble : ∀ j, K < j → j < G → n j ≠ 2 * n K)
    (hdensity :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let sR := n K + L - r
      let Q := nearHalfCenterReducedModuli n K G W A X p L sR
      let S := centerPrimeFactors Q
      let D := (S.card + 1) * (S.card + 2)
      (8 : ℝ) * D *
        (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
          W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) < 1) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C0 := nearHalfCenterConditions n K G W A X p L sR
    let O := compatibleTwoWindowConditions n K H W A X p \ C0
    let Q := nearHalfCenterReducedModuli n K G W A X p L sR
    let S := centerPrimeFactors Q
    let D := (S.card + 1) * (S.card + 2)
    let Z₁ := (laterPositionRange K H).card
    let Z₂ := (Finset.Ico G H).card
    ∃ M R : ℕ,
      0 < M ∧ M = ∏ z ∈ S, z ∧ 0 < R ∧
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      R ≤ M + 2 * D * W * (Z₁ + Z₂) := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C0 := nearHalfCenterConditions n K G W A X p L sR
  let O := compatibleTwoWindowConditions n K H W A X p \ C0
  let Q := nearHalfCenterReducedModuli n K G W A X p L sR
  let S := centerPrimeFactors Q
  let D := (S.card + 1) * (S.card + 2)
  let Z₁ := (laterPositionRange K H).card
  let Z₂ := (Finset.Ico G H).card
  let sigma₁ : ℝ := ∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)
  let sigma₂ : ℝ := ∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)
  have hdensity' : (8 : ℝ) * D *
      (W ^ 2 * sigma₁ + W * n K * sigma₂) < 1 := by
    simpa [A, W, p, sR, Q, S, D, sigma₁, sigma₂] using hdensity
  obtain ⟨M, hM, hMeq, hprotected⟩ :=
    exists_exact_scaled_polynomially_many_nearHalf_center_candidates
      n hpos hmono K G L J X r v hKG hL hX hv hrUpper
        hsRWindow hnoDouble
  have hDpos : 0 < D := by dsimp [D]; positivity
  let delta : ℝ := 2 - 8 * D *
    (W ^ 2 * sigma₁ + W * n K * sigma₂)
  have hdeltaOne : 1 < delta := by
    dsimp [delta]
    nlinarith
  have hdelta : 0 < delta := lt_trans (by norm_num) hdeltaOne
  have hden : 0 < delta * (M : ℝ) :=
    mul_pos hdelta (by exact_mod_cast hM)
  let E : ℕ := 2 * D * W * (Z₁ + Z₂)
  let q : ℝ := (E : ℝ) / (delta * (M : ℝ))
  let T : ℕ := ⌊q⌋₊ + 1
  have hqnonneg : 0 ≤ q := by
    dsimp [q]
    exact div_nonneg (by positivity) hden.le
  have hqT : q < (T : ℝ) := by
    dsimp [T]
    simpa using (Nat.lt_floor_add_one q)
  have hTpos : 0 < T := by dsimp [T]; omega
  let R := T * M
  have hRpos : 0 < R := mul_pos hTpos hM
  have hendpoint : (E : ℝ) < delta * (R : ℝ) := by
    have hm : (E : ℝ) < (T : ℝ) * (delta * (M : ℝ)) := by
      apply (div_lt_iff₀ hden).mp
      simpa [q] using hqT
    calc
      (E : ℝ) < (T : ℝ) * (delta * (M : ℝ)) := hm
      _ = delta * (R : ℝ) := by
        dsimp [R]
        push_cast
        ring
  have hRbound : R ≤ M + E := by
    have hfloor : ((⌊q⌋₊ : ℕ) : ℝ) ≤ q := Nat.floor_le hqnonneg
    have hTle : (T : ℝ) ≤ q + 1 := by
      dsimp [T]
      push_cast
      linarith
    have hqM : q * (M : ℝ) = (E : ℝ) / delta := by
      dsimp [q]
      field_simp
    have hdivle : (E : ℝ) / delta ≤ (E : ℝ) := by
      apply (div_le_iff₀ hdelta).mpr
      have hEnonneg : (0 : ℝ) ≤ E := by positivity
      nlinarith
    have hreal : (R : ℝ) ≤ (M + E : ℕ) := by
      calc
        (R : ℝ) = (T : ℝ) * (M : ℝ) := by simp [R]
        _ ≤ (q + 1) * (M : ℝ) := by gcongr
        _ = q * (M : ℝ) + (M : ℝ) := by ring
        _ = (E : ℝ) / delta + (M : ℝ) := by rw [hqM]
        _ ≤ (E : ℝ) + (M : ℝ) := by gcongr
        _ = (M + E : ℕ) := by push_cast; ring
    exact_mod_cast hreal
  let B := ∑ u ∈ O, (R / (twoWindowModulus n u /
    (twoWindowModulus n u).gcd p) + 1)
  have hBnat : B ≤
      2 * W * ∑ j ∈ laterPositionRange K H,
        ((R * (4 * W)) / n j + 1) +
      2 * W * ∑ j ∈ Finset.Ico G H,
        ((R * (4 * n K)) / n j + 1) := by
    dsimp [B]
    exact partialCenter_offBudget_le n hpos K G H L J X r v R
      hKG hGH hL hX hrUpper hsRWindow
  have hsum₁ := cast_sum_nat_div_add_one_le
    (laterPositionRange K H) n (fun j hj => hpos j) (R * (4 * W))
  have hsum₂ := cast_sum_nat_div_add_one_le
    (Finset.Ico G H) n (fun j hj => hpos j) (R * (4 * n K))
  have hBreal : (B : ℝ) ≤
      8 * (R : ℝ) *
          (W ^ 2 * sigma₁ + W * n K * sigma₂) +
        2 * W * (Z₁ + Z₂) := by
    have hc : (B : ℝ) ≤
        ((2 * W * ∑ j ∈ laterPositionRange K H,
            ((R * (4 * W)) / n j + 1) +
          2 * W * ∑ j ∈ Finset.Ico G H,
            ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) := by
      exact_mod_cast hBnat
    push_cast at hc
    have hsum₁' :
        ((∑ j ∈ laterPositionRange K H,
          ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) ≤
          (R * (4 * W) : ℕ) * sigma₁ + Z₁ := by
      simpa [sigma₁, Z₁] using hsum₁
    have hsum₂' :
        ((∑ j ∈ Finset.Ico G H,
          ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) ≤
          (R * (4 * n K) : ℕ) * sigma₂ + Z₂ := by
      simpa [sigma₂, Z₂] using hsum₂
    have hs1 :
        ((∑ j ∈ laterPositionRange K H,
          ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) ≤
          (R : ℝ) * (4 * W : ℕ) * sigma₁ + Z₁ := by
      calc
        _ ≤ ((R * (4 * W) : ℕ) : ℝ) * sigma₁ + Z₁ := hsum₁'
        _ = (R : ℝ) * (4 * W : ℕ) * sigma₁ + Z₁ := by
          push_cast
          ring
    have hs2 :
        ((∑ j ∈ Finset.Ico G H,
          ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) ≤
          (R : ℝ) * (4 * n K : ℕ) * sigma₂ + Z₂ := by
      calc
        _ ≤ ((R * (4 * n K) : ℕ) : ℝ) * sigma₂ + Z₂ := hsum₂'
        _ = (R : ℝ) * (4 * n K : ℕ) * sigma₂ + Z₂ := by
          push_cast
          ring
    calc
      (B : ℝ) ≤
          (2 * W : ℕ) *
            ((∑ j ∈ laterPositionRange K H,
              ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) +
          (2 * W : ℕ) *
            ((∑ j ∈ Finset.Ico G H,
              ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) := by
        simpa using hc
      _ ≤ (2 * W : ℕ) *
            ((R : ℝ) * (4 * W : ℕ) * sigma₁ + Z₁) +
          (2 * W : ℕ) *
            ((R : ℝ) * (4 * n K : ℕ) * sigma₂ + Z₂) := by
        exact add_le_add
          (mul_le_mul_of_nonneg_left hs1 (by positivity))
          (mul_le_mul_of_nonneg_left hs2 (by positivity))
      _ = 8 * (R : ℝ) *
          (W ^ 2 * sigma₁ + W * n K * sigma₂) +
            2 * W * (Z₁ + Z₂) := by
        push_cast
        ring
  have hDBreal : (D * B : ℕ) < 2 * R := by
    have hmain : (D : ℝ) * (B : ℝ) < 2 * (R : ℝ) := by
      have hscaled := mul_le_mul_of_nonneg_left hBreal
        (show (0 : ℝ) ≤ D by positivity)
      dsimp [delta, E] at hendpoint
      push_cast at hendpoint hscaled
      nlinarith
    exact_mod_cast hmain
  have hprot := hprotected T
  have hBcard : B < (protectedCandidates C0 (twoWindowOffset A X)
      (twoWindowModulus n) p R).card := by
    have hchain : D * B < D *
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
      calc
        D * B < 2 * R := hDBreal
        _ ≤ D * (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
            simpa [D, R, S, Q, C0, A, W, p, sR] using hprot
    exact (Nat.mul_lt_mul_left hDpos).mp hchain
  refine ⟨M, R, hM, ?_, hRpos, hBcard, ?_⟩
  · simpa [S, Q, A, W, p, sR] using hMeq
  · simpa [E, D, W, Z₁, Z₂, S, Q, A, p, sR] using hRbound

end Research


/-!
# A ratio gap eventually dominates every affine cutoff cost
-/

namespace Research

open Filter Topology

/-- Under a uniform ratio gap, selected indices eventually dominate any fixed
affine function of the position, even when the comparison starts at an
arbitrary position `G`. -/
theorem exists_ratio_cutoff_dominating_affine
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (G U V : ℕ) :
    ∃ H : ℕ, G ≤ H ∧ U + V * H < n H := by
  let A : ℕ := U + V * G + V
  let eps : ℝ := (n G : ℝ) / (A + 1 : ℕ)
  have heps : 0 < eps := by
    dsimp [eps]
    exact div_pos (by exact_mod_cast hpos G) (by positivity)
  have htend : Tendsto (fun t : ℕ => (t : ℝ) / c ^ t)
      Filter.atTop (𝓝 0) := by
    simpa only [pow_one] using
      (tendsto_pow_const_div_const_pow_of_one_lt 1 hc)
  have hevent : ∀ᶠ t : ℕ in Filter.atTop,
      (t : ℝ) / c ^ t < eps :=
    htend.eventually (Iio_mem_nhds heps)
  rw [Filter.eventually_atTop] at hevent
  obtain ⟨T, hT⟩ := hevent
  let t := max T 1
  have htT : T ≤ t := le_max_left _ _
  have htpos : 0 < t := lt_of_lt_of_le (by norm_num) (le_max_right T 1)
  have hratioSmall : (t : ℝ) / c ^ t < eps := hT t htT
  have hcpos : 0 < c := lt_trans (by norm_num) hc
  have hcpow : 0 < c ^ t := pow_pos hcpos _
  have hApos : (0 : ℝ) < (A + 1 : ℕ) := by positivity
  have hcross : (t : ℝ) * (A + 1 : ℕ) < (n G : ℝ) * c ^ t := by
    have h := (div_lt_div_iff₀ hcpow hApos).mp hratioSmall
    simpa [eps, mul_comm, mul_left_comm, mul_assoc] using h
  let H := G + t
  have hleft : (U + V * H : ℕ) < (n G : ℝ) * c ^ t := by
    have hcast : ((U + V * H : ℕ) : ℝ) ≤ (A : ℝ) * t := by
      have htone : (1 : ℝ) ≤ t := by exact_mod_cast htpos
      calc
        ((U + V * H : ℕ) : ℝ) =
            ((U + V * G : ℕ) : ℝ) + (V : ℝ) * t := by
          dsimp [H]
          push_cast
          ring
        _ ≤ ((U + V * G : ℕ) : ℝ) * t + (V : ℝ) * t := by
          have hx : ((U + V * G : ℕ) : ℝ) ≤
              ((U + V * G : ℕ) : ℝ) * t := by
            calc
              ((U + V * G : ℕ) : ℝ) =
                  ((U + V * G : ℕ) : ℝ) * 1 := by ring
              _ ≤ ((U + V * G : ℕ) : ℝ) * t :=
                mul_le_mul_of_nonneg_left htone (by positivity)
          linarith
        _ = (A : ℝ) * t := by
          dsimp [A]
          push_cast
          ring
    have hstrict : (A : ℝ) * t < (t : ℝ) * (A + 1 : ℕ) := by
      calc
        (A : ℝ) * t < (A : ℝ) * t + t := by
          exact lt_add_of_pos_right _ (by exact_mod_cast htpos)
        _ = (t : ℝ) * (A + 1 : ℕ) := by
          push_cast
          ring
    exact hcast.trans_lt (hstrict.trans hcross)
  have hgrowth := ratio_gap_geometric_growth_from
    n c hcpos.le hratio G t
  refine ⟨H, by dsimp [H]; omega, ?_⟩
  have hreal : ((U + V * H : ℕ) : ℝ) < (n H : ℕ) := by
    calc
      ((U + V * H : ℕ) : ℝ) < (n G : ℝ) * c ^ t := hleft
      _ = c ^ t * (n G : ℝ) := by ring
      _ ≤ n (G + t) := hgrowth
      _ = n H := by rfl
  exact_mod_cast hreal

end Research


/-!
# Closing the protected-sieve cutoff circularity
-/

namespace Research

open scoped BigOperators

/-- Factor-eight version of F-088's finite geometric-tail substitution. -/
theorem partialCenter_density_eight_of_geometric_bounds
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K G H W A X p L sR : ℕ) (hG : 0 < G)
    (hbound :
      (8 : ℝ) * ((2 * G + 1) * (2 * G + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n (G - 1) : ℝ)⁻¹)) < 1) :
    let Q := nearHalfCenterReducedModuli n K G W A X p L sR
    let S := centerPrimeFactors Q
    let D := (S.card + 1) * (S.card + 2)
    (8 : ℝ) * D *
      (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) < 1 := by
  let Q := nearHalfCenterReducedModuli n K G W A X p L sR
  let S := centerPrimeFactors Q
  let D := (S.card + 1) * (S.card + 2)
  have hScard : S.card ≤ 2 * G :=
    nearHalf_centerPrimeFactors_card_le_two_mul_G
      n K G W A X p L sR
  have hD : D ≤ (2 * G + 1) * (2 * G + 2) := by
    dsimp [D]
    exact Nat.mul_le_mul (Nat.add_le_add_right hScard 1)
      (Nat.add_le_add_right hScard 2)
  have htail₁ := sum_laterPositionRange_inv_le
    n hpos c hc hratio K H
  have htail₂ := sum_Ico_inv_le n hpos c hc hratio G H hG
  have hinner :
      W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) ≤
      W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K *
          (c⁻¹ * (1 - c⁻¹)⁻¹ * (n (G - 1) : ℝ)⁻¹) := by
    gcongr
  have hDreal : (D : ℝ) ≤
      (((2 * G + 1) * (2 * G + 2) : ℕ) : ℝ) := by
    exact_mod_cast hD
  calc
    (8 : ℝ) * D *
      (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) ≤
      8 * (((2 * G + 1) * (2 * G + 2) : ℕ) : ℝ) *
      (W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K *
          (c⁻¹ * (1 - c⁻¹)⁻¹ * (n (G - 1) : ℝ)⁻¹)) := by
      gcongr
    _ < 1 := hbound

/-- Once a fixed initial center cluster has enough geometric tail density, one
can choose a later cutoff and a protected candidate range simultaneously.  The
canonical-prime product bound and F-090 make the range only affine in the
cutoff, while the ratio gap makes `n_H` dominate that affine cost. -/
theorem exists_partialCenter_budget_with_valid_cutoff
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K G L J X r v : ℕ) (hKG : K < G)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDouble : ∀ j, K < j → j < G → n j ≠ 2 * n K)
    (hdensity :
      let W := L + 1 + J
      (8 : ℝ) * ((2 * G + 1) * (2 * G + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n (G - 1) : ℝ)⁻¹)) < 1) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C0 := nearHalfCenterConditions n K G W A X p L sR
    ∃ H R : ℕ, G ≤ H ∧ 0 < R ∧
      let O := compatibleTwoWindowConditions n K H W A X p \ C0
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let Q := nearHalfCenterReducedModuli n K G W A X p L sR
  let S := centerPrimeFactors Q
  let D := (S.card + 1) * (S.card + 2)
  let Dmax := (2 * G + 1) * (2 * G + 2)
  let Mmax := (n (G - 1)) ^ (2 * G)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  obtain ⟨H, hGH, haffine⟩ :=
    exists_ratio_cutoff_dominating_affine n hpos c hc hratio G U V
  have hGpos : 0 < G := lt_of_le_of_lt (Nat.zero_le K) hKG
  have hdensityH :
      let Q' := nearHalfCenterReducedModuli n K G W A X p L sR
      let S' := centerPrimeFactors Q'
      let D' := (S'.card + 1) * (S'.card + 2)
      (8 : ℝ) * D' *
        (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
          W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) < 1 := by
    apply partialCenter_density_eight_of_geometric_bounds
      n hpos c hc hratio K G H W A X p L sR hGpos
    simpa [W] using hdensity
  obtain ⟨M, R, hM, hMeq, hR, hbudget, hRbound⟩ :=
    exists_bounded_partialCenter_protected_budget
      n hpos hmono K G H L J X r v hKG hGH hL hX hv hrUpper
        hsRWindow hnoDouble hdensityH
  have hMle : M ≤ Mmax := by
    rw [hMeq]
    dsimp [Mmax]
    exact nearHalf_centerPrime_product_le_last_pow
      n hpos hmono K G W A X p L sR
  have hDle : D ≤ Dmax := by
    have hScard : S.card ≤ 2 * G :=
      nearHalf_centerPrimeFactors_card_le_two_mul_G
        n K G W A X p L sR
    dsimp [D, Dmax]
    exact Nat.mul_le_mul (Nat.add_le_add_right hScard 1)
      (Nat.add_le_add_right hScard 2)
  have hZ₁ : (laterPositionRange K H).card ≤ H := by
    calc
      (laterPositionRange K H).card ≤ (Finset.range H).card :=
        Finset.card_le_card (Finset.filter_subset _ _)
      _ = H := Finset.card_range H
  have hZ₂ : (Finset.Ico G H).card ≤ H := by
    have hcard : (Finset.Ico G H).card = H - G := by simp
    omega
  have hZsum : (laterPositionRange K H).card +
      (Finset.Ico G H).card ≤ 2 * H := by omega
  have hendpointCost :
      2 * D * W * ((laterPositionRange K H).card +
        (Finset.Ico G H).card) ≤ 4 * Dmax * W * H := by
    calc
      2 * D * W * ((laterPositionRange K H).card +
          (Finset.Ico G H).card) ≤
          2 * Dmax * W * (2 * H) := by
            gcongr
      _ = 4 * Dmax * W * H := by ring
  have hRcoarse : R ≤ Mmax + 4 * Dmax * W * H := by
    calc
      R ≤ M + 2 * D * W * ((laterPositionRange K H).card +
          (Finset.Ico G H).card) := by
            simpa [D, S, Q, A, W, p, sR] using hRbound
      _ ≤ Mmax + 4 * Dmax * W * H :=
        Nat.add_le_add hMle hendpointCost
  have hcut : A + p * R + X + W < n H := by
    have hcost : A + p * R + X + W ≤ U + V * H := by
      calc
        A + p * R + X + W ≤
            A + p * (Mmax + 4 * Dmax * W * H) + X + W := by
          gcongr
        _ = U + V * H := by
          dsimp [U, V]
          ring
    exact hcost.trans_lt haffine
  refine ⟨H, R, hGH, hR, ?_⟩
  simpa [A, W, p, sR] using And.intro hbudget hcut

end Research


/-!
# Adaptive center cutoffs and sharp tail/product bounds
-/

namespace Research

open scoped BigOperators

/-- The reciprocal-index tail beginning *at* `G` is controlled by the actual
value `n_G`.  Unlike the predecessor-based version, this retains the full
benefit of an exceptionally large jump at `G`. -/
theorem sum_Ico_inv_le_from
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (G H : ℕ) :
    (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) ≤
      (1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹ := by
  let ρ : ℝ := c⁻¹
  have hcpos : 0 < c := lt_trans (by norm_num) hc
  have hρpos : 0 < ρ := inv_pos.mpr hcpos
  have hρlt : ρ < 1 := by
    dsimp [ρ]
    exact (inv_lt_one₀ hcpos).2 hc
  have hρnorm : ‖ρ‖ < 1 := by
    simpa [Real.norm_eq_abs, abs_of_pos hρpos]
  have hmajor : Summable (fun r : ℕ => ρ ^ r * (n G : ℝ)⁻¹) :=
    (summable_geometric_of_norm_lt_one hρnorm).mul_right _
  have hterm (r : ℕ) : (n (G + r) : ℝ)⁻¹ ≤
      ρ ^ r * (n G : ℝ)⁻¹ := by
    have hgrowth := ratio_gap_geometric_growth_from
      n c hcpos.le hratio G r
    have hdenpos : 0 < c ^ r * (n G : ℝ) :=
      mul_pos (pow_pos hcpos _) (by exact_mod_cast hpos G)
    calc
      (n (G + r) : ℝ)⁻¹ ≤ (c ^ r * (n G : ℝ))⁻¹ :=
        inv_anti₀ hdenpos hgrowth
      _ = ρ ^ r * (n G : ℝ)⁻¹ := by
        simp [ρ, mul_inv_rev, inv_pow, mul_comm]
  have hsum : Summable (fun r : ℕ => (n (G + r) : ℝ)⁻¹) :=
    hmajor.of_nonneg_of_le (fun r => by positivity) hterm
  have hfinite :
      (∑ r ∈ Finset.range (H - G), ((n (G + r) : ℝ)⁻¹)) ≤
        ∑' r : ℕ, ((n (G + r) : ℝ)⁻¹) :=
    hsum.sum_le_tsum _ (fun r hr => by positivity)
  calc
    (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) =
        ∑ r ∈ Finset.range (H - G), ((n (G + r) : ℝ)⁻¹) := by
      rw [Finset.sum_Ico_eq_sum_range]
    _ ≤ ∑' r : ℕ, ((n (G + r) : ℝ)⁻¹) := hfinite
    _ ≤ ∑' r : ℕ, ρ ^ r * (n G : ℝ)⁻¹ :=
      hsum.tsum_le_tsum hterm hmajor
    _ = (1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹ := by
      rw [tsum_mul_right, tsum_geometric_of_norm_lt_one hρnorm]

/-- There is a first selected position after `K` crossing any threshold `B≥K`;
all intervening selected values are at most `B`. -/
theorem exists_first_index_above
    (n : ℕ → ℕ) (hmono : StrictMono n)
    (K B : ℕ) (hKB : K ≤ B) :
    ∃ G : ℕ, K < G ∧ B < n G ∧
      ∀ j, K < j → j < G → n j ≤ B := by
  have hex : ∃ G : ℕ, K < G ∧ B < n G := by
    refine ⟨B + 1, by omega, ?_⟩
    exact lt_of_lt_of_le (Nat.lt_succ_self B) hmono.le_apply
  let G := Nat.find hex
  have hG := Nat.find_spec hex
  refine ⟨G, hG.1, hG.2, ?_⟩
  intro j hKj hjG
  by_contra hnot
  have hjCandidate : K < j ∧ B < n j := ⟨hKj, by omega⟩
  have hGj := Nat.find_min' hex hjCandidate
  omega

/-- If all protected center positions before `G` have selected value at most
`B`, then every canonical center prime is at most `B`. -/
theorem nearHalf_centerPrime_le_threshold
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K G W A X p L sR B z : ℕ)
    (hbound : ∀ j, K < j → j < G → n j ≤ B)
    (hz : z ∈ centerPrimeFactors
      (nearHalfCenterReducedModuli n K G W A X p L sR)) :
    z ≤ B := by
  obtain ⟨q, hqQ, hqz⟩ :=
    (mem_centerPrimeFactors_iff
      (nearHalfCenterReducedModuli n K G W A X p L sR) z).mp hz
  obtain ⟨u, huC, hqu⟩ := Finset.mem_image.mp hqQ
  rw [← hqz, ← hqu]
  have huCompat := (Finset.mem_filter.mp huC).1
  have huBase := (Finset.mem_filter.mp huCompat).1
  have huOuter := Finset.mem_product.mp huBase
  have huInner := Finset.mem_product.mp huOuter.1
  have huPos := Finset.mem_filter.mp huInner.1
  have hjG := Finset.mem_range.mp huPos.1
  have hKj := huPos.2
  have hqpos : 0 < n u.1.1 / (n u.1.1).gcd p := by
    apply Nat.div_pos
    · exact Nat.gcd_le_left p (hpos u.1.1)
    · exact Nat.gcd_pos_of_pos_left p (hpos u.1.1)
  exact (Nat.minFac_le hqpos).trans <|
    (Nat.div_le_self _ _).trans (hbound u.1.1 hKj hjG)

/-- Adaptive version of F-089: the canonical CRT period is bounded by the
threshold to the power twice the *number of intervening positions*, rather
than twice the absolute cutoff position. -/
theorem nearHalf_centerPrime_product_le_threshold_pow
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K G W A X p L sR B : ℕ) (hB : 0 < B)
    (hbound : ∀ j, K < j → j < G → n j ≤ B) :
    let S := centerPrimeFactors
      (nearHalfCenterReducedModuli n K G W A X p L sR)
    let d := (laterPositionRange K G).card
    (∏ z ∈ S, z) ≤ B ^ (2 * d) := by
  let S := centerPrimeFactors
    (nearHalfCenterReducedModuli n K G W A X p L sR)
  let d := (laterPositionRange K G).card
  have hprod : (∏ z ∈ S, z) ≤ B ^ S.card := by
    apply Finset.prod_le_pow_card
    intro z hz
    exact nearHalf_centerPrime_le_threshold
      n hpos K G W A X p L sR B z hbound hz
  have hcard : S.card ≤ 2 * d :=
    nearHalf_centerPrimeFactors_card_le
      n K G W A X p L sR
  exact hprod.trans (pow_le_pow_right₀ (by omega) hcard)

end Research


/-!
# Adaptive protected cutoff using an actual threshold crossing
-/

namespace Research

open scoped BigOperators

/-- Substitute the sharp center count and the actual `n_G` tail into F-090's
factor-eight density condition. -/
theorem partialCenter_density_eight_of_adaptive_bounds
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K G H W A X p L sR : ℕ)
    (hbound :
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K *
            ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1) :
    let Q := nearHalfCenterReducedModuli n K G W A X p L sR
    let S := centerPrimeFactors Q
    let D := (S.card + 1) * (S.card + 2)
    (8 : ℝ) * D *
      (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) < 1 := by
  let Q := nearHalfCenterReducedModuli n K G W A X p L sR
  let S := centerPrimeFactors Q
  let d := (laterPositionRange K G).card
  let D := (S.card + 1) * (S.card + 2)
  let Dmax := (2 * d + 1) * (2 * d + 2)
  have hScard : S.card ≤ 2 * d :=
    nearHalf_centerPrimeFactors_card_le n K G W A X p L sR
  have hD : D ≤ Dmax := by
    dsimp [D, Dmax]
    exact Nat.mul_le_mul (Nat.add_le_add_right hScard 1)
      (Nat.add_le_add_right hScard 2)
  have htail₁ := sum_laterPositionRange_inv_le
    n hpos c hc hratio K H
  have htail₂ := sum_Ico_inv_le_from n hpos c hc hratio G H
  have hinner :
      W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) ≤
      W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹) := by
    gcongr
  have hDreal : (D : ℝ) ≤ (Dmax : ℝ) := by exact_mod_cast hD
  calc
    (8 : ℝ) * D *
      (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) ≤
      8 * (Dmax : ℝ) *
      (W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) := by
      gcongr
    _ < 1 := by simpa [d, Dmax] using hbound

/-- Adaptive analogue of F-092.  The protected CRT period now depends only on
an a priori threshold `B` for the intervening selected values and on their
actual count `d`; the post-center tail uses the actual crossing value `n_G`. -/
theorem exists_adaptive_partialCenter_budget_with_valid_cutoff
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K G B L J X r v : ℕ) (hKG : K < G) (hB : 0 < B)
    (hvalues : ∀ j, K < j → j < G → n j ≤ B)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDouble : ∀ j, K < j → j < G → n j ≠ 2 * n K)
    (hdensity :
      let W := L + 1 + J
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K *
            ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C0 := nearHalfCenterConditions n K G W A X p L sR
    ∃ H R : ℕ, G ≤ H ∧ 0 < R ∧
      let O := compatibleTwoWindowConditions n K H W A X p \ C0
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let Q := nearHalfCenterReducedModuli n K G W A X p L sR
  let S := centerPrimeFactors Q
  let d := (laterPositionRange K G).card
  let D := (S.card + 1) * (S.card + 2)
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := B ^ (2 * d)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  obtain ⟨H, hGH, haffine⟩ :=
    exists_ratio_cutoff_dominating_affine n hpos c hc hratio G U V
  have hdensityH :
      let Q' := nearHalfCenterReducedModuli n K G W A X p L sR
      let S' := centerPrimeFactors Q'
      let D' := (S'.card + 1) * (S'.card + 2)
      (8 : ℝ) * D' *
        (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
          W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) < 1 := by
    apply partialCenter_density_eight_of_adaptive_bounds
      n hpos c hc hratio K G H W A X p L sR
    simpa [W, d] using hdensity
  obtain ⟨M, R, hM, hMeq, hR, hbudget, hRbound⟩ :=
    exists_bounded_partialCenter_protected_budget
      n hpos hmono K G H L J X r v hKG hGH hL hX hv hrUpper
        hsRWindow hnoDouble hdensityH
  have hMle : M ≤ Mmax := by
    rw [hMeq]
    dsimp [Mmax]
    exact nearHalf_centerPrime_product_le_threshold_pow
      n hpos K G W A X p L sR B hB hvalues
  have hDle : D ≤ Dmax := by
    have hScard : S.card ≤ 2 * d :=
      nearHalf_centerPrimeFactors_card_le n K G W A X p L sR
    dsimp [D, Dmax]
    exact Nat.mul_le_mul (Nat.add_le_add_right hScard 1)
      (Nat.add_le_add_right hScard 2)
  have hZ₁ : (laterPositionRange K H).card ≤ H := by
    calc
      (laterPositionRange K H).card ≤ (Finset.range H).card :=
        Finset.card_le_card (Finset.filter_subset _ _)
      _ = H := Finset.card_range H
  have hZ₂ : (Finset.Ico G H).card ≤ H := by
    have hcard : (Finset.Ico G H).card = H - G := by simp
    omega
  have hZsum : (laterPositionRange K H).card +
      (Finset.Ico G H).card ≤ 2 * H := by omega
  have hendpointCost :
      2 * D * W * ((laterPositionRange K H).card +
        (Finset.Ico G H).card) ≤ 4 * Dmax * W * H := by
    calc
      2 * D * W * ((laterPositionRange K H).card +
          (Finset.Ico G H).card) ≤
          2 * Dmax * W * (2 * H) := by gcongr
      _ = 4 * Dmax * W * H := by ring
  have hRcoarse : R ≤ Mmax + 4 * Dmax * W * H := by
    calc
      R ≤ M + 2 * D * W * ((laterPositionRange K H).card +
          (Finset.Ico G H).card) := by
            simpa [D, S, Q, A, W, p, sR] using hRbound
      _ ≤ Mmax + 4 * Dmax * W * H :=
        Nat.add_le_add hMle hendpointCost
  have hcut : A + p * R + X + W < n H := by
    have hcost : A + p * R + X + W ≤ U + V * H := by
      calc
        A + p * R + X + W ≤
            A + p * (Mmax + 4 * Dmax * W * H) + X + W := by
          gcongr
        _ = U + V * H := by
          dsimp [U, V]
          ring
    exact hcost.trans_lt haffine
  refine ⟨H, R, hGH, hR, ?_⟩
  simpa [A, W, p, sR] using And.intro hbudget hcut

end Research


/-!
# Position bound for an adaptive threshold crossing
-/

namespace Research

/-- If the geometric lower bound crosses `B` within `Q` steps, the first actual
crossing after `K` occurs within those `Q` steps and has at most `Q`
intervening positions. -/
theorem exists_first_index_above_with_position_bound
    (n : ℕ → ℕ) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K B Q : ℕ) (hKB : n K ≤ B)
    (hcross : (B : ℝ) < c ^ Q * (n K : ℝ)) :
    ∃ G : ℕ, K < G ∧ B < n G ∧
      (∀ j, K < j → j < G → n j ≤ B) ∧
      G ≤ K + Q ∧ (laterPositionRange K G).card ≤ Q := by
  have hKleB : K ≤ B := by
    exact le_trans (hmono.le_apply) hKB
  obtain ⟨G, hKG, hBG, hfirst⟩ :=
    exists_first_index_above n hmono K B hKleB
  have hcpos : 0 < c := lt_trans (by norm_num) hc
  have hgrowth := ratio_gap_geometric_growth_from
    n c hcpos.le hratio K Q
  have hBQ : B < n (K + Q) := by exact_mod_cast hcross.trans_le hgrowth
  have hGQ : G ≤ K + Q := by
    by_contra hnot
    have hKQ : K < K + Q := by
      by_contra hQ0
      have : Q = 0 := by omega
      subst Q
      simp at hcross
      have hnKB : (n K : ℝ) ≤ B := by exact_mod_cast hKB
      linarith
    have hle := hfirst (K + Q) hKQ (by omega)
    omega
  have hcard : (laterPositionRange K G).card ≤ Q := by
    have hsub : laterPositionRange K G ⊆ Finset.Ico (K + 1) (K + Q + 1) := by
      intro j hj
      have hd := Finset.mem_filter.mp hj
      have hjG := Finset.mem_range.mp hd.1
      have hKj := hd.2
      simp only [Finset.mem_Ico]
      omega
    calc
      (laterPositionRange K G).card ≤
          (Finset.Ico (K + 1) (K + Q + 1)).card :=
        Finset.card_le_card hsub
      _ = Q := by simp
  exact ⟨G, hKG, hBG, hfirst, hGQ, hcard⟩

end Research


/-!
# Uniform norm-gate bounds below a selected-index cutoff
-/

namespace Research

open Real goldenRatio

/-- A common upper bound for every principal coefficient tail whose exponent is
below the `H`-th selected index. -/
noncomputable def cutoffTailCap (H : ℕ) : ℝ :=
  (H : ℝ) * (1 - φ⁻¹)⁻¹ + φ⁻¹ / (1 - φ⁻¹) ^ 2

/-- A common upper bound for every conjugate residual whose exponent is below
the `H`-th selected index. -/
noncomputable def cutoffConjugateCap (Tconj : ℝ) (H : ℕ) : ℝ :=
  |Tconj| + (H : ℝ) * (1 - φ⁻¹)⁻¹

lemma indexCountTailBound_le_cutoffTailCap
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    {x H : ℕ} (hx : x < n H) :
    indexCountTailBound n x ≤ cutoffTailCap H := by
  have hc := selectedIndexCount_lt_index n hpos hmono hx
  unfold indexCountTailBound cutoffTailCap
  have hfactor : 0 ≤ (1 - φ⁻¹)⁻¹ := by
    exact inv_nonneg.mpr (sub_nonneg.mpr
      ((inv_le_one₀ Real.goldenRatio_pos).mpr Real.one_lt_goldenRatio.le))
  have hcast : (selectedIndexCount n x : ℝ) ≤ H := by exact_mod_cast hc
  have hm := mul_le_mul_of_nonneg_right hcast hfactor
  linarith

lemma indexCountConjugateBound_le_cutoffConjugateCap
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (Tconj : ℝ) {x H : ℕ} (hx : x < n H) :
    indexCountConjugateBound n Tconj x ≤ cutoffConjugateCap Tconj H := by
  have hc := selectedIndexCount_lt_index n hpos hmono hx
  unfold indexCountConjugateBound cutoffConjugateCap
  have hfactor : 0 ≤ (1 - φ⁻¹)⁻¹ := by
    exact inv_nonneg.mpr (sub_nonneg.mpr
      ((inv_le_one₀ Real.goldenRatio_pos).mpr Real.one_lt_goldenRatio.le))
  have hcast : (selectedIndexCount n x : ℝ) ≤ H := by exact_mod_cast hc
  have hm := mul_le_mul_of_nonneg_right hcast hfactor
  linarith

/-- If the full two-window candidate range lies below `n_H`, the two numerical
norm hypotheses in F-066 follow from two inequalities involving only the common
caps at `H`. -/
theorem uniform_protected_norm_bounds_of_cutoff
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (a : ℤ) (b : ℕ)
    (K H L J A X R : ℕ)
    (hcut : A + (4 * n K) * R + X + (L + 1 + J) < n H)
    (hpostCap :
      (φ⁻¹) ^ (J + 1) * (2 * cutoffTailCap H) < 1)
    (hpreCap :
      (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap
          (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H) <
        (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    (∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (N + X + L + 1 + J)) < 1) ∧
    (∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (N + X + L)) *
        (indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) N +
          indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) (N + X)) <
      (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) := by
  let Tc : ℝ := -((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))
  have hp : 0 < 4 * n K := by nlinarith [hpos K]
  have htailCapNonneg : 0 ≤ cutoffTailCap H := by
    unfold cutoffTailCap
    have hr0 : 0 < φ⁻¹ := inv_pos.mpr Real.goldenRatio_pos
    have hden : 0 < 1 - φ⁻¹ := sub_pos.mpr
      (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
    positivity
  have hconjCapNonneg : 0 ≤ cutoffConjugateCap Tc H := by
    unfold cutoffConjugateCap
    have hden : 0 < 1 - φ⁻¹ := sub_pos.mpr
      (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
    positivity
  constructor
  · intro t ht
    let N := A + (4 * n K) * t
    have hpt : (4 * n K) * t < (4 * n K) * R :=
      (Nat.mul_lt_mul_left hp).mpr ht
    have hx₁ : N + L + 1 + J < n H := by dsimp [N]; omega
    have hx₂ : N + X + L + 1 + J < n H := by dsimp [N]; omega
    have hb₁ := indexCountTailBound_le_cutoffTailCap
      n hpos hmono hx₁
    have hb₂ := indexCountTailBound_le_cutoffTailCap
      n hpos hmono hx₂
    calc
      (φ⁻¹) ^ (J + 1) *
          (indexCountTailBound n (N + L + 1 + J) +
            indexCountTailBound n (N + X + L + 1 + J)) ≤
        (φ⁻¹) ^ (J + 1) * (2 * cutoffTailCap H) := by
          gcongr
          linarith
      _ < 1 := hpostCap
  · intro t ht
    let N := A + (4 * n K) * t
    have hpt : (4 * n K) * t < (4 * n K) * R :=
      (Nat.mul_lt_mul_left hp).mpr ht
    have hxN : N < n H := by dsimp [N]; omega
    have hxNX : N + X < n H := by dsimp [N]; omega
    have hxL : N + L < n H := by dsimp [N]; omega
    have hxXL : N + X + L < n H := by dsimp [N]; omega
    have ht₁ := indexCountTailBound_le_cutoffTailCap
      n hpos hmono hxL
    have ht₂ := indexCountTailBound_le_cutoffTailCap
      n hpos hmono hxXL
    have hc₁ := indexCountConjugateBound_le_cutoffConjugateCap
      n hpos hmono Tc hxN
    have hc₂ := indexCountConjugateBound_le_cutoffConjugateCap
      n hpos hmono Tc hxNX
    have htailSum :
        indexCountTailBound n (N + L) +
          indexCountTailBound n (N + X + L) ≤
        2 * cutoffTailCap H := by linarith
    have hconjSum :
        indexCountConjugateBound n Tc N +
          indexCountConjugateBound n Tc (N + X) ≤
        2 * cutoffConjugateCap Tc H := by linarith
    have hconjSumNonneg : 0 ≤
        indexCountConjugateBound n Tc N +
          indexCountConjugateBound n Tc (N + X) := by
      unfold indexCountConjugateBound
      have hden : 0 < 1 - φ⁻¹ := sub_pos.mpr
        (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
      positivity
    calc
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (N + X + L)) *
        (indexCountConjugateBound n Tc N +
          indexCountConjugateBound n Tc (N + X)) ≤
        (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
          (2 * cutoffConjugateCap Tc H) := by
            gcongr
      _ < (((5 * b : ℕ) : ℝ)⁻¹) ^ 2 := by
        simpa [Tc] using hpreCap

end Research


/-!
# An explicit ratio-gap cutoff for affine costs
-/

namespace Research

/-- Explicit version of F-091.  If a fixed block of `q` ratio steps grows by at
least two, define `A=U+VG`, `B=Vq`, `C=A+2B+1`, `s=2C`, and
`H=G+qs`.  Then `U+VH<n_H`.  The formula gives an upper bound on the cutoff
position needed for the norm caps. -/
theorem explicit_ratio_cutoff_dominating_affine
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (G U V : ℕ) :
    let A := U + V * G
    let B := V * q
    let C := A + 2 * B + 1
    let s := 2 * C
    let H := G + q * s
    G ≤ H ∧ U + V * H < n H := by
  let A := U + V * G
  let B := V * q
  let C := A + 2 * B + 1
  let s := 2 * C
  let H := G + q * s
  have htarget : U + V * H = A + B * s := by
    dsimp [H, A, B]
    ring
  have hpoly : A + B * s < 2 * C ^ 2 + 1 := by
    dsimp [s, C]
    nlinarith
  have htwoPow : 2 * C ^ 2 + 1 ≤ 2 ^ (2 * C) :=
    Nat.two_mul_sq_add_one_le_two_pow_two_mul C
  have htargetPow : U + V * H < 2 ^ s := by
    rw [htarget]
    calc
      A + B * s < 2 * C ^ 2 + 1 := hpoly
      _ ≤ 2 ^ (2 * C) := htwoPow
      _ = 2 ^ s := by rfl
  have hcpos : 0 < c := lt_trans (by norm_num) hc
  have hbasePow : (2 : ℝ) ^ s ≤ (c ^ q) ^ s := by
    exact (pow_le_pow_left₀ (by norm_num) hq) s
  have hnGone : (1 : ℝ) ≤ n G := by exact_mod_cast hpos G
  have hgrowth := ratio_gap_geometric_growth_from
    n c hcpos.le hratio G (q * s)
  refine ⟨by omega, ?_⟩
  have hreal : ((U + V * H : ℕ) : ℝ) < (n H : ℕ) := by
    calc
      ((U + V * H : ℕ) : ℝ) < ((2 ^ s : ℕ) : ℝ) := by
        exact_mod_cast htargetPow
      _ = (2 : ℝ) ^ s := by norm_num
      _ ≤ (c ^ q) ^ s := hbasePow
      _ = c ^ (q * s) := (pow_mul c q s).symm
      _ ≤ c ^ (q * s) * (n G : ℝ) := by
        exact le_mul_of_one_le_right (pow_nonneg hcpos.le _) hnGone
      _ ≤ n (G + q * s) := hgrowth
      _ = n H := rfl
  exact_mod_cast hreal

end Research


/-!
# Explicit adaptive protected cutoff
-/

namespace Research

open scoped BigOperators

/-- The adaptive protected budget at any cutoff already known to dominate its
explicit affine range cost. -/
theorem adaptive_partialCenter_budget_at_affine_cutoff
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K G B L J X r v H : ℕ) (hKG : K < G) (hB : 0 < B)
    (hvalues : ∀ j, K < j → j < G → n j ≤ B)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDouble : ∀ j, K < j → j < G → n j ≠ 2 * n K)
    (hdensity :
      let W := L + 1 + J
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1)
    (hGH : G ≤ H)
    (haffine :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let Mmax := B ^ (2 * d)
      let U := A + p * Mmax + X + W
      let V := 4 * p * Dmax * W
      U + V * H < n H) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C0 := nearHalfCenterConditions n K G W A X p L sR
    ∃ R : ℕ, 0 < R ∧
      let O := compatibleTwoWindowConditions n K H W A X p \ C0
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let Q := nearHalfCenterReducedModuli n K G W A X p L sR
  let S := centerPrimeFactors Q
  let d := (laterPositionRange K G).card
  let D := (S.card + 1) * (S.card + 2)
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := B ^ (2 * d)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  have haffine' : U + V * H < n H := by
    simpa [A, W, p, d, Dmax, Mmax, U, V] using haffine
  have hdensityH :
      let Q' := nearHalfCenterReducedModuli n K G W A X p L sR
      let S' := centerPrimeFactors Q'
      let D' := (S'.card + 1) * (S'.card + 2)
      (8 : ℝ) * D' *
        (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
          W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) < 1 := by
    apply partialCenter_density_eight_of_adaptive_bounds
      n hpos c hc hratio K G H W A X p L sR
    simpa [W, d] using hdensity
  obtain ⟨M, R, hM, hMeq, hR, hbudget, hRbound⟩ :=
    exists_bounded_partialCenter_protected_budget
      n hpos hmono K G H L J X r v hKG hGH hL hX hv hrUpper
        hsRWindow hnoDouble hdensityH
  have hMle : M ≤ Mmax := by
    rw [hMeq]
    dsimp [Mmax]
    exact nearHalf_centerPrime_product_le_threshold_pow
      n hpos K G W A X p L sR B hB hvalues
  have hDle : D ≤ Dmax := by
    have hScard : S.card ≤ 2 * d :=
      nearHalf_centerPrimeFactors_card_le n K G W A X p L sR
    dsimp [D, Dmax]
    exact Nat.mul_le_mul (Nat.add_le_add_right hScard 1)
      (Nat.add_le_add_right hScard 2)
  have hZ₁ : (laterPositionRange K H).card ≤ H := by
    calc
      (laterPositionRange K H).card ≤ (Finset.range H).card :=
        Finset.card_le_card (Finset.filter_subset _ _)
      _ = H := Finset.card_range H
  have hZ₂ : (Finset.Ico G H).card ≤ H := by
    have hcard : (Finset.Ico G H).card = H - G := by simp
    omega
  have hZsum : (laterPositionRange K H).card +
      (Finset.Ico G H).card ≤ 2 * H := by omega
  have hendpointCost :
      2 * D * W * ((laterPositionRange K H).card +
        (Finset.Ico G H).card) ≤ 4 * Dmax * W * H := by
    calc
      2 * D * W * ((laterPositionRange K H).card +
          (Finset.Ico G H).card) ≤
          2 * Dmax * W * (2 * H) := by gcongr
      _ = 4 * Dmax * W * H := by ring
  have hRcoarse : R ≤ Mmax + 4 * Dmax * W * H := by
    calc
      R ≤ M + 2 * D * W * ((laterPositionRange K H).card +
          (Finset.Ico G H).card) := by
            simpa [D, S, Q, A, W, p, sR] using hRbound
      _ ≤ Mmax + 4 * Dmax * W * H :=
        Nat.add_le_add hMle hendpointCost
  have hcut : A + p * R + X + W < n H := by
    have hcost : A + p * R + X + W ≤ U + V * H := by
      calc
        A + p * R + X + W ≤
            A + p * (Mmax + 4 * Dmax * W * H) + X + W := by
          gcongr
        _ = U + V * H := by
          dsimp [U, V]
          ring
    exact hcost.trans_lt haffine'
  refine ⟨R, hR, ?_⟩
  simpa [A, W, p, sR] using And.intro hbudget hcut

/-- Fully explicit adaptive cutoff.  The displayed `H` is obtained from F-097,
so its size is available before checking the two norm-cap inequalities. -/
theorem exists_explicit_adaptive_partialCenter_budget
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (K G B L J X r v : ℕ) (hKG : K < G) (hB : 0 < B)
    (hvalues : ∀ j, K < j → j < G → n j ≤ B)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDouble : ∀ j, K < j → j < G → n j ≠ 2 * n K)
    (hdensity :
      let W := L + 1 + J
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let d := (laterPositionRange K G).card
    let Dmax := (2 * d + 1) * (2 * d + 2)
    let Mmax := B ^ (2 * d)
    let U := A + p * Mmax + X + W
    let V := 4 * p * Dmax * W
    let A₀ := U + V * G
    let B₀ := V * q
    let C := A₀ + 2 * B₀ + 1
    let H := G + q * (2 * C)
    let C0 := nearHalfCenterConditions n K G W A X p L sR
    ∃ R : ℕ, 0 < R ∧
      let O := compatibleTwoWindowConditions n K H W A X p \ C0
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H := by
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let d := (laterPositionRange K G).card
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := B ^ (2 * d)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  let A₀ := U + V * G
  let B₀ := V * q
  let C := A₀ + 2 * B₀ + 1
  let H := G + q * (2 * C)
  have hAff := explicit_ratio_cutoff_dominating_affine
    n hpos c hc hratio q hq G U V
  have hGH : G ≤ H := by omega
  have haffine : U + V * H < n H := by
    simpa [A₀, B₀, C, H] using hAff.2
  exact adaptive_partialCenter_budget_at_affine_cutoff
    n hpos hmono c hc hratio K G B L J X r v H hKG hB hvalues
      hL hX hv hrUpper hsRWindow hnoDouble hdensity hGH
      (by simpa [A, W, p, d, Dmax, Mmax, U, V] using haffine)

end Research


/-!
# Two-window avoidance with an exactly protected center family
-/

namespace Research

/-- Protected-center version of F-041's two-window sieve.  The soluble
conditions are partitioned into an exactly protected family `C` and an
ordinary union-bounded family `O`. -/
theorem exists_two_windows_avoiding_all_later_indices_protected
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H W A X p R : ℕ) (hA : 0 < A) (_hKH : K < H)
    (C O : Finset ((ℕ × ℕ) × Bool))
    (hpartition : C ∪ O = compatibleTwoWindowConditions n K H W A X p)
    (hbudget :
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p R).card)
    (hcut : A + p * R + X + W < n H) :
    ∃ t < R, ∀ j, K < j → ∀ s < W,
      (¬ n j ∣ A + p * t + s) ∧
      (¬ n j ∣ A + p * t + s + X) := by
  classical
  let a := twoWindowOffset A X
  let q := twoWindowModulus n
  have hq : ∀ u ∈ O, 0 < q u := by
    intro u _
    exact hpos u.1.1
  have hbudget' :
      (∑ u ∈ O, (R / (q u / (q u).gcd p) + 1)) <
        (protectedCandidates C a q p R).card := by
    simpa [a, q] using hbudget
  obtain ⟨t, htR, hC, hO⟩ :=
    exists_avoiding_with_protected_centers C O a q p R hq hbudget'
  have havI : ∀ u ∈ twoWindowConditions K H W,
      ¬ q u ∣ a u + p * t := by
    intro u hu
    by_cases hc : (q u).gcd p ∣ a u
    · have huComp : u ∈ compatibleTwoWindowConditions n K H W A X p := by
        exact Finset.mem_filter.mpr ⟨hu, hc⟩
      have huUnion : u ∈ C ∪ O := by rw [hpartition]; exact huComp
      rcases Finset.mem_union.mp huUnion with huC | huO
      · exact hC u huC
      · exact hO u huO
    · intro hdvd
      exact hc (gcd_dvd_offset_of_dvd_add_mul (a u) p (q u) t hdvd)
  refine ⟨t, htR, ?_⟩
  intro j hKj s hsW
  by_cases hjH : j < H
  · have hjI : j ∈ laterPositionRange K H := by
      simp [laterPositionRange, hjH, hKj]
    have hsI : s ∈ Finset.range W := Finset.mem_range.mpr hsW
    have hleft := havI ((j, s), false) (by
      simp [twoWindowConditions, hjI, hsI])
    have hright := havI ((j, s), true) (by
      simp [twoWindowConditions, hjI, hsI])
    dsimp [a, q, twoWindowOffset, twoWindowModulus] at hleft hright
    constructor
    · simpa [add_assoc, add_comm, add_left_comm] using hleft
    · simpa [add_assoc, add_comm, add_left_comm] using hright
  · have hHj : H ≤ j := by omega
    have hnHj : n H ≤ n j := hmono.monotone hHj
    have hleftPos : 0 < A + p * t + s := by omega
    have hrightPos : 0 < A + p * t + s + X := by omega
    have hpt : p * t ≤ p * R :=
      Nat.mul_le_mul_left p (Nat.le_of_lt htR)
    have hleftLt : A + p * t + s < n H := by omega
    have hrightLt : A + p * t + s + X < n H := by omega
    constructor
    · intro hdvd
      have hle := Nat.le_of_dvd hleftPos hdvd
      omega
    · intro hdvd
      have hle := Nat.le_of_dvd hrightPos hdvd
      omega

end Research


/-!
# Complete irrationality gate with protected center conditions
-/

namespace Research

open Real goldenRatio

/-- Complete rationality contradiction using an exact protected center family,
union-bounded off-center conditions, and sharp prefix periods. -/
theorem protected_sandwiched_mismatch_rationality_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (K H L J A X R : ℕ) (hA : 0 < A) (hKH : K < H)
    (hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ X)
    (htargetPre : ∀ s < L,
      fibLambertCoeff (n K) (A + s + X) =
        fibLambertCoeff (n K) (A + s))
    (htarget : fibLambertCoeff (n K) (A + L + X) ≠
      fibLambertCoeff (n K) (A + L))
    (htargetPost : ∀ s < J,
      fibLambertCoeff (n K) (A + L + 1 + s + X) =
        fibLambertCoeff (n K) (A + L + 1 + s))
    (C O : Finset ((ℕ × ℕ) × Bool))
    (hpartition : C ∪ O = compatibleTwoWindowConditions n K H
      (L + 1 + J) A X (4 * n K))
    (hbudget :
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd (4 * n K)) + 1)) <
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) (4 * n K) R).card)
    (hcut : A + (4 * n K) * R + X + (L + 1 + J) < n H)
    (hsmallPost : ∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (N + X + L + 1 + J)) < 1)
    (hsmallPre : ∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (N + X + L)) *
        (indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) N +
          indexCountConjugateBound n
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) (N + X)) <
      (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  obtain ⟨t, htR, hav⟩ :=
    exists_two_windows_avoiding_all_later_indices_protected
      n hpos hmono K H (L + 1 + J) A X (4 * n K) R
      hA hKH C O hpartition hbudget hcut
  let N := A + (4 * n K) * t
  have htransport (u : ℕ) :
      fibLambertCoeff (n K) (N + u) = fibLambertCoeff (n K) (A + u) := by
    have hp := fibLambertCoeff_add_period_mul (n K) (A + u) t
    simpa [N, add_assoc, add_comm, add_left_comm, mul_comm] using hp
  have htransportX (u : ℕ) :
      fibLambertCoeff (n K) (N + u + X) =
        fibLambertCoeff (n K) (A + u + X) := by
    have hp := fibLambertCoeff_add_period_mul (n K) (A + u + X) t
    simpa [N, add_assoc, add_comm, add_left_comm, mul_comm] using hp
  have htargetPreN : ∀ s < L,
      fibLambertCoeff (n K) (N + s + X) =
        fibLambertCoeff (n K) (N + s) := by
    intro s hs
    rw [htransportX, htransport]
    exact htargetPre s hs
  have htargetN : fibLambertCoeff (n K) (N + L + X) ≠
      fibLambertCoeff (n K) (N + L) := by
    rw [htransportX, htransport]
    exact htarget
  have htargetPostN : ∀ s < J,
      fibLambertCoeff (n K) (N + L + 1 + s + X) =
        fibLambertCoeff (n K) (N + L + 1 + s) := by
    intro s hs
    have hx := htransportX (L + 1 + s)
    have hxbase := htransport (L + 1 + s)
    calc
      fibLambertCoeff (n K) (N + L + 1 + s + X) =
          fibLambertCoeff (n K) (A + L + 1 + s + X) := by
            simpa [add_assoc] using hx
      _ = fibLambertCoeff (n K) (A + L + 1 + s) :=
        htargetPost s hs
      _ = fibLambertCoeff (n K) (N + L + 1 + s) := by
        simpa [add_assoc] using hxbase.symm
  have hpat := sandwiched_mismatch_of_minimalPeriod_and_avoidance
    n hpos hmono K L J N X hperiod htargetPreN htargetN htargetPostN hav
  apply selected_sandwiched_mismatch_obstruction
    n hpos hmono a b hb hrat N (N + X) L J
  · intro s hs
    simpa [add_assoc, add_comm, add_left_comm] using (hpat.1 s hs).symm
  · simpa [add_assoc, add_comm, add_left_comm] using (ne_comm.mp hpat.2.1)
  · intro s hs
    simpa [add_assoc, add_comm, add_left_comm] using (hpat.2.2 s hs).symm
  · simpa [N, add_assoc, add_comm, add_left_comm] using hsmallPost t htR
  · simpa [N, add_assoc, add_comm, add_left_comm] using hsmallPre t htR

end Research


/-!
# Complete explicit protected-sieve irrationality certificate
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- A complete finite irrationality criterion in the adaptive near-half regime.
All combinatorial sieve, cutoff, and analytic norm requirements have been
reduced to the displayed target data, one density inequality, and two norm-cap
inequalities at an explicit cutoff position. -/
theorem explicit_adaptive_protected_rationality_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (K G B L J X r v : ℕ) (hKG : K < G) (hB : 0 < B)
    (hvalues : ∀ j, K < j → j < G → n j ≤ B)
    (hL : L < n K) (hJ : J < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrlt : r < 2 * n K)
    (hrLeft : L < r) (hrRight : r + J < 2 * n K)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hprefix : sharpPrefixPeriod n K ∣ X)
    (hnoDouble : ∀ j, K < j → j < G → n j ≠ 2 * n K)
    (hdensity :
      let W := L + 1 + J
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1)
    (hpostCap :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let Mmax := B ^ (2 * d)
      let U := A + p * Mmax + X + W
      let V := 4 * p * Dmax * W
      let A₀ := U + V * G
      let B₀ := V * q
      let C := A₀ + 2 * B₀ + 1
      let H := G + q * (2 * C)
      (φ⁻¹) ^ (J + 1) * (2 * cutoffTailCap H) < 1)
    (hpreCap :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let Mmax := B ^ (2 * d)
      let U := A + p * Mmax + X + W
      let V := 4 * p * Dmax * W
      let A₀ := U + V * G
      let B₀ := V * q
      let C := A₀ + 2 * B₀ + 1
      let H := G + q * (2 * C)
      (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap
          (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H) <
        (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let d := (laterPositionRange K G).card
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := B ^ (2 * d)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  let A₀ := U + V * G
  let B₀ := V * q
  let C := A₀ + 2 * B₀ + 1
  let H := G + q * (2 * C)
  let C0 := nearHalfCenterConditions n K G W A X p L sR
  let O := compatibleTwoWindowConditions n K H W A X p \ C0
  have hcert := exists_explicit_adaptive_partialCenter_budget
    n hpos hmono c hc hratio q hq K G B L J X r v hKG hB hvalues
      hL hX hv hrUpper hsRWindow hnoDouble hdensity
  change ∃ R : ℕ, 0 < R ∧
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H at hcert
  obtain ⟨R, hR, hbudget, hcut⟩ := hcert
  have hA : 0 < A := by dsimp [A]; omega
  have hGH : G ≤ H := by dsimp [H]; omega
  have hKH : K < H := lt_of_lt_of_le hKG hGH
  have hrmod : r = X % (2 * n K) := by
    rw [hX, Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt hrlt]
  have htarget := target_component_sandwiched_pattern
    (n K) L J X r (hpos K) hL hJ hrmod hrLeft hrRight
  have hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ X := by
    intro k hk
    exact dvd_trans (fibLambertPeriod_dvd_sharpPrefixPeriod n hk) hprefix
  have hCsub : C0 ⊆ compatibleTwoWindowConditions n K H W A X p := by
    intro u hu
    have huG := (Finset.mem_filter.mp hu).1
    have huGdata := Finset.mem_filter.mp huG
    apply Finset.mem_filter.mpr
    refine ⟨?_, huGdata.2⟩
    have huOuter := Finset.mem_product.mp huGdata.1
    have huInner := Finset.mem_product.mp huOuter.1
    have hjData := Finset.mem_filter.mp huInner.1
    apply Finset.mem_product.mpr
    refine ⟨Finset.mem_product.mpr ⟨?_, huInner.2⟩, huOuter.2⟩
    apply Finset.mem_filter.mpr
    exact ⟨Finset.mem_range.mpr (lt_of_lt_of_le
      (Finset.mem_range.mp hjData.1) hGH), hjData.2⟩
  have hpartition : C0 ∪ O =
      compatibleTwoWindowConditions n K H W A X p := by
    exact Finset.union_sdiff_of_subset hCsub
  have hnorm := uniform_protected_norm_bounds_of_cutoff
    n hpos hmono a b K H L J A X R
    (by simpa [p, W] using hcut)
    (by simpa [A, W, p, d, Dmax, Mmax, U, V, A₀, B₀, C, H]
      using hpostCap)
    (by simpa [A, W, p, d, Dmax, Mmax, U, V, A₀, B₀, C, H]
      using hpreCap)
  exact protected_sandwiched_mismatch_rationality_contradiction
    n hpos hmono a b hb hrat K H L J A X R hA hKH hperiod
      htarget.1 htarget.2.1 htarget.2.2 C0 O hpartition
      (by simpa [p] using hbudget)
      (by simpa [p, W] using hcut) hnorm.1 hnorm.2

end Research


/-!
# A logarithmic-size ratio-gap cutoff for affine costs
-/

namespace Research

/-- Sharp explicit replacement for F-097.  If `c^q≥2`, put
`A=U+VG`, `B=Vq`, `N=A+B+1`, `t=clog₂ N`, `s=4t+4`, and
`H=G+qs`.  Then `U+VH<n_H`.  In contrast to F-097, the number of ratio blocks
is logarithmic in the affine coefficients rather than linear in them. -/
theorem logarithmic_ratio_cutoff_dominating_affine
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (G U V : ℕ) :
    let A := U + V * G
    let B := V * q
    let N := A + B + 1
    let t := Nat.clog 2 N
    let s := 4 * t + 4
    let H := G + q * s
    G ≤ H ∧ U + V * H < n H := by
  let A := U + V * G
  let B := V * q
  let N := A + B + 1
  let t := Nat.clog 2 N
  let s := 4 * t + 4
  let H := G + q * s
  have hNpos : 0 < N := by dsimp [N]; omega
  have hNpow : N ≤ 2 ^ t := by
    exact Nat.le_pow_clog (by norm_num) N
  have hNpowSelf : N ≤ 2 ^ (2 * N) := by
    exact (show N ≤ 2 * N ^ 2 + 1 by nlinarith).trans
      (Nat.two_mul_sq_add_one_le_two_pow_two_mul N)
  have htN : t ≤ 2 * N := by
    calc
      t = Nat.clog 2 N := rfl
      _ ≤ Nat.clog 2 (2 ^ (2 * N)) :=
        Nat.clog_mono (by norm_num) le_rfl hNpowSelf
      _ = 2 * N := Nat.clog_pow 2 (2 * N) (by norm_num)
  have htarget : U + V * H = A + B * s := by
    dsimp [H, A, B]
    ring
  have hAle : A ≤ N := by dsimp [N]; omega
  have hBle : B ≤ N := by dsimp [N]; omega
  have hsle : s ≤ 8 * N + 4 := by dsimp [s]; omega
  have hBs : B * s ≤ N * (8 * N + 4) :=
    Nat.mul_le_mul hBle hsle
  have hNleN2 : N ≤ N ^ 2 := by
    simpa using (Nat.le_pow (a := N) (by norm_num : 0 < 2))
  have hN2leN4 : N ^ 2 ≤ N ^ 4 :=
    pow_le_pow_right₀ (by omega) (by omega)
  have htargetPoly : A + B * s < 16 * N ^ 4 := by
    nlinarith
  have hpowLower : 16 * N ^ 4 ≤ 2 ^ s := by
    have hp := Nat.mul_le_mul_left 16 (Nat.pow_le_pow_left hNpow 4)
    calc
      16 * N ^ 4 ≤ 16 * (2 ^ t) ^ 4 := hp
      _ = 2 ^ s := by
        dsimp [s]
        rw [pow_add, show 4 * t = t * 4 by omega, pow_mul]
        norm_num
        ring
  have htargetPow : U + V * H < 2 ^ s := by
    rw [htarget]
    exact htargetPoly.trans_le hpowLower
  have hcpos : 0 < c := lt_trans (by norm_num) hc
  have hbasePow : (2 : ℝ) ^ s ≤ (c ^ q) ^ s :=
    (pow_le_pow_left₀ (by norm_num) hq) s
  have hnGone : (1 : ℝ) ≤ n G := by exact_mod_cast hpos G
  have hgrowth := ratio_gap_geometric_growth_from
    n c hcpos.le hratio G (q * s)
  refine ⟨by omega, ?_⟩
  have hreal : ((U + V * H : ℕ) : ℝ) < (n H : ℕ) := by
    calc
      ((U + V * H : ℕ) : ℝ) < ((2 ^ s : ℕ) : ℝ) := by
        exact_mod_cast htargetPow
      _ = (2 : ℝ) ^ s := by norm_num
      _ ≤ (c ^ q) ^ s := hbasePow
      _ = c ^ (q * s) := (pow_mul c q s).symm
      _ ≤ c ^ (q * s) * (n G : ℝ) :=
        le_mul_of_one_le_right (pow_nonneg hcpos.le _) hnGone
      _ ≤ n (G + q * s) := hgrowth
      _ = n H := rfl
  exact_mod_cast hreal

end Research


/-!
# Logarithmic-size adaptive protected cutoff
-/

namespace Research

open scoped BigOperators

/-- F-098 with F-100's logarithmic affine cutoff.  The exposed `H` is small
enough for the quadratic norm caps to be dominated by sublinear coefficient
windows. -/
theorem exists_logarithmic_adaptive_partialCenter_budget
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (K G B L J X r v : ℕ) (hKG : K < G) (hB : 0 < B)
    (hvalues : ∀ j, K < j → j < G → n j ≤ B)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDouble : ∀ j, K < j → j < G → n j ≠ 2 * n K)
    (hdensity :
      let W := L + 1 + J
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let d := (laterPositionRange K G).card
    let Dmax := (2 * d + 1) * (2 * d + 2)
    let Mmax := B ^ (2 * d)
    let U := A + p * Mmax + X + W
    let V := 4 * p * Dmax * W
    let A₀ := U + V * G
    let B₀ := V * q
    let N := A₀ + B₀ + 1
    let t := Nat.clog 2 N
    let H := G + q * (4 * t + 4)
    let C0 := nearHalfCenterConditions n K G W A X p L sR
    ∃ R : ℕ, 0 < R ∧
      let O := compatibleTwoWindowConditions n K H W A X p \ C0
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H := by
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let d := (laterPositionRange K G).card
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := B ^ (2 * d)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  let A₀ := U + V * G
  let B₀ := V * q
  let N := A₀ + B₀ + 1
  let t := Nat.clog 2 N
  let H := G + q * (4 * t + 4)
  have hAff := logarithmic_ratio_cutoff_dominating_affine
    n hpos c hc hratio q hq G U V
  have hGH : G ≤ H := by omega
  have haffine : U + V * H < n H := by
    simpa [A₀, B₀, N, t, H] using hAff.2
  exact adaptive_partialCenter_budget_at_affine_cutoff
    n hpos hmono c hc hratio K G B L J X r v H hKG hB hvalues
      hL hX hv hrUpper hsRWindow hnoDouble hdensity hGH
      (by simpa [A, W, p, d, Dmax, Mmax, U, V] using haffine)

end Research


/-!
# Complete logarithmic-cutoff protected-sieve irrationality certificate
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- A complete finite irrationality criterion in the adaptive near-half regime.
All combinatorial sieve, cutoff, and analytic norm requirements have been
reduced to the displayed target data, one density inequality, and two norm-cap
inequalities at an explicit cutoff position. -/
theorem logarithmic_adaptive_protected_rationality_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (K G B L J X r v : ℕ) (hKG : K < G) (hB : 0 < B)
    (hvalues : ∀ j, K < j → j < G → n j ≤ B)
    (hL : L < n K) (hJ : J < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrlt : r < 2 * n K)
    (hrLeft : L < r) (hrRight : r + J < 2 * n K)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hprefix : sharpPrefixPeriod n K ∣ X)
    (hnoDouble : ∀ j, K < j → j < G → n j ≠ 2 * n K)
    (hdensity :
      let W := L + 1 + J
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1)
    (hpostCap :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let Mmax := B ^ (2 * d)
      let U := A + p * Mmax + X + W
      let V := 4 * p * Dmax * W
      let A₀ := U + V * G
      let B₀ := V * q
      let N := A₀ + B₀ + 1
      let t := Nat.clog 2 N
      let H := G + q * (4 * t + 4)
      (φ⁻¹) ^ (J + 1) * (2 * cutoffTailCap H) < 1)
    (hpreCap :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let Mmax := B ^ (2 * d)
      let U := A + p * Mmax + X + W
      let V := 4 * p * Dmax * W
      let A₀ := U + V * G
      let B₀ := V * q
      let N := A₀ + B₀ + 1
      let t := Nat.clog 2 N
      let H := G + q * (4 * t + 4)
      (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap
          (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H) <
        (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let d := (laterPositionRange K G).card
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := B ^ (2 * d)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  let A₀ := U + V * G
  let B₀ := V * q
  let N := A₀ + B₀ + 1
  let t := Nat.clog 2 N
  let H := G + q * (4 * t + 4)
  let C0 := nearHalfCenterConditions n K G W A X p L sR
  let O := compatibleTwoWindowConditions n K H W A X p \ C0
  have hcert := exists_logarithmic_adaptive_partialCenter_budget
    n hpos hmono c hc hratio q hq K G B L J X r v hKG hB hvalues
      hL hX hv hrUpper hsRWindow hnoDouble hdensity
  change ∃ R : ℕ, 0 < R ∧
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H at hcert
  obtain ⟨R, hR, hbudget, hcut⟩ := hcert
  have hA : 0 < A := by dsimp [A]; omega
  have hGH : G ≤ H := by dsimp [H]; omega
  have hKH : K < H := lt_of_lt_of_le hKG hGH
  have hrmod : r = X % (2 * n K) := by
    rw [hX, Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt hrlt]
  have htarget := target_component_sandwiched_pattern
    (n K) L J X r (hpos K) hL hJ hrmod hrLeft hrRight
  have hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ X := by
    intro k hk
    exact dvd_trans (fibLambertPeriod_dvd_sharpPrefixPeriod n hk) hprefix
  have hCsub : C0 ⊆ compatibleTwoWindowConditions n K H W A X p := by
    intro u hu
    have huG := (Finset.mem_filter.mp hu).1
    have huGdata := Finset.mem_filter.mp huG
    apply Finset.mem_filter.mpr
    refine ⟨?_, huGdata.2⟩
    have huOuter := Finset.mem_product.mp huGdata.1
    have huInner := Finset.mem_product.mp huOuter.1
    have hjData := Finset.mem_filter.mp huInner.1
    apply Finset.mem_product.mpr
    refine ⟨Finset.mem_product.mpr ⟨?_, huInner.2⟩, huOuter.2⟩
    apply Finset.mem_filter.mpr
    exact ⟨Finset.mem_range.mpr (lt_of_lt_of_le
      (Finset.mem_range.mp hjData.1) hGH), hjData.2⟩
  have hpartition : C0 ∪ O =
      compatibleTwoWindowConditions n K H W A X p := by
    exact Finset.union_sdiff_of_subset hCsub
  have hnorm := uniform_protected_norm_bounds_of_cutoff
    n hpos hmono a b K H L J A X R
    (by simpa [p, W] using hcut)
    (by simpa [A, W, p, d, Dmax, Mmax, U, V, A₀, B₀, N, t, H]
      using hpostCap)
    (by simpa [A, W, p, d, Dmax, Mmax, U, V, A₀, B₀, N, t, H]
      using hpreCap)
  exact protected_sandwiched_mismatch_rationality_contradiction
    n hpos hmono a b hb hrat K H L J A X R hA hKH hperiod
      htarget.1 htarget.2.1 htarget.2.2 C0 O hpartition
      (by simpa [p] using hbudget)
      (by simpa [p, W] using hcut) hnorm.1 hnorm.2

end Research


/-!
# Target shifts close to the half-period
-/

namespace Research

/-- If `2n` does not divide the prefix period `P`, a multiple of `P` can be
chosen in the lower half modulo `4n`, within half a gcd-step of `n`.  Its
quotient after reduction modulo `2n` is even. -/
theorem exists_nearHalf_evenQuotient_multiplier
    (P n : ℕ) (hn : 0 < n) (hndvd : ¬ 2 * n ∣ P) :
    let g := (4 * n).gcd P
    ∃ X r v : ℕ,
      P ∣ X ∧ X < (4 * n) * P ∧
      X = r + (2 * n) * v ∧ Even v ∧
      0 < r ∧ r < 2 * n ∧ 2 * r.dist n ≤ g := by
  let M := 4 * n
  let g := M.gcd P
  let q := M / g
  let P' := P / g
  have hM : 0 < M := by dsimp [M]; omega
  have hg : 0 < g := Nat.gcd_pos_of_pos_left P hM
  have hgM : g ∣ M := Nat.gcd_dvd_left M P
  have hgP : g ∣ P := Nat.gcd_dvd_right M P
  have hMFactor : g * q = M := by
    dsimp [q]
    exact Nat.mul_div_cancel' hgM
  have hPFactor : g * P' = P := by
    dsimp [P']
    exact Nat.mul_div_cancel' hgP
  have hqpos : 0 < q := by
    dsimp [q]
    exact Nat.div_pos (Nat.gcd_le_left P hM) hg
  have hq : 3 ≤ q := by
    by_contra hnot
    have hq12 : q = 1 ∨ q = 2 := by omega
    rcases hq12 with hq1 | hq2
    · have hgM' : g = M := by
        rw [hq1, mul_one] at hMFactor
        exact hMFactor
      apply hndvd
      exact dvd_trans (show 2 * n ∣ M by
        dsimp [M]
        exact ⟨2, by ring⟩) (by simpa [hgM'] using hgP)
    · have hg2n : g = 2 * n := by
        rw [hq2] at hMFactor
        dsimp [M] at hMFactor
        omega
      apply hndvd
      rw [← hg2n]
      exact hgP
  have hcop : P'.Coprime q := by
    have hc := Nat.coprime_div_gcd_div_gcd (m := M) (n := P) hg
    exact hc.symm
  let k := (q + 1) / 4
  have hkpos : 0 < k := by dsimp [k]; omega
  have hkltHalf : 2 * k < q := by
    dsimp [k]
    omega
  have hklt : k < q := by omega
  obtain ⟨u, huq, hu⟩ :=
    Nat.exists_mul_mod_eq_of_coprime k hcop (Nat.ne_of_gt hqpos)
  have hkmod : k % q = k := Nat.mod_eq_of_lt hklt
  rw [hkmod] at hu
  let r := g * k
  let X := P * u
  have hrmod : r = X % M := by
    dsimp [r, X]
    rw [← hPFactor, ← hMFactor, mul_assoc, Nat.mul_mod_mul_left, hu]
  have hrpos : 0 < r := mul_pos hg hkpos
  have hrlt : r < 2 * n := by
    have : 2 * (g * k) < g * q := by
      simpa [mul_assoc, mul_left_comm, mul_comm] using
        Nat.mul_lt_mul_of_pos_left hkltHalf hg
    dsimp [r, M] at this ⊢
    omega
  have hnear : 2 * r.dist n ≤ g := by
    have hkLower : q ≤ 4 * k + 2 := by dsimp [k]; omega
    have hkUpper : 4 * k ≤ q + 2 := by dsimp [k]; omega
    have hdistK : (4 * k).dist q ≤ 2 := by
      rcases le_total (4 * k) q with hle | hge
      · rw [Nat.dist_eq_sub_of_le hle]
        omega
      · rw [Nat.dist_eq_sub_of_le_right hge]
        omega
    have hr4 : 4 * r = g * (4 * k) := by
      dsimp [r]
      ring
    have hn4 : 4 * n = g * q := by simpa [M] using hMFactor.symm
    have hdistScale : 4 * r.dist n = g * (4 * k).dist q := by
      rw [← Nat.dist_mul_left, hr4, hn4, Nat.dist_mul_left]
    have hscaled := Nat.mul_le_mul_left g hdistK
    omega
  let w := X / M
  let v := X / (2 * n)
  have hdecomp : X = r + (2 * n) * (w * 2) := by
    have hx := Nat.mod_add_div X M
    rw [← hrmod] at hx
    calc
      X = r + M * (X / M) := hx.symm
      _ = r + (2 * n) * (w * 2) := by dsimp [M, w]; ring
  have hv : v = w * 2 := by
    dsimp [v]
    rw [hdecomp, Nat.add_mul_div_left r (w * 2) (by omega : 0 < 2 * n),
      Nat.div_eq_of_lt hrlt]
    simp
  have hPne : P ≠ 0 := by
    intro hP0
    apply hndvd
    rw [hP0]
    exact dvd_zero (2 * n)
  have hPpos : 0 < P := Nat.pos_of_ne_zero hPne
  have hqM : q ≤ M := Nat.div_le_self M g
  have hXbound : X < (4 * n) * P := by
    dsimp [X, M] at hqM ⊢
    nlinarith
  refine ⟨X, r, v, ⟨u, rfl⟩, hXbound, ?_, ?_, hrpos, hrlt, hnear⟩
  · rw [hdecomp, hv]
  · rw [hv]
    exact ⟨w, by ring⟩

end Research


/-!
# A complete near-half target package for one symmetric window
-/

namespace Research

/-- If the prefix-period gcd is smaller than twice a window `w`, while
`2w<n`, F-079 supplies a prefix-period multiple whose residue satisfies every
target-isolation and center-geometry inequality required by F-102 with
`L=J=w`. -/
theorem exists_nearHalf_symmetric_window_package
    (P n w : ℕ) (hn : 0 < n)
    (hw : 2 * w < n)
    (hg : (4 * n).gcd P < 2 * w) :
    ∃ X r v : ℕ,
      P ∣ X ∧ X < (4 * n) * P ∧
      X = r + (2 * n) * v ∧ Even v ∧
      0 < r ∧ r < 2 * n ∧
      w < r ∧ r + w < 2 * n ∧
      r ≤ n + w ∧ n + w - r < w + 1 + w := by
  have hndvd : ¬ 2 * n ∣ P := by
    intro hd
    have htwoFour : 2 * n ∣ 4 * n := ⟨2, by ring⟩
    have htwoG : 2 * n ∣ (4 * n).gcd P := Nat.dvd_gcd htwoFour hd
    have hgpos : 0 < (4 * n).gcd P :=
      Nat.gcd_pos_of_pos_left P (by omega)
    have hle : 2 * n ≤ (4 * n).gcd P := Nat.le_of_dvd hgpos htwoG
    omega
  obtain ⟨X, r, v, hPX, hXbound, hX, hv, hrpos, hrlt, hnear⟩ :=
    exists_nearHalf_evenQuotient_multiplier P n hn hndvd
  have hdist : r.dist n < w := by omega
  have hwr : w < r := by
    rcases le_total r n with hrn | hnr
    · rw [Nat.dist_eq_sub_of_le hrn] at hdist
      omega
    · omega
  have hrw : r + w < 2 * n := by
    rcases le_total r n with hrn | hnr
    · omega
    · rw [Nat.dist_eq_sub_of_le_right hnr] at hdist
      omega
  have hrUpper : r ≤ n + w := by
    rcases le_total r n with hrn | hnr
    · omega
    · rw [Nat.dist_eq_sub_of_le_right hnr] at hdist
      omega
  have hnlt : n < r + w := by
    rcases le_total r n with hrn | hnr
    · rw [Nat.dist_eq_sub_of_le hrn] at hdist
      omega
    · have hwpos : 0 < w := by omega
      omega
  have hsR : n + w - r < w + 1 + w := by omega
  exact ⟨X, r, v, hPX, hXbound, hX, hv, hrpos, hrlt,
    hwr, hrw, hrUpper, hsR⟩

end Research


/-!
# A polynomial adaptive-threshold package
-/

namespace Research

/-- An elementary power comparison used for the adaptive threshold. -/
theorem pow_eight_lt_two_pow_eight_mul (W : ℕ) :
    W ^ 8 < 2 ^ (8 * W) := by
  have hsq : W ^ 2 < 2 ^ (2 * W) := by
    calc
      W ^ 2 < 2 * W ^ 2 + 1 := by nlinarith
      _ ≤ 2 ^ (2 * W) := Nat.two_mul_sq_add_one_le_two_pow_two_mul W
  have hp := Nat.pow_lt_pow_left hsq (by norm_num : (4 : ℕ) ≠ 0)
  calc
    W ^ 8 = (W ^ 2) ^ 4 := by rw [← pow_mul]
    _ < (2 ^ (2 * W)) ^ 4 := hp
    _ = 2 ^ (8 * W) := by
      rw [← pow_mul]
      congr 1
      omega

/-- Let `B=n_K W^8` and `Q=8qW`. If one `q`-block grows by at least two,
the first selected index above `B` occurs by position `K+Q`; all intervening
values are at most `B` and there are at most `Q` of them. -/
theorem exists_polynomial_threshold_package
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (K W : ℕ) (hW : 0 < W) :
    let B := n K * W ^ 8
    let Q := 8 * q * W
    ∃ G : ℕ, K < G ∧ B < n G ∧
      (∀ j, K < j → j < G → n j ≤ B) ∧
      G ≤ K + Q ∧ (laterPositionRange K G).card ≤ Q := by
  let B := n K * W ^ 8
  let Q := 8 * q * W
  have hWpow : W ^ 8 < 2 ^ (8 * W) :=
    pow_eight_lt_two_pow_eight_mul W
  have hbase : (2 : ℝ) ^ (8 * W) ≤ (c ^ q) ^ (8 * W) :=
    (pow_le_pow_left₀ (by norm_num) hq) (8 * W)
  have hcQ : (2 : ℝ) ^ (8 * W) ≤ c ^ Q := by
    calc
      (2 : ℝ) ^ (8 * W) ≤ (c ^ q) ^ (8 * W) := hbase
      _ = c ^ (q * (8 * W)) := (pow_mul c q (8 * W)).symm
      _ = c ^ Q := by
        congr 1
        dsimp [Q]
        ring
  have hcross : (B : ℝ) < c ^ Q * (n K : ℝ) := by
    have hmpos : (0 : ℝ) < n K := by exact_mod_cast hpos K
    have hwreal : ((W ^ 8 : ℕ) : ℝ) < (2 : ℝ) ^ (8 * W) := by
      exact_mod_cast hWpow
    have hwc : ((W ^ 8 : ℕ) : ℝ) < c ^ Q := hwreal.trans_le hcQ
    have hm := mul_lt_mul_of_pos_right hwc hmpos
    simpa [B, mul_comm] using hm
  have hKB : n K ≤ B := by
    dsimp [B]
    have hone : 1 ≤ W ^ 8 := one_le_pow₀ (by omega)
    nlinarith
  exact exists_first_index_above_with_position_bound
    n hmono c hc hratio K B Q hKB hcross

end Research


/-!
# Density bound from the polynomial adaptive threshold
-/

namespace Research

/-- The abstract adaptive density in F-102 follows from a single inequality at
the deterministic bounds `B=n_K W^8` and `Q=8qW`. -/
theorem adaptive_density_of_polynomial_threshold
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (q K G W d : ℕ) (hW : 0 < W)
    (hd : d ≤ 8 * q * W)
    (hBG : n K * W ^ 8 < n G)
    (hsimple :
      let B := n K * W ^ 8
      let Q := 8 * q * W
      (8 : ℝ) * ((2 * Q + 1) * (2 * Q + 2) : ℕ) *
        (W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K * ((1 - c⁻¹)⁻¹ * (B : ℝ)⁻¹)) < 1) :
    (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
      (W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1 := by
  let B := n K * W ^ 8
  let Q := 8 * q * W
  have hBpos : (0 : ℝ) < B := by
    exact_mod_cast mul_pos (hpos K) (pow_pos hW 8)
  have hBle : (B : ℝ) ≤ n G := by exact_mod_cast hBG.le
  have hinv : ((n G : ℝ)⁻¹) ≤ (B : ℝ)⁻¹ := inv_anti₀ hBpos hBle
  have hcpos : 0 < c := lt_trans (by norm_num) hc
  have hgeom : 0 ≤ (1 - c⁻¹)⁻¹ := by
    exact inv_nonneg.mpr
      (sub_nonneg.mpr ((inv_le_one₀ hcpos).mpr hc.le))
  have hinner :
      W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹) ≤
      W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K * ((1 - c⁻¹)⁻¹ * (B : ℝ)⁻¹) := by
    gcongr
  have hdQ : d ≤ Q := by simpa [Q] using hd
  have hD : (2 * d + 1) * (2 * d + 2) ≤
      (2 * Q + 1) * (2 * Q + 2) := by
    gcongr
  have hDreal :
      (((2 * d + 1) * (2 * d + 2) : ℕ) : ℝ) ≤
      (((2 * Q + 1) * (2 * Q + 2) : ℕ) : ℝ) := by
    exact_mod_cast hD
  calc
    (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
      (W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) ≤
      8 * ((2 * Q + 1) * (2 * Q + 2) : ℕ) *
      (W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K * ((1 - c⁻¹)⁻¹ * (B : ℝ)⁻¹)) := by
      gcongr
    _ < 1 := by simpa [B, Q] using hsimple

end Research


/-!
# A fixed block of ratio steps at least doubles
-/

namespace Research

/-- Every real ratio constant `c>1` has a positive integer block length `q`
with `c^q≥2`. -/
theorem exists_ratio_doubling_block (c : ℝ) (hc : 1 < c) :
    ∃ q : ℕ, 0 < q ∧ (2 : ℝ) ≤ c ^ q := by
  have ht := tendsto_pow_atTop_atTop_of_one_lt hc
  have hev : ∀ᶠ q : ℕ in Filter.atTop, (2 : ℝ) ≤ c ^ q :=
    ht.eventually (Filter.eventually_ge_atTop 2)
  rw [Filter.eventually_atTop] at hev
  obtain ⟨Q, hQ⟩ := hev
  let q := max Q 1
  exact ⟨q, by dsimp [q]; omega, hQ q (le_max_left _ _)⟩

end Research


/-!
# Two elementary inequalities guaranteeing polynomial-threshold density
-/

namespace Research

/-- Concrete sufficient conditions for F-105's deterministic density bound.
The constant `5184 = 2·8·18²` is deliberately coarse. -/
theorem polynomial_threshold_simple_density_of_bounds
    (c : ℝ) (hc : 1 < c)
    (q W m : ℕ) (hq : 0 < q) (hW : 0 < W) (hm : 0 < m)
    (hfirst :
      (5184 : ℝ) * q ^ 2 *
        (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < m)
    (hsecond :
      (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < W ^ 5) :
    let B := m * W ^ 8
    let Q := 8 * q * W
    (8 : ℝ) * ((2 * Q + 1) * (2 * Q + 2) : ℕ) *
      (W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (m : ℝ)⁻¹) +
        W * m * ((1 - c⁻¹)⁻¹ * (B : ℝ)⁻¹)) < 1 := by
  let B := m * W ^ 8
  let Q := 8 * q * W
  let C₁ : ℝ := c⁻¹ * (1 - c⁻¹)⁻¹
  let C₀ : ℝ := (1 - c⁻¹)⁻¹
  have hcpos : 0 < c := lt_trans (by norm_num) hc
  have hden : 0 < 1 - c⁻¹ := sub_pos.mpr
    (inv_lt_one_of_one_lt₀ hc)
  have hC₁ : 0 ≤ C₁ := by dsimp [C₁]; positivity
  have hC₀ : 0 ≤ C₀ := by dsimp [C₀]; positivity
  have hqW : 1 ≤ q * W := mul_pos hq hW
  have hD : (2 * Q + 1) * (2 * Q + 2) ≤
      324 * q ^ 2 * W ^ 2 := by
    have h₁ : 2 * Q + 1 ≤ 18 * q * W := by dsimp [Q]; nlinarith
    have h₂ : 2 * Q + 2 ≤ 18 * q * W := by dsimp [Q]; nlinarith
    calc
      (2 * Q + 1) * (2 * Q + 2) ≤
          (18 * q * W) * (18 * q * W) := Nat.mul_le_mul h₁ h₂
      _ = 324 * q ^ 2 * W ^ 2 := by ring
  have hDreal : (((2 * Q + 1) * (2 * Q + 2) : ℕ) : ℝ) ≤
      ((324 * q ^ 2 * W ^ 2 : ℕ) : ℝ) := by exact_mod_cast hD
  have hmR : (0 : ℝ) < m := by exact_mod_cast hm
  have hWR : (0 : ℝ) < W := by exact_mod_cast hW
  have hhalf₁ :
      (2592 : ℝ) * q ^ 2 * C₁ * W ^ 4 / m < 1 / 2 := by
    apply (div_lt_iff₀ hmR).mpr
    nlinarith [hfirst]
  have hhalf₂ :
      (2592 : ℝ) * q ^ 2 * C₀ / W ^ 5 < 1 / 2 := by
    have hW5 : (0 : ℝ) < (W : ℝ) ^ 5 := pow_pos hWR _
    apply (div_lt_iff₀ hW5).mpr
    nlinarith [hsecond]
  have hrewrite :
      (2592 : ℝ) * q ^ 2 * W ^ 2 *
        (W ^ 2 * (C₁ * (m : ℝ)⁻¹) +
          W * m * (C₀ * (B : ℝ)⁻¹)) =
      2592 * q ^ 2 * C₁ * W ^ 4 / m +
        2592 * q ^ 2 * C₀ / W ^ 5 := by
    dsimp [B]
    push_cast
    field_simp
  have hcoef :
      (8 : ℝ) * (((2 * Q + 1) * (2 * Q + 2) : ℕ) : ℝ) ≤
        2592 * (q : ℝ) ^ 2 * (W : ℝ) ^ 2 := by
    calc
      (8 : ℝ) * (((2 * Q + 1) * (2 * Q + 2) : ℕ) : ℝ) ≤
          8 * (((324 * q ^ 2 * W ^ 2 : ℕ) : ℝ)) := by gcongr
      _ = 2592 * (q : ℝ) ^ 2 * (W : ℝ) ^ 2 := by
        push_cast
        ring
  calc
    (8 : ℝ) * ((2 * Q + 1) * (2 * Q + 2) : ℕ) *
      (W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (m : ℝ)⁻¹) +
        W * m * ((1 - c⁻¹)⁻¹ * (B : ℝ)⁻¹)) ≤
      2592 * q ^ 2 * W ^ 2 *
      (W ^ 2 * (C₁ * (m : ℝ)⁻¹) +
        W * m * (C₀ * (B : ℝ)⁻¹)) := by
      have hinnerNonneg : 0 ≤
          W ^ 2 * (C₁ * (m : ℝ)⁻¹) +
            W * m * (C₀ * (B : ℝ)⁻¹) := by positivity
      dsimp [C₁, C₀] at hinnerNonneg ⊢
      exact mul_le_mul_of_nonneg_right hcoef hinnerNonneg
    _ = 2592 * q ^ 2 * C₁ * W ^ 4 / m +
        2592 * q ^ 2 * C₀ / W ^ 5 := hrewrite
    _ < 1 / 2 + 1 / 2 := add_lt_add hhalf₁ hhalf₂
    _ = 1 := by norm_num

end Research


/-!
# Complete favorable small-prefix-gcd gate
-/

namespace Research

open Real goldenRatio

/-- The logarithmic cutoff position used by F-101/F-102, exposed as a reusable
natural-valued function. -/
def adaptiveLogCutoffPosition
    (n : ℕ → ℕ) (K G B L J X q : ℕ) : ℕ :=
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let d := (laterPositionRange K G).card
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := B ^ (2 * d)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  let N := U + V * G + V * q + 1
  G + q * (4 * Nat.clog 2 N + 4)

/-- A complete rationality contradiction for the favorable branch: a symmetric
window catches the near-half target, a polynomial first-crossing threshold
supplies the protected center cluster, and it remains only to verify the two
uniform norm caps at the explicitly bounded logarithmic cutoff. -/
theorem favorable_small_prefixGcd_rationality_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (K w : ℕ)
    (hw : 2 * w < n K)
    (hg : (4 * n K).gcd (sharpPrefixPeriod n K) < 2 * w)
    (hnoDouble : ∀ j, K < j → n j ≠ 2 * n K)
    (hfirst :
      let W := w + 1 + w
      (5184 : ℝ) * q ^ 2 *
        (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < n K)
    (hsecond :
      let W := w + 1 + w
      (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < W ^ 5)
    (hcaps :
      let P := sharpPrefixPeriod n K
      let W := w + 1 + w
      let B := n K * W ^ 8
      let Q := 8 * q * W
      ∀ X G,
        X < (4 * n K) * P →
        G ≤ K + Q →
        (laterPositionRange K G).card ≤ Q →
        let H := adaptiveLogCutoffPosition n K G B w w X q
        (φ⁻¹) ^ (w + 1) * (2 * cutoffTailCap H) < 1 ∧
        (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
          (2 * cutoffConjugateCap
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H) <
          (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  let P := sharpPrefixPeriod n K
  let W := w + 1 + w
  let B := n K * W ^ 8
  let Q := 8 * q * W
  have hwpos : 0 < w := by
    have hg0 : 0 ≤ (4 * n K).gcd P := Nat.zero_le _
    omega
  have hWpos : 0 < W := by dsimp [W]; omega
  have hmpos := hpos K
  obtain ⟨X, r, v, hPX, hXbound, hX, hv, hrpos, hrlt,
      hrLeft, hrRight, hrUpper, hsRWindow⟩ :=
    exists_nearHalf_symmetric_window_package P (n K) w hmpos hw
      (by simpa [P] using hg)
  obtain ⟨G, hKG, hBG, hvalues, hGbound, hdBound⟩ :=
    exists_polynomial_threshold_package
      n hpos hmono c hc hratio q hq K W hWpos
  let d := (laterPositionRange K G).card
  have hBpos : 0 < B := by
    dsimp [B]
    exact mul_pos hmpos (pow_pos hWpos _)
  have hsimple := polynomial_threshold_simple_density_of_bounds
    c hc q W (n K) hqpos hWpos hmpos
    (by simpa [W] using hfirst) (by simpa [W] using hsecond)
  have hdensity := adaptive_density_of_polynomial_threshold
    n hpos c hc q K G W d hWpos
      (by simpa [d, Q] using hdBound)
      (by simpa [B] using hBG)
      (by simpa [B, Q] using hsimple)
  have hcap := hcaps X G
    (by simpa [P] using hXbound)
    (by simpa [Q] using hGbound)
    (by simpa [Q, d] using hdBound)
  apply logarithmic_adaptive_protected_rationality_contradiction
    n hpos hmono c hc hratio a b hb hrat q hq
      K G B w w X r v hKG hBpos hvalues
  · omega
  · omega
  · exact hX
  · exact hv
  · exact hrlt
  · exact hrLeft
  · exact hrRight
  · exact hrUpper
  · exact hsRWindow
  · exact hPX
  · intro j hKj hjG
    exact hnoDouble j hKj
  · simpa [W, d] using hdensity
  · simpa [P, W, B, Q, adaptiveLogCutoffPosition, d] using hcap.1
  · simpa [P, W, B, Q, adaptiveLogCutoffPosition, d] using hcap.2

end Research


/-!
# A witness-independent upper bound for the favorable logarithmic cutoff
-/

namespace Research

open Real goldenRatio

/-- Uniform upper cutoff obtained by replacing the chosen target shift,
threshold position, and center count by their deterministic bounds. -/
def favorableCutoffUpper
    (n : ℕ → ℕ) (K w q : ℕ) : ℕ :=
  let m := n K
  let P := sharpPrefixPeriod n K
  let W := w + 1 + w
  let B := m * W ^ 8
  let Q := 8 * q * W
  let D := (2 * Q + 1) * (2 * Q + 2)
  let M := B ^ (2 * Q)
  let U := m + (4 * m) * M + (4 * m) * P + W
  let V := 4 * (4 * m) * D * W
  let N := U + V * (K + Q) + V * q + 1
  K + Q + q * (4 * Nat.clog 2 N + 4)

/-- Every actual logarithmic cutoff admitted by F-108's bounded witnesses lies
below `favorableCutoffUpper`. -/
theorem adaptiveLogCutoffPosition_le_favorableCutoffUpper
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K w q X G : ℕ) (hw : 0 < w)
    (hX : X < (4 * n K) * sharpPrefixPeriod n K)
    (hG : G ≤ K + 8 * q * (w + 1 + w))
    (hd : (laterPositionRange K G).card ≤
      8 * q * (w + 1 + w)) :
    adaptiveLogCutoffPosition n K G
      (n K * (w + 1 + w) ^ 8) w w X q ≤
      favorableCutoffUpper n K w q := by
  let m := n K
  let P := sharpPrefixPeriod n K
  let W := w + 1 + w
  let B := m * W ^ 8
  let Q := 8 * q * W
  let d := (laterPositionRange K G).card
  let Da := (2 * d + 1) * (2 * d + 2)
  let D := (2 * Q + 1) * (2 * Q + 2)
  let Ma := B ^ (2 * d)
  let M := B ^ (2 * Q)
  let Aa := m - w
  let Ua := Aa + (4 * m) * Ma + X + W
  let Va := 4 * (4 * m) * Da * W
  let Na := Ua + Va * G + Va * q + 1
  let U := m + (4 * m) * M + (4 * m) * P + W
  let V := 4 * (4 * m) * D * W
  let N := U + V * (K + Q) + V * q + 1
  have hdQ : d ≤ Q := by simpa [d, Q, W] using hd
  have hB : 1 ≤ B := by
    have hWpos : 0 < W := by dsimp [W]; omega
    have hBpos : 0 < B := by
      dsimp [B, m]
      exact mul_pos (hpos K) (pow_pos hWpos _)
    omega
  have hMa : Ma ≤ M := by
    dsimp [Ma, M]
    exact pow_le_pow_right₀ hB (by omega)
  have hDa : Da ≤ D := by
    dsimp [Da, D]
    gcongr
  have hUa : Ua ≤ U := by
    dsimp [Ua, U, Aa]
    have hXle : X ≤ (4 * m) * P := by simpa [m, P] using hX.le
    gcongr
    omega
  have hVa : Va ≤ V := by
    dsimp [Va, V]
    gcongr
  have hG' : G ≤ K + Q := by simpa [Q, W] using hG
  have hNa : Na ≤ N := by
    dsimp [Na, N]
    gcongr
  have hclog : Nat.clog 2 Na ≤ Nat.clog 2 N :=
    Nat.clog_mono (by norm_num) le_rfl hNa
  unfold adaptiveLogCutoffPosition favorableCutoffUpper
  dsimp only
  change G + q * (4 * Nat.clog 2 Na + 4) ≤
    K + Q + q * (4 * Nat.clog 2 N + 4)
  gcongr

lemma cutoffTailCap_mono {H H' : ℕ} (hHH : H ≤ H') :
    cutoffTailCap H ≤ cutoffTailCap H' := by
  unfold cutoffTailCap
  have hfactor : 0 ≤ (1 - φ⁻¹)⁻¹ := by
    exact inv_nonneg.mpr (sub_nonneg.mpr
      ((inv_le_one₀ Real.goldenRatio_pos).mpr Real.one_lt_goldenRatio.le))
  have hcast : (H : ℝ) ≤ H' := by exact_mod_cast hHH
  nlinarith [mul_le_mul_of_nonneg_right hcast hfactor]

lemma cutoffConjugateCap_mono (T : ℝ) {H H' : ℕ} (hHH : H ≤ H') :
    cutoffConjugateCap T H ≤ cutoffConjugateCap T H' := by
  unfold cutoffConjugateCap
  have hfactor : 0 ≤ (1 - φ⁻¹)⁻¹ := by
    exact inv_nonneg.mpr (sub_nonneg.mpr
      ((inv_le_one₀ Real.goldenRatio_pos).mpr Real.one_lt_goldenRatio.le))
  have hcast : (H : ℝ) ≤ H' := by exact_mod_cast hHH
  nlinarith [mul_le_mul_of_nonneg_right hcast hfactor]

/-- Norm-cap inequalities at the witness-independent upper cutoff imply the
universal cap hypothesis of F-108. -/
theorem favorable_uniform_caps_of_upper
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (a : ℤ) (b : ℕ) (K w q : ℕ) (hw : 0 < w)
    (hpost :
      let H := favorableCutoffUpper n K w q
      (φ⁻¹) ^ (w + 1) * (2 * cutoffTailCap H) < 1)
    (hpre :
      let H := favorableCutoffUpper n K w q
      (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap
          (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H) <
        (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    let P := sharpPrefixPeriod n K
    let W := w + 1 + w
    let B := n K * W ^ 8
    let Q := 8 * q * W
    ∀ X G,
      X < (4 * n K) * P →
      G ≤ K + Q →
      (laterPositionRange K G).card ≤ Q →
      let H := adaptiveLogCutoffPosition n K G B w w X q
      (φ⁻¹) ^ (w + 1) * (2 * cutoffTailCap H) < 1 ∧
      (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap
          (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H) <
        (((5 * b : ℕ) : ℝ)⁻¹) ^ 2 := by
  let P := sharpPrefixPeriod n K
  let W := w + 1 + w
  let B := n K * W ^ 8
  let Q := 8 * q * W
  dsimp only
  intro X G hX hG hd
  let H := adaptiveLogCutoffPosition n K G B w w X q
  let H' := favorableCutoffUpper n K w q
  have hHH : H ≤ H' := by
    exact adaptiveLogCutoffPosition_le_favorableCutoffUpper
      n hpos K w q X G hw (by simpa [P] using hX)
        (by simpa [Q, W] using hG) (by simpa [Q, W] using hd)
  have ht := cutoffTailCap_mono hHH
  have hc := cutoffConjugateCap_mono
    (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) hHH
  constructor
  · have hnonneg : 0 ≤ (φ⁻¹ : ℝ) ^ (w + 1) := by positivity
    have htwo : 2 * cutoffTailCap H ≤ 2 * cutoffTailCap H' := by
      gcongr
    exact (mul_le_mul_of_nonneg_left htwo hnonneg).trans_lt
      (by simpa [H'] using hpost)
  · have hpow : 0 ≤ (φ⁻¹ : ℝ) ^ w := by positivity
    have htail : 0 ≤ 2 * cutoffTailCap H := by
      unfold cutoffTailCap
      have hden : 0 < 1 - φ⁻¹ := sub_pos.mpr
        (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
      positivity
    have hfirst :
        (φ⁻¹) ^ w * (2 * cutoffTailCap H) ≤
          (φ⁻¹) ^ w * (2 * cutoffTailCap H') := by gcongr
    have hsecond :
        2 * cutoffConjugateCap
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H ≤
          2 * cutoffConjugateCap
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H' := by gcongr
    have hconjNonneg : 0 ≤
        2 * cutoffConjugateCap
          (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H := by
      unfold cutoffConjugateCap
      have hden : 0 < 1 - φ⁻¹ := sub_pos.mpr
        (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
      positivity
    have htail' : 0 ≤ 2 * cutoffTailCap H' := by
      unfold cutoffTailCap
      have hden : 0 < 1 - φ⁻¹ := sub_pos.mpr
        (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
      positivity
    have hfirstNonneg : 0 ≤
        (φ⁻¹) ^ w * (2 * cutoffTailCap H') :=
      mul_nonneg hpow htail'
    calc
      (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
          (2 * cutoffConjugateCap
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H) ≤
        (φ⁻¹) ^ w * (2 * cutoffTailCap H') *
          (2 * cutoffConjugateCap
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H) :=
        mul_le_mul_of_nonneg_right hfirst hconjNonneg
      _ ≤ (φ⁻¹) ^ w * (2 * cutoffTailCap H') *
          (2 * cutoffConjugateCap
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H') :=
        mul_le_mul_of_nonneg_left hsecond hfirstNonneg
      _ < (((5 * b : ℕ) : ℝ)⁻¹) ^ 2 := by simpa [H'] using hpre

end Research


/-!
# Favorable small-gcd gate with two deterministic norm inequalities
-/

namespace Research

open Real goldenRatio

/-- F-108 with its universal witness-dependent cap hypothesis replaced by two
inequalities at F-109's one deterministic upper cutoff. -/
theorem favorable_small_prefixGcd_upperCap_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (K w : ℕ)
    (hw : 2 * w < n K)
    (hg : (4 * n K).gcd (sharpPrefixPeriod n K) < 2 * w)
    (hnoDouble : ∀ j, K < j → n j ≠ 2 * n K)
    (hfirst :
      let W := w + 1 + w
      (5184 : ℝ) * q ^ 2 *
        (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < n K)
    (hsecond :
      let W := w + 1 + w
      (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < W ^ 5)
    (hpost :
      let H := favorableCutoffUpper n K w q
      (φ⁻¹) ^ (w + 1) * (2 * cutoffTailCap H) < 1)
    (hpre :
      let H := favorableCutoffUpper n K w q
      (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap
          (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H) <
        (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  have hwpos : 0 < w := by
    have hg0 : 0 ≤ (4 * n K).gcd (sharpPrefixPeriod n K) := Nat.zero_le _
    omega
  apply favorable_small_prefixGcd_rationality_contradiction
    n hpos hmono c hc hratio a b hb hrat q hqpos hq K w hw hg
      hnoDouble hfirst hsecond
  exact favorable_uniform_caps_of_upper
    n hpos a b K w q hwpos hpost hpre

end Research


/-!
# Elementary compositional binary-size bounds
-/

namespace Research

/-- Every natural number is at most `2^(2x)`. -/
theorem nat_le_two_pow_two_mul (x : ℕ) : x ≤ 2 ^ (2 * x) := by
  exact (show x ≤ 2 * x ^ 2 + 1 by nlinarith).trans
    (Nat.two_mul_sq_add_one_le_two_pow_two_mul x)

/-- Binary exponent bounds compose additively under multiplication. -/
theorem mul_le_two_pow_add
    {x y a b : ℕ} (hx : x ≤ 2 ^ a) (hy : y ≤ 2 ^ b) :
    x * y ≤ 2 ^ (a + b) := by
  calc
    x * y ≤ 2 ^ a * 2 ^ b := Nat.mul_le_mul hx hy
    _ = 2 ^ (a + b) := (pow_add 2 a b).symm

/-- A deliberately coarse compositional bound under addition. -/
theorem add_le_two_pow_add_add_one
    {x y a b : ℕ} (hx : x ≤ 2 ^ a) (hy : y ≤ 2 ^ b) :
    x + y ≤ 2 ^ (a + b + 1) := by
  have ha : 2 ^ a ≤ 2 ^ (a + b) :=
    pow_le_pow_right₀ (by norm_num) (by omega)
  have hb : 2 ^ b ≤ 2 ^ (a + b) :=
    pow_le_pow_right₀ (by norm_num) (by omega)
  calc
    x + y ≤ 2 ^ a + 2 ^ b := Nat.add_le_add hx hy
    _ ≤ 2 ^ (a + b) + 2 ^ (a + b) := Nat.add_le_add ha hb
    _ = 2 ^ (a + b + 1) := by rw [pow_succ]; ring

/-- Binary exponent bounds scale under natural powers. -/
theorem pow_le_two_pow_mul
    {x a : ℕ} (hx : x ≤ 2 ^ a) (k : ℕ) :
    x ^ k ≤ 2 ^ (a * k) := by
  calc
    x ^ k ≤ (2 ^ a) ^ k := Nat.pow_le_pow_left hx k
    _ = 2 ^ (a * k) := (pow_mul 2 a k).symm

end Research
/-!
# Elementary size bounds for sharp prefix periods and isolating shifts
-/

namespace Research

open scoped BigOperators

/-- The sharp prefix lcm divides the product of all preceding sharp periods. -/
theorem sharpPrefixPeriod_dvd_period_product
    (n : ℕ → ℕ) (K : ℕ) :
    sharpPrefixPeriod n K ∣
      ∏ k ∈ Finset.range K, fibLambertPeriod (n k) := by
  induction K with
  | zero => simp [sharpPrefixPeriod]
  | succ K ih =>
      simp only [sharpPrefixPeriod, Finset.prod_range_succ]
      apply Nat.lcm_dvd
      · exact dvd_trans ih (dvd_mul_right _ _)
      · exact dvd_mul_left _ _

/-- Every sharp prefix period is at most `(4n_K)^K`. -/
theorem sharpPrefixPeriod_le_pow_target
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K : ℕ) :
    sharpPrefixPeriod n K ≤ (4 * n K) ^ K := by
  have hprod :
      (∏ k ∈ Finset.range K, fibLambertPeriod (n k)) ≤
        (4 * n K) ^ K := by
    calc
      (∏ k ∈ Finset.range K, fibLambertPeriod (n k)) ≤
          (4 * n K) ^ (Finset.range K).card := by
        apply Finset.prod_le_pow_card
        intro k hk
        have hkK : k ≤ K := by
          have := Finset.mem_range.mp hk
          omega
        have hnk : n k ≤ n K := hmono.monotone hkK
        unfold fibLambertPeriod
        split <;> omega
      _ = (4 * n K) ^ K := by simp
  have hPpos := sharpPrefixPeriod_pos n hpos K
  exact (Nat.le_of_dvd (by
    have hfactorPos : ∀ k ∈ Finset.range K,
        0 < fibLambertPeriod (n k) := by
      intro k _
      unfold fibLambertPeriod
      split <;> nlinarith [hpos k]
    exact Finset.prod_pos hfactorPos)
    (sharpPrefixPeriod_dvd_period_product n K)).trans hprod

end Research

/-!
# A polynomial upper bound for the favorable cutoff
-/

namespace Research

/-- A compositional binary exponent bounding the large integer inside
`favorableCutoffUpper`'s binary logarithm. -/
def favorableCutoffBinaryExponent
    (n : ℕ → ℕ) (K w q : ℕ) : ℕ :=
  let m := n K
  let W := w + 1 + w
  let Q := 8 * q * W
  let D := (2 * Q + 1) * (2 * Q + 2)
  let eB := 2 * m + (2 * W) * 8
  let eM := eB * (2 * Q)
  let eP := (2 + 2 * m) * K
  let eT₁ := 2 + 2 * m + eM
  let eT₂ := 2 + 2 * m + eP
  let eU := 2 * m + eT₁ + 1 + eT₂ + 1 + 2 * W + 1
  let eV := 4 + 2 * m + 2 * D + 2 * W
  let eG := 2 * (K + Q)
  let eQ := 2 * q
  eU + (eV + eG) + 1 + (eV + eQ) + 1 + 0 + 1

/-- Explicit polynomial bound for `favorableCutoffUpper`. -/
def favorableCutoffPolynomial
    (n : ℕ → ℕ) (K w q : ℕ) : ℕ :=
  let W := w + 1 + w
  let Q := 8 * q * W
  let E := favorableCutoffBinaryExponent n K w q
  K + Q + q * (4 * E + 4)

/-- The witness-independent cutoff from F-109 is no larger than the explicit
polynomial `favorableCutoffPolynomial`. -/
theorem favorableCutoffUpper_le_polynomial
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K w q : ℕ) :
    favorableCutoffUpper n K w q ≤ favorableCutoffPolynomial n K w q := by
  let m := n K
  let P := sharpPrefixPeriod n K
  let W := w + 1 + w
  let B := m * W ^ 8
  let Q := 8 * q * W
  let D := (2 * Q + 1) * (2 * Q + 2)
  let M := B ^ (2 * Q)
  let U := m + (4 * m) * M + (4 * m) * P + W
  let V := 4 * (4 * m) * D * W
  let N := U + V * (K + Q) + V * q + 1
  let eB := 2 * m + (2 * W) * 8
  let eM := eB * (2 * Q)
  let eP := (2 + 2 * m) * K
  let eT₁ := 2 + 2 * m + eM
  let eT₂ := 2 + 2 * m + eP
  let eU := 2 * m + eT₁ + 1 + eT₂ + 1 + 2 * W + 1
  let eV := 4 + 2 * m + 2 * D + 2 * W
  let eG := 2 * (K + Q)
  let eQ := 2 * q
  let E := eU + (eV + eG) + 1 + (eV + eQ) + 1 + 0 + 1
  have hm : m ≤ 2 ^ (2 * m) := nat_le_two_pow_two_mul m
  have hW : W ≤ 2 ^ (2 * W) := nat_le_two_pow_two_mul W
  have h4 : 4 ≤ 2 ^ 2 := by norm_num
  have h16 : 16 ≤ 2 ^ 4 := by norm_num
  have hW8 : W ^ 8 ≤ 2 ^ ((2 * W) * 8) :=
    pow_le_two_pow_mul hW 8
  have hB : B ≤ 2 ^ eB := by
    dsimp [B, eB]
    exact mul_le_two_pow_add hm hW8
  have hM : M ≤ 2 ^ eM := by
    dsimp [M, eM]
    exact pow_le_two_pow_mul hB (2 * Q)
  have h4m : 4 * m ≤ 2 ^ (2 + 2 * m) :=
    mul_le_two_pow_add h4 hm
  have hPbase : P ≤ (4 * m) ^ K := by
    dsimp [P, m]
    exact sharpPrefixPeriod_le_pow_target n hpos hmono K
  have hP : P ≤ 2 ^ eP := by
    calc
      P ≤ (4 * m) ^ K := hPbase
      _ ≤ 2 ^ ((2 + 2 * m) * K) := pow_le_two_pow_mul h4m K
      _ = 2 ^ eP := rfl
  have hT₁ : (4 * m) * M ≤ 2 ^ eT₁ := by
    dsimp [eT₁]
    exact mul_le_two_pow_add h4m hM
  have hT₂ : (4 * m) * P ≤ 2 ^ eT₂ := by
    dsimp [eT₂]
    exact mul_le_two_pow_add h4m hP
  have hU₁ : m + (4 * m) * M ≤ 2 ^ (2 * m + eT₁ + 1) :=
    add_le_two_pow_add_add_one hm hT₁
  have hU₂ : m + (4 * m) * M + (4 * m) * P ≤
      2 ^ (2 * m + eT₁ + 1 + eT₂ + 1) :=
    add_le_two_pow_add_add_one hU₁ hT₂
  have hU : U ≤ 2 ^ eU := by
    dsimp [U, eU]
    exact add_le_two_pow_add_add_one hU₂ hW
  have hD : D ≤ 2 ^ (2 * D) := nat_le_two_pow_two_mul D
  have h44 : 4 * 4 ≤ 2 ^ (2 + 2) := mul_le_two_pow_add h4 h4
  have h44m : (4 * 4) * m ≤ 2 ^ (2 + 2 + 2 * m) :=
    mul_le_two_pow_add h44 hm
  have h44mD : (4 * 4) * m * D ≤
      2 ^ (2 + 2 + 2 * m + 2 * D) :=
    mul_le_two_pow_add h44m hD
  have hV : V ≤ 2 ^ eV := by
    have hv' : (4 * 4) * m * D * W ≤
        2 ^ (2 + 2 + 2 * m + 2 * D + 2 * W) :=
      mul_le_two_pow_add h44mD hW
    dsimp [V, eV]
    calc
      4 * (4 * m) * D * W = (4 * 4) * m * D * W := by ring
      _ ≤ 2 ^ (2 + 2 + 2 * m + 2 * D + 2 * W) := hv'
      _ = 2 ^ (4 + 2 * m + 2 * D + 2 * W) := by rfl
  have hG : K + Q ≤ 2 ^ eG := by
    dsimp [eG]
    exact nat_le_two_pow_two_mul (K + Q)
  have hq : q ≤ 2 ^ eQ := by
    dsimp [eQ]
    exact nat_le_two_pow_two_mul q
  have hVG : V * (K + Q) ≤ 2 ^ (eV + eG) :=
    mul_le_two_pow_add hV hG
  have hVq : V * q ≤ 2 ^ (eV + eQ) :=
    mul_le_two_pow_add hV hq
  have hN₁ : U + V * (K + Q) ≤
      2 ^ (eU + (eV + eG) + 1) :=
    add_le_two_pow_add_add_one hU hVG
  have hN₂ : U + V * (K + Q) + V * q ≤
      2 ^ (eU + (eV + eG) + 1 + (eV + eQ) + 1) :=
    add_le_two_pow_add_add_one hN₁ hVq
  have h1 : 1 ≤ 2 ^ 0 := by simp
  have hN : N ≤ 2 ^ E := by
    have hh := add_le_two_pow_add_add_one
      (a := eU + (eV + eG) + 1 + (eV + eQ) + 1) (b := 0) hN₂ h1
    dsimp [N, E]
    simpa using hh
  have hclog : Nat.clog 2 N ≤ E := by
    calc
      Nat.clog 2 N ≤ Nat.clog 2 (2 ^ E) :=
        Nat.clog_mono (by norm_num) le_rfl hN
      _ = E := Nat.clog_pow 2 E (by norm_num)
  unfold favorableCutoffUpper favorableCutoffPolynomial
  dsimp only
  change K + Q + q * (4 * Nat.clog 2 N + 4) ≤
    K + Q + q * (4 * E + 4)
  gcongr

end Research

/-!
# A coarse fixed-degree bound for the favorable cutoff
-/

namespace Research

/-- The explicit polynomial cutoff is bounded by one simple degree-five
polynomial in all of its natural parameters. -/
theorem favorableCutoffPolynomial_le_coarse
    (n : ℕ → ℕ) (K w q : ℕ) :
    favorableCutoffPolynomial n K w q ≤
      60000 * (n K + K + w + q + 2) ^ 5 := by
  let m := n K
  let s := m + K + w + q + 2
  let W := w + 1 + w
  let Q := 8 * q * W
  let D := (2 * Q + 1) * (2 * Q + 2)
  let eB := 2 * m + (2 * W) * 8
  let eM := eB * (2 * Q)
  let eP := (2 + 2 * m) * K
  let eT₁ := 2 + 2 * m + eM
  let eT₂ := 2 + 2 * m + eP
  let eU := 2 * m + eT₁ + 1 + eT₂ + 1 + 2 * W + 1
  let eV := 4 + 2 * m + 2 * D + 2 * W
  let eG := 2 * (K + Q)
  let eQ := 2 * q
  let E := eU + (eV + eG) + 1 + (eV + eQ) + 1 + 0 + 1
  have hs1 : 1 ≤ s := by dsimp [s]; omega
  have hm : m ≤ s := by dsimp [s]; omega
  have hK : K ≤ s := by dsimp [s]; omega
  have hw : w ≤ s := by dsimp [s]; omega
  have hq : q ≤ s := by dsimp [s]; omega
  have hs2 : 1 ≤ s ^ 2 := one_le_pow₀ hs1
  have hs3 : 1 ≤ s ^ 3 := one_le_pow₀ hs1
  have hs4 : 1 ≤ s ^ 4 := one_le_pow₀ hs1
  have hs_le_sq : s ≤ s ^ 2 := by
    simpa [pow_two] using Nat.mul_le_mul_left s hs1
  have hs2_le_s3 : s ^ 2 ≤ s ^ 3 := by
    rw [pow_succ]
    exact Nat.le_mul_of_pos_right _ (by omega)
  have hs3_le_s4 : s ^ 3 ≤ s ^ 4 := by
    rw [pow_succ]
    exact Nat.le_mul_of_pos_right _ (by omega)
  have hs4_le_s5 : s ^ 4 ≤ s ^ 5 := by
    rw [pow_succ]
    exact Nat.le_mul_of_pos_right _ (by omega)
  have hW : W ≤ 3 * s := by
    dsimp [W]
    omega
  have hQ : Q ≤ 24 * s ^ 2 := by
    calc
      Q = 8 * q * W := rfl
      _ ≤ 8 * s * (3 * s) := by gcongr
      _ = 24 * s ^ 2 := by ring
  have h2Q1 : 2 * Q + 1 ≤ 49 * s ^ 2 := by omega
  have h2Q2 : 2 * Q + 2 ≤ 50 * s ^ 2 := by omega
  have hD : D ≤ 2450 * s ^ 4 := by
    calc
      D = (2 * Q + 1) * (2 * Q + 2) := rfl
      _ ≤ (49 * s ^ 2) * (50 * s ^ 2) := Nat.mul_le_mul h2Q1 h2Q2
      _ = 2450 * s ^ 4 := by ring
  have heB : eB ≤ 50 * s := by
    dsimp [eB]
    omega
  have heM : eM ≤ 2400 * s ^ 3 := by
    calc
      eM = eB * (2 * Q) := rfl
      _ ≤ (50 * s) * (2 * (24 * s ^ 2)) := Nat.mul_le_mul heB (Nat.mul_le_mul_left 2 hQ)
      _ = 2400 * s ^ 3 := by ring
  have heP : eP ≤ 4 * s ^ 2 := by
    calc
      eP = (2 + 2 * m) * K := rfl
      _ ≤ (4 * s) * s := by
        apply Nat.mul_le_mul
        · omega
        · exact hK
      _ = 4 * s ^ 2 := by ring
  have heT₁ : eT₁ ≤ 2404 * s ^ 3 := by
    dsimp [eT₁]
    omega
  have heT₂ : eT₂ ≤ 8 * s ^ 3 := by
    dsimp [eT₂]
    omega
  have heU : eU ≤ 2423 * s ^ 3 := by
    dsimp [eU]
    omega
  have heV : eV ≤ 4912 * s ^ 4 := by
    dsimp [eV]
    omega
  have heG : eG ≤ 50 * s ^ 4 := by
    dsimp [eG]
    omega
  have heQ : eQ ≤ 2 * s ^ 4 := by
    dsimp [eQ]
    omega
  have hE : E ≤ 13000 * s ^ 4 := by
    dsimp [E]
    omega
  unfold favorableCutoffPolynomial favorableCutoffBinaryExponent
  dsimp only
  change K + Q + q * (4 * E + 4) ≤ 60000 * s ^ 5
  calc
    K + Q + q * (4 * E + 4) ≤
        s + 24 * s ^ 2 + s * (4 * (13000 * s ^ 4) + 4) := by gcongr
    _ ≤ 60000 * s ^ 5 := by nlinarith

/-- Consequently F-109's deterministic cutoff has the same coarse degree-five
bound. -/
theorem favorableCutoffUpper_le_coarse
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K w q : ℕ) :
    favorableCutoffUpper n K w q ≤
      60000 * (n K + K + w + q + 2) ^ 5 :=
  (favorableCutoffUpper_le_polynomial n hpos hmono K w q).trans
    (favorableCutoffPolynomial_le_coarse n K w q)

end Research

/-!
# A window-polynomial upper bound for the favorable cutoff
-/

namespace Research

/-- A fixed degree-forty cutoff bound after the target is bounded by the eighth
power of the window parameter. -/
def favorableWindowCutoffBound (q w : ℕ) : ℕ :=
  60000 * (q + 5) ^ 5 * (w + 1) ^ 40

/-- If the target lies below `(w+1)^8`, then the favorable cutoff is bounded by
an explicit degree-forty polynomial in `w` (with `q` fixed). -/
theorem favorableCutoffUpper_le_windowCutoffBound
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K w q : ℕ) (hm : n K ≤ (w + 1) ^ 8) :
    favorableCutoffUpper n K w q ≤ favorableWindowCutoffBound q w := by
  let m := n K
  let R := (w + 1) ^ 8
  let s := m + K + w + q + 2
  have hKm : K ≤ m := by simpa [m] using hmono.le_apply
  have hKR : K ≤ R := hKm.trans (by simpa [m, R] using hm)
  have hmR : m ≤ R := by simpa [m, R] using hm
  have hRpos : 0 < R := by dsimp [R]; positivity
  have hwR : w ≤ R := by
    calc
      w ≤ w + 1 := by omega
      _ ≤ (w + 1) ^ 8 := Nat.le_pow (by norm_num)
      _ = R := rfl
  have hqR : q ≤ q * R := Nat.le_mul_of_pos_right q hRpos
  have hRone : 1 ≤ R := by omega
  have h2R : 2 ≤ 2 * R := Nat.mul_le_mul_left 2 hRone
  have hs : s ≤ (q + 5) * R := by
    dsimp [s]
    calc
      m + K + w + q + 2 ≤ R + R + R + q * R + 2 * R := by gcongr
      _ = (q + 5) * R := by ring
  calc
    favorableCutoffUpper n K w q ≤ 60000 * s ^ 5 := by
      simpa [s, m] using favorableCutoffUpper_le_coarse n hpos hmono K w q
    _ ≤ 60000 * ((q + 5) * R) ^ 5 := by gcongr
    _ = favorableWindowCutoffBound q w := by
      simp only [favorableWindowCutoffBound]
      dsimp [R]
      ring

end Research

/-!
# Exponential norm decay for the polynomial favorable cutoff
-/

namespace Research

open Filter Topology Real goldenRatio

/-- The fixed linear coefficient controlling the principal cutoff cap. -/
noncomputable def cutoffTailLinearConstant : ℝ :=
  (1 - φ⁻¹)⁻¹ + φ⁻¹ / (1 - φ⁻¹) ^ 2

/-- The fixed linear coefficient controlling the conjugate cutoff cap. -/
noncomputable def cutoffConjugateLinearConstant (T : ℝ) : ℝ :=
  |T| + (1 - φ⁻¹)⁻¹

lemma cutoffTailLinearConstant_nonneg : 0 ≤ cutoffTailLinearConstant := by
  unfold cutoffTailLinearConstant
  have hr : 0 < φ⁻¹ := inv_pos.mpr Real.goldenRatio_pos
  have hd : 0 < 1 - φ⁻¹ := sub_pos.mpr
    (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
  positivity

lemma cutoffConjugateLinearConstant_nonneg (T : ℝ) :
    0 ≤ cutoffConjugateLinearConstant T := by
  unfold cutoffConjugateLinearConstant
  have hd : 0 < 1 - φ⁻¹ := sub_pos.mpr
    (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
  positivity

lemma cutoffTailCap_nonneg (H : ℕ) : 0 ≤ cutoffTailCap H := by
  unfold cutoffTailCap
  have hr : 0 < φ⁻¹ := inv_pos.mpr Real.goldenRatio_pos
  have hd : 0 < 1 - φ⁻¹ := sub_pos.mpr
    (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
  positivity

lemma cutoffConjugateCap_nonneg (T : ℝ) (H : ℕ) :
    0 ≤ cutoffConjugateCap T H := by
  unfold cutoffConjugateCap
  have hd : 0 < 1 - φ⁻¹ := sub_pos.mpr
    (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
  positivity

/-- Both summands of the principal cap are absorbed by one linear function. -/
lemma cutoffTailCap_le_linear (H : ℕ) :
    cutoffTailCap H ≤ cutoffTailLinearConstant * ((H : ℝ) + 1) := by
  unfold cutoffTailCap cutoffTailLinearConstant
  have hH : 0 ≤ (H : ℝ) := by positivity
  have hA : 0 ≤ (1 - φ⁻¹)⁻¹ := by
    have hd : 0 < 1 - φ⁻¹ := sub_pos.mpr
      (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
    positivity
  have hB : 0 ≤ φ⁻¹ / (1 - φ⁻¹) ^ 2 := by
    have hr : 0 < φ⁻¹ := inv_pos.mpr Real.goldenRatio_pos
    have hd : 0 < 1 - φ⁻¹ := sub_pos.mpr
      (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
    positivity
  nlinarith

/-- The conjugate cap is likewise absorbed by one linear function. -/
lemma cutoffConjugateCap_le_linear (T : ℝ) (H : ℕ) :
    cutoffConjugateCap T H ≤
      cutoffConjugateLinearConstant T * ((H : ℝ) + 1) := by
  unfold cutoffConjugateCap cutoffConjugateLinearConstant
  have hH : 0 ≤ (H : ℝ) := by positivity
  have hA : 0 ≤ (1 - φ⁻¹)⁻¹ := by
    have hd : 0 < 1 - φ⁻¹ := sub_pos.mpr
      (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
    positivity
  have hT : 0 ≤ |T| := abs_nonneg T
  nlinarith

/-- The natural cutoff plus one is bounded by its fixed coefficient times the
same degree-forty monomial. -/
lemma favorableWindowCutoffBound_add_one_le (q w : ℕ) :
    favorableWindowCutoffBound q w + 1 ≤
      (60000 * (q + 5) ^ 5 + 1) * (w + 1) ^ 40 := by
  unfold favorableWindowCutoffBound
  have hp : 1 ≤ (w + 1) ^ 40 := one_le_pow₀ (by omega)
  calc
    60000 * (q + 5) ^ 5 * (w + 1) ^ 40 + 1 ≤
        60000 * (q + 5) ^ 5 * (w + 1) ^ 40 + (w + 1) ^ 40 := by
      gcongr
    _ = (60000 * (q + 5) ^ 5 + 1) * (w + 1) ^ 40 := by ring

/-- The principal cap at the window-polynomial cutoff, multiplied by the
corresponding golden power, tends to zero. -/
theorem tendsto_favorableWindow_tailCap :
    Tendsto (fun w : ℕ =>
      (φ⁻¹) ^ (w + 1) *
        (2 * cutoffTailCap (favorableWindowCutoffBound q w)))
      atTop (𝓝 0) := by
  let C : ℝ :=
    2 * cutoffTailLinearConstant *
      (60000 * (q + 5) ^ 5 + 1 : ℕ)
  let g : ℕ → ℝ := fun w =>
    C * ((w + 1 : ℕ) : ℝ) ^ 40 * (φ⁻¹) ^ (w + 1)
  have hr0 : 0 ≤ (φ⁻¹ : ℝ) := (inv_pos.mpr Real.goldenRatio_pos).le
  have hr1 : (φ⁻¹ : ℝ) < 1 :=
    inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hg : Tendsto g atTop (𝓝 0) := by
    have hbase := tendsto_pow_const_mul_const_pow_of_lt_one 40 hr0 hr1
    have hshift := hbase.comp (Filter.tendsto_add_atTop_nat 1)
    have hconst := hshift.const_mul C
    simpa [g, mul_assoc] using hconst
  apply squeeze_zero
  · intro w
    have ht := cutoffTailCap_nonneg (favorableWindowCutoffBound q w)
    positivity
  · intro w
    have hcap := cutoffTailCap_le_linear
      (favorableWindowCutoffBound q w)
    have hnat := favorableWindowCutoffBound_add_one_le q w
    have hcast :
        ((favorableWindowCutoffBound q w : ℕ) : ℝ) + 1 ≤
          ((60000 * (q + 5) ^ 5 + 1 : ℕ) : ℝ) *
            ((w + 1 : ℕ) : ℝ) ^ 40 := by
      exact_mod_cast hnat
    have hc := mul_le_mul_of_nonneg_left hcast
      cutoffTailLinearConstant_nonneg
    have hp : 0 ≤ (φ⁻¹ : ℝ) ^ (w + 1) := by positivity
    calc
      (φ⁻¹) ^ (w + 1) *
          (2 * cutoffTailCap (favorableWindowCutoffBound q w)) ≤
        (φ⁻¹) ^ (w + 1) *
          (2 * (cutoffTailLinearConstant *
            (((favorableWindowCutoffBound q w : ℕ) : ℝ) + 1))) := by
              gcongr
      _ ≤ (φ⁻¹) ^ (w + 1) *
          (2 * (cutoffTailLinearConstant *
            (((60000 * (q + 5) ^ 5 + 1 : ℕ) : ℝ) *
              ((w + 1 : ℕ) : ℝ) ^ 40))) := by gcongr
      _ = 2 * cutoffTailLinearConstant *
          ((60000 * (q + 5) ^ 5 + 1 : ℕ) : ℝ) *
          ((w + 1 : ℕ) : ℝ) ^ 40 * (φ⁻¹) ^ (w + 1) := by ring
  · exact hg

/-- The product of principal and conjugate caps at the window-polynomial
cutoff, multiplied by the golden power, tends to zero. -/
theorem tendsto_favorableWindow_normProduct (T : ℝ) :
    Tendsto (fun w : ℕ =>
      (φ⁻¹) ^ w *
        (2 * cutoffTailCap (favorableWindowCutoffBound q w)) *
        (2 * cutoffConjugateCap T (favorableWindowCutoffBound q w)))
      atTop (𝓝 0) := by
  let r : ℝ := φ⁻¹
  let A : ℝ := ((60000 * (q + 5) ^ 5 + 1 : ℕ) : ℝ)
  let C : ℝ :=
    4 * cutoffTailLinearConstant * cutoffConjugateLinearConstant T *
      A ^ 2 * r⁻¹
  let g : ℕ → ℝ := fun w =>
    C * ((w + 1 : ℕ) : ℝ) ^ 80 * r ^ (w + 1)
  have hrpos : 0 < r := by dsimp [r]; exact inv_pos.mpr Real.goldenRatio_pos
  have hr0 : 0 ≤ r := hrpos.le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hg : Tendsto g atTop (𝓝 0) := by
    have hbase := tendsto_pow_const_mul_const_pow_of_lt_one 80 hr0 hr1
    have hshift := hbase.comp (Filter.tendsto_add_atTop_nat 1)
    have hconst := hshift.const_mul C
    simpa [g, mul_assoc] using hconst
  apply squeeze_zero
  · intro w
    have ht := cutoffTailCap_nonneg (favorableWindowCutoffBound q w)
    have hc := cutoffConjugateCap_nonneg T (favorableWindowCutoffBound q w)
    positivity
  · intro w
    have ht := cutoffTailCap_le_linear (favorableWindowCutoffBound q w)
    have hc := cutoffConjugateCap_le_linear T (favorableWindowCutoffBound q w)
    have hnat := favorableWindowCutoffBound_add_one_le q w
    have hcast :
        ((favorableWindowCutoffBound q w : ℕ) : ℝ) + 1 ≤
          A * ((w + 1 : ℕ) : ℝ) ^ 40 := by
      dsimp [A]
      exact_mod_cast hnat
    have ht' : cutoffTailCap (favorableWindowCutoffBound q w) ≤
        cutoffTailLinearConstant * A * ((w + 1 : ℕ) : ℝ) ^ 40 := by
      calc
        cutoffTailCap (favorableWindowCutoffBound q w) ≤
            cutoffTailLinearConstant *
              (((favorableWindowCutoffBound q w : ℕ) : ℝ) + 1) := ht
        _ ≤ cutoffTailLinearConstant *
            (A * ((w + 1 : ℕ) : ℝ) ^ 40) :=
          mul_le_mul_of_nonneg_left hcast cutoffTailLinearConstant_nonneg
        _ = cutoffTailLinearConstant * A *
            ((w + 1 : ℕ) : ℝ) ^ 40 := by ring
    have hc' : cutoffConjugateCap T (favorableWindowCutoffBound q w) ≤
        cutoffConjugateLinearConstant T * A *
          ((w + 1 : ℕ) : ℝ) ^ 40 := by
      calc
        cutoffConjugateCap T (favorableWindowCutoffBound q w) ≤
            cutoffConjugateLinearConstant T *
              (((favorableWindowCutoffBound q w : ℕ) : ℝ) + 1) := hc
        _ ≤ cutoffConjugateLinearConstant T *
            (A * ((w + 1 : ℕ) : ℝ) ^ 40) :=
          mul_le_mul_of_nonneg_left hcast
            (cutoffConjugateLinearConstant_nonneg T)
        _ = cutoffConjugateLinearConstant T * A *
            ((w + 1 : ℕ) : ℝ) ^ 40 := by ring
    have ht0 := cutoffTailCap_nonneg (favorableWindowCutoffBound q w)
    have hc0 := cutoffConjugateCap_nonneg T (favorableWindowCutoffBound q w)
    have hAt : 0 ≤ cutoffTailLinearConstant * A *
        ((w + 1 : ℕ) : ℝ) ^ 40 := ht0.trans ht'
    have hAc : 0 ≤ cutoffConjugateLinearConstant T * A *
        ((w + 1 : ℕ) : ℝ) ^ 40 := hc0.trans hc'
    have h2t : 2 * cutoffTailCap (favorableWindowCutoffBound q w) ≤
        2 * (cutoffTailLinearConstant * A *
          ((w + 1 : ℕ) : ℝ) ^ 40) := by gcongr
    have h2c : 2 * cutoffConjugateCap T (favorableWindowCutoffBound q w) ≤
        2 * (cutoffConjugateLinearConstant T * A *
          ((w + 1 : ℕ) : ℝ) ^ 40) := by gcongr
    have hrpow : 0 ≤ r ^ w := pow_nonneg hr0 _
    have hfirst :
        r ^ w * (2 * cutoffTailCap (favorableWindowCutoffBound q w)) ≤
          r ^ w * (2 * (cutoffTailLinearConstant * A *
            ((w + 1 : ℕ) : ℝ) ^ 40)) :=
      mul_le_mul_of_nonneg_left h2t hrpow
    have hrshift : r⁻¹ * r ^ (w + 1) = r ^ w := by
      rw [pow_succ]
      field_simp
    change r ^ w *
        (2 * cutoffTailCap (favorableWindowCutoffBound q w)) *
        (2 * cutoffConjugateCap T (favorableWindowCutoffBound q w)) ≤
      4 * cutoffTailLinearConstant * cutoffConjugateLinearConstant T *
        A ^ 2 * r⁻¹ * ((w + 1 : ℕ) : ℝ) ^ 80 * r ^ (w + 1)
    calc
      r ^ w * (2 * cutoffTailCap (favorableWindowCutoffBound q w)) *
          (2 * cutoffConjugateCap T (favorableWindowCutoffBound q w)) ≤
        r ^ w *
          (2 * (cutoffTailLinearConstant * A *
            ((w + 1 : ℕ) : ℝ) ^ 40)) *
          (2 * cutoffConjugateCap T (favorableWindowCutoffBound q w)) :=
        mul_le_mul_of_nonneg_right hfirst (by positivity)
      _ ≤ r ^ w *
          (2 * (cutoffTailLinearConstant * A *
            ((w + 1 : ℕ) : ℝ) ^ 40)) *
          (2 * (cutoffConjugateLinearConstant T * A *
            ((w + 1 : ℕ) : ℝ) ^ 40)) := by
        exact mul_le_mul_of_nonneg_left h2c (mul_nonneg hrpow (by positivity))
      _ = 4 * cutoffTailLinearConstant * cutoffConjugateLinearConstant T *
          A ^ 2 * r⁻¹ * ((w + 1 : ℕ) : ℝ) ^ 80 * r ^ (w + 1) := by
            rw [← hrshift]
            ring
  · exact hg

/-- Thus both numerical norm inequalities hold for all sufficiently large
window parameters, with any fixed positive target on the norm product. -/
theorem eventually_favorableWindow_normCaps (q : ℕ) (T ε : ℝ) (hε : 0 < ε) :
    ∀ᶠ w : ℕ in atTop,
      (φ⁻¹) ^ (w + 1) *
          (2 * cutoffTailCap (favorableWindowCutoffBound q w)) < 1 ∧
      (φ⁻¹) ^ w *
          (2 * cutoffTailCap (favorableWindowCutoffBound q w)) *
          (2 * cutoffConjugateCap T (favorableWindowCutoffBound q w)) < ε := by
  exact ((tendsto_favorableWindow_tailCap (q := q)).eventually
      (gt_mem_nhds zero_lt_one)).and
    ((tendsto_favorableWindow_normProduct (q := q) T).eventually
      (gt_mem_nhds hε))

end Research

/-!
# Polynomial density inequalities for eighth-root windows
-/

namespace Research

open Filter Topology

/-- For any fixed nonnegative leading constant, a symmetric window of width
`2w+1` has fourth power negligible compared with `w^8`; its fifth power also
dominates every fixed constant. -/
theorem eventually_affineWindow_density (A B : ℝ) (hA : 0 ≤ A) :
    ∀ᶠ w : ℕ in atTop,
      A * (((w + 1 + w : ℕ) : ℝ) ^ 4) < (w : ℝ) ^ 8 ∧
      B < (((w + 1 + w : ℕ) : ℝ) ^ 5) := by
  have hpow4 : Tendsto (fun w : ℕ => (w : ℝ) ^ 4) atTop atTop :=
    (Filter.tendsto_pow_atTop (α := ℝ) (by norm_num)).comp
      (tendsto_natCast_atTop_atTop (R := ℝ))
  have hpow5 : Tendsto (fun w : ℕ => (w : ℝ) ^ 5) atTop atTop :=
    (Filter.tendsto_pow_atTop (α := ℝ) (by norm_num)).comp
      (tendsto_natCast_atTop_atTop (R := ℝ))
  filter_upwards [eventually_ge_atTop 1,
    hpow4.eventually_gt_atTop (81 * A),
    hpow5.eventually_gt_atTop B] with w hw h4 h5
  have hW : w + 1 + w ≤ 3 * w := by omega
  have hwpos : 0 < (w : ℝ) ^ 4 := by positivity
  constructor
  · have hstrict := mul_lt_mul_of_pos_right h4 hwpos
    calc
      A * (((w + 1 + w : ℕ) : ℝ) ^ 4) ≤
          A * ((3 * (w : ℝ)) ^ 4) := by
            gcongr
            exact_mod_cast hW
      _ = (81 * A) * (w : ℝ) ^ 4 := by ring
      _ < (w : ℝ) ^ 4 * (w : ℝ) ^ 4 := hstrict
      _ = (w : ℝ) ^ 8 := by ring
  · calc
      B < (w : ℝ) ^ 5 := h5
      _ ≤ (((w + 1 + w : ℕ) : ℝ) ^ 5) := by
        gcongr
        norm_num

/-- F-107's two concrete density inequalities hold for every sufficiently
large eighth-root window, before comparison with the actual target. -/
theorem eventually_polynomialDensity_window
    (c : ℝ) (hc : 1 < c) (q : ℕ) :
    ∀ᶠ w : ℕ in atTop,
      let W : ℕ := w + 1 + w
      (5184 : ℝ) * q ^ 2 *
          (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < (w : ℝ) ^ 8 ∧
        (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < (W : ℝ) ^ 5 := by
  have hinvpos : 0 < c⁻¹ := inv_pos.mpr (lt_trans zero_lt_one hc)
  have hden : 0 < 1 - c⁻¹ := sub_pos.mpr (inv_lt_one_of_one_lt₀ hc)
  have hA : 0 ≤
      (5184 : ℝ) * q ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹) := by positivity
  filter_upwards [eventually_affineWindow_density
    ((5184 : ℝ) * q ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹))
    ((5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹) hA] with w hw
  dsimp only
  constructor
  · simpa [mul_assoc] using hw.1
  · simpa [mul_assoc] using hw.2

/-- If `w^8≤n_K`, the eventual window estimates imply exactly F-110's two
density hypotheses at the target. -/
theorem polynomialDensity_of_window_le_target
    (c : ℝ) (q w m : ℕ)
    (hfirst :
      let W : ℕ := w + 1 + w
      (5184 : ℝ) * q ^ 2 *
        (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < (w : ℝ) ^ 8)
    (hsecond :
      let W : ℕ := w + 1 + w
      (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < (W : ℝ) ^ 5)
    (hwm : w ^ 8 ≤ m) :
    let W : ℕ := w + 1 + w
    (5184 : ℝ) * q ^ 2 *
        (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < m ∧
      (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < W ^ 5 := by
  dsimp only at hfirst hsecond ⊢
  constructor
  · exact hfirst.trans_le (by exact_mod_cast hwm)
  · simpa using hsecond

end Research

/-!
# The favorable branch reduced to a structural eighth-root dichotomy
-/

namespace Research

open Filter Topology Real goldenRatio

/-- Norm inequalities at F-114's window-only upper bound descend to every
smaller cutoff. -/
theorem favorable_normCaps_of_windowCutoffBound
    (T : ℝ) (q w H : ℕ)
    (hH : H ≤ favorableWindowCutoffBound q w)
    (hpost :
      (φ⁻¹) ^ (w + 1) *
        (2 * cutoffTailCap (favorableWindowCutoffBound q w)) < 1)
    (hpre :
      (φ⁻¹) ^ w *
        (2 * cutoffTailCap (favorableWindowCutoffBound q w)) *
        (2 * cutoffConjugateCap T (favorableWindowCutoffBound q w)) < ε) :
    (φ⁻¹) ^ (w + 1) * (2 * cutoffTailCap H) < 1 ∧
      (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap T H) < ε := by
  have ht := cutoffTailCap_mono hH
  have hc := cutoffConjugateCap_mono T hH
  have hrw : 0 ≤ (φ⁻¹ : ℝ) ^ w := by positivity
  have hrw1 : 0 ≤ (φ⁻¹ : ℝ) ^ (w + 1) := by positivity
  have htB0 := cutoffTailCap_nonneg (favorableWindowCutoffBound q w)
  have hc0 := cutoffConjugateCap_nonneg T H
  have h2t : 2 * cutoffTailCap H ≤
      2 * cutoffTailCap (favorableWindowCutoffBound q w) :=
    mul_le_mul_of_nonneg_left ht (by norm_num)
  have h2c : 2 * cutoffConjugateCap T H ≤
      2 * cutoffConjugateCap T (favorableWindowCutoffBound q w) :=
    mul_le_mul_of_nonneg_left hc (by norm_num)
  constructor
  · exact (mul_le_mul_of_nonneg_left h2t hrw1).trans_lt hpost
  · have hfirst :
        (φ⁻¹) ^ w * (2 * cutoffTailCap H) ≤
          (φ⁻¹) ^ w *
            (2 * cutoffTailCap (favorableWindowCutoffBound q w)) :=
      mul_le_mul_of_nonneg_left h2t hrw
    have hfirst0 : 0 ≤
        (φ⁻¹) ^ w *
          (2 * cutoffTailCap (favorableWindowCutoffBound q w)) :=
      mul_nonneg hrw (mul_nonneg (by norm_num) htB0)
    calc
      (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
          (2 * cutoffConjugateCap T H) ≤
        (φ⁻¹) ^ w *
          (2 * cutoffTailCap (favorableWindowCutoffBound q w)) *
          (2 * cutoffConjugateCap T H) :=
        mul_le_mul_of_nonneg_right hfirst
          (mul_nonneg (by norm_num) hc0)
      _ ≤ (φ⁻¹) ^ w *
          (2 * cutoffTailCap (favorableWindowCutoffBound q w)) *
          (2 * cutoffConjugateCap T
            (favorableWindowCutoffBound q w)) :=
        mul_le_mul_of_nonneg_left h2c hfirst0
      _ < ε := hpre

/-- Under a hypothetical rational value, every sufficiently large target in
its eighth-root window has either a large prefix-period gcd or an exact selected
double. Thus all numerical hypotheses of F-110 have been discharged. -/
theorem eventually_largePrefixGcd_or_selectedDouble_of_rational
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    ∀ᶠ w : ℕ in atTop, ∀ K : ℕ,
      w ^ 8 ≤ n K → n K ≤ (w + 1) ^ 8 →
      2 * w ≤ (4 * n K).gcd (sharpPrefixPeriod n K) ∨
        ∃ j, K < j ∧ n j = 2 * n K := by
  let T : ℝ := -((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))
  let ε : ℝ := (((5 * b : ℕ) : ℝ)⁻¹) ^ 2
  have hε : 0 < ε := by
    dsimp [ε]
    have h5b : 0 < 5 * b := mul_pos (by norm_num) hb
    positivity
  have hdensity := eventually_polynomialDensity_window c hc q
  have hnorm := eventually_favorableWindow_normCaps q T ε hε
  filter_upwards [eventually_ge_atTop 2, hdensity, hnorm] with w hw hd hn
  intro K hlow hupp
  by_contra hstruct
  push Not at hstruct
  rcases hstruct with ⟨hg, hnoDouble⟩
  have h2w_sq : 2 * w ≤ w ^ 2 := by nlinarith
  have hsquare_eighth : w ^ 2 < w ^ 8 :=
    Nat.pow_lt_pow_right (by omega) (by norm_num)
  have hwindow : 2 * w < n K :=
    (h2w_sq.trans_lt hsquare_eighth).trans_le hlow
  obtain ⟨hfirst, hsecond⟩ := polynomialDensity_of_window_le_target
    c q w (n K) hd.1 hd.2 hlow
  have hH : favorableCutoffUpper n K w q ≤
      favorableWindowCutoffBound q w :=
    favorableCutoffUpper_le_windowCutoffBound n hpos hmono K w q hupp
  obtain ⟨hpost, hpre⟩ := favorable_normCaps_of_windowCutoffBound
    T q w (favorableCutoffUpper n K w q) hH hn.1 hn.2
  exact favorable_small_prefixGcd_upperCap_contradiction
    n hpos hmono c hc hratio a b hb hrat q hqpos hq K w
      hwindow hg hnoDouble hfirst hsecond hpost
        (by simpa only [T, ε] using hpre)

end Research

/-!
# Intrinsic eighth-root form of the rational structural dichotomy
-/

namespace Research

open Filter Topology

/-- The canonical natural eighth root of a selected target. -/
def targetEighthRoot (n : ℕ → ℕ) (K : ℕ) : ℕ :=
  Nat.nthRoot 8 (n K)

lemma targetEighthRoot_pow_le (n : ℕ → ℕ) (K : ℕ) :
    targetEighthRoot n K ^ 8 ≤ n K := by
  exact Nat.pow_nthRoot_le (Or.inl (by norm_num))

lemma target_lt_eighthRoot_add_one_pow (n : ℕ → ℕ) (K : ℕ) :
    n K < (targetEighthRoot n K + 1) ^ 8 := by
  exact Nat.lt_pow_nthRoot_add_one (by norm_num) (n K)

/-- Along a strictly increasing selected sequence, its canonical eighth-root
scale tends to infinity. -/
theorem tendsto_targetEighthRoot_atTop
    (n : ℕ → ℕ) (hmono : StrictMono n) :
    Tendsto (targetEighthRoot n) atTop atTop := by
  rw [tendsto_atTop]
  intro W
  filter_upwards [hmono.tendsto_atTop.eventually_ge_atTop (W ^ 8)] with K hK
  exact (Nat.le_nthRoot_iff (by norm_num)).2 hK

/-- Intrinsic version of F-117: under rationality, every sufficiently late
selected target has prefix-period gcd at least twice its natural eighth root,
or has an exact selected double. -/
theorem eventually_eighthRoot_le_prefixGcd_or_selectedDouble_of_rational
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    ∀ᶠ K : ℕ in atTop,
      2 * targetEighthRoot n K ≤
          (4 * n K).gcd (sharpPrefixPeriod n K) ∨
        ∃ j, K < j ∧ n j = 2 * n K := by
  have hd := eventually_largePrefixGcd_or_selectedDouble_of_rational
    n hpos hmono c hc hratio a b hb hrat q hqpos hq
  have hroot := tendsto_targetEighthRoot_atTop n hmono
  filter_upwards [hroot.eventually hd] with K hK
  apply hK K
  · exact targetEighthRoot_pow_le n K
  · exact (target_lt_eighthRoot_add_one_pow n K).le

end Research

/-!
# Exact half-period targets when the prefix gcd divides the target
-/

namespace Research

/-- If `gcd(4n,P)` divides `n`, the near-half multiplier from F-079 lands
exactly at the half period. -/
theorem exists_exactHalf_evenQuotient_multiplier
    (P n : ℕ) (hn : 0 < n) (hgdiv : (4 * n).gcd P ∣ n) :
    ∃ X v : ℕ,
      P ∣ X ∧ X < (4 * n) * P ∧
      X = n + (2 * n) * v ∧ Even v := by
  let g := (4 * n).gcd P
  have hgpos : 0 < g := Nat.gcd_pos_of_pos_left P (by omega)
  have hndvd : ¬ 2 * n ∣ P := by
    intro htwoP
    have htwoFour : 2 * n ∣ 4 * n := ⟨2, by ring⟩
    have htwoG : 2 * n ∣ g := by
      dsimp [g]
      exact Nat.dvd_gcd htwoFour htwoP
    have hgn : g ≤ n := Nat.le_of_dvd hn (by simpa [g] using hgdiv)
    have htwoLe : 2 * n ≤ g := Nat.le_of_dvd hgpos htwoG
    omega
  obtain ⟨X, r, v, hPX, hXbound, hX, hv, _hrpos, _hrlt, hnear⟩ :=
    exists_nearHalf_evenQuotient_multiplier P n hn hndvd
  have hgP : g ∣ P := by
    dsimp [g]
    exact Nat.gcd_dvd_right _ _
  have hgX : g ∣ X := dvd_trans hgP hPX
  have hgTwoNv : g ∣ (2 * n) * v := by
    exact dvd_mul_of_dvd_left (dvd_trans (by simpa [g] using hgdiv)
      (show n ∣ 2 * n by exact ⟨2, by ring⟩)) v
  have hgr : g ∣ r := by
    apply (Nat.dvd_add_iff_left hgTwoNv).mpr
    rw [← hX]
    exact hgX
  have hrn : r = n := by
    by_contra hne
    have hdistpos : 0 < r.dist n := Nat.dist_pos_of_ne hne
    obtain ⟨r0, hr0⟩ := hgr
    obtain ⟨n0, hn0⟩ := hgdiv
    have hgdist : g ∣ r.dist n := by
      refine ⟨r0.dist n0, ?_⟩
      rw [hr0, hn0, Nat.dist_mul_left]
    have hg_le_dist : g ≤ r.dist n := Nat.le_of_dvd hdistpos hgdist
    omega
  refine ⟨X, v, hPX, hXbound, ?_, hv⟩
  simpa [hrn] using hX

/-- Exact half placement supplies all target and center geometry for every
symmetric window shorter than half the target. -/
theorem exists_exactHalf_symmetric_window_package
    (P n w : ℕ) (hn : 0 < n)
    (hw : 2 * w < n) (hgdiv : (4 * n).gcd P ∣ n) :
    ∃ X r v : ℕ,
      P ∣ X ∧ X < (4 * n) * P ∧
      X = r + (2 * n) * v ∧ Even v ∧
      0 < r ∧ r < 2 * n ∧
      w < r ∧ r + w < 2 * n ∧
      r ≤ n + w ∧ n + w - r < w + 1 + w := by
  obtain ⟨X, v, hPX, hXbound, hX, hv⟩ :=
    exists_exactHalf_evenQuotient_multiplier P n hn hgdiv
  refine ⟨X, n, v, hPX, hXbound, hX, hv, hn, by omega,
    by omega, by omega, by omega, ?_⟩
  omega

end Research

/-!
# Favorable protected gate from an explicit target package
-/

namespace Research

open Real goldenRatio

/-- F-108 with target production separated from all threshold, density, cutoff,
and norm arguments. -/
theorem favorable_explicitTarget_rationality_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (K w X r v : ℕ)
    (hwpos : 0 < w)
    (hPX : sharpPrefixPeriod n K ∣ X)
    (hXbound : X < (4 * n K) * sharpPrefixPeriod n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrlt : r < 2 * n K)
    (hrLeft : w < r) (hrRight : r + w < 2 * n K)
    (hrUpper : r ≤ n K + w)
    (hsRWindow : n K + w - r < w + 1 + w)
    (hnoDouble : ∀ j, K < j → n j ≠ 2 * n K)
    (hfirst :
      let W := w + 1 + w
      (5184 : ℝ) * q ^ 2 *
        (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < n K)
    (hsecond :
      let W := w + 1 + w
      (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < W ^ 5)
    (hcaps :
      let P := sharpPrefixPeriod n K
      let W := w + 1 + w
      let B := n K * W ^ 8
      let Q := 8 * q * W
      ∀ X G,
        X < (4 * n K) * P →
        G ≤ K + Q →
        (laterPositionRange K G).card ≤ Q →
        let H := adaptiveLogCutoffPosition n K G B w w X q
        (φ⁻¹) ^ (w + 1) * (2 * cutoffTailCap H) < 1 ∧
        (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
          (2 * cutoffConjugateCap
            (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H) <
          (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  let P := sharpPrefixPeriod n K
  let W := w + 1 + w
  let B := n K * W ^ 8
  let Q := 8 * q * W
  have hWpos : 0 < W := by dsimp [W]; omega
  have hmpos := hpos K
  obtain ⟨G, hKG, hBG, hvalues, hGbound, hdBound⟩ :=
    exists_polynomial_threshold_package
      n hpos hmono c hc hratio q hq K W hWpos
  let d := (laterPositionRange K G).card
  have hBpos : 0 < B := by
    dsimp [B]
    exact mul_pos hmpos (pow_pos hWpos _)
  have hsimple := polynomial_threshold_simple_density_of_bounds
    c hc q W (n K) hqpos hWpos hmpos
    (by simpa [W] using hfirst) (by simpa [W] using hsecond)
  have hdensity := adaptive_density_of_polynomial_threshold
    n hpos c hc q K G W d hWpos
      (by simpa [d, Q] using hdBound)
      (by simpa [B] using hBG)
      (by simpa [B, Q] using hsimple)
  have hcap := hcaps X G
    (by simpa [P] using hXbound)
    (by simpa [Q] using hGbound)
    (by simpa [Q, d] using hdBound)
  apply logarithmic_adaptive_protected_rationality_contradiction
    n hpos hmono c hc hratio a b hb hrat q hq
      K G B w w X r v hKG hBpos hvalues
  · omega
  · omega
  · exact hX
  · exact hv
  · exact hrlt
  · exact hrLeft
  · exact hrRight
  · exact hrUpper
  · exact hsRWindow
  · exact hPX
  · intro j hKj _hjG
    exact hnoDouble j hKj
  · simpa [W, d] using hdensity
  · simpa [P, W, B, Q, adaptiveLogCutoffPosition, d] using hcap.1
  · simpa [P, W, B, Q, adaptiveLogCutoffPosition, d] using hcap.2

/-- If the prefix gcd divides the target, F-119 supplies the explicit target;
the rest is reduced to the same two density and two deterministic norm bounds
as F-110. -/
theorem favorable_exactHalf_upperCap_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (K w : ℕ)
    (hwpos : 0 < w) (hw : 2 * w < n K)
    (hgdiv : (4 * n K).gcd (sharpPrefixPeriod n K) ∣ n K)
    (hnoDouble : ∀ j, K < j → n j ≠ 2 * n K)
    (hfirst :
      let W := w + 1 + w
      (5184 : ℝ) * q ^ 2 *
        (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < n K)
    (hsecond :
      let W := w + 1 + w
      (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < W ^ 5)
    (hpost :
      let H := favorableCutoffUpper n K w q
      (φ⁻¹) ^ (w + 1) * (2 * cutoffTailCap H) < 1)
    (hpre :
      let H := favorableCutoffUpper n K w q
      (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap
          (-((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))) H) <
        (((5 * b : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  obtain ⟨X, r, v, hPX, hXbound, hX, hv, _hrpos, hrlt,
      hrLeft, hrRight, hrUpper, hsRWindow⟩ :=
    exists_exactHalf_symmetric_window_package
      (sharpPrefixPeriod n K) (n K) w (hpos K) hw hgdiv
  apply favorable_explicitTarget_rationality_contradiction
    n hpos hmono c hc hratio a b hb hrat q hqpos hq
      K w X r v hwpos hPX hXbound hX hv hrlt hrLeft hrRight
      hrUpper hsRWindow hnoDouble hfirst hsecond
  exact favorable_uniform_caps_of_upper
    n hpos a b K w q hwpos hpost hpre

end Research

/-!
# Structural consequence of the exact-half favorable gate
-/

namespace Research

open Filter Topology Real goldenRatio

/-- Under rationality, every sufficiently late target either has prefix gcd not
dividing the target itself, or has an exact selected double. -/
theorem eventually_prefixGcd_not_dvd_or_selectedDouble_of_rational
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    ∀ᶠ K : ℕ in atTop,
      ¬(4 * n K).gcd (sharpPrefixPeriod n K) ∣ n K ∨
        ∃ j, K < j ∧ n j = 2 * n K := by
  let T : ℝ := -((√5)⁻¹ * ((a : ℝ) / (b : ℝ)))
  let ε : ℝ := (((5 * b : ℕ) : ℝ)⁻¹) ^ 2
  have hε : 0 < ε := by
    dsimp [ε]
    have h5b : 0 < 5 * b := mul_pos (by norm_num) hb
    positivity
  have hevent : ∀ᶠ w : ℕ in atTop,
      2 ≤ w ∧
      (let W : ℕ := w + 1 + w
       (5184 : ℝ) * q ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < (w : ℝ) ^ 8 ∧
          (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < (W : ℝ) ^ 5) ∧
      ((φ⁻¹) ^ (w + 1) *
            (2 * cutoffTailCap (favorableWindowCutoffBound q w)) < 1 ∧
        (φ⁻¹) ^ w *
            (2 * cutoffTailCap (favorableWindowCutoffBound q w)) *
            (2 * cutoffConjugateCap T
              (favorableWindowCutoffBound q w)) < ε) := by
    exact (eventually_ge_atTop 2).and
      ((eventually_polynomialDensity_window c hc q).and
        (eventually_favorableWindow_normCaps q T ε hε))
  have hroot := tendsto_targetEighthRoot_atTop n hmono
  filter_upwards [hroot.eventually hevent] with K hK
  let w := targetEighthRoot n K
  change ¬(4 * n K).gcd (sharpPrefixPeriod n K) ∣ n K ∨
    ∃ j, K < j ∧ n j = 2 * n K
  by_contra hstruct
  push Not at hstruct
  rcases hstruct with ⟨hgdiv, hnoDouble⟩
  have hw : 2 ≤ w := hK.1
  have hd := hK.2.1
  have hncap := hK.2.2
  have hlow : w ^ 8 ≤ n K := by
    exact targetEighthRoot_pow_le n K
  have hupp : n K ≤ (w + 1) ^ 8 :=
    (target_lt_eighthRoot_add_one_pow n K).le
  have h2w_sq : 2 * w ≤ w ^ 2 := by nlinarith
  have hsquare_eighth : w ^ 2 < w ^ 8 :=
    Nat.pow_lt_pow_right (by omega) (by norm_num)
  have hwindow : 2 * w < n K :=
    (h2w_sq.trans_lt hsquare_eighth).trans_le hlow
  obtain ⟨hfirst, hsecond⟩ := polynomialDensity_of_window_le_target
    c q w (n K) hd.1 hd.2 hlow
  have hH : favorableCutoffUpper n K w q ≤
      favorableWindowCutoffBound q w :=
    favorableCutoffUpper_le_windowCutoffBound n hpos hmono K w q hupp
  obtain ⟨hpost, hpre⟩ := favorable_normCaps_of_windowCutoffBound
    T q w (favorableCutoffUpper n K w q) hH hncap.1 hncap.2
  exact favorable_exactHalf_upperCap_contradiction
    n hpos hmono c hc hratio a b hb hrat q hqpos hq K w
      (by omega) hwindow hgdiv hnoDouble hfirst hsecond hpost
      (by simpa only [T, ε] using hpre)

end Research

/-!
# The exact parity content of the nondividing prefix-gcd obstruction
-/

namespace Research

/-- A common divisor of `4n` and `P` fails to divide `n` exactly when `P`
contains one more factor of two than the ordinary gcd of `n` and `P`. -/
theorem gcd_four_mul_not_dvd_iff_two_gcd_dvd
    (n P : ℕ) (hn : 0 < n) :
    ¬(4 * n).gcd P ∣ n ↔ 2 * n.gcd P ∣ P := by
  let d := n.gcd P
  have hdpos : 0 < d := by
    dsimp [d]
    exact Nat.gcd_pos_of_pos_left P hn
  have hdn : d ∣ n := by dsimp [d]; exact Nat.gcd_dvd_left _ _
  have hdP : d ∣ P := by dsimp [d]; exact Nat.gcd_dvd_right _ _
  constructor
  · contrapose!
    intro hnot
    let a := n / d
    let b := P / d
    have hnFactor : d * a = n := by
      dsimp [a]
      exact Nat.mul_div_cancel' hdn
    have hPFactor : d * b = P := by
      dsimp [b]
      exact Nat.mul_div_cancel' hdP
    have htwoNot : ¬2 ∣ b := by
      intro htwo
      have hmul : d * 2 ∣ P :=
        (Nat.dvd_div_iff_mul_dvd hdP).mp (by simpa [b] using htwo)
      exact hnot (by simpa [mul_comm] using hmul)
    have hbOdd : Odd b := by
      rw [← Nat.not_even_iff_odd]
      simpa [even_iff_two_dvd] using htwoNot
    have hcopAB : a.Coprime b := by
      dsimp [a, b, d]
      exact Nat.coprime_div_gcd_div_gcd
        (Nat.gcd_pos_of_pos_left P hn)
    have hcop4B : (4 * a).Coprime b := by
      have htwo : (2 : ℕ).Coprime b := Nat.coprime_two_left.mpr hbOdd
      have hfour : (4 : ℕ).Coprime b := by
        simpa using htwo.mul_left htwo
      exact hfour.mul_left hcopAB
    have hgcd : (4 * n).gcd P = d := by
      rw [← hnFactor, ← hPFactor]
      calc
        (4 * (d * a)).gcd (d * b) = (d * (4 * a)).gcd (d * b) := by ring_nf
        _ = d * (4 * a).gcd b := Nat.gcd_mul_left d (4 * a) b
        _ = d := by rw [hcop4B.gcd_eq_one, mul_one]
    rw [hgcd]
    exact hdn
  · intro htwo hgdiv
    have htwoN : 2 * d ∣ 4 * n := by
      exact dvd_trans (Nat.mul_dvd_mul_left 2 hdn)
        (show 2 * n ∣ 4 * n by exact ⟨2, by ring⟩)
    have htwoG : 2 * d ∣ (4 * n).gcd P := by
      apply Nat.dvd_gcd htwoN
      simpa [d] using htwo
    have htwoDn : 2 * d ∣ n := dvd_trans htwoG hgdiv
    have htwoDd : 2 * d ∣ d := by
      have := Nat.dvd_gcd htwoDn (by simpa [d] using htwo)
      simpa [d] using this
    have hle : 2 * d ≤ d := Nat.le_of_dvd hdpos htwoDd
    omega

/-- F-121 rewritten without a negated gcd divisibility: rationality eventually
forces an explicit extra factor of two in the prefix period, or an exact
selected double. -/
theorem eventually_two_targetGcd_dvd_prefix_or_selectedDouble_of_rational
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    ∀ᶠ K : ℕ in Filter.atTop,
      2 * (n K).gcd (sharpPrefixPeriod n K) ∣
          sharpPrefixPeriod n K ∨
        ∃ j, K < j ∧ n j = 2 * n K := by
  filter_upwards [eventually_prefixGcd_not_dvd_or_selectedDouble_of_rational
    n hpos hmono c hc hratio a b hb hrat q hqpos hq] with K hK
  rcases hK with hg | hd
  · left
    exact (gcd_four_mul_not_dvd_iff_two_gcd_dvd
      (n K) (sharpPrefixPeriod n K) (hpos K)).mp hg
  · exact Or.inr hd

end Research

/-!
# Two-adic interpretation of the prefix-period obstruction
-/

namespace Research

/-- The ordinary exponent of two in a positive natural. -/
def twoAdicOrder (m : ℕ) : ℕ := m.factorization 2

lemma factorization_two_at_two : Nat.factorization 2 2 = 1 := by
  norm_num [Nat.factorization]

lemma factorization_four_at_two : Nat.factorization 4 2 = 2 := by
  change Nat.factorization (2 ^ 2) 2 = 2
  rw [Nat.factorization_pow]
  norm_num [Nat.factorization]

/-- The parity obstruction is exactly strict growth of the two-adic exponent
from the target to the prefix period. -/
theorem two_mul_gcd_dvd_iff_twoAdicOrder_lt
    (n P : ℕ) (hn : 0 < n) (hP : 0 < P) :
    2 * n.gcd P ∣ P ↔ twoAdicOrder n < twoAdicOrder P := by
  let d := n.gcd P
  have hdpos : 0 < d := by
    dsimp [d]
    exact Nat.gcd_pos_of_pos_left P hn
  have hdP : d ∣ P := by dsimp [d]; exact Nat.gcd_dvd_right _ _
  have hfacD : d.factorization 2 =
      min (n.factorization 2) (P.factorization 2) := by
    dsimp [d]
    rw [Nat.factorization_gcd (Nat.ne_of_gt hn) (Nat.ne_of_gt hP),
      Finsupp.inf_apply]
  constructor
  · intro hdvd
    have hfac := (Nat.factorization_le_iff_dvd
      (mul_ne_zero (by norm_num) (Nat.ne_of_gt hdpos))
      (Nat.ne_of_gt hP)).mpr hdvd
    have htwo := hfac 2
    rw [Nat.factorization_mul (by norm_num) (Nat.ne_of_gt hdpos),
      Finsupp.add_apply, factorization_two_at_two, hfacD] at htwo
    dsimp [twoAdicOrder]
    omega
  · intro hlt
    apply (Nat.factorization_le_iff_dvd
      (mul_ne_zero (by norm_num) (Nat.ne_of_gt hdpos))
      (Nat.ne_of_gt hP)).mp
    intro p
    rw [Nat.factorization_mul (by norm_num) (Nat.ne_of_gt hdpos),
      Finsupp.add_apply]
    by_cases hp : p = 2
    · subst p
      rw [factorization_two_at_two, hfacD]
      dsimp [twoAdicOrder] at hlt
      omega
    · have htwoZero : Nat.factorization 2 p = 0 := by
        by_cases hprime : Nat.Prime p
        · apply Nat.factorization_eq_zero_of_not_dvd
          intro hpdvd
          have hp12 := (Nat.dvd_prime Nat.prime_two).mp hpdvd
          rcases hp12 with hp1 | hp2
          · exact hprime.ne_one hp1
          · exact hp hp2
        · exact Nat.factorization_eq_zero_of_not_prime 2 hprime
      rw [htwoZero, zero_add]
      exact ((Nat.factorization_le_iff_dvd
        (Nat.ne_of_gt hdpos) (Nat.ne_of_gt hP)).mpr hdP) p

/-- Exact two-adic exponent of one sharp Lambert component period. -/
theorem fibLambertPeriod_twoAdicOrder
    (m : ℕ) (hm : 0 < m) :
    twoAdicOrder (fibLambertPeriod m) =
      if Even m then twoAdicOrder m + 1 else 2 := by
  unfold fibLambertPeriod twoAdicOrder
  split_ifs with he
  · rw [Nat.factorization_mul (by norm_num) (Nat.ne_of_gt hm),
      Finsupp.add_apply, factorization_two_at_two]
    omega
  · have htwoNot : ¬2 ∣ m := by
      simpa [even_iff_two_dvd] using he
    have hmzero : m.factorization 2 = 0 :=
      Nat.factorization_eq_zero_of_not_dvd htwoNot
    rw [Nat.factorization_mul (by norm_num) (Nat.ne_of_gt hm),
      Finsupp.add_apply, factorization_four_at_two, hmzero]

/-- If a prefix lcm has two-adic exponent above `v`, one earlier sharp period
already has exponent above `v`. -/
theorem exists_prior_period_twoAdicOrder_gt
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) {K v : ℕ}
    (h : v < twoAdicOrder (sharpPrefixPeriod n K)) :
    ∃ i < K, v < twoAdicOrder (fibLambertPeriod (n i)) := by
  induction K with
  | zero =>
      simp [sharpPrefixPeriod, twoAdicOrder, Nat.factorization] at h
  | succ K ih =>
      have hPpos := sharpPrefixPeriod_pos n hpos K
      have hpPos : 0 < fibLambertPeriod (n K) := by
        unfold fibLambertPeriod
        split <;> nlinarith [hpos K]
      have hmax : v < max
          (twoAdicOrder (sharpPrefixPeriod n K))
          (twoAdicOrder (fibLambertPeriod (n K))) := by
        simpa [sharpPrefixPeriod, twoAdicOrder,
          Nat.factorization_lcm (Nat.ne_of_gt hPpos) (Nat.ne_of_gt hpPos),
          Finsupp.sup_apply] using h
      rcases (lt_max_iff.mp hmax) with hprev | hlast
      · obtain ⟨i, hiK, hi⟩ := ih hprev
        exact ⟨i, by omega, hi⟩
      · exact ⟨K, by omega, hlast⟩

/-- A target is a strict two-adic record once its exponent is at least two and
exceeds every earlier selected exponent. -/
def IsHighTwoAdicRecord (n : ℕ → ℕ) (K : ℕ) : Prop :=
  2 ≤ twoAdicOrder (n K) ∧
    ∀ i < K, twoAdicOrder (n i) < twoAdicOrder (n K)

/-- At a high two-adic record, the extra-prefix-factor branch of F-122 is
impossible. -/
theorem not_two_targetGcd_dvd_prefix_of_highRecord
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (K : ℕ)
    (hrec : IsHighTwoAdicRecord n K) :
    ¬2 * (n K).gcd (sharpPrefixPeriod n K) ∣
      sharpPrefixPeriod n K := by
  intro hdvd
  have hPpos := sharpPrefixPeriod_pos n hpos K
  have hvlt : twoAdicOrder (n K) <
      twoAdicOrder (sharpPrefixPeriod n K) :=
    (two_mul_gcd_dvd_iff_twoAdicOrder_lt
      (n K) (sharpPrefixPeriod n K) (hpos K) hPpos).mp hdvd
  obtain ⟨i, hiK, hi⟩ := exists_prior_period_twoAdicOrder_gt
    n hpos hvlt
  have hv2 := hrec.1
  rw [fibLambertPeriod_twoAdicOrder (n i) (hpos i)] at hi
  split_ifs at hi with hie
  · have hir := hrec.2 i hiK
    omega
  · omega

end Research

/-!
# Rationality forces every late high two-adic record to be doubled
-/

namespace Research

open Filter

/-- The extra-prefix-factor branch is unavailable at a high strict two-adic
record, so F-122 forces its exact double to occur later in the sequence. -/
theorem eventually_highTwoAdicRecord_has_selectedDouble_of_rational
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    ∀ᶠ K : ℕ in atTop,
      IsHighTwoAdicRecord n K →
        ∃ j, K < j ∧ n j = 2 * n K := by
  filter_upwards [eventually_two_targetGcd_dvd_prefix_or_selectedDouble_of_rational
    n hpos hmono c hc hratio a b hb hrat q hqpos hq] with K hK
  intro hrec
  rcases hK with hp | hd
  · exact False.elim
      (not_two_targetGcd_dvd_prefix_of_highRecord n hpos K hrec hp)
  · exact hd

end Research

/-!
# Chains with increasing two-adic order and at-most-doubling growth
-/

namespace Research

/-- Increasing two-adic order under an at-most-doubling size bound makes the
odd parts nonincreasing. -/
theorem ordCompl_two_le_of_order_lt_of_le_double
    {x y : ℕ} (hv : twoAdicOrder x < twoAdicOrder y)
    (hxy : y ≤ 2 * x) :
    ordCompl[2] y ≤ ordCompl[2] x := by
  let vx := twoAdicOrder x
  let vy := twoAdicOrder y
  let ox := ordCompl[2] x
  let oy := ordCompl[2] y
  have hxdec : 2 ^ vx * ox = x := by
    simpa [vx, ox, twoAdicOrder] using Nat.ordProj_mul_ordCompl_eq_self x 2
  have hydec : 2 ^ vy * oy = y := by
    simpa [vy, oy, twoAdicOrder] using Nat.ordProj_mul_ordCompl_eq_self y 2
  have hv' : vx < vy := by simpa [vx, vy] using hv
  obtain ⟨d, hvd0⟩ := Nat.exists_eq_add_of_le (Nat.succ_le_iff.mpr hv')
  have hvd : vy = vx + 1 + d := by
    simpa [Nat.succ_eq_add_one] using hvd0
  have hfactor : 0 < 2 ^ (vx + 1) := pow_pos (by norm_num) _
  have hcancel : 2 ^ d * oy ≤ ox := by
    apply Nat.le_of_mul_le_mul_left (c := 2 ^ (vx + 1))
    · calc
        2 ^ (vx + 1) * (2 ^ d * oy) = 2 ^ vy * oy := by
          rw [hvd, pow_add]
          ring
        _ = y := hydec
        _ ≤ 2 * x := hxy
        _ = 2 ^ (vx + 1) * ox := by rw [← hxdec, pow_succ]; ring
    · exact hfactor
  have hoy : oy ≤ 2 ^ d * oy :=
    Nat.le_mul_of_pos_left oy (pow_pos (by norm_num) _)
  exact hoy.trans hcancel

/-- If the odd parts are equal, the same hypotheses force exact doubling. -/
theorem eq_two_mul_of_order_lt_of_le_double_of_ordCompl_eq
    {x y : ℕ} (hv : twoAdicOrder x < twoAdicOrder y)
    (hxy : y ≤ 2 * x)
    (hodd : ordCompl[2] y = ordCompl[2] x) :
    y = 2 * x := by
  let vx := twoAdicOrder x
  let vy := twoAdicOrder y
  let o := ordCompl[2] x
  have hxdec : 2 ^ vx * o = x := by
    simpa [vx, o, twoAdicOrder] using Nat.ordProj_mul_ordCompl_eq_self x 2
  have hydec : 2 ^ vy * o = y := by
    simpa [vy, o, twoAdicOrder, hodd] using
      Nat.ordProj_mul_ordCompl_eq_self y 2
  have hv' : vx < vy := by simpa [vx, vy] using hv
  obtain ⟨d, hvd0⟩ := Nat.exists_eq_add_of_le (Nat.succ_le_iff.mpr hv')
  have hvd : vy = vx + 1 + d := by
    simpa [Nat.succ_eq_add_one] using hvd0
  apply le_antisymm hxy
  calc
    2 * x = 2 ^ (vx + 1) * o := by rw [← hxdec, pow_succ]; ring
    _ ≤ 2 ^ (vx + 1) * (2 ^ d * o) := by
      gcongr
      exact Nat.le_mul_of_pos_left o (pow_pos (by norm_num) _)
    _ = 2 ^ vy * o := by rw [hvd, pow_add]; ring
    _ = y := hydec

/-- Any positive chain whose two-adic orders strictly rise and whose values grow
by at most a factor two is eventually an exact dyadic orbit. -/
theorem eventually_eq_double_of_twoAdicOrder_strictMono_le_double
    (x : ℕ → ℕ)
    (hv : ∀ t, twoAdicOrder (x t) < twoAdicOrder (x (t + 1)))
    (hbound : ∀ t, x (t + 1) ≤ 2 * x t) :
    ∃ T, ∀ t, T ≤ t → x (t + 1) = 2 * x t := by
  let o : ℕ → ℕ := fun t => ordCompl[2] (x t)
  have hoStep : ∀ t, o (t + 1) ≤ o t := by
    intro t
    exact ordCompl_two_le_of_order_lt_of_le_double (hv t) (hbound t)
  have hoAnti : Antitone o := antitone_nat_of_succ_le hoStep
  obtain ⟨T, hT⟩ := WellFoundedLT.antitone_chain_condition hoAnti
  refine ⟨T, fun t ht => ?_⟩
  apply eq_two_mul_of_order_lt_of_le_double_of_ordCompl_eq
    (hv t) (hbound t)
  exact (hT (t + 1) (by omega)).symm.trans (hT t ht)

end Research

/-!
# Building a record chain from forced selected doubles
-/

namespace Research

/-- Doubling raises the natural two-adic order by exactly one. -/
theorem twoAdicOrder_two_mul (m : ℕ) (hm : 0 < m) :
    twoAdicOrder (2 * m) = twoAdicOrder m + 1 := by
  unfold twoAdicOrder
  rw [Nat.factorization_mul (by norm_num) (Nat.ne_of_gt hm),
    Finsupp.add_apply, factorization_two_at_two]
  omega

/-- The first later position with strictly higher two-adic order, defaulting to
`K` only when no such position exists. -/
noncomputable def nextHigherRecord (n : ℕ → ℕ) (K : ℕ) : ℕ := by
  classical
  exact if h : ∃ i, K < i ∧ twoAdicOrder (n K) < twoAdicOrder (n i)
    then Nat.find h else K

lemma nextHigherRecord_spec (n : ℕ → ℕ) (K : ℕ)
    (h : ∃ i, K < i ∧ twoAdicOrder (n K) < twoAdicOrder (n i)) :
    K < nextHigherRecord n K ∧
      twoAdicOrder (n K) < twoAdicOrder (n (nextHigherRecord n K)) := by
  classical
  rw [nextHigherRecord, dif_pos h]
  exact Nat.find_spec h

lemma nextHigherRecord_le (n : ℕ → ℕ) (K j : ℕ)
    (h : ∃ i, K < i ∧ twoAdicOrder (n K) < twoAdicOrder (n i))
    (hj : K < j ∧ twoAdicOrder (n K) < twoAdicOrder (n j)) :
    nextHigherRecord n K ≤ j := by
  classical
  rw [nextHigherRecord, dif_pos h]
  exact Nat.find_min' h hj

/-- The first higher-order position after a high record is again a high record;
if one candidate lies below twice the current value, so does this first one. -/
theorem nextHigherRecord_is_highRecord_and_le_double
    (n : ℕ → ℕ) (hmono : StrictMono n) (K j : ℕ)
    (hrec : IsHighTwoAdicRecord n K)
    (hjK : K < j)
    (hjv : twoAdicOrder (n K) < twoAdicOrder (n j))
    (hjbound : n j ≤ 2 * n K) :
    IsHighTwoAdicRecord n (nextHigherRecord n K) ∧
      K < nextHigherRecord n K ∧
      n (nextHigherRecord n K) ≤ 2 * n K := by
  let I := nextHigherRecord n K
  have hex : ∃ i, K < i ∧
      twoAdicOrder (n K) < twoAdicOrder (n i) := ⟨j, hjK, hjv⟩
  have hspec := nextHigherRecord_spec n K hex
  have hIj : I ≤ j := by
    dsimp [I]
    exact nextHigherRecord_le n K j hex ⟨hjK, hjv⟩
  have hvalue : n I ≤ 2 * n K :=
    (hmono.monotone hIj).trans hjbound
  have hrecord : IsHighTwoAdicRecord n I := by
    constructor
    · exact hrec.1.trans (hspec.2.le)
    · intro l hlI
      by_cases hlK : l < K
      · exact (hrec.2 l hlK).trans hspec.2
      · by_cases hlEq : l = K
        · simpa [hlEq] using hspec.2
        · have hKl : K < l := by omega
          have hnot : ¬twoAdicOrder (n K) < twoAdicOrder (n l) := by
            intro hlt
            have hIl : I ≤ l := by
              dsimp [I]
              exact nextHigherRecord_le n K l hex ⟨hKl, hlt⟩
            omega
          exact lt_of_le_of_lt (by omega) hspec.2
  exact ⟨hrecord, hspec.1, hvalue⟩

/-- The recursively chosen chain of first higher two-adic records. -/
noncomputable def highRecordChain (n : ℕ → ℕ) (K : ℕ) : ℕ → ℕ
  | 0 => K
  | t + 1 => nextHigherRecord n (highRecordChain n K t)

/-- If every high record after `K₀` has a selected double, then starting from
one such record produces an infinite chain of high records, with increasing
positions and next selected value at most twice the current one. -/
theorem highRecordChain_properties
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K₀ K : ℕ) (hK₀ : K₀ ≤ K) (hrecK : IsHighTwoAdicRecord n K)
    (hdouble : ∀ i, K₀ ≤ i → IsHighTwoAdicRecord n i →
      ∃ j, i < j ∧ n j = 2 * n i) :
    ∀ t,
      K₀ ≤ highRecordChain n K t ∧
      IsHighTwoAdicRecord n (highRecordChain n K t) ∧
      highRecordChain n K t < highRecordChain n K (t + 1) ∧
      n (highRecordChain n K (t + 1)) ≤
        2 * n (highRecordChain n K t) := by
  intro t
  induction t with
  | zero =>
      dsimp [highRecordChain]
      obtain ⟨j, hj, hjeq⟩ := hdouble K hK₀ hrecK
      have hjv : twoAdicOrder (n K) < twoAdicOrder (n j) := by
        rw [hjeq, twoAdicOrder_two_mul (n K) (hpos K)]
        omega
      have hs := nextHigherRecord_is_highRecord_and_le_double
        n hmono K j hrecK hj hjv (by simp [hjeq])
      exact ⟨hK₀, hrecK, hs.2.1, hs.2.2⟩
  | succ t ih =>
      let I := highRecordChain n K (t + 1)
      have hI0 : K₀ ≤ I := ih.1.trans ih.2.2.1.le
      have hIrec : IsHighTwoAdicRecord n I := by
        dsimp [I, highRecordChain]
        obtain ⟨j, hj, hjeq⟩ := hdouble
          (highRecordChain n K t) ih.1 ih.2.1
        have hjv : twoAdicOrder (n (highRecordChain n K t)) <
            twoAdicOrder (n j) := by
          rw [hjeq, twoAdicOrder_two_mul
            (n (highRecordChain n K t)) (hpos _)]
          omega
        exact (nextHigherRecord_is_highRecord_and_le_double n hmono
          (highRecordChain n K t) j ih.2.1 hj hjv
          (by simp [hjeq])).1
      obtain ⟨j, hj, hjeq⟩ := hdouble I hI0 hIrec
      have hjv : twoAdicOrder (n I) < twoAdicOrder (n j) := by
        rw [hjeq, twoAdicOrder_two_mul (n I) (hpos I)]
        omega
      have hs := nextHigherRecord_is_highRecord_and_le_double
        n hmono I j hIrec hj hjv (by simp [hjeq])
      change K₀ ≤ I ∧ IsHighTwoAdicRecord n I ∧
        I < highRecordChain n K (t + 1 + 1) ∧
        n (highRecordChain n K (t + 1 + 1)) ≤ 2 * n I
      simpa [I, highRecordChain] using ⟨hI0, hIrec, hs.2.1, hs.2.2⟩

end Research

/-!
# Unbounded two-adic order forces a complete selected dyadic tail
-/

namespace Research

open Filter
open scoped BigOperators

/-- The selected two-adic orders are unbounded. -/
def UnboundedTwoAdicOrder (n : ℕ → ℕ) : Prop :=
  ∀ V, ∃ K, V < twoAdicOrder (n K)

/-- An unbounded order sequence has a high strict record after every prescribed
position. -/
theorem exists_highTwoAdicRecord_ge_of_unbounded
    (n : ℕ → ℕ) (hunb : UnboundedTwoAdicOrder n) (K₀ : ℕ) :
    ∃ K, K₀ ≤ K ∧ IsHighTwoAdicRecord n K := by
  classical
  let S := ∑ i ∈ Finset.range K₀, twoAdicOrder (n i)
  let V := S + 2
  let K := Nat.find (hunb V)
  have hKspec : V < twoAdicOrder (n K) := Nat.find_spec (hunb V)
  have hK₀ : K₀ ≤ K := by
    by_contra hnot
    have hKK₀ : K < K₀ := by omega
    have hmem : K ∈ Finset.range K₀ := Finset.mem_range.mpr hKK₀
    have hleS : twoAdicOrder (n K) ≤ S := by
      dsimp [S]
      exact Finset.single_le_sum
        (s := Finset.range K₀) (f := fun i => twoAdicOrder (n i))
        (fun i _ => Nat.zero_le _) hmem
    dsimp [V] at hKspec
    omega
  have hrecord : IsHighTwoAdicRecord n K := by
    constructor
    · dsimp [V] at hKspec
      omega
    · intro i hiK
      have hnot : ¬V < twoAdicOrder (n i) := by
        intro hi
        have hKi : K ≤ i := Nat.find_min' (hunb V) hi
        omega
      omega
  exact ⟨K, hK₀, hrecord⟩

/-- Under rationality, unbounded selected two-adic orders force an embedded
complete dyadic tail: there are selected positions `k_s` carrying exactly
`m*2^s`. -/
theorem exists_complete_selected_dyadic_tail_of_rational_of_unboundedOrder
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (a : ℤ) (b : ℕ) (hb : 0 < b)
    (hrat : (∑' k : ℕ, (Nat.fib (n k) : ℝ)⁻¹) =
      (a : ℝ) / (b : ℝ))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (hunb : UnboundedTwoAdicOrder n) :
    ∃ m : ℕ, 0 < m ∧ ∃ k : ℕ → ℕ, StrictMono k ∧
      ∀ s, n (k s) = m * 2 ^ s := by
  have hevent := eventually_highTwoAdicRecord_has_selectedDouble_of_rational
    n hpos hmono c hc hratio a b hb hrat q hqpos hq
  rw [eventually_atTop] at hevent
  obtain ⟨K₀, hdouble⟩ := hevent
  obtain ⟨K, hK₀, hrec⟩ :=
    exists_highTwoAdicRecord_ge_of_unbounded n hunb K₀
  have hprops := highRecordChain_properties
    n hpos hmono K₀ K hK₀ hrec (fun i hi hirec => hdouble i hi hirec)
  let x : ℕ → ℕ := fun t => n (highRecordChain n K t)
  have hv : ∀ t, twoAdicOrder (x t) < twoAdicOrder (x (t + 1)) := by
    intro t
    have ht := hprops t
    have ht1 := hprops (t + 1)
    exact ht1.2.1.2 (highRecordChain n K t) ht.2.2.1
  have hxbound : ∀ t, x (t + 1) ≤ 2 * x t := fun t => (hprops t).2.2.2
  obtain ⟨T, hT⟩ :=
    eventually_eq_double_of_twoAdicOrder_strictMono_le_double x hv hxbound
  let m := x T
  let k : ℕ → ℕ := fun s => highRecordChain n K (T + s)
  have hkmono : StrictMono k := by
    apply strictMono_nat_of_lt_succ
    intro s
    dsimp [k]
    exact (hprops (T + s)).2.2.1
  have hformula : ∀ s, n (k s) = m * 2 ^ s := by
    intro s
    induction s with
    | zero => simp [k, m, x]
    | succ s ih =>
        have hstep := hT (T + s) (by omega)
        change n (highRecordChain n K (T + (s + 1))) = m * 2 ^ (s + 1)
        have hidx : T + (s + 1) = (T + s) + 1 := by omega
        rw [hidx]
        change x (T + s + 1) = m * 2 ^ (s + 1)
        rw [hstep]
        change 2 * n (k s) = m * 2 ^ (s + 1)
        rw [ih, pow_succ]
        ring
  refine ⟨m, ?_, k, hkmono, hformula⟩
  dsimp [m, x]
  exact hpos _

end Research

/-!
# Norm gates for an arbitrary fixed quadratic pair
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- If the total principal/conjugate values form one fixed scaled golden pair,
then every pair of normalized residuals has the same denominator. -/
theorem normalized_and_conjugate_residual_mem_pair_of_total_pair
    (C : ℕ → ℤ) (q : ℕ) (T Tconj : ℝ) (N : ℕ) (hq : 0 < q)
    (hpair : InScaledGoldenPair q T Tconj) :
    InScaledGoldenPair q
      (normalizedCoefficientResidual C T N)
      (conjugateCoefficientResidual C Tconj N) := by
  apply InScaledGoldenPair.sub hq
  · exact hpair.powers_mul N
  · apply finset_sum_mem_scaledGoldenPair hq
    intro m hm
    exact int_mul_golden_powers_mem_pair q hq (C m) (N - m)

/-- The sharp matched-block norm obstruction with an arbitrary algebraic total
pair instead of a rational total. -/
theorem selected_matched_block_pair_obstruction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (q : ℕ) (hq : 0 < q) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair q T Tconj)
    (N M L : ℕ)
    (hblock : ∀ t < L,
      selectedFibLambertCoeff n (N + t) =
        selectedFibLambertCoeff n (M + t))
    (hne : coefficientTail (selectedFibLambertCoeff n) N ≠
      coefficientTail (selectedFibLambertCoeff n) M)
    (hsmall :
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (M + L)) *
        (indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj M) <
      (((q : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  let C := selectedFibLambertCoeff n
  let x : ℝ := coefficientTail C N - coefficientTail C M
  let y : ℝ := conjugateCoefficientResidual C Tconj N -
    conjugateCoefficientResidual C Tconj M
  have hpairN := normalized_and_conjugate_residual_mem_pair_of_total_pair
    C q T Tconj N hq htotal
  have hpairM := normalized_and_conjugate_residual_mem_pair_of_total_pair
    C q T Tconj M hq htotal
  have hresN := normalizedCoefficientResidual_eq_coefficientTail C T hsum N
  have hresM := normalizedCoefficientResidual_eq_coefficientTail C T hsum M
  have hpair : InScaledGoldenPair q x y := by
    dsimp [x, y]
    rw [← hresN, ← hresM]
    exact hpairN.sub hq hpairM
  have hx : x ≠ 0 := sub_ne_zero.mpr hne
  have hlower := hpair.norm_lower hq hx
  have hxupper : |x| ≤
      (φ⁻¹) ^ L *
        (indexCountTailBound n (N + L) +
          indexCountTailBound n (M + L)) :=
    abs_selectedTail_sub_le_indexCount_of_block_eq
      n hpos hmono N M L hblock
  have hyupper : |y| ≤
      indexCountConjugateBound n Tconj N +
        indexCountConjugateBound n Tconj M :=
    abs_selectedConjugateResidual_sub_le_indexCount
      n hpos hmono Tconj N M
  have hpnonneg : 0 ≤
      (φ⁻¹) ^ L *
        (indexCountTailBound n (N + L) +
          indexCountTailBound n (M + L)) :=
    (abs_nonneg x).trans hxupper
  have hproduct : |x| * |y| ≤
      ((φ⁻¹) ^ L *
        (indexCountTailBound n (N + L) +
          indexCountTailBound n (M + L))) *
      (indexCountConjugateBound n Tconj N +
        indexCountConjugateBound n Tconj M) :=
    mul_le_mul hxupper hyupper (abs_nonneg _) hpnonneg
  exact (not_lt_of_ge (hlower.trans hproduct)) hsmall

/-- Sandwiched-mismatch gate for an arbitrary fixed quadratic pair. -/
theorem selected_sandwiched_mismatch_pair_obstruction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (q : ℕ) (hq : 0 < q) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair q T Tconj)
    (N M L J : ℕ)
    (hpre : ∀ t < L,
      selectedFibLambertCoeff n (N + t) =
        selectedFibLambertCoeff n (M + t))
    (hmismatch : selectedFibLambertCoeff n (N + L) ≠
      selectedFibLambertCoeff n (M + L))
    (hpost : ∀ t < J,
      selectedFibLambertCoeff n (N + L + 1 + t) =
        selectedFibLambertCoeff n (M + L + 1 + t))
    (hsmallPost :
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (M + L + 1 + J)) < 1)
    (hsmallPre :
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (M + L)) *
        (indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj M) <
      (((q : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  apply selected_matched_block_pair_obstruction
    n hpos hmono q hq T Tconj hsum htotal N M L hpre
  · exact selected_coefficientTail_ne_of_sandwiched_mismatch
      n hpos hmono N M L J hpre hmismatch hpost hsmallPost
  · exact hsmallPre

end Research

/-!
# Protected sieve gate for an arbitrary quadratic total pair
-/

namespace Research

open Real goldenRatio

/-- F-066 with an arbitrary fixed scaled golden pair in place of rationality. -/
theorem protected_sandwiched_mismatch_pair_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (K H L J A X R : ℕ) (hA : 0 < A) (hKH : K < H)
    (hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ X)
    (htargetPre : ∀ s < L,
      fibLambertCoeff (n K) (A + s + X) =
        fibLambertCoeff (n K) (A + s))
    (htarget : fibLambertCoeff (n K) (A + L + X) ≠
      fibLambertCoeff (n K) (A + L))
    (htargetPost : ∀ s < J,
      fibLambertCoeff (n K) (A + L + 1 + s + X) =
        fibLambertCoeff (n K) (A + L + 1 + s))
    (C O : Finset ((ℕ × ℕ) × Bool))
    (hpartition : C ∪ O = compatibleTwoWindowConditions n K H
      (L + 1 + J) A X (4 * n K))
    (hbudget :
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd (4 * n K)) + 1)) <
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) (4 * n K) R).card)
    (hcut : A + (4 * n K) * R + X + (L + 1 + J) < n H)
    (hsmallPost : ∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (N + X + L + 1 + J)) < 1)
    (hsmallPre : ∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (N + X + L)) *
        (indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj (N + X)) <
      (((qden : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  obtain ⟨t, htR, hav⟩ :=
    exists_two_windows_avoiding_all_later_indices_protected
      n hpos hmono K H (L + 1 + J) A X (4 * n K) R
      hA hKH C O hpartition hbudget hcut
  let N := A + (4 * n K) * t
  have htransport (u : ℕ) :
      fibLambertCoeff (n K) (N + u) = fibLambertCoeff (n K) (A + u) := by
    have hp := fibLambertCoeff_add_period_mul (n K) (A + u) t
    simpa [N, add_assoc, add_comm, add_left_comm, mul_comm] using hp
  have htransportX (u : ℕ) :
      fibLambertCoeff (n K) (N + u + X) =
        fibLambertCoeff (n K) (A + u + X) := by
    have hp := fibLambertCoeff_add_period_mul (n K) (A + u + X) t
    simpa [N, add_assoc, add_comm, add_left_comm, mul_comm] using hp
  have htargetPreN : ∀ s < L,
      fibLambertCoeff (n K) (N + s + X) =
        fibLambertCoeff (n K) (N + s) := by
    intro s hs
    rw [htransportX, htransport]
    exact htargetPre s hs
  have htargetN : fibLambertCoeff (n K) (N + L + X) ≠
      fibLambertCoeff (n K) (N + L) := by
    rw [htransportX, htransport]
    exact htarget
  have htargetPostN : ∀ s < J,
      fibLambertCoeff (n K) (N + L + 1 + s + X) =
        fibLambertCoeff (n K) (N + L + 1 + s) := by
    intro s hs
    have hx := htransportX (L + 1 + s)
    have hxbase := htransport (L + 1 + s)
    calc
      fibLambertCoeff (n K) (N + L + 1 + s + X) =
          fibLambertCoeff (n K) (A + L + 1 + s + X) := by
            simpa [add_assoc] using hx
      _ = fibLambertCoeff (n K) (A + L + 1 + s) := htargetPost s hs
      _ = fibLambertCoeff (n K) (N + L + 1 + s) := by
        simpa [add_assoc] using hxbase.symm
  have hpat := sandwiched_mismatch_of_minimalPeriod_and_avoidance
    n hpos hmono K L J N X hperiod htargetPreN htargetN htargetPostN hav
  apply selected_sandwiched_mismatch_pair_obstruction
    n hpos hmono qden hqden T Tconj hsum htotal N (N + X) L J
  · intro s hs
    simpa [add_assoc, add_comm, add_left_comm] using (hpat.1 s hs).symm
  · simpa [add_assoc, add_comm, add_left_comm] using ne_comm.mp hpat.2.1
  · intro s hs
    simpa [add_assoc, add_comm, add_left_comm] using (hpat.2.2 s hs).symm
  · simpa [N, add_assoc, add_comm, add_left_comm] using hsmallPost t htR
  · simpa [N, add_assoc, add_comm, add_left_comm] using hsmallPre t htR

/-- Uniform cutoff norm bounds with an arbitrary conjugate total and lattice
denominator. -/
theorem uniform_protected_pair_norm_bounds_of_cutoff
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (qden : ℕ) (Tconj : ℝ)
    (K H L J A X R : ℕ)
    (hcut : A + (4 * n K) * R + X + (L + 1 + J) < n H)
    (hpostCap :
      (φ⁻¹) ^ (J + 1) * (2 * cutoffTailCap H) < 1)
    (hpreCap :
      (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap Tconj H) <
        (((qden : ℕ) : ℝ)⁻¹) ^ 2) :
    (∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (N + X + L + 1 + J)) < 1) ∧
    (∀ t < R,
      let N := A + (4 * n K) * t
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (N + X + L)) *
        (indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj (N + X)) <
      (((qden : ℕ) : ℝ)⁻¹) ^ 2) := by
  have hp : 0 < 4 * n K := by nlinarith [hpos K]
  have htailCapNonneg := cutoffTailCap_nonneg H
  have hconjCapNonneg := cutoffConjugateCap_nonneg Tconj H
  constructor
  · intro t ht
    let N := A + (4 * n K) * t
    have hpt : (4 * n K) * t < (4 * n K) * R :=
      (Nat.mul_lt_mul_left hp).mpr ht
    have hx₁ : N + L + 1 + J < n H := by dsimp [N]; omega
    have hx₂ : N + X + L + 1 + J < n H := by dsimp [N]; omega
    have hb₁ := indexCountTailBound_le_cutoffTailCap n hpos hmono hx₁
    have hb₂ := indexCountTailBound_le_cutoffTailCap n hpos hmono hx₂
    calc
      (φ⁻¹) ^ (J + 1) *
          (indexCountTailBound n (N + L + 1 + J) +
            indexCountTailBound n (N + X + L + 1 + J)) ≤
        (φ⁻¹) ^ (J + 1) * (2 * cutoffTailCap H) := by
          gcongr
          linarith
      _ < 1 := hpostCap
  · intro t ht
    let N := A + (4 * n K) * t
    have hpt : (4 * n K) * t < (4 * n K) * R :=
      (Nat.mul_lt_mul_left hp).mpr ht
    have hxN : N < n H := by dsimp [N]; omega
    have hxNX : N + X < n H := by dsimp [N]; omega
    have hxL : N + L < n H := by dsimp [N]; omega
    have hxXL : N + X + L < n H := by dsimp [N]; omega
    have ht₁ := indexCountTailBound_le_cutoffTailCap n hpos hmono hxL
    have ht₂ := indexCountTailBound_le_cutoffTailCap n hpos hmono hxXL
    have hc₁ := indexCountConjugateBound_le_cutoffConjugateCap
      n hpos hmono Tconj hxN
    have hc₂ := indexCountConjugateBound_le_cutoffConjugateCap
      n hpos hmono Tconj hxNX
    have htailSum :
        indexCountTailBound n (N + L) +
          indexCountTailBound n (N + X + L) ≤ 2 * cutoffTailCap H := by
      linarith
    have hconjSum :
        indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj (N + X) ≤
        2 * cutoffConjugateCap Tconj H := by linarith
    have hconjSumNonneg : 0 ≤
        indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj (N + X) := by
      unfold indexCountConjugateBound
      have hden : 0 < 1 - φ⁻¹ := sub_pos.mpr
        (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
      positivity
    have hfirstNonneg : 0 ≤
        (φ⁻¹) ^ L * (2 * cutoffTailCap H) := by positivity
    calc
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (N + X + L)) *
        (indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj (N + X)) ≤
        (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
          (indexCountConjugateBound n Tconj N +
            indexCountConjugateBound n Tconj (N + X)) := by
          gcongr
      _ ≤ (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
          (2 * cutoffConjugateCap Tconj H) :=
        mul_le_mul_of_nonneg_left hconjSum hfirstNonneg
      _ < (((qden : ℕ) : ℝ)⁻¹) ^ 2 := hpreCap

end Research

/-!
# Logarithmic protected cutoff for arbitrary quadratic totals
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- F-102 with an arbitrary fixed scaled golden total pair. -/
theorem logarithmic_adaptive_protected_pair_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (K G B L J X r v : ℕ) (hKG : K < G) (hB : 0 < B)
    (hvalues : ∀ j, K < j → j < G → n j ≤ B)
    (hL : L < n K) (hJ : J < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrlt : r < 2 * n K)
    (hrLeft : L < r) (hrRight : r + J < 2 * n K)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hprefix : sharpPrefixPeriod n K ∣ X)
    (hnoDouble : ∀ j, K < j → j < G → n j ≠ 2 * n K)
    (hdensity :
      let W := L + 1 + J
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1)
    (hpostCap :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let Mmax := B ^ (2 * d)
      let U := A + p * Mmax + X + W
      let V := 4 * p * Dmax * W
      let A₀ := U + V * G
      let B₀ := V * q
      let N := A₀ + B₀ + 1
      let t := Nat.clog 2 N
      let H := G + q * (4 * t + 4)
      (φ⁻¹) ^ (J + 1) * (2 * cutoffTailCap H) < 1)
    (hpreCap :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let Mmax := B ^ (2 * d)
      let U := A + p * Mmax + X + W
      let V := 4 * p * Dmax * W
      let A₀ := U + V * G
      let B₀ := V * q
      let N := A₀ + B₀ + 1
      let t := Nat.clog 2 N
      let H := G + q * (4 * t + 4)
      (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap Tconj H) <
        (((qden : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let d := (laterPositionRange K G).card
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := B ^ (2 * d)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  let A₀ := U + V * G
  let B₀ := V * q
  let N := A₀ + B₀ + 1
  let t := Nat.clog 2 N
  let H := G + q * (4 * t + 4)
  let C0 := nearHalfCenterConditions n K G W A X p L sR
  let O := compatibleTwoWindowConditions n K H W A X p \ C0
  have hcert := exists_logarithmic_adaptive_partialCenter_budget
    n hpos hmono c hc hratio q hq K G B L J X r v hKG hB hvalues
      hL hX hv hrUpper hsRWindow hnoDouble hdensity
  change ∃ R : ℕ, 0 < R ∧
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H at hcert
  obtain ⟨R, hR, hbudget, hcut⟩ := hcert
  have hA : 0 < A := by dsimp [A]; omega
  have hGH : G ≤ H := by dsimp [H]; omega
  have hKH : K < H := lt_of_lt_of_le hKG hGH
  have hrmod : r = X % (2 * n K) := by
    rw [hX, Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt hrlt]
  have htarget := target_component_sandwiched_pattern
    (n K) L J X r (hpos K) hL hJ hrmod hrLeft hrRight
  have hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ X := by
    intro k hk
    exact dvd_trans (fibLambertPeriod_dvd_sharpPrefixPeriod n hk) hprefix
  have hCsub : C0 ⊆ compatibleTwoWindowConditions n K H W A X p := by
    intro u hu
    have huG := (Finset.mem_filter.mp hu).1
    have huGdata := Finset.mem_filter.mp huG
    apply Finset.mem_filter.mpr
    refine ⟨?_, huGdata.2⟩
    have huOuter := Finset.mem_product.mp huGdata.1
    have huInner := Finset.mem_product.mp huOuter.1
    have hjData := Finset.mem_filter.mp huInner.1
    apply Finset.mem_product.mpr
    refine ⟨Finset.mem_product.mpr ⟨?_, huInner.2⟩, huOuter.2⟩
    apply Finset.mem_filter.mpr
    exact ⟨Finset.mem_range.mpr (lt_of_lt_of_le
      (Finset.mem_range.mp hjData.1) hGH), hjData.2⟩
  have hpartition : C0 ∪ O =
      compatibleTwoWindowConditions n K H W A X p :=
    Finset.union_sdiff_of_subset hCsub
  have hnorm := uniform_protected_pair_norm_bounds_of_cutoff
    n hpos hmono qden Tconj K H L J A X R
    (by simpa [p, W] using hcut)
    (by simpa [A, W, p, d, Dmax, Mmax, U, V, A₀, B₀, N, t, H]
      using hpostCap)
    (by simpa [A, W, p, d, Dmax, Mmax, U, V, A₀, B₀, N, t, H]
      using hpreCap)
  exact protected_sandwiched_mismatch_pair_contradiction
    n hpos hmono qden hqden T Tconj hsum htotal
      K H L J A X R hA hKH hperiod
      htarget.1 htarget.2.1 htarget.2.2 C0 O hpartition
      (by simpa [p] using hbudget)
      (by simpa [p, W] using hcut) hnorm.1 hnorm.2

end Research

/-!
# Favorable explicit-target gate for arbitrary quadratic totals
-/

namespace Research

open Real goldenRatio

/-- F-120's explicit-target favorable gate for an arbitrary fixed scaled
golden total pair. -/
theorem favorable_explicitTarget_pair_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (K w X r v : ℕ) (hwpos : 0 < w)
    (hPX : sharpPrefixPeriod n K ∣ X)
    (hXbound : X < (4 * n K) * sharpPrefixPeriod n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrlt : r < 2 * n K)
    (hrLeft : w < r) (hrRight : r + w < 2 * n K)
    (hrUpper : r ≤ n K + w)
    (hsRWindow : n K + w - r < w + 1 + w)
    (hnoDouble : ∀ j, K < j → n j ≠ 2 * n K)
    (hfirst :
      let W := w + 1 + w
      (5184 : ℝ) * q ^ 2 *
        (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < n K)
    (hsecond :
      let W := w + 1 + w
      (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < W ^ 5)
    (hcaps :
      let P := sharpPrefixPeriod n K
      let W := w + 1 + w
      let B := n K * W ^ 8
      let Q := 8 * q * W
      ∀ X G,
        X < (4 * n K) * P →
        G ≤ K + Q →
        (laterPositionRange K G).card ≤ Q →
        let H := adaptiveLogCutoffPosition n K G B w w X q
        (φ⁻¹) ^ (w + 1) * (2 * cutoffTailCap H) < 1 ∧
        (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
          (2 * cutoffConjugateCap Tconj H) <
          (((qden : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  let P := sharpPrefixPeriod n K
  let W := w + 1 + w
  let B := n K * W ^ 8
  let Q := 8 * q * W
  have hWpos : 0 < W := by dsimp [W]; omega
  have hmpos := hpos K
  obtain ⟨G, hKG, hBG, hvalues, hGbound, hdBound⟩ :=
    exists_polynomial_threshold_package
      n hpos hmono c hc hratio q hq K W hWpos
  let d := (laterPositionRange K G).card
  have hBpos : 0 < B := by
    dsimp [B]
    exact mul_pos hmpos (pow_pos hWpos _)
  have hsimple := polynomial_threshold_simple_density_of_bounds
    c hc q W (n K) hqpos hWpos hmpos
    (by simpa [W] using hfirst) (by simpa [W] using hsecond)
  have hdensity := adaptive_density_of_polynomial_threshold
    n hpos c hc q K G W d hWpos
      (by simpa [d, Q] using hdBound)
      (by simpa [B] using hBG)
      (by simpa [B, Q] using hsimple)
  have hcap := hcaps X G
    (by simpa [P] using hXbound)
    (by simpa [Q] using hGbound)
    (by simpa [Q, d] using hdBound)
  apply logarithmic_adaptive_protected_pair_contradiction
    n hpos hmono c hc hratio qden hqden T Tconj hsum htotal q hq
      K G B w w X r v hKG hBpos hvalues
  · omega
  · omega
  · exact hX
  · exact hv
  · exact hrlt
  · exact hrLeft
  · exact hrRight
  · exact hrUpper
  · exact hsRWindow
  · exact hPX
  · intro j hKj _hjG
    exact hnoDouble j hKj
  · simpa [W, d] using hdensity
  · simpa [P, W, B, Q, adaptiveLogCutoffPosition, d] using hcap.1
  · simpa [P, W, B, Q, adaptiveLogCutoffPosition, d] using hcap.2

end Research

/-!
# Exact-half structural dichotomy for arbitrary quadratic totals
-/

namespace Research

open Filter Topology Real goldenRatio

/-- F-121 for an arbitrary fixed scaled golden total pair. -/
theorem eventually_prefixGcd_not_dvd_or_selectedDouble_of_pair
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    ∀ᶠ K : ℕ in atTop,
      ¬(4 * n K).gcd (sharpPrefixPeriod n K) ∣ n K ∨
        ∃ j, K < j ∧ n j = 2 * n K := by
  let ε : ℝ := (((qden : ℕ) : ℝ)⁻¹) ^ 2
  have hε : 0 < ε := by dsimp [ε]; positivity
  have hevent : ∀ᶠ w : ℕ in atTop,
      2 ≤ w ∧
      (let W : ℕ := w + 1 + w
       (5184 : ℝ) * q ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < (w : ℝ) ^ 8 ∧
          (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < (W : ℝ) ^ 5) ∧
      ((φ⁻¹) ^ (w + 1) *
            (2 * cutoffTailCap (favorableWindowCutoffBound q w)) < 1 ∧
        (φ⁻¹) ^ w *
            (2 * cutoffTailCap (favorableWindowCutoffBound q w)) *
            (2 * cutoffConjugateCap Tconj
              (favorableWindowCutoffBound q w)) < ε) := by
    exact (eventually_ge_atTop 2).and
      ((eventually_polynomialDensity_window c hc q).and
        (eventually_favorableWindow_normCaps q Tconj ε hε))
  have hroot := tendsto_targetEighthRoot_atTop n hmono
  filter_upwards [hroot.eventually hevent] with K hK
  let w := targetEighthRoot n K
  change ¬(4 * n K).gcd (sharpPrefixPeriod n K) ∣ n K ∨
    ∃ j, K < j ∧ n j = 2 * n K
  by_contra hstruct
  push Not at hstruct
  rcases hstruct with ⟨hgdiv, hnoDouble⟩
  have hw : 2 ≤ w := hK.1
  have hd := hK.2.1
  have hncap := hK.2.2
  have hlow : w ^ 8 ≤ n K := targetEighthRoot_pow_le n K
  have hupp : n K ≤ (w + 1) ^ 8 :=
    (target_lt_eighthRoot_add_one_pow n K).le
  have h2w_sq : 2 * w ≤ w ^ 2 := by nlinarith
  have hsquare_eighth : w ^ 2 < w ^ 8 :=
    Nat.pow_lt_pow_right (by omega) (by norm_num)
  have hwindow : 2 * w < n K :=
    (h2w_sq.trans_lt hsquare_eighth).trans_le hlow
  obtain ⟨hfirst, hsecond⟩ := polynomialDensity_of_window_le_target
    c q w (n K) hd.1 hd.2 hlow
  obtain ⟨X, r, v, hPX, hXbound, hX, hv, _hrpos, hrlt,
      hrLeft, hrRight, hrUpper, hsRWindow⟩ :=
    exists_exactHalf_symmetric_window_package
      (sharpPrefixPeriod n K) (n K) w (hpos K) hwindow hgdiv
  apply favorable_explicitTarget_pair_contradiction
    n hpos hmono c hc hratio qden hqden T Tconj hsum htotal
      q hqpos hq K w X r v (by omega) hPX hXbound hX hv hrlt
      hrLeft hrRight hrUpper hsRWindow hnoDouble hfirst hsecond
  let P := sharpPrefixPeriod n K
  let W := w + 1 + w
  let B := n K * W ^ 8
  let Q := 8 * q * W
  dsimp only
  intro X' G hX' hG hdG
  let H := adaptiveLogCutoffPosition n K G B w w X' q
  have hHupper : H ≤ favorableCutoffUpper n K w q := by
    exact adaptiveLogCutoffPosition_le_favorableCutoffUpper
      n hpos K w q X' G (by omega)
        (by simpa [P] using hX')
        (by simpa [Q, W] using hG)
        (by simpa [Q, W] using hdG)
  have hUpperWindow : favorableCutoffUpper n K w q ≤
      favorableWindowCutoffBound q w :=
    favorableCutoffUpper_le_windowCutoffBound n hpos hmono K w q hupp
  exact favorable_normCaps_of_windowCutoffBound
    Tconj q w H (hHupper.trans hUpperWindow) hncap.1
      (by simpa only [ε] using hncap.2)

end Research

/-!
# Unbounded two-adic order under an arbitrary quadratic total
-/

namespace Research

open Filter
open Real goldenRatio

/-- Every sufficiently late high record is doubled whenever the total is a
fixed scaled golden pair. -/
theorem eventually_highTwoAdicRecord_has_selectedDouble_of_pair
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    ∀ᶠ K : ℕ in atTop,
      IsHighTwoAdicRecord n K →
        ∃ j, K < j ∧ n j = 2 * n K := by
  filter_upwards [eventually_prefixGcd_not_dvd_or_selectedDouble_of_pair
    n hpos hmono c hc hratio qden hqden T Tconj hsum htotal
      q hqpos hq] with K hK
  intro hrec
  rcases hK with hg | hd
  · have hp : 2 * (n K).gcd (sharpPrefixPeriod n K) ∣
        sharpPrefixPeriod n K :=
      (gcd_four_mul_not_dvd_iff_two_gcd_dvd
        (n K) (sharpPrefixPeriod n K) (hpos K)).mp hg
    exact False.elim
      (not_two_targetGcd_dvd_prefix_of_highRecord n hpos K hrec hp)
  · exact hd

/-- Under any fixed scaled golden total pair, unbounded selected two-adic order
forces an embedded complete dyadic tail. -/
theorem exists_complete_selected_dyadic_tail_of_pair_of_unboundedOrder
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (hunb : UnboundedTwoAdicOrder n) :
    ∃ m : ℕ, 0 < m ∧ ∃ k : ℕ → ℕ, StrictMono k ∧
      ∀ s, n (k s) = m * 2 ^ s := by
  have hevent := eventually_highTwoAdicRecord_has_selectedDouble_of_pair
    n hpos hmono c hc hratio qden hqden T Tconj hsum htotal q hqpos hq
  rw [eventually_atTop] at hevent
  obtain ⟨K₀, hdouble⟩ := hevent
  obtain ⟨K, hK₀, hrec⟩ :=
    exists_highTwoAdicRecord_ge_of_unbounded n hunb K₀
  have hprops := highRecordChain_properties
    n hpos hmono K₀ K hK₀ hrec (fun i hi hirec => hdouble i hi hirec)
  let x : ℕ → ℕ := fun t => n (highRecordChain n K t)
  have hv : ∀ t, twoAdicOrder (x t) < twoAdicOrder (x (t + 1)) := by
    intro t
    have ht := hprops t
    have ht1 := hprops (t + 1)
    exact ht1.2.1.2 (highRecordChain n K t) ht.2.2.1
  have hxbound : ∀ t, x (t + 1) ≤ 2 * x t := fun t => (hprops t).2.2.2
  obtain ⟨R, hR⟩ :=
    eventually_eq_double_of_twoAdicOrder_strictMono_le_double x hv hxbound
  let m := x R
  let k : ℕ → ℕ := fun s => highRecordChain n K (R + s)
  have hkmono : StrictMono k := by
    apply strictMono_nat_of_lt_succ
    intro s
    exact (hprops (R + s)).2.2.1
  have hformula : ∀ s, n (k s) = m * 2 ^ s := by
    intro s
    induction s with
    | zero => simp [k, m, x]
    | succ s ih =>
        have hstep := hR (R + s) (by omega)
        change n (highRecordChain n K (R + (s + 1))) = m * 2 ^ (s + 1)
        have hidx : R + (s + 1) = (R + s) + 1 := by omega
        rw [hidx]
        change x (R + s + 1) = m * 2 ^ (s + 1)
        rw [hstep]
        change 2 * n (k s) = m * 2 ^ (s + 1)
        rw [ih, pow_succ]
        ring
  refine ⟨m, ?_, k, hkmono, hformula⟩
  exact hpos _

end Research

/-!
# Enumerating the complement of a selected position subsequence
-/

namespace Research

open Filter Topology

/-- Increasing enumeration of the positions outside the range of `k`. -/
noncomputable def complementPositionSequence (k : ℕ → ℕ) : ℕ → ℕ :=
  Nat.nth (fun i => i ∉ Set.range k)

/-- Deleting an infinite position subsequence and enumerating the remaining
positions. -/
noncomputable def deletePositionSubsequence
    (n k : ℕ → ℕ) : ℕ → ℕ :=
  fun t => n (complementPositionSequence k t)

lemma complementPositionSequence_strictMono
    (k : ℕ → ℕ)
    (hinf : {i : ℕ | i ∉ Set.range k}.Infinite) :
    StrictMono (complementPositionSequence k) := by
  exact Nat.nth_strictMono hinf

lemma complementPositionSequence_not_mem_range
    (k : ℕ → ℕ)
    (hinf : {i : ℕ | i ∉ Set.range k}.Infinite) (t : ℕ) :
    complementPositionSequence k t ∉ Set.range k := by
  exact Nat.nth_mem_of_infinite hinf t

lemma range_complementPositionSequence
    (k : ℕ → ℕ)
    (hinf : {i : ℕ | i ∉ Set.range k}.Infinite) :
    Set.range (complementPositionSequence k) = (Set.range k)ᶜ := by
  exact Nat.range_nth_of_infinite hinf

/-- The complement enumeration preserves positivity and strict increase. -/
theorem deletePositionSubsequence_pos_strictMono
    (n k : ℕ → ℕ) (hpos : ∀ i, 0 < n i) (hmono : StrictMono n)
    (hinf : {i : ℕ | i ∉ Set.range k}.Infinite) :
    (∀ t, 0 < deletePositionSubsequence n k t) ∧
      StrictMono (deletePositionSubsequence n k) := by
  constructor
  · intro t
    exact hpos _
  · exact hmono.comp (complementPositionSequence_strictMono k hinf)

/-- A real ratio gap is inherited by every infinite complement subsequence. -/
theorem deletePositionSubsequence_ratioGap
    (n k : ℕ → ℕ) (hmono : StrictMono n)
    (hinf : {i : ℕ | i ∉ Set.range k}.Infinite)
    (c : ℝ) (hratio : ∀ i, c * (n i : ℝ) ≤ n (i + 1)) :
    ∀ t, c * (deletePositionSubsequence n k t : ℝ) ≤
      deletePositionSubsequence n k (t + 1) := by
  intro t
  let e := complementPositionSequence k
  have he : e t < e (t + 1) :=
    (complementPositionSequence_strictMono k hinf) (Nat.lt_succ_self t)
  have hstep : e t + 1 ≤ e (t + 1) := he
  have hnle : n (e t + 1) ≤ n (e (t + 1)) := hmono.monotone hstep
  have hnleR : (n (e t + 1) : ℝ) ≤ n (e (t + 1)) := by exact_mod_cast hnle
  exact (hratio (e t)).trans hnleR

/-- Exact absolutely-convergent partition of a series into a strictly
increasing selected position subsequence and its infinite complement. -/
theorem tsum_range_add_tsum_complement
    (f : ℕ → ℝ) (hf : Summable f)
    (k : ℕ → ℕ) (hk : StrictMono k)
    (hinf : {i : ℕ | i ∉ Set.range k}.Infinite) :
    (∑' s : ℕ, f (k s)) +
      (∑' t : ℕ, f (complementPositionSequence k t)) =
        ∑' i : ℕ, f i := by
  let S : Set ℕ := Set.range k
  have hsplit := hf.tsum_subtype_add_tsum_subtype_compl S
  have htail : (∑' s : ℕ, f (k s)) = ∑' x : S, f x := by
    let e : ℕ ≃ S := Equiv.ofInjective k hk.injective
    calc
      (∑' s : ℕ, f (k s)) = ∑' s : ℕ, f (e s) := by
        apply tsum_congr
        intro s
        change f (k s) = f ((Equiv.ofInjective k hk.injective s : S).val)
        congr 1
      _ = ∑' x : S, f x := e.tsum_eq (fun x : S => f x)
  let C : Set ℕ := {i : ℕ | i ∉ Set.range k}
  have hCinf : C.Infinite := by simpa [C] using hinf
  have hcomp : (∑' t : ℕ, f (complementPositionSequence k t)) =
      ∑' x : C, f x := by
    let e : ℕ ≃o C := @Nat.Subtype.orderIsoOfNat C hCinf.to_subtype
    have heq (t : ℕ) : complementPositionSequence k t = (e t : ℕ) := by
      dsimp [complementPositionSequence, e, C, S]
      exact Nat.nth_apply_eq_orderIsoOfNat hinf t
    calc
      (∑' t : ℕ, f (complementPositionSequence k t)) =
          ∑' t : ℕ, f (e t) := by
        apply tsum_congr
        intro t
        rw [heq]
      _ = ∑' x : C, f x := e.toEquiv.tsum_eq (fun x : C => f x)
  have hCS : C = (Sᶜ : Set ℕ) := by
    ext i
    simp [C, S]
  rw [hCS] at hcomp
  rw [htail, hcomp]
  exact hsplit

end Research

/-!
# Dyadic telescoping series

The analytic core of Millin's reciprocal-Fibonacci identity.  Kept independent
of the open target in `Research.Basic`, so this file can be checked with
`lake --wfail build +Research.Dyadic`.
-/

namespace Research

open Filter Topology
open scoped BigOperators

/-- The elementary dyadic telescoping identity. -/
theorem hasSum_dyadic_telescoping (x : ℝ) (hx0 : 0 ≤ x) (hx1 : x < 1) :
    HasSum (fun j : ℕ => x ^ (2 ^ j) / (1 - x ^ (2 ^ (j + 1)))) (x / (1 - x)) := by
  let u : ℕ → ℝ := fun j => x ^ (2 ^ j) / (1 - x ^ (2 ^ j))
  have hpow : Tendsto (fun j : ℕ => x ^ (2 ^ j)) atTop (𝓝 0) := by
    exact (tendsto_pow_atTop_nhds_zero_of_lt_one hx0 hx1).comp
      (tendsto_pow_atTop_atTop_of_one_lt (by norm_num : (1 : ℕ) < 2))
  have hu : Tendsto u atTop (𝓝 0) := by
    have hden : Tendsto (fun j : ℕ => 1 - x ^ (2 ^ j)) atTop (𝓝 (1 - 0)) :=
      tendsto_const_nhds.sub hpow
    change Tendsto
      ((fun j : ℕ => x ^ (2 ^ j)) / (fun j : ℕ => 1 - x ^ (2 ^ j)))
      atTop (𝓝 0)
    convert hpow.div hden (by norm_num : (1 - 0 : ℝ) ≠ 0) using 1
    norm_num
  have hden_pos (j : ℕ) : 0 < 1 - x ^ (2 ^ j) := by
    have hp : x ^ (2 ^ j) < 1 := pow_lt_one₀ hx0 hx1 (by positivity)
    linarith
  have hterm (j : ℕ) :
      x ^ (2 ^ j) / (1 - x ^ (2 ^ (j + 1))) = u j - u (j + 1) := by
    have hpow2 : x ^ (2 ^ (j + 1)) = (x ^ (2 ^ j)) ^ 2 := by
      rw [pow_succ, pow_mul]
    dsimp [u]
    rw [hpow2]
    have h₁ : 1 - x ^ (2 ^ j) ≠ 0 := ne_of_gt (hden_pos j)
    have h₂ : 1 - (x ^ (2 ^ j)) ^ 2 ≠ 0 := by
      rw [← hpow2]
      exact ne_of_gt (hden_pos (j + 1))
    field_simp
    ring
  have hnonneg (j : ℕ) : 0 ≤ x ^ (2 ^ j) / (1 - x ^ (2 ^ (j + 1))) := by
    exact div_nonneg (pow_nonneg hx0 _) (le_of_lt (hden_pos (j + 1)))
  rw [hasSum_iff_tendsto_nat_of_nonneg hnonneg]
  have htel (N : ℕ) :
      (∑ j ∈ Finset.range N, x ^ (2 ^ j) / (1 - x ^ (2 ^ (j + 1)))) = u 0 - u N := by
    calc
      _ = ∑ j ∈ Finset.range N, (u j - u (j + 1)) := by
        apply Finset.sum_congr rfl
        intro j hj
        exact hterm j
      _ = u 0 - u N := Finset.sum_range_sub' u N
  have hlim : Tendsto (fun N : ℕ => u 0 - u N) atTop (𝓝 (u 0 - 0)) :=
    tendsto_const_nhds.sub hu
  simpa [htel, u] using hlim

open Real goldenRatio

/-- Binet's formula rewritten as a positive geometric fraction at an even
Fibonacci index. -/
theorem inv_fib_two_mul (r : ℕ) (hr : 0 < r) :
    (Nat.fib (2 * r) : ℝ)⁻¹ =
      √5 * (φ⁻¹) ^ (2 * r) / (1 - ((φ⁻¹) ^ (2 * r)) ^ 2) := by
  have hpsi : ψ = -φ⁻¹ := by
    linarith [Real.inv_goldenRatio]
  have hpsi_pow : ψ ^ (2 * r) = (φ⁻¹) ^ (2 * r) := by
    rw [hpsi, pow_mul, pow_mul]
    congr 1
    ring
  have hphi_ne : φ ≠ 0 := Real.goldenRatio_ne_zero
  have hunit : φ ^ (2 * r) * (φ⁻¹) ^ (2 * r) = 1 := by
    rw [inv_pow, mul_inv_cancel₀ (pow_ne_zero _ hphi_ne)]
  have hinv0 : 0 ≤ φ⁻¹ := le_of_lt (inv_pos.mpr Real.goldenRatio_pos)
  have hinv1 : φ⁻¹ < 1 := inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hy1 : (φ⁻¹) ^ (2 * r) < 1 :=
    pow_lt_one₀ hinv0 hinv1
      (Nat.ne_of_gt (Nat.mul_pos (by norm_num : 0 < (2 : ℕ)) hr))
  have hy0 : 0 ≤ (φ⁻¹) ^ (2 * r) := pow_nonneg hinv0 _
  have hden : 1 - ((φ⁻¹) ^ (2 * r)) ^ 2 ≠ 0 := by
    have hsquare : ((φ⁻¹) ^ (2 * r)) ^ 2 < 1 :=
      pow_lt_one₀ hy0 hy1 (by norm_num : (2 : ℕ) ≠ 0)
    linarith
  apply inv_eq_of_mul_eq_one_right
  rw [Real.coe_fib_eq, hpsi_pow]
  have hsqrt : √5 ≠ 0 := by positivity
  calc
    ((φ ^ (2 * r) - (φ⁻¹) ^ (2 * r)) / √5) *
        (√5 * (φ⁻¹) ^ (2 * r) / (1 - ((φ⁻¹) ^ (2 * r)) ^ 2)) =
        (φ ^ (2 * r) * (φ⁻¹) ^ (2 * r) - ((φ⁻¹) ^ (2 * r)) ^ 2) /
          (1 - ((φ⁻¹) ^ (2 * r)) ^ 2) := by
            field_simp [hsqrt, hden]
    _ = 1 := by rw [hunit]; exact div_self hden

/-- The reciprocal Fibonacci numbers on every dyadic orbit beginning at a
positive even index have the explicit quadratic sum given below. -/
theorem hasSum_reciprocal_fib_dyadic_even (r : ℕ) (hr : 0 < r) :
    HasSum (fun j : ℕ => (Nat.fib (2 * (r * 2 ^ j)) : ℝ)⁻¹)
      (√5 * ((φ⁻¹) ^ (2 * r) / (1 - (φ⁻¹) ^ (2 * r)))) := by
  let x : ℝ := (φ⁻¹) ^ (2 * r)
  have hinv0 : 0 ≤ φ⁻¹ := le_of_lt (inv_pos.mpr Real.goldenRatio_pos)
  have hinv1 : φ⁻¹ < 1 := inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hx0 : 0 ≤ x := pow_nonneg hinv0 _
  have hx1 : x < 1 := by
    exact pow_lt_one₀ hinv0 hinv1
      (Nat.ne_of_gt (Nat.mul_pos (by norm_num : 0 < (2 : ℕ)) hr))
  have hscaled := (hasSum_dyadic_telescoping x hx0 hx1).const_smul √5
  have hscaled' :
      HasSum (fun j : ℕ => √5 * (x ^ (2 ^ j) / (1 - x ^ (2 ^ (j + 1)))))
        (√5 * (x / (1 - x))) := by
    simpa only [smul_eq_mul] using hscaled
  apply hscaled'.congr_fun
  intro j
  rw [inv_fib_two_mul (r * 2 ^ j) (Nat.mul_pos hr (by positivity))]
  have hexp : 2 * (r * 2 ^ j) = (2 * r) * 2 ^ j := by ring
  have hnext : x ^ (2 ^ (j + 1)) = (x ^ (2 ^ j)) ^ 2 := by
    rw [pow_succ, pow_mul]
  rw [hexp, pow_mul, ← hnext]
  dsimp [x]
  ring

/-- The even powers of the golden ratio in the rational basis `1, √5`. -/
theorem goldenRatio_pow_two_mul_fib (r : ℕ) (hr : 0 < r) :
    φ ^ (2 * r) =
      ((Nat.fib (2 * r) : ℝ) / 2 + Nat.fib (2 * r - 1)) +
        ((Nat.fib (2 * r) : ℝ) / 2) * √5 := by
  have hn : (2 * r - 1) + 1 = 2 * r := by omega
  calc
    φ ^ (2 * r) = φ ^ ((2 * r - 1) + 1) := by rw [hn]
    _ = φ * Nat.fib ((2 * r - 1) + 1) + Nat.fib (2 * r - 1) :=
      (Real.goldenRatio_mul_fib_succ_add_fib (2 * r - 1)).symm
    _ = _ := by rw [hn]; change ((1 + √5) / 2) * _ + _ = _; ring

/-- The matching even powers of the conjugate golden ratio. -/
theorem goldenConj_pow_two_mul_fib (r : ℕ) (hr : 0 < r) :
    ψ ^ (2 * r) =
      ((Nat.fib (2 * r) : ℝ) / 2 + Nat.fib (2 * r - 1)) -
        ((Nat.fib (2 * r) : ℝ) / 2) * √5 := by
  have hn : (2 * r - 1) + 1 = 2 * r := by omega
  calc
    ψ ^ (2 * r) = ψ ^ ((2 * r - 1) + 1) := by rw [hn]
    _ = ψ * Nat.fib ((2 * r - 1) + 1) + Nat.fib (2 * r - 1) :=
      (Real.goldenConj_mul_fib_succ_add_fib (2 * r - 1)).symm
    _ = _ := by rw [hn]; change ((1 - √5) / 2) * _ + _ = _; ring

/-- Every complete positive even dyadic orbit has the same irrational component
`-√5/2`; the other displayed component is rational. -/
theorem dyadic_even_value_decomposition (r : ℕ) (hr : 0 < r) :
    √5 / (φ ^ (2 * r) - 1) =
      5 * ((Nat.fib (2 * r) : ℝ) / 2) /
          (2 * ((Nat.fib (2 * r) : ℝ) / 2 + Nat.fib (2 * r - 1) - 1)) - √5 / 2 := by
  let F : ℝ := Nat.fib (2 * r)
  let G : ℝ := Nat.fib (2 * r - 1)
  let A : ℝ := F / 2 + G - 1
  let B : ℝ := F / 2
  have hp : φ ^ (2 * r) = A + 1 + B * √5 := by
    rw [goldenRatio_pow_two_mul_fib r hr]
    dsimp [A, B, F, G]
    ring
  have hc : ψ ^ (2 * r) = A + 1 - B * √5 := by
    rw [goldenConj_pow_two_mul_fib r hr]
    dsimp [A, B, F, G]
    ring
  have hprod : φ ^ (2 * r) * ψ ^ (2 * r) = 1 := by
    rw [← mul_pow, Real.goldenRatio_mul_goldenConj, pow_mul]
    norm_num
  rw [hp, hc] at hprod
  have hsqrt_sq : (√5) ^ 2 = (5 : ℝ) := by norm_num
  have hnorm : A ^ 2 - 5 * B ^ 2 = -2 * A := by
    nlinarith
  have hn : 0 < 2 * r := Nat.mul_pos (by norm_num) hr
  have hnprev : 0 < 2 * r - 1 := by omega
  have hFpos : 0 < F := by
    dsimp [F]
    exact_mod_cast (Nat.fib_pos.mpr hn)
  have hGone : 1 ≤ G := by
    dsimp [G]
    exact_mod_cast (show 1 ≤ Nat.fib (2 * r - 1) by
      have := Nat.fib_pos.mpr hnprev
      omega)
  have hA : 0 < A := by dsimp [A]; linarith
  have heq : φ ^ (2 * r) - 1 = A + B * √5 := by rw [hp]; ring
  have hpgt : 1 < φ ^ (2 * r) :=
    one_lt_pow₀ Real.one_lt_goldenRatio (Nat.ne_of_gt hn)
  have hden : A + B * √5 ≠ 0 := by rw [← heq]; linarith
  have hden' : A + √5 * B ≠ 0 := by
    have he : A + √5 * B = A + B * √5 := by ring
    rwa [he]
  have habstract :
      √5 / (φ ^ (2 * r) - 1) = 5 * B / (2 * A) - √5 / 2 := by
    rw [heq]
    field_simp [hden, hden', ne_of_gt hA]
    linear_combination √5 * hnorm + A * B * hsqrt_sq
  simpa [A, B, F, G] using habstract

/-- The geometric form of the dyadic-orbit limit equals its simpler closed
form. -/
theorem dyadic_even_geometric_eq (r : ℕ) (hr : 0 < r) :
    √5 * ((φ⁻¹) ^ (2 * r) / (1 - (φ⁻¹) ^ (2 * r))) =
      √5 / (φ ^ (2 * r) - 1) := by
  let a : ℝ := φ ^ (2 * r)
  let y : ℝ := (φ⁻¹) ^ (2 * r)
  have hphi_ne : φ ≠ 0 := Real.goldenRatio_ne_zero
  have hunit : a * y = 1 := by
    dsimp [a, y]
    rw [inv_pow, mul_inv_cancel₀ (pow_ne_zero _ hphi_ne)]
  have hn : 0 < 2 * r := Nat.mul_pos (by norm_num) hr
  have ha1 : 1 < a := by
    dsimp [a]
    exact one_lt_pow₀ Real.one_lt_goldenRatio (Nat.ne_of_gt hn)
  have hinv0 : 0 ≤ φ⁻¹ := le_of_lt (inv_pos.mpr Real.goldenRatio_pos)
  have hinv1 : φ⁻¹ < 1 := inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hy1 : y < 1 := by
    dsimp [y]
    exact pow_lt_one₀ hinv0 hinv1 (Nat.ne_of_gt hn)
  have hya : 1 - y ≠ 0 := by linarith
  have hay : a - 1 ≠ 0 := by linarith
  have hfrac : y / (1 - y) = 1 / (a - 1) := by
    field_simp [hya, hay]
    nlinarith
  rw [hfrac]
  dsimp [a, y]
  ring

/-- Closed form for the reciprocal-Fibonacci series on a positive even dyadic
orbit. -/
theorem hasSum_reciprocal_fib_dyadic_even_closed (r : ℕ) (hr : 0 < r) :
    HasSum (fun j : ℕ => (Nat.fib (2 * (r * 2 ^ j)) : ℝ)⁻¹)
      (√5 / (φ ^ (2 * r) - 1)) := by
  rw [← dyadic_even_geometric_eq r hr]
  exact hasSum_reciprocal_fib_dyadic_even r hr

/-- The closed value of every complete positive even dyadic orbit is
irrational. -/
theorem irrational_dyadic_even_value (r : ℕ) (hr : 0 < r) :
    Irrational (√5 / (φ ^ (2 * r) - 1)) := by
  let q : ℚ :=
    5 * ((Nat.fib (2 * r) : ℚ) / 2) /
      (2 * ((Nat.fib (2 * r) : ℚ) / 2 + Nat.fib (2 * r - 1) - 1))
  have hsqrt : Irrational (√5) :=
    Nat.Prime.irrational_sqrt (show Nat.Prime 5 by norm_num)
  have hhalf : Irrational (√5 / (2 : ℚ)) :=
    hsqrt.div_ratCast (by norm_num)
  have hqsub : Irrational ((q : ℝ) - √5 / 2) := by
    simpa using hhalf.ratCast_sub q
  have hqcast :
      (q : ℝ) =
        5 * ((Nat.fib (2 * r) : ℝ) / 2) /
          (2 * ((Nat.fib (2 * r) : ℝ) / 2 + Nat.fib (2 * r - 1) - 1)) := by
    simp [q]
  rw [hqcast] at hqsub
  rw [dyadic_even_value_decomposition r hr]
  exact hqsub

/-- Every complete dyadic orbit, with an arbitrary positive starting index,
has a closed form obtained by separating its first term. -/
theorem hasSum_reciprocal_fib_complete_dyadic (m : ℕ) (hm : 0 < m) :
    HasSum (fun j : ℕ => (Nat.fib (m * 2 ^ j) : ℝ)⁻¹)
      ((Nat.fib m : ℝ)⁻¹ + √5 / (φ ^ (2 * m) - 1)) := by
  let f : ℕ → ℝ := fun j => (Nat.fib (m * 2 ^ j) : ℝ)⁻¹
  have htail := hasSum_reciprocal_fib_dyadic_even_closed m hm
  have htail' : HasSum (fun j : ℕ => f (j + 1)) (√5 / (φ ^ (2 * m) - 1)) := by
    apply htail.congr_fun
    intro j
    dsimp [f]
    congr 3
    rw [pow_succ]
    ring
  simpa [f] using htail'.zero_add

/-- The closed value of every complete dyadic orbit is irrational, irrespective
of the parity of its starting index. -/
theorem irrational_complete_dyadic_value (m : ℕ) (hm : 0 < m) :
    Irrational ((Nat.fib m : ℝ)⁻¹ + √5 / (φ ^ (2 * m) - 1)) := by
  let q : ℚ := (Nat.fib m : ℚ)⁻¹
  have htail := irrational_dyadic_even_value m hm
  have h := htail.ratCast_add q
  simpa [q] using h

/-- The `tsum` over any complete positive dyadic Fibonacci orbit is
irrational. -/
theorem irrational_tsum_reciprocal_fib_complete_dyadic (m : ℕ) (hm : 0 < m) :
    Irrational (∑' j : ℕ, (Nat.fib (m * 2 ^ j) : ℝ)⁻¹) := by
  rw [(hasSum_reciprocal_fib_complete_dyadic m hm).tsum_eq]
  exact irrational_complete_dyadic_value m hm

/-- The arbitrary-start complete dyadic orbit again has irrational component
exactly `-√5/2`. -/
theorem complete_dyadic_value_decomposition (m : ℕ) (hm : 0 < m) :
    (Nat.fib m : ℝ)⁻¹ + √5 / (φ ^ (2 * m) - 1) =
      (Nat.fib m : ℝ)⁻¹ +
        5 * ((Nat.fib (2 * m) : ℝ) / 2) /
          (2 * ((Nat.fib (2 * m) : ℝ) / 2 + Nat.fib (2 * m - 1) - 1)) - √5 / 2 := by
  rw [dyadic_even_value_decomposition m hm]
  ring

/-- No nonempty finite sum of complete positive dyadic-orbit values can be
rational.  This is the algebraic obstruction behind the failure of finite
unions of such orbits as counterexamples. -/
theorem irrational_finset_sum_complete_dyadic_values
    (s : Finset ℕ) (hs : s.Nonempty) (hpos : ∀ m ∈ s, 0 < m) :
    Irrational
      (∑ m ∈ s, ((Nat.fib m : ℝ)⁻¹ + √5 / (φ ^ (2 * m) - 1))) := by
  let p : ℕ → ℚ := fun m =>
    (Nat.fib m : ℚ)⁻¹ +
      5 * ((Nat.fib (2 * m) : ℚ) / 2) /
        (2 * ((Nat.fib (2 * m) : ℚ) / 2 + Nat.fib (2 * m - 1) - 1))
  let Q : ℚ := ∑ m ∈ s, p m
  let C : ℚ := (s.card : ℚ) / 2
  have hterm (m : ℕ) (hm : m ∈ s) :
      (Nat.fib m : ℝ)⁻¹ + √5 / (φ ^ (2 * m) - 1) = (p m : ℝ) - √5 / 2 := by
    simpa [p] using complete_dyadic_value_decomposition m (hpos m hm)
  have hsum :
      (∑ m ∈ s, ((Nat.fib m : ℝ)⁻¹ + √5 / (φ ^ (2 * m) - 1))) =
        (Q : ℝ) - (C : ℝ) * √5 := by
    calc
      _ = ∑ m ∈ s, ((p m : ℝ) - √5 / 2) := by
        apply Finset.sum_congr rfl
        intro m hm
        exact hterm m hm
      _ = (Q : ℝ) - (C : ℝ) * √5 := by
        simp [Q, C]
        ring
  have hcard : s.card ≠ 0 := Finset.card_ne_zero.mpr hs
  have hC : C ≠ 0 := by
    dsimp [C]
    exact div_ne_zero (by exact_mod_cast hcard) (by norm_num)
  have hsqrt : Irrational (√5) :=
    Nat.Prime.irrational_sqrt (show Nat.Prime 5 by norm_num)
  have hscaled : Irrational ((C : ℝ) * √5) := hsqrt.ratCast_mul hC
  have hirr : Irrational ((Q : ℝ) - (C : ℝ) * √5) := hscaled.ratCast_sub Q
  rw [hsum]
  exact hirr

end Research

/-!
# Scaled golden pairs with an existential common denominator
-/

namespace Research

open Real goldenRatio

/-- Membership in the two real embeddings of `ℚ(φ)`, with an unspecified
positive natural denominator. -/
def InGoldenPair (x y : ℝ) : Prop :=
  ∃ q : ℕ, 0 < q ∧ InScaledGoldenPair q x y

/-- A scaled pair can be moved to any positive multiple denominator. -/
theorem InScaledGoldenPair.to_mul_denominator
    {q : ℕ} {x y : ℝ} (h : InScaledGoldenPair q x y)
    (r : ℕ) (hq : 0 < q) (hr : 0 < r) :
    InScaledGoldenPair (q * r) x y := by
  obtain ⟨A, B, hx, hy⟩ := h
  refine ⟨(r : ℤ) * A, (r : ℤ) * B, ?_, ?_⟩
  · rw [hx]
    push_cast
    field_simp
  · rw [hy]
    push_cast
    field_simp

/-- Existential golden pairs are closed under subtraction. -/
theorem InGoldenPair.sub {x y x' y' : ℝ}
    (h : InGoldenPair x y) (h' : InGoldenPair x' y') :
    InGoldenPair (x - x') (y - y') := by
  obtain ⟨q, hq, hxy⟩ := h
  obtain ⟨r, hr, hxy'⟩ := h'
  refine ⟨q * r, mul_pos hq hr, ?_⟩
  exact (hxy.to_mul_denominator r hq hr).sub (mul_pos hq hr)
    (by simpa [mul_comm] using hxy'.to_mul_denominator q hr hq)

/-- Existential golden pairs are closed under addition. -/
theorem InGoldenPair.add {x y x' y' : ℝ}
    (h : InGoldenPair x y) (h' : InGoldenPair x' y') :
    InGoldenPair (x + x') (y + y') := by
  obtain ⟨q, hq, hxy⟩ := h
  obtain ⟨r, hr, hxy'⟩ := h'
  refine ⟨q * r, mul_pos hq hr, ?_⟩
  exact (hxy.to_mul_denominator r hq hr).add (mul_pos hq hr)
    (by simpa [mul_comm] using hxy'.to_mul_denominator q hr hq)

/-- A rational number has the same value under both embeddings. -/
theorem rational_mem_goldenPair (p : ℚ) :
    InGoldenPair (p : ℝ) (p : ℝ) := by
  refine ⟨p.den, p.den_pos, p.num, 0, ?_, ?_⟩
  · simp only [Int.cast_zero, zero_mul, add_zero]
    rw [Rat.cast_def]
  · simp only [Int.cast_zero, zero_mul, add_zero]
    rw [Rat.cast_def]

/-- A rational divided by `√5` has opposite values under the two embeddings. -/
theorem rational_inv_sqrtFive_mem_goldenPair (p : ℚ) :
    InGoldenPair ((√5)⁻¹ * (p : ℝ)) (-((√5)⁻¹ * (p : ℝ))) := by
  refine ⟨5 * p.den, by positivity, ?_⟩
  have h := rational_inv_sqrtFive_mem_pair p.num p.den p.den_pos
  simpa only [Rat.cast_def] using h

/-- The rational part in the decomposition of one complete dyadic orbit. -/
def completeDyadicRationalPart (m : ℕ) : ℚ :=
  (Nat.fib m : ℚ)⁻¹ +
    5 * ((Nat.fib (2 * m) : ℚ) / 2) /
      (2 * ((Nat.fib (2 * m) : ℚ) / 2 + Nat.fib (2 * m - 1) - 1))

/-- Chosen conjugate of the normalized value of one complete dyadic orbit. -/
noncomputable def completeDyadicNormalizedConjugate (m : ℕ) : ℝ :=
  -((√5)⁻¹ * (completeDyadicRationalPart m : ℝ)) - 1 / 2

/-- The normalized complete-dyadic value and its chosen conjugate lie in
`ℚ(φ)` with one positive common denominator. -/
theorem complete_dyadic_normalized_mem_goldenPair
    (m : ℕ) (hm : 0 < m) :
    InGoldenPair
      ((√5)⁻¹ * (∑' s : ℕ, (Nat.fib (m * 2 ^ s) : ℝ)⁻¹))
      (completeDyadicNormalizedConjugate m) := by
  have hp := rational_inv_sqrtFive_mem_goldenPair
    (completeDyadicRationalPart m)
  have hh := rational_mem_goldenPair (-(1 : ℚ) / 2)
  have hadd := hp.add hh
  have hsum := (hasSum_reciprocal_fib_complete_dyadic m hm).tsum_eq
  have hdecomp :
      (Nat.fib m : ℝ)⁻¹ + √5 / (φ ^ (2 * m) - 1) =
        (completeDyadicRationalPart m : ℝ) - √5 / 2 := by
    simpa [completeDyadicRationalPart] using
      complete_dyadic_value_decomposition m hm
  rw [hsum, hdecomp]
  dsimp only [completeDyadicNormalizedConjugate]
  have hs : √(5 : ℝ) ≠ 0 := by positivity
  convert hadd using 1
  · norm_num
    field_simp
    ring
  · norm_num
    ring

/-- Deleting one embedded complete dyadic tail from a quadratic total leaves
the infinite complement with another quadratic total pair. -/
theorem delete_complete_dyadic_tail_mem_goldenPair
    (n k : ℕ → ℕ) (hpos : ∀ i, 0 < n i) (hmono : StrictMono n)
    (hinf : {i : ℕ | i ∉ Set.range k}.Infinite)
    (m : ℕ) (hm : 0 < m) (hk : StrictMono k)
    (htail : ∀ s, n (k s) = m * 2 ^ s)
    (Tconj : ℝ)
    (horig : InGoldenPair
      ((√5)⁻¹ * (∑' i : ℕ, (Nat.fib (n i) : ℝ)⁻¹)) Tconj) :
    InGoldenPair
      ((√5)⁻¹ * (∑' t : ℕ,
        (Nat.fib (deletePositionSubsequence n k t) : ℝ)⁻¹))
      (Tconj - completeDyadicNormalizedConjugate m) := by
  let f : ℕ → ℝ := fun i => (Nat.fib (n i) : ℝ)⁻¹
  have hf : Summable f := by
    simpa [f] using (summable_and_tsum_shift_le n hpos hmono 0).1
  have hsplit := tsum_range_add_tsum_complement f hf k hk hinf
  have htailTsum : (∑' s : ℕ, f (k s)) =
      ∑' s : ℕ, (Nat.fib (m * 2 ^ s) : ℝ)⁻¹ := by
    apply tsum_congr
    intro s
    simp only [f, htail s]
  have hpairTail := complete_dyadic_normalized_mem_goldenPair m hm
  have hsub := horig.sub hpairTail
  convert hsub using 1
  dsimp [deletePositionSubsequence, f] at hsplit ⊢
  dsimp [f] at htailTsum
  rw [← htailTsum]
  linear_combination (√5)⁻¹ * hsplit

end Research

/-!
# Iterating complete-tail extraction through an infinite complement
-/

namespace Research

open Real goldenRatio

/-- If the infinite complement after deleting one complete tail still has
unbounded two-adic order, the quadratic-pair argument extracts a second,
disjoint complete tail in the original sequence. -/
theorem exists_disjoint_complete_tail_in_unbounded_complement
    (n k : ℕ → ℕ) (hpos : ∀ i, 0 < n i) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ i, c * (n i : ℝ) ≤ n (i + 1))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (m : ℕ) (hm : 0 < m) (hk : StrictMono k)
    (htail : ∀ s, n (k s) = m * 2 ^ s)
    (hinf : {i : ℕ | i ∉ Set.range k}.Infinite)
    (Tconj : ℝ)
    (horig : InGoldenPair
      ((√5)⁻¹ * (∑' i : ℕ, (Nat.fib (n i) : ℝ)⁻¹)) Tconj)
    (hunb : UnboundedTwoAdicOrder (deletePositionSubsequence n k)) :
    ∃ m' : ℕ, 0 < m' ∧ ∃ l : ℕ → ℕ, StrictMono l ∧
      (∀ s, n (l s) = m' * 2 ^ s) ∧
      (∀ s, l s ∉ Set.range k) := by
  let n' := deletePositionSubsequence n k
  have hnData := deletePositionSubsequence_pos_strictMono
    n k hpos hmono hinf
  have hratio' := deletePositionSubsequence_ratioGap
    n k hmono hinf c hratio
  have hpairComp := delete_complete_dyadic_tail_mem_goldenPair
    n k hpos hmono hinf m hm hk htail Tconj horig
  obtain ⟨qden, hqden, htotal⟩ := hpairComp
  let T' : ℝ := (√5)⁻¹ *
    (∑' t : ℕ, (Nat.fib (n' t) : ℝ)⁻¹)
  let Tconj' : ℝ := Tconj - completeDyadicNormalizedConjugate m
  have hsum : HasSum (fun z : ℕ =>
      (selectedFibLambertCoeff n' z : ℝ) * (φ⁻¹) ^ z) T' := by
    exact hasSum_selectedFibLambertCoeff n' hnData.1 hnData.2
  have htotal' : InScaledGoldenPair qden T' Tconj' := by
    simpa [T', Tconj', n'] using htotal
  obtain ⟨m', hm', k', hk', htail'⟩ :=
    exists_complete_selected_dyadic_tail_of_pair_of_unboundedOrder
      n' hnData.1 hnData.2 c hc hratio' qden hqden T' Tconj'
        hsum htotal' q hqpos hq hunb
  let l : ℕ → ℕ := fun s => complementPositionSequence k (k' s)
  have hlmono : StrictMono l :=
    (complementPositionSequence_strictMono k hinf).comp hk'
  refine ⟨m', hm', l, hlmono, ?_, ?_⟩
  · intro s
    simpa [l, n', deletePositionSubsequence] using htail' s
  · intro s
    exact complementPositionSequence_not_mem_range k hinf (k' s)

end Research

/-!
# Packing selected positions inside one multiplicative doubling window
-/

namespace Research

/-- If `c^q≥2`, at most `q` selected values can lie in any half-open window
`[M,2M)`. -/
theorem card_positions_in_doubling_window_le
    (n : ℕ → ℕ) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ i, c * (n i : ℝ) ≤ n (i + 1))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (M : ℕ) (hM : 0 < M) (J : Finset ℕ)
    (hJ : ∀ i ∈ J, M ≤ n i ∧ n i < 2 * M) :
    J.card ≤ q := by
  by_contra hcard
  have hqcard : q < J.card := by omega
  have hJne : J.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro he
    rw [he] at hqcard
    simp at hqcard
  let lo := J.min' hJne
  let hi := J.max' hJne
  have hloMem : lo ∈ J := Finset.min'_mem J hJne
  have hhiMem : hi ∈ J := Finset.max'_mem J hJne
  have hsubset : J ⊆ Finset.Icc lo hi := by
    intro i hiJ
    exact Finset.mem_Icc.mpr
      ⟨Finset.min'_le J i hiJ, Finset.le_max' J i hiJ⟩
  have hcardInterval := Finset.card_le_card hsubset
  have hqspan : lo + q ≤ hi := by
    have hlohi : lo ≤ hi := Finset.min'_le J hi hhiMem
    rw [Nat.card_Icc] at hcardInterval
    omega
  have hgrowth := ratio_gap_geometric_growth_from
    n c (le_trans (by norm_num : (0 : ℝ) ≤ 1) hc.le) hratio lo q
  have hnmono : n (lo + q) ≤ n hi := hmono.monotone hqspan
  have hnmonoR : (n (lo + q) : ℝ) ≤ n hi := by exact_mod_cast hnmono
  have hloWindow := (hJ lo hloMem).1
  have hhiWindow := (hJ hi hhiMem).2
  have hloWindowR : (M : ℝ) ≤ n lo := by exact_mod_cast hloWindow
  have hhiWindowR : (n hi : ℝ) < 2 * M := by exact_mod_cast hhiWindow
  have hcq0 : 0 ≤ c ^ q := pow_nonneg (le_trans (by norm_num) hc.le) _
  have hchain : (2 : ℝ) * M ≤ c ^ q * n lo := by
    calc
      (2 : ℝ) * M ≤ c ^ q * M := by gcongr
      _ ≤ c ^ q * n lo := by gcongr
  linarith [hchain, hgrowth, hnmonoR, hhiWindowR]

end Research


/-!
# Packing pairwise-disjoint complete dyadic tails
-/

namespace Research

/-- Every positive dyadic ray whose root is at most `M` has a unique first
point in the half-open doubling window `[M,2M)`.  Only existence is needed
here. -/
theorem exists_dyadic_ray_point_in_window
    (m M : ℕ) (hm : 0 < m) (hmM : m ≤ M) :
    ∃ s : ℕ, M ≤ m * 2 ^ s ∧ m * 2 ^ s < 2 * M := by
  have hex : ∃ s : ℕ, M ≤ m * 2 ^ s := by
    obtain ⟨s, hs⟩ :=
      pow_unbounded_of_one_lt M (by norm_num : (1 : ℕ) < 2)
    refine ⟨s, ?_⟩
    have hpow : 2 ^ s ≤ m * 2 ^ s := by
      simpa using Nat.mul_le_mul_right (2 ^ s) hm
    exact hs.le.trans hpow
  let s := Nat.find hex
  have hsLower : M ≤ m * 2 ^ s := Nat.find_spec hex
  refine ⟨s, hsLower, ?_⟩
  rcases hsval : Nat.find hex with _ | t
  · have hs0 : s = 0 := by simpa [s] using hsval
    simp only [hs0, pow_zero, mul_one] at hsLower ⊢
    omega
  · have hsSucc : s = t + 1 := by simpa [s] using hsval
    have htlt : t < Nat.find hex := by rw [hsval]; omega
    have hprev : ¬ M ≤ m * 2 ^ t := Nat.find_min hex htlt
    have hprev' : m * 2 ^ t < M := Nat.lt_of_not_ge hprev
    rw [hsSucc, pow_succ]
    calc
      m * (2 ^ t * 2) = 2 * (m * 2 ^ t) := by ring
      _ < 2 * M := Nat.mul_lt_mul_of_pos_left hprev' (by omega)

/-- A ratio-gap sequence contains at most `q` pairwise position-disjoint
embedded complete dyadic tails when `c^q ≥ 2`. -/
theorem card_pairwise_disjoint_complete_dyadic_tails_le
    {ι : Type*} [Fintype ι]
    (n : ℕ → ℕ) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ i, c * (n i : ℝ) ≤ n (i + 1))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (m : ι → ℕ) (hm : ∀ a, 0 < m a)
    (k : ι → ℕ → ℕ)
    (htail : ∀ a s, n (k a s) = m a * 2 ^ s)
    (hdisj : Pairwise fun a b =>
      Disjoint (Set.range (k a)) (Set.range (k b))) :
    Fintype.card ι ≤ q := by
  classical
  cases isEmpty_or_nonempty ι with
  | inl hempty =>
      letI := hempty
      simp
  | inr hnonempty =>
      letI := hnonempty
      let M : ℕ := ∑ a : ι, m a
      have hM : 0 < M := by
        dsimp [M]
        exact Finset.sum_pos (fun a _ => hm a) Finset.univ_nonempty
      have hroot_le : ∀ a : ι, m a ≤ M := by
        intro a
        dsimp [M]
        exact Finset.single_le_sum (fun _ _ => Nat.zero_le _) (Finset.mem_univ a)
      have hscale : ∀ a : ι, ∃ s : ℕ,
          M ≤ m a * 2 ^ s ∧ m a * 2 ^ s < 2 * M := by
        intro a
        exact exists_dyadic_ray_point_in_window (m a) M (hm a) (hroot_le a)
      choose s hs using hscale
      let pos : ι → ℕ := fun a => k a (s a)
      have hposinj : Function.Injective pos := by
        intro a b hab
        by_contra hne
        have hd := hdisj hne
        change Disjoint (Set.range (k a)) (Set.range (k b)) at hd
        change k a (s a) = k b (s b) at hab
        have ha : k a (s a) ∈ Set.range (k a) := ⟨s a, rfl⟩
        have hb : k a (s a) ∈ Set.range (k b) := ⟨s b, hab.symm⟩
        exact (Set.disjoint_left.mp hd ha) hb
      let J : Finset ℕ := Finset.univ.image pos
      have hcardJ : J.card = Fintype.card ι := by
        dsimp [J]
        rw [Finset.card_image_iff.mpr hposinj.injOn]
        simp
      have hJ : ∀ i ∈ J, M ≤ n i ∧ n i < 2 * M := by
        intro i hi
        rw [Finset.mem_image] at hi
        obtain ⟨a, -, rfl⟩ := hi
        dsimp [pos]
        rw [htail]
        exact hs a
      have hpack := card_positions_in_doubling_window_le
        n hmono c hc hratio q hq M hM J hJ
      omega

end Research


/-!
# Finite iteration of complete-dyadic-tail deletion
-/

namespace Research

open Real goldenRatio

/-- One complete dyadic tail embedded in the positions of the original
sequence. -/
structure EmbeddedCompleteDyadicTail (n : ℕ → ℕ) where
  root : ℕ
  root_pos : 0 < root
  positions : ℕ → ℕ
  positions_strictMono : StrictMono positions
  values : ∀ s, n (positions s) = root * 2 ^ s

/-- A state obtained after deleting finitely many pairwise-disjoint complete
 tails.  `remainingPositions` embeds the still-infinite remainder back into the
 original sequence. -/
structure DyadicDeletionConfig (n : ℕ → ℕ) where
  remainingPositions : ℕ → ℕ
  remaining_strictMono : StrictMono remainingPositions
  tails : List (EmbeddedCompleteDyadicTail n)
  tails_pairwise : tails.Pairwise fun A B =>
    Disjoint (Set.range A.positions) (Set.range B.positions)
  remaining_avoids : ∀ t A, A ∈ tails →
    remainingPositions t ∉ Set.range A.positions
  conjugate : ℝ
  total_pair : InGoldenPair
    ((√5)⁻¹ * (∑' t : ℕ,
      (Nat.fib (n (remainingPositions t)) : ℝ)⁻¹)) conjugate

/-- The sequence represented by the infinite remainder of a deletion state. -/
def DyadicDeletionConfig.sequence {n : ℕ → ℕ}
    (cfg : DyadicDeletionConfig n) : ℕ → ℕ :=
  fun t => n (cfg.remainingPositions t)

lemma DyadicDeletionConfig.sequence_pos
    {n : ℕ → ℕ} (cfg : DyadicDeletionConfig n)
    (hpos : ∀ i, 0 < n i) :
    ∀ t, 0 < cfg.sequence t := by
  intro t
  exact hpos _

lemma DyadicDeletionConfig.sequence_strictMono
    {n : ℕ → ℕ} (cfg : DyadicDeletionConfig n)
    (hmono : StrictMono n) :
    StrictMono cfg.sequence := by
  exact hmono.comp cfg.remaining_strictMono

lemma DyadicDeletionConfig.sequence_ratioGap
    {n : ℕ → ℕ} (cfg : DyadicDeletionConfig n)
    (hmono : StrictMono n) (c : ℝ)
    (hratio : ∀ i, c * (n i : ℝ) ≤ n (i + 1)) :
    ∀ t, c * (cfg.sequence t : ℝ) ≤ cfg.sequence (t + 1) := by
  intro t
  have he : cfg.remainingPositions t + 1 ≤
      cfg.remainingPositions (t + 1) :=
    cfg.remaining_strictMono (Nat.lt_succ_self t)
  have hnle : n (cfg.remainingPositions t + 1) ≤
      n (cfg.remainingPositions (t + 1)) := hmono.monotone he
  have hnleR : (n (cfg.remainingPositions t + 1) : ℝ) ≤
      n (cfg.remainingPositions (t + 1)) := by exact_mod_cast hnle
  exact (hratio (cfg.remainingPositions t)).trans hnleR

/-- The initial state has deleted no tails. -/
def initialDyadicDeletionConfig
    (n : ℕ → ℕ) (Tconj : ℝ)
    (htotal : InGoldenPair
      ((√5)⁻¹ * (∑' i : ℕ, (Nat.fib (n i) : ℝ)⁻¹)) Tconj) :
    DyadicDeletionConfig n where
  remainingPositions := id
  remaining_strictMono := strictMono_id
  tails := []
  tails_pairwise := by simp
  remaining_avoids := by simp
  conjugate := Tconj
  total_pair := by simpa

/-- A state is terminal if its infinite remainder has bounded two-adic order,
or if one final complete tail leaves only finitely many positions. -/
def DyadicDeletionConfig.Terminal {n : ℕ → ℕ}
    (cfg : DyadicDeletionConfig n) : Prop :=
  ¬ UnboundedTwoAdicOrder cfg.sequence ∨
    ∃ m : ℕ, 0 < m ∧ ∃ k : ℕ → ℕ, StrictMono k ∧
      (∀ s, cfg.sequence (k s) = m * 2 ^ s) ∧
      {i : ℕ | i ∉ Set.range k}.Finite

/-- The finite list stored in any deletion state obeys the global packing
bound. -/
theorem DyadicDeletionConfig.tails_length_le
    {n : ℕ → ℕ} (cfg : DyadicDeletionConfig n)
    (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ i, c * (n i : ℝ) ≤ n (i + 1))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q) :
    cfg.tails.length ≤ q := by
  classical
  let getTail : Fin cfg.tails.length → EmbeddedCompleteDyadicTail n :=
    fun a => cfg.tails.get a
  have hdisj : Pairwise fun a b : Fin cfg.tails.length =>
      Disjoint (Set.range (getTail a).positions)
        (Set.range (getTail b).positions) := by
    intro a b hab
    rcases lt_or_gt_of_ne hab with hablt | hbalt
    · exact (List.pairwise_iff_get.mp cfg.tails_pairwise) a b hablt
    · exact ((List.pairwise_iff_get.mp cfg.tails_pairwise) b a hbalt).symm
  have hpack := card_pairwise_disjoint_complete_dyadic_tails_le
    n hmono c hc hratio q hq
    (fun a => (getTail a).root)
    (fun a => (getTail a).root_pos)
    (fun a => (getTail a).positions)
    (fun a s => (getTail a).values s) hdisj
  simpa using hpack

/-- From a nonterminal state with unbounded order, either the extracted tail
leaves a finite remainder (so the state is terminal), or deleting it produces
another valid state with one more stored tail. -/
theorem DyadicDeletionConfig.terminal_or_extend
    {n : ℕ → ℕ} (cfg : DyadicDeletionConfig n)
    (hpos : ∀ i, 0 < n i) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ i, c * (n i : ℝ) ≤ n (i + 1))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    cfg.Terminal ∨
      ∃ cfg' : DyadicDeletionConfig n,
        cfg'.tails.length = cfg.tails.length + 1 := by
  classical
  by_cases hunb : UnboundedTwoAdicOrder cfg.sequence
  · have hposCur := cfg.sequence_pos hpos
    have hmonoCur := cfg.sequence_strictMono hmono
    have hratioCur := cfg.sequence_ratioGap hmono c hratio
    obtain ⟨qden, hqden, hpair⟩ := cfg.total_pair
    have hsum := hasSum_selectedFibLambertCoeff cfg.sequence hposCur hmonoCur
    obtain ⟨m, hm, k, hk, htail⟩ :=
      exists_complete_selected_dyadic_tail_of_pair_of_unboundedOrder
        cfg.sequence hposCur hmonoCur c hc hratioCur
        qden hqden
        ((√5)⁻¹ * (∑' t : ℕ,
          (Nat.fib (cfg.sequence t) : ℝ)⁻¹)) cfg.conjugate
        hsum (by simpa [DyadicDeletionConfig.sequence] using hpair)
        q hqpos hq hunb
    by_cases hinf : {i : ℕ | i ∉ Set.range k}.Infinite
    · let newTail : EmbeddedCompleteDyadicTail n :=
        { root := m
          root_pos := hm
          positions := cfg.remainingPositions ∘ k
          positions_strictMono := cfg.remaining_strictMono.comp hk
          values := by
            intro s
            simpa [DyadicDeletionConfig.sequence, Function.comp_def] using htail s }
      let newRemaining : ℕ → ℕ :=
        cfg.remainingPositions ∘ complementPositionSequence k
      have hnewRemainingMono : StrictMono newRemaining :=
        cfg.remaining_strictMono.comp
          (complementPositionSequence_strictMono k hinf)
      have hnewPair := delete_complete_dyadic_tail_mem_goldenPair
        cfg.sequence k hposCur hmonoCur hinf m hm hk htail
          cfg.conjugate
          (by simpa [DyadicDeletionConfig.sequence] using cfg.total_pair)
      have hnewPair' : InGoldenPair
          ((√5)⁻¹ * (∑' t : ℕ,
            (Nat.fib (n (newRemaining t)) : ℝ)⁻¹))
          (cfg.conjugate - completeDyadicNormalizedConjugate m) := by
        simpa [newRemaining, deletePositionSubsequence,
          DyadicDeletionConfig.sequence, Function.comp_def] using hnewPair
      let cfg' : DyadicDeletionConfig n :=
        { remainingPositions := newRemaining
          remaining_strictMono := hnewRemainingMono
          tails := newTail :: cfg.tails
          tails_pairwise := by
            rw [List.pairwise_cons]
            refine ⟨?_, cfg.tails_pairwise⟩
            intro A hA
            rw [Set.disjoint_left]
            intro x hx
            rcases hx with ⟨s, rfl⟩
            exact cfg.remaining_avoids (k s) A hA
          remaining_avoids := by
            intro t A hA
            rw [List.mem_cons] at hA
            rcases hA with rfl | hA
            · intro hmem
              rcases hmem with ⟨s, hs⟩
              have heq : k s = complementPositionSequence k t :=
                cfg.remaining_strictMono.injective (by
                  simpa [newTail, newRemaining, Function.comp_def] using hs)
              exact (complementPositionSequence_not_mem_range k hinf t)
                ⟨s, heq⟩
            · exact cfg.remaining_avoids
                (complementPositionSequence k t) A hA
          conjugate := cfg.conjugate - completeDyadicNormalizedConjugate m
          total_pair := hnewPair' }
      right
      refine ⟨cfg', ?_⟩
      simp [cfg']
    · left
      right
      exact ⟨m, hm, k, hk, htail, Set.not_infinite.mp hinf⟩
  · left
    exact Or.inl hunb

/-- Finite iteration must terminate: after deleting at most the packing-bound
number of pairwise-disjoint complete tails, the remaining sequence either has
bounded two-adic order, or consists of one final complete tail plus finitely
many exceptional positions. -/
theorem exists_terminal_dyadic_deletion_config
    (n : ℕ → ℕ) (hpos : ∀ i, 0 < n i) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ i, c * (n i : ℝ) ≤ n (i + 1))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (Tconj : ℝ)
    (htotal : InGoldenPair
      ((√5)⁻¹ * (∑' i : ℕ, (Nat.fib (n i) : ℝ)⁻¹)) Tconj) :
    ∃ cfg : DyadicDeletionConfig n, cfg.Terminal := by
  classical
  let init := initialDyadicDeletionConfig n Tconj htotal
  by_contra hterminal
  have hnot : ∀ cfg : DyadicDeletionConfig n, ¬ cfg.Terminal := by
    simpa only [not_exists] using hterminal
  have hstep : ∀ cfg : DyadicDeletionConfig n,
      ∃ cfg' : DyadicDeletionConfig n,
        cfg'.tails.length = cfg.tails.length + 1 := by
    intro cfg
    rcases cfg.terminal_or_extend hpos hmono c hc hratio q hqpos hq with
      hterm | hext
    · exact False.elim (hnot cfg hterm)
    · exact hext
  let next : DyadicDeletionConfig n → DyadicDeletionConfig n :=
    fun cfg => Classical.choose (hstep cfg)
  have hnext : ∀ cfg : DyadicDeletionConfig n,
      (next cfg).tails.length = cfg.tails.length + 1 := by
    intro cfg
    exact Classical.choose_spec (hstep cfg)
  let cfgAt : ℕ → DyadicDeletionConfig n :=
    fun r => (next^[r]) init
  have hlength : ∀ r, (cfgAt r).tails.length = r := by
    intro r
    induction r with
    | zero => simp [cfgAt, init, initialDyadicDeletionConfig]
    | succ r ihr =>
        rw [show cfgAt (r + 1) = next (cfgAt r) by
          simp [cfgAt, Function.iterate_succ_apply']]
        rw [hnext, ihr]
  have hbound := (cfgAt (q + 1)).tails_length_le
    hmono c hc hratio q hq
  rw [hlength (q + 1)] at hbound
  omega

end Research


/-!
# Tail-deletion configurations which exactly cover the original positions
-/

namespace Research

open Real goldenRatio

/-- The remaining positions together with all stored deleted tails cover every
position of the original sequence.  Disjointness is already part of
`DyadicDeletionConfig`. -/
def DyadicDeletionConfig.CoversOriginal
    {n : ℕ → ℕ} (cfg : DyadicDeletionConfig n) : Prop :=
  ∀ i : ℕ,
    i ∈ Set.range cfg.remainingPositions ∨
      ∃ A ∈ cfg.tails, i ∈ Set.range A.positions

lemma initialDyadicDeletionConfig_coversOriginal
    (n : ℕ → ℕ) (Tconj : ℝ)
    (htotal : InGoldenPair
      ((√5)⁻¹ * (∑' i : ℕ, (Nat.fib (n i) : ℝ)⁻¹)) Tconj) :
    (initialDyadicDeletionConfig n Tconj htotal).CoversOriginal := by
  intro i
  left
  exact ⟨i, rfl⟩

/-- Delete one specified complete tail from a covered configuration whose
complement is infinite.  The resulting state remains covered and has one more
stored tail. -/
theorem DyadicDeletionConfig.extend_by_complete_tail
    {n : ℕ → ℕ} (cfg : DyadicDeletionConfig n)
    (hcovers : cfg.CoversOriginal)
    (hpos : ∀ i, 0 < n i) (hmono : StrictMono n)
    (m : ℕ) (hm : 0 < m) (k : ℕ → ℕ) (hk : StrictMono k)
    (htail : ∀ s, cfg.sequence (k s) = m * 2 ^ s)
    (hinf : {i : ℕ | i ∉ Set.range k}.Infinite) :
    ∃ cfg' : DyadicDeletionConfig n,
      cfg'.tails.length = cfg.tails.length + 1 ∧
      cfg'.CoversOriginal := by
  classical
  have hposCur := cfg.sequence_pos hpos
  have hmonoCur := cfg.sequence_strictMono hmono
  let newTail : EmbeddedCompleteDyadicTail n :=
    { root := m
      root_pos := hm
      positions := cfg.remainingPositions ∘ k
      positions_strictMono := cfg.remaining_strictMono.comp hk
      values := by
        intro s
        simpa [DyadicDeletionConfig.sequence, Function.comp_def] using htail s }
  let newRemaining : ℕ → ℕ :=
    cfg.remainingPositions ∘ complementPositionSequence k
  have hnewRemainingMono : StrictMono newRemaining :=
    cfg.remaining_strictMono.comp
      (complementPositionSequence_strictMono k hinf)
  have hnewPair := delete_complete_dyadic_tail_mem_goldenPair
    cfg.sequence k hposCur hmonoCur hinf m hm hk htail
      cfg.conjugate
      (by simpa [DyadicDeletionConfig.sequence] using cfg.total_pair)
  have hnewPair' : InGoldenPair
      ((√5)⁻¹ * (∑' t : ℕ,
        (Nat.fib (n (newRemaining t)) : ℝ)⁻¹))
      (cfg.conjugate - completeDyadicNormalizedConjugate m) := by
    simpa [newRemaining, deletePositionSubsequence,
      DyadicDeletionConfig.sequence, Function.comp_def] using hnewPair
  let cfg' : DyadicDeletionConfig n :=
    { remainingPositions := newRemaining
      remaining_strictMono := hnewRemainingMono
      tails := newTail :: cfg.tails
      tails_pairwise := by
        rw [List.pairwise_cons]
        refine ⟨?_, cfg.tails_pairwise⟩
        intro A hA
        rw [Set.disjoint_left]
        intro x hx
        rcases hx with ⟨s, rfl⟩
        exact cfg.remaining_avoids (k s) A hA
      remaining_avoids := by
        intro t A hA
        rw [List.mem_cons] at hA
        rcases hA with rfl | hA
        · intro hmem
          rcases hmem with ⟨s, hs⟩
          have heq : k s = complementPositionSequence k t :=
            cfg.remaining_strictMono.injective (by
              simpa [newTail, newRemaining, Function.comp_def] using hs)
          exact (complementPositionSequence_not_mem_range k hinf t)
            ⟨s, heq⟩
        · exact cfg.remaining_avoids
            (complementPositionSequence k t) A hA
      conjugate := cfg.conjugate - completeDyadicNormalizedConjugate m
      total_pair := hnewPair' }
  refine ⟨cfg', by simp [cfg'], ?_⟩
  intro i
  rcases hcovers i with hi | ⟨A, hA, hiA⟩
  · rcases hi with ⟨j, rfl⟩
    by_cases hj : j ∈ Set.range k
    · right
      refine ⟨newTail, by simp [cfg'], ?_⟩
      rcases hj with ⟨s, rfl⟩
      exact ⟨s, by simp [newTail]⟩
    · left
      have hj' : j ∈ Set.range (complementPositionSequence k) := by
        rw [range_complementPositionSequence k hinf]
        exact hj
      rcases hj' with ⟨t, rfl⟩
      exact ⟨t, by simp [cfg', newRemaining, Function.comp_def]⟩
  · right
    exact ⟨A, by simp [cfg', hA], hiA⟩

/-- The covered version of the one-step alternative. -/
theorem DyadicDeletionConfig.covered_terminal_or_extend
    {n : ℕ → ℕ} (cfg : DyadicDeletionConfig n)
    (hcovers : cfg.CoversOriginal)
    (hpos : ∀ i, 0 < n i) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ i, c * (n i : ℝ) ≤ n (i + 1))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    cfg.Terminal ∨
      ∃ cfg' : DyadicDeletionConfig n,
        cfg'.tails.length = cfg.tails.length + 1 ∧
        cfg'.CoversOriginal := by
  classical
  by_cases hunb : UnboundedTwoAdicOrder cfg.sequence
  · have hposCur := cfg.sequence_pos hpos
    have hmonoCur := cfg.sequence_strictMono hmono
    have hratioCur := cfg.sequence_ratioGap hmono c hratio
    obtain ⟨qden, hqden, hpair⟩ := cfg.total_pair
    have hsum := hasSum_selectedFibLambertCoeff cfg.sequence hposCur hmonoCur
    obtain ⟨m, hm, k, hk, htail⟩ :=
      exists_complete_selected_dyadic_tail_of_pair_of_unboundedOrder
        cfg.sequence hposCur hmonoCur c hc hratioCur
        qden hqden
        ((√5)⁻¹ * (∑' t : ℕ,
          (Nat.fib (cfg.sequence t) : ℝ)⁻¹)) cfg.conjugate
        hsum (by simpa [DyadicDeletionConfig.sequence] using hpair)
        q hqpos hq hunb
    by_cases hinf : {i : ℕ | i ∉ Set.range k}.Infinite
    · right
      exact cfg.extend_by_complete_tail hcovers hpos hmono
        m hm k hk htail hinf
    · left
      right
      exact ⟨m, hm, k, hk, htail, Set.not_infinite.mp hinf⟩
  · left
    exact Or.inl hunb

/-- The finite deletion process can be chosen to preserve exact coverage of
all original positions. -/
theorem exists_covered_terminal_dyadic_deletion_config
    (n : ℕ → ℕ) (hpos : ∀ i, 0 < n i) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ i, c * (n i : ℝ) ≤ n (i + 1))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (Tconj : ℝ)
    (htotal : InGoldenPair
      ((√5)⁻¹ * (∑' i : ℕ, (Nat.fib (n i) : ℝ)⁻¹)) Tconj) :
    ∃ cfg : DyadicDeletionConfig n,
      cfg.Terminal ∧ cfg.CoversOriginal := by
  classical
  let init := initialDyadicDeletionConfig n Tconj htotal
  have hinitCover : init.CoversOriginal := by
    exact initialDyadicDeletionConfig_coversOriginal n Tconj htotal
  by_contra hterminal
  have hnot : ∀ cfg : DyadicDeletionConfig n,
      cfg.CoversOriginal → ¬ cfg.Terminal := by
    intro cfg hcov hterm
    exact hterminal ⟨cfg, hterm, hcov⟩
  have hstep : ∀ cfg : DyadicDeletionConfig n,
      cfg.CoversOriginal →
      ∃ cfg' : DyadicDeletionConfig n,
        cfg'.tails.length = cfg.tails.length + 1 ∧
        cfg'.CoversOriginal := by
    intro cfg hcov
    rcases cfg.covered_terminal_or_extend hcov hpos hmono
      c hc hratio q hqpos hq with hterm | hext
    · exact False.elim (hnot cfg hcov hterm)
    · exact hext
  let next : DyadicDeletionConfig n → DyadicDeletionConfig n :=
    fun cfg => if hcov : cfg.CoversOriginal then
      Classical.choose (hstep cfg hcov) else cfg
  have hnext : ∀ cfg : DyadicDeletionConfig n,
      ∀ hcov : cfg.CoversOriginal,
        (next cfg).tails.length = cfg.tails.length + 1 ∧
        (next cfg).CoversOriginal := by
    intro cfg hcov
    rw [show next cfg = Classical.choose (hstep cfg hcov) by
      simp [next, hcov]]
    exact Classical.choose_spec (hstep cfg hcov)
  let cfgAt : ℕ → DyadicDeletionConfig n :=
    fun r => (next^[r]) init
  have hdata : ∀ r,
      (cfgAt r).tails.length = r ∧ (cfgAt r).CoversOriginal := by
    intro r
    induction r with
    | zero =>
        exact ⟨by simp [cfgAt, init, initialDyadicDeletionConfig], hinitCover⟩
    | succ r ihr =>
        have heq : cfgAt (r + 1) = next (cfgAt r) := by
          simp [cfgAt, Function.iterate_succ_apply']
        rw [heq]
        have hn := hnext (cfgAt r) ihr.2
        constructor
        · rw [hn.1, ihr.1]
        · exact hn.2
  have hbound := (cfgAt (q + 1)).tails_length_le
    hmono c hc hratio q hq
  rw [(hdata (q + 1)).1] at hbound
  omega

end Research


/-!
# Irrationality of the finite-remainder terminal branch
-/

namespace Research

set_option maxHeartbeats 1200000

open Real goldenRatio

/-- If a covered deletion configuration has one final complete tail with only
finitely many remaining exceptional positions, then the original reciprocal-
Fibonacci sum is irrational. -/
theorem irrational_of_covered_config_finite_remainder
    (n : ℕ → ℕ) (hpos : ∀ i, 0 < n i) (hmono : StrictMono n)
    (cfg : DyadicDeletionConfig n) (hcovers : cfg.CoversOriginal)
    (m : ℕ) (hm : 0 < m) (k : ℕ → ℕ) (hk : StrictMono k)
    (htail : ∀ s, cfg.sequence (k s) = m * 2 ^ s)
    (hfinite : {i : ℕ | i ∉ Set.range k}.Finite) :
    Irrational (∑' i : ℕ, (Nat.fib (n i) : ℝ)⁻¹) := by
  classical
  let C : Set ℕ := {i : ℕ | i ∉ Set.range k}
  letI : Fintype C := hfinite.fintype
  let getTail : Fin cfg.tails.length → EmbeddedCompleteDyadicTail n :=
    fun a => cfg.tails.get a
  let f : ℕ → ℝ := fun i => (Nat.fib (n i) : ℝ)⁻¹
  let X := (C ⊕ ℕ) ⊕ (Fin cfg.tails.length × ℕ)
  let positionMap : X → ℕ
    | Sum.inl (Sum.inl j) => cfg.remainingPositions j
    | Sum.inl (Sum.inr s) => cfg.remainingPositions (k s)
    | Sum.inr p => (getTail p.1).positions p.2
  have hstoredDisjoint : ∀ a b : Fin cfg.tails.length, a ≠ b →
      Disjoint (Set.range (getTail a).positions)
        (Set.range (getTail b).positions) := by
    intro a b hab
    rcases lt_or_gt_of_ne hab with hablt | hbalt
    · exact (List.pairwise_iff_get.mp cfg.tails_pairwise) a b hablt
    · exact ((List.pairwise_iff_get.mp cfg.tails_pairwise) b a hbalt).symm
  have hmapInj : Function.Injective positionMap := by
    intro x y hxy
    rcases x with xL | xS
    · rcases xL with xE | xF
      · rcases y with yL | yS
        · rcases yL with yE | yF
          · apply congrArg Sum.inl
            apply congrArg Sum.inl
            apply Subtype.ext
            exact cfg.remaining_strictMono.injective hxy
          · exfalso
            have heq : (xE : ℕ) = k yF :=
              cfg.remaining_strictMono.injective hxy
            exact xE.property ⟨yF, heq.symm⟩
        · exfalso
          exact (cfg.remaining_avoids xE (getTail yS.1)
            (List.get_mem cfg.tails yS.1)) ⟨yS.2, hxy.symm⟩
      · rcases y with yL | yS
        · rcases yL with yE | yF
          · exfalso
            have heq : k xF = (yE : ℕ) :=
              cfg.remaining_strictMono.injective hxy
            exact yE.property ⟨xF, heq⟩
          · apply congrArg Sum.inl
            apply congrArg Sum.inr
            exact hk.injective (cfg.remaining_strictMono.injective hxy)
        · exfalso
          exact (cfg.remaining_avoids (k xF) (getTail yS.1)
            (List.get_mem cfg.tails yS.1)) ⟨yS.2, hxy.symm⟩
    · rcases y with yL | yS
      · rcases yL with yE | yF
        · exfalso
          exact (cfg.remaining_avoids yE (getTail xS.1)
            (List.get_mem cfg.tails xS.1)) ⟨xS.2, hxy⟩
        · exfalso
          exact (cfg.remaining_avoids (k yF) (getTail xS.1)
            (List.get_mem cfg.tails xS.1)) ⟨xS.2, hxy⟩
      · rcases xS with ⟨a, s⟩
        rcases yS with ⟨b, t⟩
        by_cases hab : a = b
        · subst b
          have hst : s = t := (getTail a).positions_strictMono.injective hxy
          subst t
          rfl
        · exfalso
          have hd := hstoredDisjoint a b hab
          exact (Set.disjoint_left.mp hd
            (show (getTail a).positions s ∈ Set.range (getTail a).positions
              from ⟨s, rfl⟩)) ⟨t, hxy.symm⟩
  have hmapSurj : Function.Surjective positionMap := by
    intro i
    rcases hcovers i with hi | ⟨A, hA, hiA⟩
    · rcases hi with ⟨j, rfl⟩
      by_cases hj : j ∈ Set.range k
      · rcases hj with ⟨s, rfl⟩
        exact ⟨Sum.inl (Sum.inr s), rfl⟩
      · let jC : C := ⟨j, hj⟩
        exact ⟨Sum.inl (Sum.inl jC), rfl⟩
    · obtain ⟨a, ha⟩ := List.get_of_mem hA
      rcases hiA with ⟨s, hs⟩
      refine ⟨Sum.inr (a, s), ?_⟩
      change (getTail a).positions s = i
      rw [show getTail a = A by simpa [getTail] using ha]
      exact hs
  let e : X ≃ ℕ := Equiv.ofBijective positionMap ⟨hmapInj, hmapSurj⟩
  have hf : Summable f := by
    simpa [f] using (summable_and_tsum_shift_le n hpos hmono 0).1
  let g : X → ℝ := fun x => f (positionMap x)
  have hg : Summable g := by
    exact hf.comp_injective hmapInj
  have hgLeft : Summable (g ∘ Sum.inl) :=
    hg.comp_injective Sum.inl_injective
  have hgStored : Summable (g ∘ Sum.inr) :=
    hg.comp_injective Sum.inr_injective
  have hgExceptional : Summable ((g ∘ Sum.inl) ∘ Sum.inl) :=
    hgLeft.comp_injective Sum.inl_injective
  have hgFinal : Summable ((g ∘ Sum.inl) ∘ Sum.inr) :=
    hgLeft.comp_injective Sum.inr_injective
  have hsplitDomain :
      (∑' x : X, g x) =
        (∑' j : C, f (cfg.remainingPositions j)) +
        (∑' s : ℕ, f (cfg.remainingPositions (k s))) +
        (∑' p : Fin cfg.tails.length × ℕ,
          f ((getTail p.1).positions p.2)) := by
    have hinner := hgExceptional.hasSum.sum hgFinal.hasSum
    have houter := hinner.sum hgStored.hasSum
    simpa [g, positionMap, Function.comp_def] using houter.tsum_eq
  have horiginal :
      (∑' i : ℕ, f i) =
        (∑' j : C, f (cfg.remainingPositions j)) +
        (∑' s : ℕ, f (cfg.remainingPositions (k s))) +
        (∑' p : Fin cfg.tails.length × ℕ,
          f ((getTail p.1).positions p.2)) := by
    rw [← hsplitDomain]
    exact (e.tsum_eq f).symm
  let orbitValue (r : ℕ) : ℝ :=
    (Nat.fib r : ℝ)⁻¹ + √5 / (φ ^ (2 * r) - 1)
  have hfinalValue :
      (∑' s : ℕ, f (cfg.remainingPositions (k s))) = orbitValue m := by
    have heq : (∑' s : ℕ, f (cfg.remainingPositions (k s))) =
        ∑' s : ℕ, (Nat.fib (m * 2 ^ s) : ℝ)⁻¹ := by
      apply tsum_congr
      intro s
      have hv := htail s
      change n (cfg.remainingPositions (k s)) = m * 2 ^ s at hv
      simp only [f, hv]
    rw [heq]
    exact (hasSum_reciprocal_fib_complete_dyadic m hm).tsum_eq
  have hgStored' : Summable (fun p : Fin cfg.tails.length × ℕ =>
      f ((getTail p.1).positions p.2)) := by
    simpa [g, positionMap, Function.comp_def] using hgStored
  have hstoredValue :
      (∑' p : Fin cfg.tails.length × ℕ,
        f ((getTail p.1).positions p.2)) =
      ∑ a : Fin cfg.tails.length, orbitValue (getTail a).root := by
    rw [hgStored'.tsum_prod, tsum_fintype]
    apply Finset.sum_congr rfl
    intro a _
    have heq : (∑' s : ℕ, f ((getTail a).positions s)) =
        ∑' s : ℕ, (Nat.fib ((getTail a).root * 2 ^ s) : ℝ)⁻¹ := by
      apply tsum_congr
      intro s
      simp only [f, (getTail a).values s]
    rw [heq]
    exact (hasSum_reciprocal_fib_complete_dyadic
      (getTail a).root (getTail a).root_pos).tsum_eq
  let root : Option (Fin cfg.tails.length) → ℕ
    | none => m
    | some a => (getTail a).root
  have hrootPos : ∀ a, 0 < root a := by
    intro a
    cases a with
    | none => exact hm
    | some a => exact (getTail a).root_pos
  have hrootInj : Function.Injective root := by
    intro a b hab
    cases a with
    | none =>
        cases b with
        | none => rfl
        | some b =>
            exfalso
            have hvFinal : n (cfg.remainingPositions (k 0)) = m := by
              simpa [DyadicDeletionConfig.sequence] using htail 0
            have hvStored : n ((getTail b).positions 0) = (getTail b).root := by
              simpa using (getTail b).values 0
            have hpEq : cfg.remainingPositions (k 0) =
                (getTail b).positions 0 := hmono.injective
              (hvFinal.trans (hab.trans hvStored.symm))
            exact (cfg.remaining_avoids (k 0) (getTail b)
              (List.get_mem cfg.tails b)) ⟨0, hpEq.symm⟩
    | some a =>
        cases b with
        | none =>
            exfalso
            have hvFinal : n (cfg.remainingPositions (k 0)) = m := by
              simpa [DyadicDeletionConfig.sequence] using htail 0
            have hvStored : n ((getTail a).positions 0) = (getTail a).root := by
              simpa using (getTail a).values 0
            have hpEq : cfg.remainingPositions (k 0) =
                (getTail a).positions 0 := hmono.injective
              (hvFinal.trans (hab.symm.trans hvStored.symm))
            exact (cfg.remaining_avoids (k 0) (getTail a)
              (List.get_mem cfg.tails a)) ⟨0, hpEq.symm⟩
        | some b =>
            apply congrArg some
            by_contra hne
            have hvA : n ((getTail a).positions 0) = (getTail a).root := by
              simpa using (getTail a).values 0
            have hvB : n ((getTail b).positions 0) = (getTail b).root := by
              simpa using (getTail b).values 0
            have hpEq : (getTail a).positions 0 =
                (getTail b).positions 0 := hmono.injective
              (hvA.trans (hab.trans hvB.symm))
            have hd := hstoredDisjoint a b hne
            exact (Set.disjoint_left.mp hd
              (show (getTail a).positions 0 ∈ Set.range (getTail a).positions
                from ⟨0, rfl⟩)) ⟨0, hpEq.symm⟩
  let roots : Finset ℕ := Finset.univ.image root
  have hrootsNonempty : roots.Nonempty := by
    exact ⟨root none, Finset.mem_image.mpr ⟨none, Finset.mem_univ _, rfl⟩⟩
  have hrootsPos : ∀ r ∈ roots, 0 < r := by
    intro r hr
    obtain ⟨a, -, rfl⟩ := Finset.mem_image.mp hr
    exact hrootPos a
  have hirrRoots := irrational_finset_sum_complete_dyadic_values
    roots hrootsNonempty hrootsPos
  have hrootsSum :
      (∑ r ∈ roots, orbitValue r) =
        orbitValue m +
          ∑ a : Fin cfg.tails.length, orbitValue (getTail a).root := by
    dsimp [roots]
    rw [Finset.sum_image hrootInj.injOn]
    rw [Fintype.sum_option]
  have hirrTail : Irrational
      (orbitValue m +
        ∑ a : Fin cfg.tails.length, orbitValue (getTail a).root) := by
    rw [← hrootsSum]
    exact hirrRoots
  let qexc : ℚ := ∑ j : C,
    (Nat.fib (n (cfg.remainingPositions j)) : ℚ)⁻¹
  have hqexc : (qexc : ℝ) =
      ∑' j : C, f (cfg.remainingPositions j) := by
    rw [tsum_fintype]
    simp [qexc, f]
  rw [horiginal, hfinalValue, hstoredValue]
  rw [← hqexc]
  rw [add_assoc]
  exact hirrTail.ratCast_add qexc

end Research


/-!
# Reduction of a rational counterexample to bounded two-adic order
-/

namespace Research

open Real

/-- If the original reciprocal-Fibonacci sum is rational, finitely many
pairwise-disjoint complete dyadic tails can be deleted so that the exact-cover
infinite remainder has uniformly bounded two-adic order. -/
theorem exists_covered_boundedOrder_remainder_of_rational
    (n : ℕ → ℕ) (hpos : ∀ i, 0 < n i) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ i, c * (n i : ℝ) ≤ n (i + 1))
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (r : ℚ)
    (hrat : (∑' i : ℕ, (Nat.fib (n i) : ℝ)⁻¹) = (r : ℝ)) :
    ∃ cfg : DyadicDeletionConfig n,
      cfg.CoversOriginal ∧
      (∃ V : ℕ, ∀ K : ℕ,
        twoAdicOrder (cfg.sequence K) ≤ V) ∧
      cfg.tails.length ≤ q := by
  have hpair := rational_inv_sqrtFive_mem_goldenPair r
  have hpair' : InGoldenPair
      ((√5)⁻¹ * (∑' i : ℕ, (Nat.fib (n i) : ℝ)⁻¹))
      (-((√5)⁻¹ * (r : ℝ))) := by
    simpa [hrat] using hpair
  obtain ⟨cfg, hterm, hcov⟩ :=
    exists_covered_terminal_dyadic_deletion_config
      n hpos hmono c hc hratio q hqpos hq
      (-((√5)⁻¹ * (r : ℝ))) hpair'
  rcases hterm with hbdd | hfinite
  · have hV : ∃ V : ℕ, ∀ K : ℕ,
        twoAdicOrder (cfg.sequence K) ≤ V := by
      simpa only [UnboundedTwoAdicOrder, not_forall, not_exists, not_lt] using hbdd
    exact ⟨cfg, hcov, hV,
      cfg.tails_length_le hmono c hc hratio q hq⟩
  · obtain ⟨m, hm, k, hk, htail, hcomp⟩ := hfinite
    have hirr := irrational_of_covered_config_finite_remainder
      n hpos hmono cfg hcov m hm k hk htail hcomp
    exact False.elim (hirr.ne_rat r hrat)

end Research


/-!
# Stabilized two-adic parity in the bounded-order branch
-/

namespace Research

/-- If the two-adic order of `a` is at most that of `b`, all factors of two in
`a` lie in `gcd(a,b)`, so the reduced quotient is odd. -/
theorem odd_div_gcd_of_twoAdicOrder_le
    (a b : ℕ) (ha : 0 < a) (hb : 0 < b)
    (hle : twoAdicOrder a ≤ twoAdicOrder b) :
    Odd (a / a.gcd b) := by
  rw [← Nat.not_even_iff_odd]
  intro heven
  have htwo : 2 ∣ a / a.gcd b := even_iff_two_dvd.mp heven
  obtain ⟨z, hz⟩ := htwo
  have hgcdA : a.gcd b ∣ a := Nat.gcd_dvd_left _ _
  have haFactor : a.gcd b * (a / a.gcd b) = a :=
    Nat.mul_div_cancel' hgcdA
  have htwoGcd : 2 * b.gcd a ∣ a := by
    refine ⟨z, ?_⟩
    calc
      a = a.gcd b * (a / a.gcd b) := haFactor.symm
      _ = a.gcd b * (2 * z) := by rw [hz]
      _ = 2 * b.gcd a * z := by
        rw [Nat.gcd_comm b a]
        ring
  have hlt : twoAdicOrder b < twoAdicOrder a :=
    (two_mul_gcd_dvd_iff_twoAdicOrder_lt b a hb ha).mp htwoGcd
  omega

/-- Uniform boundedness of selected two-adic orders makes the sharp component
period orders attain a global maximum.  Once a maximizing component lies in
the prefix, every later sharp period has two-adic order at most that of the
prefix lcm. -/
theorem exists_eventually_periodOrder_le_prefixOrder
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (V : ℕ) (hV : ∀ k, twoAdicOrder (n k) ≤ V) :
    ∃ K₀ : ℕ, ∀ K : ℕ, K₀ < K →
      twoAdicOrder (fibLambertPeriod (n K)) ≤
        twoAdicOrder (sharpPrefixPeriod n K) := by
  let ord : ℕ → ℕ := fun k => twoAdicOrder (fibLambertPeriod (n k))
  have hordBound : ∀ k, ord k ≤ V + 2 := by
    intro k
    dsimp [ord]
    rw [fibLambertPeriod_twoAdicOrder (n k) (hpos k)]
    have hkV := hV k
    split_ifs
    · omega
    · omega
  have hbdd : BddAbove (Set.range ord) := by
    refine ⟨V + 2, ?_⟩
    rintro x ⟨k, rfl⟩
    exact hordBound k
  have hnonempty : (Set.range ord).Nonempty := Set.range_nonempty ord
  have hmaxMem := Nat.sSup_mem hnonempty hbdd
  obtain ⟨K₀, hK₀⟩ := hmaxMem
  refine ⟨K₀, ?_⟩
  intro K hK
  have hKleMax : ord K ≤ sSup (Set.range ord) :=
    le_csSup hbdd ⟨K, rfl⟩
  have hperiodDvd : fibLambertPeriod (n K₀) ∣
      sharpPrefixPeriod n K :=
    fibLambertPeriod_dvd_sharpPrefixPeriod n hK
  have hperiodPos : 0 < fibLambertPeriod (n K₀) := by
    unfold fibLambertPeriod
    split <;> nlinarith [hpos K₀]
  have hprefixPos : 0 < sharpPrefixPeriod n K :=
    sharpPrefixPeriod_pos n hpos K
  have horderDvd : twoAdicOrder (fibLambertPeriod (n K₀)) ≤
      twoAdicOrder (sharpPrefixPeriod n K) := by
    have hfac := (Nat.factorization_le_iff_dvd
      (Nat.ne_of_gt hperiodPos) (Nat.ne_of_gt hprefixPos)).mpr hperiodDvd
    exact hfac 2
  change ord K ≤ twoAdicOrder (sharpPrefixPeriod n K)
  calc
    ord K ≤ sSup (Set.range ord) := hKleMax
    _ = ord K₀ := hK₀.symm
    _ ≤ twoAdicOrder (sharpPrefixPeriod n K) := horderDvd

/-- Consequently, every sufficiently late sharp target has odd quotient after
removing its gcd with the sharp prefix period. -/
theorem exists_eventually_odd_reduced_sharpPeriod
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (V : ℕ) (hV : ∀ k, twoAdicOrder (n k) ≤ V) :
    ∃ K₀ : ℕ, ∀ K : ℕ, K₀ < K →
      Odd (fibLambertPeriod (n K) /
        (fibLambertPeriod (n K)).gcd (sharpPrefixPeriod n K)) := by
  obtain ⟨K₀, hK₀⟩ :=
    exists_eventually_periodOrder_le_prefixOrder n hpos V hV
  refine ⟨K₀, ?_⟩
  intro K hK
  apply odd_div_gcd_of_twoAdicOrder_le
  · unfold fibLambertPeriod
    split <;> nlinarith [hpos K]
  · exact sharpPrefixPeriod_pos n hpos K
  · exact hK₀ K hK

end Research


/-!
# Eighth-root gcd dichotomy for arbitrary quadratic totals
-/

namespace Research

open Filter Topology Real goldenRatio

/-- The intrinsic eighth-root large-gcd-or-double dichotomy holds for every
fixed scaled golden total pair, not only for a rational total. -/
theorem eventually_eighthRoot_le_prefixGcd_or_selectedDouble_of_pair
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    ∀ᶠ K : ℕ in atTop,
      2 * targetEighthRoot n K ≤
          (4 * n K).gcd (sharpPrefixPeriod n K) ∨
        ∃ j, K < j ∧ n j = 2 * n K := by
  let ε : ℝ := (((qden : ℕ) : ℝ)⁻¹) ^ 2
  have hε : 0 < ε := by dsimp [ε]; positivity
  have hevent : ∀ᶠ w : ℕ in atTop,
      2 ≤ w ∧
      (let W : ℕ := w + 1 + w
       (5184 : ℝ) * q ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < (w : ℝ) ^ 8 ∧
          (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < (W : ℝ) ^ 5) ∧
      ((φ⁻¹) ^ (w + 1) *
            (2 * cutoffTailCap (favorableWindowCutoffBound q w)) < 1 ∧
        (φ⁻¹) ^ w *
            (2 * cutoffTailCap (favorableWindowCutoffBound q w)) *
            (2 * cutoffConjugateCap Tconj
              (favorableWindowCutoffBound q w)) < ε) := by
    exact (eventually_ge_atTop 2).and
      ((eventually_polynomialDensity_window c hc q).and
        (eventually_favorableWindow_normCaps q Tconj ε hε))
  have hroot := tendsto_targetEighthRoot_atTop n hmono
  filter_upwards [hroot.eventually hevent] with K hK
  let w := targetEighthRoot n K
  change 2 * w ≤ (4 * n K).gcd (sharpPrefixPeriod n K) ∨
    ∃ j, K < j ∧ n j = 2 * n K
  by_contra hstruct
  push Not at hstruct
  rcases hstruct with ⟨hgsmall, hnoDouble⟩
  have hw : 2 ≤ w := hK.1
  have hd := hK.2.1
  have hncap := hK.2.2
  have hlow : w ^ 8 ≤ n K := targetEighthRoot_pow_le n K
  have hupp : n K ≤ (w + 1) ^ 8 :=
    (target_lt_eighthRoot_add_one_pow n K).le
  have h2w_sq : 2 * w ≤ w ^ 2 := by nlinarith
  have hsquare_eighth : w ^ 2 < w ^ 8 :=
    Nat.pow_lt_pow_right (by omega) (by norm_num)
  have hwindow : 2 * w < n K :=
    (h2w_sq.trans_lt hsquare_eighth).trans_le hlow
  obtain ⟨hfirst, hsecond⟩ := polynomialDensity_of_window_le_target
    c q w (n K) hd.1 hd.2 hlow
  obtain ⟨X, r, v, hPX, hXbound, hX, hv, _hrpos, hrlt,
      hrLeft, hrRight, hrUpper, hsRWindow⟩ :=
    exists_nearHalf_symmetric_window_package
      (sharpPrefixPeriod n K) (n K) w (hpos K) hwindow
        (by omega)
  apply favorable_explicitTarget_pair_contradiction
    n hpos hmono c hc hratio qden hqden T Tconj hsum htotal
      q hqpos hq K w X r v (by omega) hPX hXbound hX hv hrlt
      hrLeft hrRight hrUpper hsRWindow hnoDouble hfirst hsecond
  let P := sharpPrefixPeriod n K
  let W := w + 1 + w
  let B := n K * W ^ 8
  let Q := 8 * q * W
  dsimp only
  intro X' G hX' hG hdG
  let H := adaptiveLogCutoffPosition n K G B w w X' q
  have hHupper : H ≤ favorableCutoffUpper n K w q := by
    exact adaptiveLogCutoffPosition_le_favorableCutoffUpper
      n hpos K w q X' G (by omega)
        (by simpa [P] using hX')
        (by simpa [Q, W] using hG)
        (by simpa [Q, W] using hdG)
  have hUpperWindow : favorableCutoffUpper n K w q ≤
      favorableWindowCutoffBound q w :=
    favorableCutoffUpper_le_windowCutoffBound n hpos hmono K w q hupp
  exact favorable_normCaps_of_windowCutoffBound
    Tconj q w H (hHupper.trans hUpperWindow) hncap.1
      (by simpa only [ε] using hncap.2)

end Research


/-!
# Reduced sharp-period bounds in the bounded-order branch
-/

namespace Research

open Filter Real goldenRatio

/-- Multiplying one gcd input by `z` can increase the gcd by at most a factor
`z`. -/
theorem gcd_mul_left_le_mul_gcd
    (z d P : ℕ) (hz : 0 < z) (hd : 0 < d) :
    (z * d).gcd P ≤ z * d.gcd P := by
  have h₁ : P.gcd (z * d) ∣ P.gcd z * P.gcd d :=
    gcd_mul_dvd_mul_gcd P z d
  have h₂ : P.gcd z * P.gcd d ∣ z * P.gcd d :=
    Nat.mul_dvd_mul_right (Nat.gcd_dvd_right P z) (P.gcd d)
  have hdiv : (z * d).gcd P ∣ z * d.gcd P := by
    simpa [Nat.gcd_comm] using h₁.trans h₂
  have htargetPos : 0 < z * d.gcd P :=
    mul_pos hz (Nat.gcd_pos_of_pos_left P hd)
  exact Nat.le_of_dvd htargetPos hdiv

/-- In the bounded-order branch, every sufficiently late target either has an
exact selected double, or its odd reduced sharp-period quotient times the
canonical eighth-root window is at most the sharp period itself. -/
theorem eventually_double_or_odd_reducedPeriod_mul_root_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (V : ℕ) (hV : ∀ k, twoAdicOrder (n k) ≤ V) :
    ∀ᶠ K : ℕ in atTop,
      (∃ j, K < j ∧ n j = 2 * n K) ∨
      let d := fibLambertPeriod (n K)
      let Q := d / d.gcd (sharpPrefixPeriod n K)
      Odd Q ∧ Q * targetEighthRoot n K ≤ d := by
  obtain ⟨K₀, hodd⟩ :=
    exists_eventually_odd_reduced_sharpPeriod n hpos V hV
  have hoddEvent : ∀ᶠ K : ℕ in atTop,
      Odd (fibLambertPeriod (n K) /
        (fibLambertPeriod (n K)).gcd (sharpPrefixPeriod n K)) := by
    filter_upwards [eventually_gt_atTop K₀] with K hK
    exact hodd K hK
  have hdich := eventually_eighthRoot_le_prefixGcd_or_selectedDouble_of_pair
    n hpos hmono c hc hratio qden hqden T Tconj hsum htotal
      q hqpos hq
  filter_upwards [hoddEvent, hdich] with K hQodd hK
  rcases hK with hG | hdouble
  · right
    dsimp only
    let d := fibLambertPeriod (n K)
    let P := sharpPrefixPeriod n K
    let g := d.gcd P
    let w := targetEighthRoot n K
    have hdpos : 0 < d := by
      dsimp [d]
      unfold fibLambertPeriod
      split <;> nlinarith [hpos K]
    have hPpos : 0 < P := by
      dsimp [P]
      exact sharpPrefixPeriod_pos n hpos K
    have hgpos : 0 < g := by
      dsimp [g]
      exact Nat.gcd_pos_of_pos_left P hdpos
    have hGle : (4 * n K).gcd P ≤ 2 * g := by
      by_cases he : Even (n K)
      · have hd : d = 2 * n K := by simp [d, fibLambertPeriod, he]
        have hfour : 4 * n K = 2 * d := by rw [hd]; ring
        rw [hfour]
        exact gcd_mul_left_le_mul_gcd 2 d P (by omega) hdpos
      · have hd : d = 4 * n K := by simp [d, fibLambertPeriod, he]
        rw [← hd]
        dsimp [g]
        omega
    have hwg : w ≤ g := by
      change 2 * w ≤ (4 * n K).gcd P at hG
      omega
    have hgd : g ∣ d := by
      dsimp [g]
      exact Nat.gcd_dvd_left _ _
    refine ⟨by simpa [d, P, g] using hQodd, ?_⟩
    calc
      (d / g) * w ≤ (d / g) * g := Nat.mul_le_mul_left (d / g) hwg
      _ = g * (d / g) := by ring
      _ = d := Nat.mul_div_cancel' hgd
  · exact Or.inl hdouble

end Research


/-!
# No-double targets in a bounded two-adic branch
-/

namespace Research

open Filter Real goldenRatio

/-- If every target after `B` has its exact double selected later, iterating
those witnesses realizes arbitrarily large two-adic order. -/
theorem exists_large_twoAdicOrder_of_eventually_every_target_doubled
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (B : ℕ)
    (hdouble : ∀ K, B ≤ K →
      ∃ j, K < j ∧ n j = 2 * n K) :
    ∀ r : ℕ, ∃ K, B ≤ K ∧
      twoAdicOrder (n K) = twoAdicOrder (n B) + r := by
  intro r
  induction r with
  | zero => exact ⟨B, le_rfl, by simp⟩
  | succ r ihr =>
      obtain ⟨K, hBK, horder⟩ := ihr
      obtain ⟨j, hKj, hj⟩ := hdouble K hBK
      refine ⟨j, hBK.trans hKj.le, ?_⟩
      rw [hj, twoAdicOrder_two_mul (n K) (hpos K), horder]
      omega

/-- Uniformly bounded two-adic order forces arbitrarily late selected targets
whose exact double is absent from the entire later sequence. -/
theorem exists_no_selectedDouble_ge_of_boundedOrder
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (V : ℕ) (hV : ∀ k, twoAdicOrder (n k) ≤ V) :
    ∀ B : ℕ, ∃ K, B ≤ K ∧
      ∀ j, K < j → n j ≠ 2 * n K := by
  intro B
  by_contra hnone
  push Not at hnone
  have hdouble : ∀ K, B ≤ K →
      ∃ j, K < j ∧ n j = 2 * n K := by
    intro K hBK
    obtain ⟨j, hKj, hj⟩ := hnone K hBK
    exact ⟨j, hKj, hj⟩
  obtain ⟨K, _hBK, horder⟩ :=
    exists_large_twoAdicOrder_of_eventually_every_target_doubled
      n hpos B hdouble (V + 1)
  have hbound := hV K
  omega

/-- Combining F-144 with the preceding combinatorial fact yields arbitrarily
late no-double targets whose reduced sharp-period quotient is odd and obeys
the eighth-root product bound. -/
theorem exists_noDouble_odd_reducedPeriod_bound_ge
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (V : ℕ) (hV : ∀ k, twoAdicOrder (n k) ≤ V) :
    ∀ B : ℕ, ∃ K, B ≤ K ∧
      (∀ j, K < j → n j ≠ 2 * n K) ∧
      let d := fibLambertPeriod (n K)
      let Q := d / d.gcd (sharpPrefixPeriod n K)
      Odd Q ∧ Q * targetEighthRoot n K ≤ d := by
  have hevent := eventually_double_or_odd_reducedPeriod_mul_root_le
    n hpos hmono c hc hratio qden hqden T Tconj hsum htotal
      q hqpos hq V hV
  rw [eventually_atTop] at hevent
  obtain ⟨N, hN⟩ := hevent
  intro B
  obtain ⟨K, hK, hnoDouble⟩ :=
    exists_no_selectedDouble_ge_of_boundedOrder n hpos V hV (max B N)
  have hBK : B ≤ K := (le_max_left B N).trans hK
  have hNK : N ≤ K := (le_max_right B N).trans hK
  have hstruct := hN K hNK
  rcases hstruct with hdouble | hbound
  · obtain ⟨j, hKj, hj⟩ := hdouble
    exact False.elim (hnoDouble j hKj hj)
  · exact ⟨K, hBK, hnoDouble, hbound⟩

end Research


/-!
# Necessity of the parity-sensitive component period
-/

namespace Research

/-- The period `2n` for even indices and `4n` for odd indices is not merely a
usable period: it is the exact divisibility condition for a translation to fix
the entire individual coefficient pattern. -/
theorem fibLambertPeriod_dvd_iff_all_shift_eq
    (n X : ℕ) (hn : 0 < n) :
    fibLambertPeriod n ∣ X ↔
      ∀ m, fibLambertCoeff n (m + X) = fibLambertCoeff n m := by
  constructor
  · intro hdvd m
    obtain ⟨t, rfl⟩ := hdvd
    simpa [mul_comm] using fibLambertCoeff_add_period_mul_minimal n m t
  · intro hall
    by_cases he : Even n
    · have hvalue : fibLambertCoeff n (n + X) = 1 := by
        rw [hall n, fibLambertCoeff_self n hn]
      have hres : (n + X) % (2 * n) = n := by
        unfold fibLambertCoeff at hvalue
        rw [if_pos he] at hvalue
        split at hvalue
        next h => exact h
        next h => norm_num at hvalue
      have hadd : n + X ≡ n + 0 [MOD 2 * n] := by
        change (n + X) % (2 * n) = (n + 0) % (2 * n)
        calc
          (n + X) % (2 * n) = n := hres
          _ = (n + 0) % (2 * n) := by
            rw [add_zero, Nat.mod_eq_of_lt (by omega)]
      have hzero : X ≡ 0 [MOD 2 * n] :=
        (Nat.ModEq.refl n).add_left_cancel hadd
      have hd : 2 * n ∣ X := Nat.modEq_zero_iff_dvd.mp hzero
      simpa [fibLambertPeriod, he] using hd
    · have hvalue : fibLambertCoeff n (n + X) = 1 := by
        rw [hall n, fibLambertCoeff_self n hn]
      have hres : (n + X) % (4 * n) = n := by
        unfold fibLambertCoeff at hvalue
        rw [if_neg he] at hvalue
        split at hvalue
        next h => exact h
        next h₁ =>
          split at hvalue
          next h₃ => norm_num at hvalue
          next h₃ => norm_num at hvalue
      have hadd : n + X ≡ n + 0 [MOD 4 * n] := by
        change (n + X) % (4 * n) = (n + 0) % (4 * n)
        calc
          (n + X) % (4 * n) = n := hres
          _ = (n + 0) % (4 * n) := by
            rw [add_zero, Nat.mod_eq_of_lt (by omega)]
      have hzero : X ≡ 0 [MOD 4 * n] :=
        (Nat.ModEq.refl n).add_left_cancel hadd
      have hd : 4 * n ∣ X := Nat.modEq_zero_iff_dvd.mp hzero
      simpa [fibLambertPeriod, he] using hd

/-- Equivalently, if the sharp period does not divide a shift, some coefficient
of that individual component changes. -/
theorem exists_fibLambertCoeff_ne_of_period_not_dvd
    (n X : ℕ) (hn : 0 < n)
    (hndvd : ¬ fibLambertPeriod n ∣ X) :
    ∃ m, fibLambertCoeff n (m + X) ≠ fibLambertCoeff n m := by
  by_contra hnone
  push Not at hnone
  exact hndvd ((fibLambertPeriod_dvd_iff_all_shift_eq n X hn).mpr hnone)

end Research


/-!
# The only two distinct components sharing one sharp period
-/

namespace Research

/-- Aggregate of the odd component rooted at `a` and its even double.  These
are the only two distinct indices that can have the same sharp period `4a`. -/
def oddDoublePairCoeff (a m : ℕ) : ℤ :=
  fibLambertCoeff a m + fibLambertCoeff (2 * a) m

/-- Exact four-symbol word of the odd/double pair on multiples of `a`. -/
theorem oddDoublePairCoeff_mul
    (a q : ℕ) (ha : 0 < a) (haodd : ¬ Even a) :
    oddDoublePairCoeff a (a * q) =
      if q % 4 = 1 then 1 else if q % 4 = 2 then 1
      else if q % 4 = 3 then -1 else 0 := by
  have heven : Even (2 * a) := ⟨a, by ring⟩
  have hmod : (a * q) % (4 * a) = a * (q % 4) := by
    rw [show 4 * a = a * 4 by ring, Nat.mul_mod_mul_left]
  unfold oddDoublePairCoeff fibLambertCoeff
  rw [if_neg haodd, if_pos heven]
  rw [show 2 * (2 * a) = 4 * a by ring, hmod]
  have hq4 : q % 4 < 4 := Nat.mod_lt _ (by norm_num)
  interval_cases h : q % 4 <;> simp <;> omega

/-- The odd/double pair still has exact minimal period `4a`; its two components
cannot cancel their shared sharp period. -/
theorem four_mul_dvd_iff_oddDoublePair_all_shift_eq
    (a X : ℕ) (ha : 0 < a) (haodd : ¬ Even a) :
    4 * a ∣ X ↔ ∀ m, oddDoublePairCoeff a (m + X) = oddDoublePairCoeff a m := by
  constructor
  · intro hdvd m
    obtain ⟨t, rfl⟩ := hdvd
    unfold oddDoublePairCoeff
    congr 1
    · simpa [fibLambertPeriod, haodd, mul_comm] using
        fibLambertCoeff_add_period_mul_minimal a m t
    · have heven : Even (2 * a) := ⟨a, by ring⟩
      have hp := fibLambertCoeff_add_period_mul_minimal (2 * a) m t
      rw [fibLambertPeriod, if_pos heven] at hp
      convert hp using 1
      ring_nf
  · intro hall
    have haX : a ∣ X := by
      by_contra hndvd
      have hnotA : ¬ a ∣ a + X := by
        intro hd
        have hsum : a ∣ X + a := by simpa [add_comm] using hd
        exact hndvd ((Nat.dvd_add_iff_left (dvd_refl a)).mpr hsum)
      have hnotTwoA : ¬ 2 * a ∣ a + X := by
        intro hd
        have hd' : a * 2 ∣ a + X := by simpa [mul_comm] using hd
        exact hnotA (dvd_trans (dvd_mul_right a 2) hd')
      have hzero₁ : oddDoublePairCoeff a (a + X) = 0 := by
        unfold oddDoublePairCoeff
        rw [fibLambertCoeff_eq_zero_of_not_dvd _ _ hnotA,
          fibLambertCoeff_eq_zero_of_not_dvd _ _ hnotTwoA]
        norm_num
      have hroot : oddDoublePairCoeff a a = 1 := by
        unfold oddDoublePairCoeff
        rw [fibLambertCoeff_self a ha,
          fibLambertCoeff_eq_zero_of_not_dvd]
        · norm_num
        · intro hd
          have hle := Nat.le_of_dvd ha hd
          omega
      have := hall a
      rw [hzero₁, hroot] at this
      norm_num at this
    obtain ⟨t, rfl⟩ := haX
    have h₁ := hall a
    have h₂ := hall (2 * a)
    have hroot₁ : oddDoublePairCoeff a a = 1 := by
      simpa using oddDoublePairCoeff_mul a 1 ha haodd
    have hroot₂ : oddDoublePairCoeff a (2 * a) = 1 := by
      simpa [mul_comm] using oddDoublePairCoeff_mul a 2 ha haodd
    rw [show a + a * t = a * (t + 1) by ring,
      oddDoublePairCoeff_mul a (t + 1) ha haodd, hroot₁] at h₁
    rw [show 2 * a + a * t = a * (t + 2) by ring,
      oddDoublePairCoeff_mul a (t + 2) ha haodd, hroot₂] at h₂
    have ht4 : t % 4 = 0 := by
      have hrem := Nat.mod_lt t (by norm_num : 0 < 4)
      interval_cases h : t % 4 <;> simp [Nat.add_mod, h] at h₁ h₂ ⊢
    obtain ⟨u, hu⟩ := Nat.dvd_of_mod_eq_zero ht4
    use u
    rw [hu]
    ring

end Research


/-!
# Fibers of the sharp-period map
-/

namespace Research

/-- Two positive indices have the same sharp coefficient period only when they
are equal or form the odd/double pair from F-068. -/
theorem fibLambertPeriod_eq_iff
    (a b : ℕ) (ha : 0 < a) (hb : 0 < b) :
    fibLambertPeriod a = fibLambertPeriod b ↔
      a = b ∨ (¬ Even a ∧ b = 2 * a) ∨ (¬ Even b ∧ a = 2 * b) := by
  constructor
  · intro hper
    by_cases hea : Even a
    · by_cases heb : Even b
      · left
        simp [fibLambertPeriod, hea, heb] at hper
        omega
      · right
        right
        refine ⟨heb, ?_⟩
        simp [fibLambertPeriod, hea, heb] at hper
        omega
    · by_cases heb : Even b
      · right
        left
        refine ⟨hea, ?_⟩
        simp [fibLambertPeriod, hea, heb] at hper
        omega
      · left
        simp [fibLambertPeriod, hea, heb] at hper
        omega
  · rintro (rfl | ⟨haodd, rfl⟩ | ⟨hbodd, rfl⟩)
    · rfl
    · have heven : Even (2 * a) := ⟨a, by ring⟩
      simp [fibLambertPeriod, haodd, heven]
      ring
    · have heven : Even (2 * b) := ⟨b, by ring⟩
      simp [fibLambertPeriod, hbodd, heven]
      ring

/-- Every sharp-period fiber on positive indices has at most two elements. -/
theorem card_filter_fibLambertPeriod_eq_le_two
    (S : Finset ℕ) (hpos : ∀ n ∈ S, 0 < n) (P : ℕ) :
    (S.filter fun n => fibLambertPeriod n = P).card ≤ 2 := by
  classical
  by_contra hnot
  have hlt : 2 < (S.filter fun n => fibLambertPeriod n = P).card := by omega
  rw [Finset.two_lt_card] at hlt
  obtain ⟨a, ha, b, hb, c, hc, habne, hacne, hbcne⟩ := hlt
  have haData := Finset.mem_filter.mp ha
  have hbData := Finset.mem_filter.mp hb
  have hcData := Finset.mem_filter.mp hc
  have hab := (fibLambertPeriod_eq_iff a b
    (hpos a haData.1) (hpos b hbData.1)).mp (haData.2.trans hbData.2.symm)
  have hac := (fibLambertPeriod_eq_iff a c
    (hpos a haData.1) (hpos c hcData.1)).mp (haData.2.trans hcData.2.symm)
  have heq : a = b ∨ a = c ∨ b = c := by
    rcases hab with habEq | ⟨haodd, hb2⟩ | ⟨hbodd, ha2b⟩
    · exact Or.inl habEq
    · rcases hac with hacEq | ⟨_, hc2⟩ | ⟨hcodd, ha2c⟩
      · exact Or.inr (Or.inl hacEq)
      · exact Or.inr (Or.inr (by omega))
      · exfalso
        apply haodd
        exact ⟨c, by omega⟩
    · rcases hac with hacEq | ⟨haodd, hc2⟩ | ⟨hcodd, ha2c⟩
      · exact Or.inr (Or.inl hacEq)
      · exfalso
        apply haodd
        exact ⟨b, by omega⟩
      · exact Or.inr (Or.inr (by omega))
  rcases heq with heq | heq | heq
  · exact habne heq
  · exact hacne heq
  · exact hbcne heq

end Research


/-!
# Finite Fourier tools for coefficient-period rigidity
-/

namespace Research

open scoped BigOperators ComplexConjugate

/-- Finite Fourier coefficient at frequency `ζ` over one block of length `L`. -/
noncomputable def cyclicFourier (f : ℕ → ℤ) (L : ℕ) (ζ : ℂ) : ℂ :=
  ∑ m : Fin L, (f m : ℂ) * ζ ^ (m : ℕ)

/-- Range form of the finite Fourier coefficient. -/
theorem cyclicFourier_eq_sum_range (f : ℕ → ℤ) (L : ℕ) (ζ : ℂ) :
    cyclicFourier f L ζ =
      ∑ m ∈ Finset.range L, (f m : ℂ) * ζ ^ m := by
  simpa [cyclicFourier] using
    (Fin.sum_univ_eq_sum_range (fun m => (f m : ℂ) * ζ ^ m) L)

/-- Reindex a repeated period into period position × repetition number and
factor its Fourier coefficient. -/
theorem cyclicFourier_repeat_factor
    (f : ℕ → ℤ) (s q : ℕ) (ζ : ℂ)
    (hperiod : ∀ a < s, ∀ b < q, f (a + s * b) = f a) :
    cyclicFourier f (q * s) ζ =
      (∑ a : Fin s, (f a : ℂ) * ζ ^ (a : ℕ)) *
        ∑ b : Fin q, (ζ ^ s) ^ (b : ℕ) := by
  unfold cyclicFourier
  calc
    (∑ m : Fin (q * s), (f m : ℂ) * ζ ^ (m : ℕ)) =
        ∑ z : Fin q × Fin s,
          (f (finProdFinEquiv z) : ℂ) * ζ ^ ((finProdFinEquiv z : Fin (q * s)) : ℕ) := by
      exact (Equiv.sum_comp finProdFinEquiv
        (fun m : Fin (q * s) => (f m : ℂ) * ζ ^ (m : ℕ))).symm
    _ = ∑ b : Fin q, ∑ a : Fin s,
        (f a : ℂ) * ζ ^ (a : ℕ) * (ζ ^ s) ^ (b : ℕ) := by
      rw [Fintype.sum_prod_type]
      apply Finset.sum_congr rfl
      intro b _
      apply Finset.sum_congr rfl
      intro a _
      rw [show ((finProdFinEquiv (b, a) : Fin (q * s)) : ℕ) =
          (a : ℕ) + s * (b : ℕ) by rfl,
        hperiod a a.isLt b b.isLt]
      rw [pow_add, pow_mul]
      ring
    _ = (∑ a : Fin s, (f a : ℂ) * ζ ^ (a : ℕ)) *
        ∑ b : Fin q, (ζ ^ s) ^ (b : ℕ) := by
      rw [Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro b _
      rw [Finset.sum_mul]

/-- If `ζ^L=1` but `ζ^s≠1`, every `s`-periodic contribution has zero Fourier
coefficient over length `L=q s`. -/
theorem cyclicFourier_repeat_eq_zero
    (f : ℕ → ℤ) (s q : ℕ) (ζ : ℂ)
    (hperiod : ∀ a < s, ∀ b < q, f (a + s * b) = f a)
    (hroot : ζ ^ (q * s) = 1) (hne : ζ ^ s ≠ 1) :
    cyclicFourier f (q * s) ζ = 0 := by
  rw [cyclicFourier_repeat_factor f s q ζ hperiod]
  have houter : (∑ b : Fin q, (ζ ^ s) ^ (b : ℕ)) = 0 := by
    rw [Fin.sum_univ_eq_sum_range]
    rw [geom_sum_eq hne]
    rw [← pow_mul, show s * q = q * s by ring, hroot]
    simp
  rw [houter, mul_zero]

/-- A finite sum over one period is unchanged when its starting point is
translated.  This elementary rotation lemma keeps the Fourier shift argument
independent of any particular model of the cyclic group. -/
theorem sum_range_translate_of_periodic
    {A : Type*} [AddCommGroup A] (g : ℕ → A) (L X : ℕ)
    (hperiod : ∀ m, g (m + L) = g m) :
    (∑ m ∈ Finset.range L, g (m + X)) = ∑ m ∈ Finset.range L, g m := by
  induction X with
  | zero => simp
  | succ X ih =>
      have hrotate :
          (∑ m ∈ Finset.range L, g ((m + 1) + X)) =
            ∑ m ∈ Finset.range L, g (m + X) := by
        have hleft := Finset.sum_range_succ' (fun m => g (m + X)) L
        have hright := Finset.sum_range_succ (fun m => g (m + X)) L
        have hend : g (L + X) = g X := by
          simpa [add_comm] using hperiod X
        rw [hend] at hright
        have heq :
            (∑ m ∈ Finset.range L, g ((m + 1) + X)) + g X =
              (∑ m ∈ Finset.range L, g (m + X)) + g X := by
          simpa using hleft.symm.trans hright
        exact add_right_cancel heq
      calc
        (∑ m ∈ Finset.range L, g (m + (X + 1))) =
            ∑ m ∈ Finset.range L, g ((m + 1) + X) := by
              apply Finset.sum_congr rfl
              intro m _
              congr 1
              omega
        _ = ∑ m ∈ Finset.range L, g (m + X) := hrotate
        _ = ∑ m ∈ Finset.range L, g m := ih

/-- A nonzero Fourier coefficient at a primitive `p`-th root detects every
translation period: if a sequence is both `L`-periodic and `X`-periodic, with
`p ∣ L`, then the nonvanishing coefficient forces `p ∣ X`. -/
theorem primitivePeriod_dvd_of_cyclicFourier_ne_zero
    (f : ℕ → ℤ) (L p X : ℕ) (ζ : ℂ)
    (hζ : IsPrimitiveRoot ζ p) (hpL : p ∣ L)
    (hperiodL : ∀ m, f (m + L) = f m)
    (hperiodX : ∀ m, f (m + X) = f m)
    (hne : cyclicFourier f L ζ ≠ 0) :
    p ∣ X := by
  have hζL : ζ ^ L = 1 := (hζ.pow_eq_one_iff_dvd L).2 hpL
  let g : ℕ → ℂ := fun m => (f m : ℂ) * ζ ^ m
  have hgperiod : ∀ m, g (m + L) = g m := by
    intro m
    dsimp [g]
    rw [hperiodL, pow_add, hζL, mul_one]
  have hsumShift := sum_range_translate_of_periodic g L X hgperiod
  have hcf := cyclicFourier_eq_sum_range f L ζ
  have hfactor :
      (∑ m ∈ Finset.range L, g (m + X)) =
        cyclicFourier f L ζ * ζ ^ X := by
    rw [hcf]
    rw [Finset.sum_mul]
    apply Finset.sum_congr rfl
    intro m _
    dsimp [g]
    rw [hperiodX, pow_add]
    ring
  have hsumBase :
      (∑ m ∈ Finset.range L, g m) = cyclicFourier f L ζ := by
    simpa [g] using hcf.symm
  rw [hfactor, hsumBase] at hsumShift
  have hpow : ζ ^ X = 1 := by
    apply (mul_left_cancel₀ hne)
    simpa using hsumShift
  exact (hζ.pow_eq_one_iff_dvd X).1 hpow

/-- The Fourier coefficient of an even-index Lambert component at its sharp
period consists of its single support point. -/
theorem cyclicFourier_fibLambertCoeff_even
    (n : ℕ) (hn : 0 < n) (heven : Even n) (ζ : ℂ) :
    cyclicFourier (fibLambertCoeff n) (2 * n) ζ = ζ ^ n := by
  rw [cyclicFourier_eq_sum_range]
  rw [Finset.sum_eq_single n]
  · rw [fibLambertCoeff_self n hn]
    norm_num
  · intro m hm hmn
    have hmlt : m < 2 * n := Finset.mem_range.mp hm
    have hmod : m % (2 * n) = m := Nat.mod_eq_of_lt hmlt
    simp [fibLambertCoeff, heven, hmod, hmn]
  · intro hnmem
    exact (hnmem (Finset.mem_range.mpr (by omega))).elim

/-- The Fourier coefficient of an odd-index Lambert component at its sharp
period is the difference of its two signed support points. -/
theorem cyclicFourier_fibLambertCoeff_odd
    (n : ℕ) (hn : 0 < n) (hodd : ¬ Even n) (ζ : ℂ) :
    cyclicFourier (fibLambertCoeff n) (4 * n) ζ =
      ζ ^ n - ζ ^ (3 * n) := by
  rw [cyclicFourier_eq_sum_range]
  let T : Finset ℕ := {n, 3 * n}
  have hsub : T ⊆ Finset.range (4 * n) := by
    intro m hm
    simp only [T, Finset.mem_insert, Finset.mem_singleton] at hm
    rcases hm with rfl | rfl <;> simp <;> omega
  have hsum :
      (∑ m ∈ T, (fibLambertCoeff n m : ℂ) * ζ ^ m) =
        ∑ m ∈ Finset.range (4 * n),
          (fibLambertCoeff n m : ℂ) * ζ ^ m := by
    apply Finset.sum_subset hsub
    intro m hmRange hmT
    have hmlt : m < 4 * n := Finset.mem_range.mp hmRange
    have hmod : m % (4 * n) = m := Nat.mod_eq_of_lt hmlt
    have hneN : m ≠ n := by
      intro h
      apply hmT
      simp [T, h]
    have hneThree : m ≠ 3 * n := by
      intro h
      apply hmT
      simp [T, h]
    simp [fibLambertCoeff, hodd, hmod, hneN, hneThree]
  rw [← hsum]
  have hne : n ≠ 3 * n := by omega
  have hnmod : n % (4 * n) = n := Nat.mod_eq_of_lt (by omega)
  have hthreeMod : (3 * n) % (4 * n) = 3 * n :=
    Nat.mod_eq_of_lt (by omega)
  simp [T, fibLambertCoeff, hodd, hnmod, hthreeMod, hne, hne.symm]
  ring

/-- Finite Fourier coefficients are additive in their coefficient word. -/
theorem cyclicFourier_add (f g : ℕ → ℤ) (L : ℕ) (ζ : ℂ) :
    cyclicFourier (fun m => f m + g m) L ζ =
      cyclicFourier f L ζ + cyclicFourier g L ζ := by
  unfold cyclicFourier
  rw [← Finset.sum_add_distrib]
  apply Finset.sum_congr rfl
  intro m _
  push_cast
  ring

/-- A single Lambert component has a nonzero Fourier coefficient at every
primitive root of its sharp period. -/
theorem cyclicFourier_fibLambertCoeff_ne_zero
    (n : ℕ) (hn : 0 < n) (ζ : ℂ)
    (hζ : IsPrimitiveRoot ζ (fibLambertPeriod n)) :
    cyclicFourier (fibLambertCoeff n) (fibLambertPeriod n) ζ ≠ 0 := by
  by_cases heven : Even n
  · rw [fibLambertPeriod, if_pos heven,
      cyclicFourier_fibLambertCoeff_even n hn heven]
    exact pow_ne_zero _ (hζ.ne_zero (by simp [fibLambertPeriod, heven, hn.ne']))
  · rw [fibLambertPeriod, if_neg heven,
      cyclicFourier_fibLambertCoeff_odd n hn heven]
    have hζne : ζ ≠ 0 := hζ.ne_zero (by simp [fibLambertPeriod, heven, hn.ne'])
    have hpowNe : ζ ^ (2 * n) ≠ 1 := by
      intro hpow
      have hdvd := (hζ.pow_eq_one_iff_dvd (2 * n)).1 hpow
      simp only [fibLambertPeriod, if_neg heven] at hdvd
      have hle : 4 * n ≤ 2 * n := Nat.le_of_dvd (by omega) hdvd
      omega
    rw [show 3 * n = n + 2 * n by omega, pow_add]
    intro hzero
    have hfac : ζ ^ n * (1 - ζ ^ (2 * n)) = 0 := by
      linear_combination hzero
    rcases mul_eq_zero.mp hfac with hleft | hright
    · exact (pow_ne_zero n hζne) hleft
    · exact hpowNe (sub_eq_zero.mp hright).symm

/-- Fourier coefficient of the only possible two-element sharp-period fiber. -/
theorem cyclicFourier_oddDoublePairCoeff
    (a : ℕ) (ha : 0 < a) (haodd : ¬ Even a) (ζ : ℂ) :
    cyclicFourier (oddDoublePairCoeff a) (4 * a) ζ =
      ζ ^ a + ζ ^ (2 * a) - ζ ^ (3 * a) := by
  have heven : Even (2 * a) := ⟨a, by ring⟩
  unfold oddDoublePairCoeff
  rw [cyclicFourier_add,
    cyclicFourier_fibLambertCoeff_odd a ha haodd,
    show 4 * a = 2 * (2 * a) by ring,
    cyclicFourier_fibLambertCoeff_even (2 * a) (by omega) heven]
  ring

/-- The odd/double fiber has a nonzero Fourier coefficient at a primitive root
of its common sharp period. -/
theorem cyclicFourier_oddDoublePairCoeff_ne_zero
    (a : ℕ) (ha : 0 < a) (haodd : ¬ Even a) (ζ : ℂ)
    (hζ : IsPrimitiveRoot ζ (4 * a)) :
    cyclicFourier (oddDoublePairCoeff a) (4 * a) ζ ≠ 0 := by
  rw [cyclicFourier_oddDoublePairCoeff a ha haodd]
  let w : ℂ := ζ ^ a
  have hw4 : (w ^ 2) ^ 2 = 1 := by
    calc
      (w ^ 2) ^ 2 = ζ ^ (4 * a) := by
        dsimp [w]
        rw [← pow_mul, ← pow_mul]
        congr 1
        ring
      _ = 1 := hζ.pow_eq_one
  have hw2ne : w ^ 2 ≠ 1 := by
    intro hw
    have hpow : ζ ^ (2 * a) = 1 := by
      calc
        ζ ^ (2 * a) = (ζ ^ a) ^ 2 := by
          rw [← pow_mul]
          congr 1
          ring
        _ = 1 := hw
    have hdvd := (hζ.pow_eq_one_iff_dvd (2 * a)).1 hpow
    have hle : 4 * a ≤ 2 * a := Nat.le_of_dvd (by omega) hdvd
    omega
  have hw2 : w ^ 2 = -1 :=
    (sq_eq_one_iff.mp hw4).resolve_left hw2ne
  have hw3 : w ^ 3 = -w := by
    rw [show 3 = 1 + 2 by norm_num, pow_add, pow_one, hw2]
    ring
  have hpowTwo : ζ ^ (2 * a) = w ^ 2 := by
    dsimp [w]
    rw [← pow_mul]
    congr 1
    ring
  have hpowThree : ζ ^ (3 * a) = w ^ 3 := by
    dsimp [w]
    rw [← pow_mul]
    congr 1
    ring
  rw [show ζ ^ a = w by rfl, hpowTwo, hpowThree]
  intro hzero
  have hwlin : 2 * w = 1 := by
    rw [hw2, hw3] at hzero
    linear_combination hzero
  have hcontra : (4 : ℂ) * w ^ 2 = 1 := by
    calc
      (4 : ℂ) * w ^ 2 = (2 * w) ^ 2 := by ring
      _ = 1 := by rw [hwlin]; norm_num
  rw [hw2] at hcontra
  norm_num at hcontra

/-- Aggregate Lambert coefficient word attached to a finite set of indices. -/
def finsetFibLambertCoeff (S : Finset ℕ) (m : ℕ) : ℤ :=
  ∑ n ∈ S, fibLambertCoeff n m

/-- Least common multiple of all sharp component periods in a finite set. -/
def finsetFibLambertPeriod (S : Finset ℕ) : ℕ :=
  S.lcm fibLambertPeriod

lemma fibLambertPeriod_pos {n : ℕ} (hn : 0 < n) :
    0 < fibLambertPeriod n := by
  unfold fibLambertPeriod
  split_ifs <;> omega

lemma finsetFibLambertPeriod_pos
    (S : Finset ℕ) (hpos : ∀ n ∈ S, 0 < n) :
    0 < finsetFibLambertPeriod S := by
  unfold finsetFibLambertPeriod
  rw [Nat.pos_iff_ne_zero]
  intro hzero
  rw [Finset.lcm_eq_zero_iff] at hzero
  obtain ⟨n, hnS, hnzero⟩ := hzero
  exact (fibLambertPeriod_pos (hpos n hnS)).ne' hnzero

lemma fibLambertPeriod_dvd_finsetPeriod
    {S : Finset ℕ} {n : ℕ} (hnS : n ∈ S) :
    fibLambertPeriod n ∣ finsetFibLambertPeriod S := by
  exact Finset.dvd_lcm hnS

/-- Fourier transform commutes with the finite sum over selected indices. -/
theorem cyclicFourier_finsetFibLambertCoeff
    (S : Finset ℕ) (L : ℕ) (ζ : ℂ) :
    cyclicFourier (finsetFibLambertCoeff S) L ζ =
      ∑ n ∈ S, cyclicFourier (fibLambertCoeff n) L ζ := by
  classical
  simp only [cyclicFourier_eq_sum_range, finsetFibLambertCoeff]
  push_cast
  simp only [Finset.sum_mul]
  rw [Finset.sum_comm]

/-- Any common multiple of the sharp component periods is a period of the
finite aggregate word. -/
theorem finsetFibLambertCoeff_add_commonPeriod
    (S : Finset ℕ) (L m : ℕ)
    (hdiv : ∀ n ∈ S, fibLambertPeriod n ∣ L) :
    finsetFibLambertCoeff S (m + L) = finsetFibLambertCoeff S m := by
  classical
  unfold finsetFibLambertCoeff
  apply Finset.sum_congr rfl
  intro n hnS
  obtain ⟨t, ht⟩ := hdiv n hnS
  simpa [ht, mul_comm] using
    fibLambertCoeff_add_period_mul_minimal n m t

/-- A component whose sharp period does not contain the tested primitive
frequency has zero Fourier coefficient over any common ambient period. -/
theorem cyclicFourier_fibLambertCoeff_eq_zero_of_not_dvd
    (n L q : ℕ) (ζ : ℂ)
    (hperiod : fibLambertPeriod n ∣ L)
    (hζ : IsPrimitiveRoot ζ q) (hqL : q ∣ L)
    (hnot : ¬ q ∣ fibLambertPeriod n) :
    cyclicFourier (fibLambertCoeff n) L ζ = 0 := by
  obtain ⟨r, hr⟩ := hperiod
  have hcomponent : ∀ a < fibLambertPeriod n, ∀ b < r,
      fibLambertCoeff n (a + fibLambertPeriod n * b) =
        fibLambertCoeff n a := by
    intro a ha b hb
    simpa [mul_comm] using
      fibLambertCoeff_add_period_mul_minimal n a b
  have hroot : ζ ^ (r * fibLambertPeriod n) = 1 := by
    calc
      ζ ^ (r * fibLambertPeriod n) =
          ζ ^ (fibLambertPeriod n * r) := by rw [mul_comm]
      _ = ζ ^ L := by rw [hr]
      _ = 1 := (hζ.pow_eq_one_iff_dvd L).2 hqL
  have hne : ζ ^ fibLambertPeriod n ≠ 1 := by
    intro heq
    exact hnot ((hζ.pow_eq_one_iff_dvd _).1 heq)
  rw [hr]
  simpa [mul_comm] using cyclicFourier_repeat_eq_zero
    (fibLambertCoeff n) (fibLambertPeriod n) r ζ hcomponent hroot hne

/-- Repeating a component over an ambient common period multiplies its
primitive-period Fourier coefficient by the positive repetition count. -/
theorem cyclicFourier_fibLambertCoeff_repeat
    (n r : ℕ) (ζ : ℂ)
    (hroot : ζ ^ fibLambertPeriod n = 1) :
    cyclicFourier (fibLambertCoeff n) (r * fibLambertPeriod n) ζ =
      cyclicFourier (fibLambertCoeff n) (fibLambertPeriod n) ζ * r := by
  have hcomponent : ∀ a < fibLambertPeriod n, ∀ b < r,
      fibLambertCoeff n (a + fibLambertPeriod n * b) =
        fibLambertCoeff n a := by
    intro a ha b hb
    simpa [mul_comm] using
      fibLambertCoeff_add_period_mul_minimal n a b
  rw [cyclicFourier_repeat_factor _ _ _ _ hcomponent, hroot]
  unfold cyclicFourier
  simp

/-- Every nonempty fiber of equal sharp periods has a nonzero primitive
Fourier coefficient.  F-069 reduces the fiber to a singleton or to the unique
odd/double pair, and both cases were computed above. -/
theorem cyclicFourier_periodFiber_ne_zero
    (S : Finset ℕ) (hpos : ∀ n ∈ S, 0 < n) (P : ℕ) (ζ : ℂ)
    (hζ : IsPrimitiveRoot ζ P)
    (hnonempty : ∃ n ∈ S, fibLambertPeriod n = P) :
    cyclicFourier
      (finsetFibLambertCoeff
        (S.filter fun n => fibLambertPeriod n = P)) P ζ ≠ 0 := by
  classical
  let T := S.filter fun n => fibLambertPeriod n = P
  change cyclicFourier (finsetFibLambertCoeff T) P ζ ≠ 0
  have hTcard : T.card ≤ 2 := by
    dsimp [T]
    exact card_filter_fibLambertPeriod_eq_le_two S hpos P
  obtain ⟨n, hnS, hnP⟩ := hnonempty
  have hnT : n ∈ T := by simp [T, hnS, hnP]
  have hTpos : 0 < T.card := Finset.card_pos.mpr ⟨n, hnT⟩
  have hcard : T.card = 1 ∨ T.card = 2 := by omega
  rcases hcard with hcard | hcard
  · obtain ⟨a, hTa⟩ := Finset.card_eq_one.mp hcard
    have haT : a ∈ T := by simp [hTa]
    have haData : a ∈ S ∧ fibLambertPeriod a = P := by
      simpa [T] using haT
    have hζa : IsPrimitiveRoot ζ (fibLambertPeriod a) := by
      simpa [haData.2] using hζ
    have hne := cyclicFourier_fibLambertCoeff_ne_zero
      a (hpos a haData.1) ζ hζa
    rw [hTa]
    have hfun : finsetFibLambertCoeff {a} = fibLambertCoeff a := by
      funext m
      simp [finsetFibLambertCoeff]
    rw [hfun]
    simpa [haData.2] using hne
  · obtain ⟨a, b, hab, hTab⟩ := Finset.card_eq_two.mp hcard
    have haT : a ∈ T := by simp [hTab]
    have hbT : b ∈ T := by simp [hTab]
    have haData : a ∈ S ∧ fibLambertPeriod a = P := by
      simpa [T] using haT
    have hbData : b ∈ S ∧ fibLambertPeriod b = P := by
      simpa [T] using hbT
    have hclass := (fibLambertPeriod_eq_iff a b
      (hpos a haData.1) (hpos b hbData.1)).mp
        (haData.2.trans hbData.2.symm)
    rcases hclass with heq | ⟨haodd, hb⟩ | ⟨hbodd, ha⟩
    · exact (hab heq).elim
    · subst b
      have hP : P = 4 * a := by
        rw [← haData.2]
        simp [fibLambertPeriod, haodd]
      have hpair := cyclicFourier_oddDoublePairCoeff_ne_zero
        a (hpos a haData.1) haodd ζ (by simpa [hP] using hζ)
      rw [hTab, hP]
      have hfun : finsetFibLambertCoeff {a, 2 * a} =
          oddDoublePairCoeff a := by
        funext m
        simp [finsetFibLambertCoeff, oddDoublePairCoeff,
          ne_of_gt (hpos a haData.1)]
      rw [hfun]
      exact hpair
    · subst a
      have hP : P = 4 * b := by
        rw [← hbData.2]
        simp [fibLambertPeriod, hbodd]
      have hpair := cyclicFourier_oddDoublePairCoeff_ne_zero
        b (hpos b hbData.1) hbodd ζ (by simpa [hP] using hζ)
      rw [hTab, hP]
      have hfun : finsetFibLambertCoeff {2 * b, b} =
          oddDoublePairCoeff b := by
        funext m
        simp [finsetFibLambertCoeff, oddDoublePairCoeff,
          ne_of_gt (hpos b hbData.1), add_comm]
      rw [hfun]
      exact hpair

/-- A divisibility-maximal sharp period contributes a nonzero Fourier
frequency to the entire finite aggregate.  Components not containing this
frequency vanish; maximality says every component containing it lies in the
single noncancelling equal-period fiber. -/
theorem cyclicFourier_finset_ne_zero_of_maximal_period
    (S : Finset ℕ) (hpos : ∀ n ∈ S, 0 < n) (q : ℕ) (ζ : ℂ)
    (hζ : IsPrimitiveRoot ζ q)
    (hnonempty : ∃ n ∈ S, fibLambertPeriod n = q)
    (hmax : ∀ n ∈ S, q ∣ fibLambertPeriod n →
      fibLambertPeriod n = q) :
    cyclicFourier (finsetFibLambertCoeff S)
      (finsetFibLambertPeriod S) ζ ≠ 0 := by
  classical
  let L := finsetFibLambertPeriod S
  have hLpos : 0 < L := finsetFibLambertPeriod_pos S hpos
  obtain ⟨a, haS, haPeriod⟩ := hnonempty
  have hqL : q ∣ L := by
    rw [← haPeriod]
    exact fibLambertPeriod_dvd_finsetPeriod haS
  obtain ⟨r, hr⟩ := hqL
  have hrpos : 0 < r := by
    by_contra hrnot
    have hrzero : r = 0 := by omega
    subst r
    simp at hr
    exact hLpos.ne' hr
  have hterm : ∀ n ∈ S,
      cyclicFourier (fibLambertCoeff n) L ζ =
        if fibLambertPeriod n = q then
          cyclicFourier (fibLambertCoeff n) q ζ * r else 0 := by
    intro n hnS
    split_ifs with heq
    · have hrep := cyclicFourier_fibLambertCoeff_repeat n r ζ (by
        rw [heq]
        exact hζ.pow_eq_one)
      rw [heq] at hrep
      rw [hr]
      simpa [mul_comm] using hrep
    · apply cyclicFourier_fibLambertCoeff_eq_zero_of_not_dvd
        n L q ζ
        (fibLambertPeriod_dvd_finsetPeriod hnS) hζ
        (by rw [hr]; exact dvd_mul_right q r)
      intro hdvd
      exact heq (hmax n hnS hdvd)
  have htransform :
      cyclicFourier (finsetFibLambertCoeff S) L ζ =
        cyclicFourier
          (finsetFibLambertCoeff
            (S.filter fun n => fibLambertPeriod n = q)) q ζ * r := by
    rw [cyclicFourier_finsetFibLambertCoeff]
    calc
      (∑ n ∈ S, cyclicFourier (fibLambertCoeff n) L ζ) =
          ∑ n ∈ S, if fibLambertPeriod n = q then
            cyclicFourier (fibLambertCoeff n) q ζ * r else 0 := by
              apply Finset.sum_congr rfl
              intro n hnS
              exact hterm n hnS
      _ = ∑ n ∈ (S.filter fun n => fibLambertPeriod n = q),
            cyclicFourier (fibLambertCoeff n) q ζ * r := by
              rw [Finset.sum_filter]
      _ = (∑ n ∈ (S.filter fun n => fibLambertPeriod n = q),
            cyclicFourier (fibLambertCoeff n) q ζ) * r := by
              rw [Finset.sum_mul]
      _ = cyclicFourier
          (finsetFibLambertCoeff
            (S.filter fun n => fibLambertPeriod n = q)) q ζ * r := by
              rw [cyclicFourier_finsetFibLambertCoeff]
  change cyclicFourier (finsetFibLambertCoeff S) L ζ ≠ 0
  rw [htransform]
  exact mul_ne_zero
    (cyclicFourier_periodFiber_ne_zero S hpos q ζ hζ
      ⟨a, haS, haPeriod⟩)
    (by exact_mod_cast hrpos.ne')

/-- The lcm of the parity-sensitive sharp periods is the exact translation
period of every nonempty finite aggregate (and the statement also handles the
empty set).  In particular, periods belonging to different components cannot
cancel one another. -/
theorem finsetFibLambertPeriod_dvd_iff_all_shift_eq
    (S : Finset ℕ) (hpos : ∀ n ∈ S, 0 < n) (X : ℕ) :
    finsetFibLambertPeriod S ∣ X ↔
      ∀ m, finsetFibLambertCoeff S (m + X) =
        finsetFibLambertCoeff S m := by
  classical
  constructor
  · intro hdiv m
    exact finsetFibLambertCoeff_add_commonPeriod S X m fun n hnS =>
      dvd_trans (fibLambertPeriod_dvd_finsetPeriod hnS) hdiv
  · intro hperiodX
    unfold finsetFibLambertPeriod
    apply Finset.lcm_dvd
    intro n hnS
    let U := (S.image fibLambertPeriod).filter
      (fun d => fibLambertPeriod n ∣ d)
    have hnU : fibLambertPeriod n ∈ U := by
      apply Finset.mem_filter.mpr
      exact ⟨Finset.mem_image.mpr ⟨n, hnS, rfl⟩, dvd_rfl⟩
    have hUne : U.Nonempty := ⟨fibLambertPeriod n, hnU⟩
    let q := U.max' hUne
    have hqU : q ∈ U := Finset.max'_mem U hUne
    have hqData : q ∈ S.image fibLambertPeriod ∧
        fibLambertPeriod n ∣ q := by
      simpa [U] using hqU
    obtain ⟨a, haS, haPeriod⟩ := Finset.mem_image.mp hqData.1
    have hqpos : 0 < q := by
      rw [← haPeriod]
      exact fibLambertPeriod_pos (hpos a haS)
    have hmax : ∀ j ∈ S, q ∣ fibLambertPeriod j →
        fibLambertPeriod j = q := by
      intro j hjS hqj
      have hjU : fibLambertPeriod j ∈ U := by
        apply Finset.mem_filter.mpr
        exact ⟨Finset.mem_image.mpr ⟨j, hjS, rfl⟩,
          dvd_trans hqData.2 hqj⟩
      have hjle : fibLambertPeriod j ≤ q := Finset.le_max' U _ hjU
      have hqle : q ≤ fibLambertPeriod j :=
        Nat.le_of_dvd (fibLambertPeriod_pos (hpos j hjS)) hqj
      omega
    let ζ : ℂ := Complex.exp (2 * Real.pi * Complex.I / q)
    have hζ : IsPrimitiveRoot ζ q :=
      Complex.isPrimitiveRoot_exp q hqpos.ne'
    have hqL : q ∣ finsetFibLambertPeriod S := by
      rw [← haPeriod]
      exact fibLambertPeriod_dvd_finsetPeriod haS
    have hFourier : cyclicFourier (finsetFibLambertCoeff S)
        (finsetFibLambertPeriod S) ζ ≠ 0 :=
      cyclicFourier_finset_ne_zero_of_maximal_period S hpos q ζ hζ
        ⟨a, haS, haPeriod⟩ hmax
    have hperiodL : ∀ m,
        finsetFibLambertCoeff S
          (m + finsetFibLambertPeriod S) =
            finsetFibLambertCoeff S m := fun m =>
      finsetFibLambertCoeff_add_commonPeriod S
        (finsetFibLambertPeriod S) m fun j hjS =>
          fibLambertPeriod_dvd_finsetPeriod hjS
    have hqX : q ∣ X :=
      primitivePeriod_dvd_of_cyclicFourier_ne_zero
        (finsetFibLambertCoeff S) (finsetFibLambertPeriod S) q X ζ
        hζ hqL hperiodL hperiodX hFourier
    exact dvd_trans hqData.2 hqX

/-- Equivalent exact-minimal-period formulation. -/
theorem finsetFibLambertCoeff_exact_period
    (S : Finset ℕ) (hpos : ∀ n ∈ S, 0 < n) :
    (∀ m, finsetFibLambertCoeff S
        (m + finsetFibLambertPeriod S) = finsetFibLambertCoeff S m) ∧
      ∀ X, (∀ m, finsetFibLambertCoeff S (m + X) =
        finsetFibLambertCoeff S m) → finsetFibLambertPeriod S ∣ X := by
  constructor
  · exact fun m => finsetFibLambertCoeff_add_commonPeriod S
      (finsetFibLambertPeriod S) m fun n hnS =>
        fibLambertPeriod_dvd_finsetPeriod hnS
  · intro X hX
    exact (finsetFibLambertPeriod_dvd_iff_all_shift_eq S hpos X).2 hX

end Research


/-!
# Isolating a finite dyadic completion chain as one target
-/

namespace Research

/-- The finite set of indices in the first `R` levels of a dyadic ray. -/
def dyadicChainIndexSet (n R : ℕ) : Finset ℕ :=
  (Finset.range R).image fun j => n * 2 ^ j

lemma finsetFibLambertCoeff_dyadicChainIndexSet
    (n R m : ℕ) (hn : 0 < n) :
    finsetFibLambertCoeff (dyadicChainIndexSet n R) m =
      dyadicChainCoeff n R m := by
  classical
  unfold finsetFibLambertCoeff dyadicChainIndexSet dyadicChainCoeff
  rw [Finset.sum_image]
  intro a _ b _ hab
  apply Nat.pow_right_injective (by omega : 2 ≤ 2)
  exact Nat.mul_left_cancel hn hab

lemma root_mem_dyadicChainIndexSet
    (n R : ℕ) (hR : 0 < R) :
    n ∈ dyadicChainIndexSet n R := by
  apply Finset.mem_image.mpr
  exact ⟨0, Finset.mem_range.mpr hR, by simp⟩

lemma pos_of_mem_dyadicChainIndexSet
    (n R x : ℕ) (hn : 0 < n) (hx : x ∈ dyadicChainIndexSet n R) :
    0 < x := by
  obtain ⟨j, _hj, rfl⟩ := Finset.mem_image.mp hx
  positivity

/-- A finite nonempty selected doubling chain rooted at a genuinely new sharp
period can itself be isolated by a prefix-period multiple.  The positions of
the chain need not be consecutive in the selected sequence. -/
theorem exists_dyadicChain_sandwiched_pattern_of_new_rootPeriod
    (n R P L J : ℕ) (hn : 0 < n) (hR : 0 < R)
    (hnew : ¬ fibLambertPeriod n ∣ P)
    (hL : 3 * L < n) (hJ : 3 * J < n) :
    ∃ A X : ℕ, 0 < A ∧ P ∣ X ∧ X < (4 * n) * P ∧
      (∀ s < L, dyadicChainCoeff n R (A + s + X) =
        dyadicChainCoeff n R (A + s)) ∧
      dyadicChainCoeff n R (A + L + X) ≠
        dyadicChainCoeff n R (A + L) ∧
      (∀ s < J, dyadicChainCoeff n R (A + L + 1 + s + X) =
        dyadicChainCoeff n R (A + L + 1 + s)) := by
  classical
  have hPpos : 0 < P := by
    by_contra hP
    have hP0 : P = 0 := by omega
    exact hnew (by rw [hP0]; exact dvd_zero _)
  by_cases hnP : n ∣ P
  · let S := dyadicChainIndexSet n R
    let D := finsetFibLambertPeriod S
    have hnS : n ∈ S := root_mem_dyadicChainIndexSet n R hR
    have hSpos : ∀ x ∈ S, 0 < x := by
      intro x hx
      exact pos_of_mem_dyadicChainIndexSet n R x hn hx
    have hDpos : 0 < D := finsetFibLambertPeriod_pos S hSpos
    have hpD : fibLambertPeriod n ∣ D :=
      fibLambertPeriod_dvd_finsetPeriod hnS
    have hDnot : ¬ D ∣ P := fun hDP => hnew (hpD.trans hDP)
    have hnotAll : ¬ ∀ m,
        finsetFibLambertCoeff S (m + P) =
          finsetFibLambertCoeff S m := by
      intro hall
      exact hDnot
        ((finsetFibLambertPeriod_dvd_iff_all_shift_eq S hSpos P).mpr hall)
    push Not at hnotAll
    obtain ⟨m₀, hm₀⟩ := hnotAll
    have hmismatch₀ : dyadicChainCoeff n R (m₀ + P) ≠
        dyadicChainCoeff n R m₀ := by
      simpa [S, finsetFibLambertCoeff_dyadicChainIndexSet n R _ hn] using hm₀
    have hnm₀ : n ∣ m₀ := by
      by_contra hnot
      have hnotShift : ¬n ∣ m₀ + P := by
        intro hd
        exact hnot ((Nat.dvd_add_iff_left hnP).mpr hd)
      exact hmismatch₀ (by
        rw [dyadicChainCoeff_eq_zero_of_not_dvd n R m₀ hnot,
          dyadicChainCoeff_eq_zero_of_not_dvd n R (m₀ + P) hnotShift])
    have hnPeriod : n ∣ fibLambertPeriod n := by
      unfold fibLambertPeriod
      split_ifs <;> exact dvd_mul_left n _
    have hnD : n ∣ D := hnPeriod.trans hpD
    have hchainPeriod (x : ℕ) :
        dyadicChainCoeff n R (x + D) = dyadicChainCoeff n R x := by
      have hfin := finsetFibLambertCoeff_add_commonPeriod S D x
        (fun y hy => fibLambertPeriod_dvd_finsetPeriod hy)
      simpa [S, finsetFibLambertCoeff_dyadicChainIndexSet n R _ hn] using hfin
    let m := m₀ + D
    let A := m - L
    have hmn : n ≤ m := by
      have hnDle : n ≤ D := Nat.le_of_dvd hDpos hnD
      dsimp [m]
      omega
    have hmpos : 0 < m := hn.trans_le hmn
    have hnM : n ∣ m := by
      dsimp [m]
      exact Nat.dvd_add hnm₀ hnD
    have hAL : A + L = m := by dsimp [A]; omega
    have hmismatch : dyadicChainCoeff n R (m + P) ≠
        dyadicChainCoeff n R m := by
      have hleft : dyadicChainCoeff n R (m + P) =
          dyadicChainCoeff n R (m₀ + P) := by
        rw [show m + P = (m₀ + P) + D by dsimp [m]; omega,
          hchainPeriod]
      have hright : dyadicChainCoeff n R m =
          dyadicChainCoeff n R m₀ := by
        simpa [m] using hchainPeriod m₀
      intro heq
      exact hmismatch₀ (hleft.symm.trans (heq.trans hright))
    have hnotBefore (s : ℕ) (hs : s < L) : ¬n ∣ A + s := by
      intro hd
      have hdiff : n ∣ m - (A + s) := Nat.dvd_sub hnM hd
      have heq : m - (A + s) = L - s := by dsimp [A]; omega
      rw [heq] at hdiff
      have hposDiff : 0 < L - s := by omega
      have hle := Nat.le_of_dvd hposDiff hdiff
      omega
    have hzeroBefore (s : ℕ) (hs : s < L) :
        dyadicChainCoeff n R (A + s) = 0 :=
      dyadicChainCoeff_eq_zero_of_not_dvd n R _ (hnotBefore s hs)
    have hnotAfter (s : ℕ) (hs : s < J) :
        ¬n ∣ A + L + 1 + s := by
      rw [hAL]
      intro hd
      have hdiff : n ∣ (m + (1 + s)) - m :=
        Nat.dvd_sub (by simpa [add_assoc] using hd) hnM
      have heq : (m + (1 + s)) - m = 1 + s := by omega
      rw [heq] at hdiff
      have hle := Nat.le_of_dvd (by omega : 0 < 1 + s) hdiff
      omega
    have hzeroAfter (s : ℕ) (hs : s < J) :
        dyadicChainCoeff n R (A + L + 1 + s) = 0 :=
      dyadicChainCoeff_eq_zero_of_not_dvd n R _ (hnotAfter s hs)
    refine ⟨A, P, ?_, dvd_rfl, ?_, ?_, ?_, ?_⟩
    · dsimp [A]
      omega
    · nlinarith
    · intro s hs
      have hz := hzeroBefore s hs
      have hnshift : ¬ n ∣ A + s + P := by
        rw [← Nat.dvd_add_iff_left hnP]
        exact hnotBefore s hs
      rw [hz, dyadicChainCoeff_eq_zero_of_not_dvd n R _ hnshift]
    · simpa [hAL, add_assoc] using hmismatch
    · intro s hs
      have hz := hzeroAfter s hs
      have hnshift : ¬ n ∣ A + L + 1 + s + P := by
        rw [← Nat.dvd_add_iff_left hnP]
        exact hnotAfter s hs
      rw [hz, dyadicChainCoeff_eq_zero_of_not_dvd n R _ hnshift]
  · obtain ⟨u₀, r, hr, hrLower, hrUpper⟩ :=
      exists_mul_mod_between_thirds P n hn hnP
    let u := u₀ % n
    let X := P * u
    let A := n - L
    have hu : u < n := Nat.mod_lt _ hn
    have hrX : r = X % n := by
      dsimp [X, u]
      rw [Nat.mul_mod]
      simpa [Nat.mul_mod] using hr
    have hrpos : 0 < r := by nlinarith
    have hrlt : r < n := by
      rw [hrX]
      exact Nat.mod_lt _ hn
    have hLr : L < r := by nlinarith
    have hrJ : r + J < n := by nlinarith
    have hAL : A + L = n := by dsimp [A]; omega
    have hXbound : X < (4 * n) * P := by
      dsimp [X]
      have : P * u < P * n := Nat.mul_lt_mul_of_pos_left hu hPpos
      nlinarith
    have hpreBase (s : ℕ) (hs : s < L) :
        ¬n ∣ A + s := by
      intro hd
      have hapos : 0 < A + s := by dsimp [A]; omega
      have hale : n ≤ A + s := Nat.le_of_dvd hapos hd
      dsimp [A] at hale
      omega
    have hpreShift (s : ℕ) (hs : s < L) :
        ¬n ∣ A + s + X := by
      intro hd
      have hmod0 : (A + s + X) % n = 0 := Nat.mod_eq_zero_of_dvd hd
      have htpos : 0 < r - L + s := by omega
      have htlt : r - L + s < n := by omega
      have hmod : (A + s + X) % n = r - L + s := by
        rw [Nat.add_mod, ← hrX, Nat.mod_eq_of_lt
          (show A + s < n by dsimp [A]; omega)]
        have heq : A + s + r = n + (r - L + s) := by
          dsimp [A]
          omega
        rw [heq, Nat.add_mod_left, Nat.mod_eq_of_lt htlt]
      omega
    have hpostBase (s : ℕ) (hs : s < J) :
        ¬n ∣ A + L + 1 + s := by
      rw [hAL]
      intro hd
      have hdiff : n ∣ (n + (1 + s)) - n :=
        Nat.dvd_sub (by simpa [add_assoc] using hd) (dvd_refl n)
      have heq : (n + (1 + s)) - n = 1 + s := by omega
      rw [heq] at hdiff
      have hle := Nat.le_of_dvd (by omega : 0 < 1 + s) hdiff
      omega
    have hpostShift (s : ℕ) (hs : s < J) :
        ¬n ∣ A + L + 1 + s + X := by
      intro hd
      have hmod0 := Nat.mod_eq_zero_of_dvd hd
      have htpos : 0 < r + 1 + s := by omega
      have htlt : r + 1 + s < n := by omega
      have hmod : (A + L + 1 + s + X) % n = r + 1 + s := by
        rw [hAL, Nat.add_mod, ← hrX]
        have hbaseMod : (n + 1 + s) % n = 1 + s := by
          rw [show n + 1 + s = n + (1 + s) by omega,
            Nat.add_mod_left, Nat.mod_eq_of_lt (by omega)]
        rw [hbaseMod, show 1 + s + r = r + 1 + s by omega,
          Nat.mod_eq_of_lt htlt]
      omega
    have hcenterShift : ¬n ∣ n + X := by
      intro hd
      have hmod0 := Nat.mod_eq_zero_of_dvd hd
      have hmod : (n + X) % n = r := by
        rw [Nat.add_mod_left, ← hrX]
      omega
    refine ⟨A, X, ?_, ⟨u, rfl⟩, hXbound, ?_, ?_, ?_⟩
    · dsimp [A]
      omega
    · intro s hs
      rw [dyadicChainCoeff_eq_zero_of_not_dvd n R _ (hpreShift s hs),
        dyadicChainCoeff_eq_zero_of_not_dvd n R _ (hpreBase s hs)]
    · rw [hAL, dyadicChainCoeff_at_root n R hn hR,
        dyadicChainCoeff_eq_zero_of_not_dvd n R _ hcenterShift]
      norm_num
    · intro s hs
      rw [dyadicChainCoeff_eq_zero_of_not_dvd n R _ (hpostShift s hs),
        dyadicChainCoeff_eq_zero_of_not_dvd n R _ (hpostBase s hs)]

end Research


/-!
# Compatible two-window sieving outside a finite distinguished position block
-/

namespace Research

open scoped BigOperators

/-- Coefficient contribution from an arbitrary finite set of selected
positions. -/
def selectedPositionFinsetCoeff
    (n : ℕ → ℕ) (B : Finset ℕ) (m : ℕ) : ℤ :=
  ∑ k ∈ B, fibLambertCoeff (n k) m

/-- Aggregate equality on a finite block plus componentwise equality outside
it implies equality of the full coefficient. -/
theorem selectedFibLambertCoeff_eq_of_finsetBlock_eq
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (B : Finset ℕ) (H a b : ℕ)
    (hBH : ∀ k ∈ B, k < H)
    (hblock : selectedPositionFinsetCoeff n B a =
      selectedPositionFinsetCoeff n B b)
    (hout : ∀ k, k ∉ B →
      fibLambertCoeff (n k) a = fibLambertCoeff (n k) b) :
    selectedFibLambertCoeff n a = selectedFibLambertCoeff n b := by
  let Q := max (max a b) H
  have haQ : a ≤ Q := le_trans (le_max_left _ _) (le_max_left _ _)
  have hbQ : b ≤ Q := le_trans (le_max_right _ _) (le_max_left _ _)
  have hHQ : H ≤ Q := le_max_right _ _
  have hBsub : B ⊆ Finset.range Q := by
    intro k hk
    exact Finset.mem_range.mpr ((hBH k hk).trans_le hHQ)
  rw [← prefixFibLambertCoeff_eq_selected n hpos hmono haQ,
    ← prefixFibLambertCoeff_eq_selected n hpos hmono hbQ]
  unfold prefixFibLambertCoeff
  have houtsum :
      (∑ k ∈ Finset.range Q \ B, fibLambertCoeff (n k) a) =
        ∑ k ∈ Finset.range Q \ B, fibLambertCoeff (n k) b := by
    apply Finset.sum_congr rfl
    intro k hk
    exact hout k (Finset.mem_sdiff.mp hk).2
  have hsplitA := Finset.sum_sdiff
    (f := fun k => fibLambertCoeff (n k) a) hBsub
  have hsplitB := Finset.sum_sdiff
    (f := fun k => fibLambertCoeff (n k) b) hBsub
  unfold selectedPositionFinsetCoeff at hblock
  omega

/-- Aggregate inequality on a finite block plus componentwise equality outside
it implies inequality of the full coefficient. -/
theorem selectedFibLambertCoeff_ne_of_finsetBlock_ne
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (B : Finset ℕ) (H a b : ℕ)
    (hBH : ∀ k ∈ B, k < H)
    (hblock : selectedPositionFinsetCoeff n B a ≠
      selectedPositionFinsetCoeff n B b)
    (hout : ∀ k, k ∉ B →
      fibLambertCoeff (n k) a = fibLambertCoeff (n k) b) :
    selectedFibLambertCoeff n a ≠ selectedFibLambertCoeff n b := by
  intro heq
  apply hblock
  let Q := max (max a b) H
  have haQ : a ≤ Q := le_trans (le_max_left _ _) (le_max_left _ _)
  have hbQ : b ≤ Q := le_trans (le_max_right _ _) (le_max_left _ _)
  have hHQ : H ≤ Q := le_max_right _ _
  have hBsub : B ⊆ Finset.range Q := by
    intro k hk
    exact Finset.mem_range.mpr ((hBH k hk).trans_le hHQ)
  have heq' : prefixFibLambertCoeff n Q a =
      prefixFibLambertCoeff n Q b := by
    rw [prefixFibLambertCoeff_eq_selected n hpos hmono haQ,
      prefixFibLambertCoeff_eq_selected n hpos hmono hbQ]
    exact heq
  unfold prefixFibLambertCoeff at heq'
  have houtsum :
      (∑ k ∈ Finset.range Q \ B, fibLambertCoeff (n k) a) =
        ∑ k ∈ Finset.range Q \ B, fibLambertCoeff (n k) b := by
    apply Finset.sum_congr rfl
    intro k hk
    exact hout k (Finset.mem_sdiff.mp hk).2
  have hsplitA := Finset.sum_sdiff
    (f := fun k => fibLambertCoeff (n k) a) hBsub
  have hsplitB := Finset.sum_sdiff
    (f := fun k => fibLambertCoeff (n k) b) hBsub
  unfold selectedPositionFinsetCoeff
  omega

/-- Two-window conditions whose selected position is outside the distinguished
finite block. -/
def outsideTwoWindowConditions
    (K H W : ℕ) (B : Finset ℕ) : Finset ((ℕ × ℕ) × Bool) :=
  (twoWindowConditions K H W).filter fun u => u.1.1 ∉ B

/-- Soluble outside-block conditions. -/
def compatibleOutsideTwoWindowConditions
    (n : ℕ → ℕ) (K H W A X p : ℕ) (B : Finset ℕ) :
    Finset ((ℕ × ℕ) × Bool) :=
  (outsideTwoWindowConditions K H W B).filter fun u =>
    (twoWindowModulus n u).gcd p ∣ twoWindowOffset A X u

/-- Exact compatible budget after exempting the distinguished block. -/
def compatibleOutsideTwoWindowSieveBudget
    (n : ℕ → ℕ) (K H W A X p R : ℕ) (B : Finset ℕ) : ℕ :=
  ∑ u ∈ compatibleOutsideTwoWindowConditions n K H W A X p B,
    (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1)

/-- Compatible sieving outside a finite block. -/
theorem exists_two_windows_avoiding_outside_block_compatible
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H W A X p R : ℕ) (B : Finset ℕ)
    (hA : 0 < A) (_hKH : K < H)
    (hbudget : compatibleOutsideTwoWindowSieveBudget
      n K H W A X p R B < R)
    (hcut : A + p * R + X + W < n H) :
    ∃ t < R, ∀ j, K < j → j ∉ B → ∀ s < W,
      (¬n j ∣ A + p * t + s) ∧
      (¬n j ∣ A + p * t + s + X) := by
  classical
  let I := outsideTwoWindowConditions K H W B
  let a := twoWindowOffset A X
  let q := twoWindowModulus n
  have hqI : ∀ u ∈ I, 0 < q u := by
    intro u hu
    exact hpos u.1.1
  have hbudget' :
      (∑ u ∈ I.filter (fun u => (q u).gcd p ∣ a u),
        (R / (q u / (q u).gcd p) + 1)) < R := by
    simpa [I, a, q, compatibleOutsideTwoWindowSieveBudget,
      compatibleOutsideTwoWindowConditions] using hbudget
  obtain ⟨t, htR, hav⟩ :=
    exists_avoiding_linear_divisibility_compatible I a q p R hqI hbudget'
  refine ⟨t, htR, ?_⟩
  intro j hKj hjB s hsW
  by_cases hjH : j < H
  · have hjI : j ∈ laterPositionRange K H := by
      simp [laterPositionRange, hjH, hKj]
    have hsI : s ∈ Finset.range W := Finset.mem_range.mpr hsW
    have hleft := hav ((j, s), false) (by
      simp [I, outsideTwoWindowConditions, twoWindowConditions,
        hjI, hsI, hjB])
    have hright := hav ((j, s), true) (by
      simp [I, outsideTwoWindowConditions, twoWindowConditions,
        hjI, hsI, hjB])
    dsimp [a, q, twoWindowOffset, twoWindowModulus] at hleft hright
    constructor
    · simpa [add_assoc, add_comm, add_left_comm] using hleft
    · simpa [add_assoc, add_comm, add_left_comm] using hright
  · have hHj : H ≤ j := by omega
    have hnHj : n H ≤ n j := hmono.monotone hHj
    have hleftPos : 0 < A + p * t + s := by omega
    have hrightPos : 0 < A + p * t + s + X := by omega
    have hpt : p * t ≤ p * R :=
      Nat.mul_le_mul_left p (Nat.le_of_lt htR)
    have hleftLt : A + p * t + s < n H := by omega
    have hrightLt : A + p * t + s + X < n H := by omega
    constructor
    · intro hdvd
      have hle := Nat.le_of_dvd hleftPos hdvd
      omega
    · intro hdvd
      have hle := Nat.le_of_dvd hrightPos hdvd
      omega

/-- A finite block whose component periods divide `p` is invariant under every
translation by `p*t`. -/
theorem selectedPositionFinsetCoeff_add_period_mul
    (n : ℕ → ℕ) (B : Finset ℕ) (p m t : ℕ)
    (hperiod : ∀ k ∈ B, fibLambertPeriod (n k) ∣ p) :
    selectedPositionFinsetCoeff n B (m + p * t) =
      selectedPositionFinsetCoeff n B m := by
  unfold selectedPositionFinsetCoeff
  apply Finset.sum_congr rfl
  intro k hk
  obtain ⟨z, hz⟩ := hperiod k hk
  have hp := fibLambertCoeff_add_period_mul_minimal (n k) m (z * t)
  simpa [hz, mul_assoc, mul_comm, mul_left_comm] using hp

/-- The outside-block compatible sieve transports an aggregate target pattern
to a genuine full-word sandwiched mismatch. -/
theorem exists_sandwiched_mismatch_of_finsetBlock_compatibleSieve
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H L J A X p R : ℕ) (B : Finset ℕ)
    (hA : 0 < A) (hKH : K < H)
    (hKB : K ∈ B) (hBupper : ∀ k ∈ B, k < H)
    (hprefix : ∀ k < K, fibLambertPeriod (n k) ∣ X)
    (hblockPeriod : ∀ k ∈ B, fibLambertPeriod (n k) ∣ p)
    (htargetPre : ∀ s < L,
      selectedPositionFinsetCoeff n B (A + s + X) =
        selectedPositionFinsetCoeff n B (A + s))
    (htarget : selectedPositionFinsetCoeff n B (A + L + X) ≠
      selectedPositionFinsetCoeff n B (A + L))
    (htargetPost : ∀ s < J,
      selectedPositionFinsetCoeff n B (A + L + 1 + s + X) =
        selectedPositionFinsetCoeff n B (A + L + 1 + s))
    (hbudget : compatibleOutsideTwoWindowSieveBudget n K H
      (L + 1 + J) A X p R B < R)
    (hcut : A + p * R + X + (L + 1 + J) < n H) :
    ∃ t < R,
      let N := A + p * t
      (∀ s < L, selectedFibLambertCoeff n (N + s + X) =
        selectedFibLambertCoeff n (N + s)) ∧
      selectedFibLambertCoeff n (N + L + X) ≠
        selectedFibLambertCoeff n (N + L) ∧
      (∀ s < J, selectedFibLambertCoeff n (N + L + 1 + s + X) =
        selectedFibLambertCoeff n (N + L + 1 + s)) := by
  obtain ⟨t, htR, hav⟩ :=
    exists_two_windows_avoiding_outside_block_compatible
      n hpos hmono K H (L + 1 + J) A X p R B
        hA hKH hbudget hcut
  let N := A + p * t
  have htransport (u : ℕ) :
      selectedPositionFinsetCoeff n B (N + u) =
        selectedPositionFinsetCoeff n B (A + u) := by
    have hp := selectedPositionFinsetCoeff_add_period_mul
      n B p (A + u) t hblockPeriod
    simpa [N, add_assoc, add_comm, add_left_comm] using hp
  have htransportX (u : ℕ) :
      selectedPositionFinsetCoeff n B (N + u + X) =
        selectedPositionFinsetCoeff n B (A + u + X) := by
    have hp := selectedPositionFinsetCoeff_add_period_mul
      n B p (A + u + X) t hblockPeriod
    simpa [N, add_assoc, add_comm, add_left_comm] using hp
  have hout (u : ℕ) (hu : u < L + 1 + J) (k : ℕ) (hkB : k ∉ B) :
      fibLambertCoeff (n k) (N + u + X) =
        fibLambertCoeff (n k) (N + u) := by
    by_cases hkK : k < K
    · exact prefix_component_eq_of_minimal_period n K X hprefix k hkK
    · have hKle : K ≤ k := by omega
      have hkNe : k ≠ K := fun heq => hkB (heq ▸ hKB)
      have hKk : K < k := lt_of_le_of_ne hKle (Ne.symm hkNe)
      have hz := hav k hKk hkB u hu
      rw [fibLambertCoeff_eq_zero_of_not_dvd _ _ hz.2,
        fibLambertCoeff_eq_zero_of_not_dvd _ _ hz.1]
  refine ⟨t, htR, ?_, ?_, ?_⟩
  · intro s hs
    apply selectedFibLambertCoeff_eq_of_finsetBlock_eq
      n hpos hmono B H _ _ hBupper
    · rw [htransportX, htransport]
      exact htargetPre s hs
    · exact hout s (by omega)
  · apply selectedFibLambertCoeff_ne_of_finsetBlock_ne
      n hpos hmono B H _ _ hBupper
    · rw [htransportX, htransport]
      exact htarget
    · exact hout L (by omega)
  · intro s hs
    let u := L + 1 + s
    have hcore : selectedFibLambertCoeff n (N + u + X) =
        selectedFibLambertCoeff n (N + u) := by
      apply selectedFibLambertCoeff_eq_of_finsetBlock_eq
        n hpos hmono B H _ _ hBupper
      · have hx := htransportX u
        have hb := htransport u
        calc
          selectedPositionFinsetCoeff n B (N + u + X) =
              selectedPositionFinsetCoeff n B (A + u + X) := hx
          _ = selectedPositionFinsetCoeff n B (A + u) := by
            simpa [u, add_assoc] using htargetPost s hs
          _ = selectedPositionFinsetCoeff n B (N + u) := hb.symm
      · exact hout u (by dsimp [u]; omega)
    simpa [N, u, add_assoc] using hcore

end Research


/-!
# Maximal finite selected dyadic chains in the bounded-order branch
-/

namespace Research

/-- Exact two-adic order after multiplication by a power of two. -/
theorem twoAdicOrder_mul_two_pow
    (x s : ℕ) (hx : 0 < x) :
    twoAdicOrder (x * 2 ^ s) = twoAdicOrder x + s := by
  induction s with
  | zero => simp
  | succ s ih =>
      rw [pow_succ]
      have heq : x * (2 ^ s * 2) = 2 * (x * 2 ^ s) := by ring
      rw [heq, twoAdicOrder_two_mul (x * 2 ^ s) (by positivity), ih]
      omega

/-- From any selected root in a bounded-order sequence, take all consecutive
selected dyadic levels until the first missing level.  This yields a nonempty
finite strictly increasing position family, and the next doubled value is not
selected anywhere. -/
theorem exists_maximal_selected_dyadic_chain
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (V : ℕ) (hV : ∀ k, twoAdicOrder (n k) ≤ V)
    (K : ℕ) :
    ∃ R : ℕ, 0 < R ∧ ∃ pos : Fin R → ℕ,
      StrictMono pos ∧
      (∀ h0 : 0 < R, pos ⟨0, h0⟩ = K) ∧
      (∀ j : Fin R, n (pos j) = n K * 2 ^ (j : ℕ)) ∧
      ¬∃ k : ℕ, n k = n K * 2 ^ R := by
  classical
  let Missing : ℕ → Prop := fun s => ¬∃ k : ℕ, n k = n K * 2 ^ s
  have hmissing : ∃ s, Missing s := by
    refine ⟨V + 1, ?_⟩
    rintro ⟨k, hk⟩
    have hbound := hV k
    rw [hk, twoAdicOrder_mul_two_pow (n K) (V + 1) (hpos K)] at hbound
    omega
  let R := Nat.find hmissing
  have hRmissing : Missing R := Nat.find_spec hmissing
  have hRpos : 0 < R := by
    by_contra hnot
    have hR0 : R = 0 := by omega
    apply hRmissing
    exact ⟨K, by simp [hR0]⟩
  have hselected : ∀ j : Fin R,
      ∃ k : ℕ, n k = n K * 2 ^ (j : ℕ) := by
    intro j
    have hnotMissing : ¬Missing (j : ℕ) :=
      Nat.find_min hmissing j.isLt
    exact not_not.mp hnotMissing
  choose pos hposValue using hselected
  have hposMono : StrictMono pos := by
    intro a b hab
    apply (hmono.lt_iff_lt).mp
    rw [hposValue a, hposValue b]
    exact Nat.mul_lt_mul_of_pos_left
      (Nat.pow_lt_pow_right (by omega : 1 < 2) hab) (hpos K)
  have hposZero : ∀ h0 : 0 < R, pos ⟨0, h0⟩ = K := by
    intro h0
    apply hmono.injective
    rw [hposValue]
    simp
  exact ⟨R, hRpos, pos, hposMono, hposZero, hposValue, hRmissing⟩

/-- Genuinely new roots occur arbitrarily late, and each can be enlarged to
its maximal finite selected doubling chain. -/
theorem exists_new_root_maximal_selected_dyadic_chain_after
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (V : ℕ) (hV : ∀ k, twoAdicOrder (n k) ≤ V)
    (B : ℕ) :
    ∃ K, B < K ∧
      ¬fibLambertPeriod (n K) ∣ sharpPrefixPeriod n K ∧
      ∃ R : ℕ, 0 < R ∧ ∃ pos : Fin R → ℕ,
        StrictMono pos ∧
        (∀ h0 : 0 < R, pos ⟨0, h0⟩ = K) ∧
        (∀ j : Fin R, n (pos j) = n K * 2 ^ (j : ℕ)) ∧
        ¬∃ k : ℕ, n k = n K * 2 ^ R := by
  obtain ⟨K, hBK, hnew⟩ := exists_new_sharpPeriod_after n hpos hmono B
  obtain ⟨R, hR, pos, hposMono, hposZero, hvalues, hmissing⟩ :=
    exists_maximal_selected_dyadic_chain n hpos hmono V hV K
  exact ⟨K, hBK, hnew, R, hR, pos, hposMono,
    hposZero, hvalues, hmissing⟩

end Research

/-!
# Protected two-window sieving outside a finite distinguished position block
-/

namespace Research

/-- Protected-center version of the compatible two-window sieve after all
conditions belonging to a finite distinguished position block have been
removed. -/
theorem exists_two_windows_avoiding_outside_block_protected
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H W A X p R : ℕ) (B : Finset ℕ)
    (hA : 0 < A) (_hKH : K < H)
    (C O : Finset ((ℕ × ℕ) × Bool))
    (hpartition : C ∪ O =
      compatibleOutsideTwoWindowConditions n K H W A X p B)
    (hbudget :
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p R).card)
    (hcut : A + p * R + X + W < n H) :
    ∃ t < R, ∀ j, K < j → j ∉ B → ∀ s < W,
      (¬ n j ∣ A + p * t + s) ∧
      (¬ n j ∣ A + p * t + s + X) := by
  classical
  let I := outsideTwoWindowConditions K H W B
  let a := twoWindowOffset A X
  let q := twoWindowModulus n
  have hq : ∀ u ∈ O, 0 < q u := by
    intro u _
    exact hpos u.1.1
  have hbudget' :
      (∑ u ∈ O, (R / (q u / (q u).gcd p) + 1)) <
        (protectedCandidates C a q p R).card := by
    simpa [a, q] using hbudget
  obtain ⟨t, htR, hC, hO⟩ :=
    exists_avoiding_with_protected_centers C O a q p R hq hbudget'
  have havI : ∀ u ∈ I, ¬ q u ∣ a u + p * t := by
    intro u hu
    by_cases hc : (q u).gcd p ∣ a u
    · have huComp :
          u ∈ compatibleOutsideTwoWindowConditions n K H W A X p B := by
        exact Finset.mem_filter.mpr ⟨hu, hc⟩
      have huUnion : u ∈ C ∪ O := by
        rw [hpartition]
        exact huComp
      rcases Finset.mem_union.mp huUnion with huC | huO
      · exact hC u huC
      · exact hO u huO
    · intro hdvd
      exact hc (gcd_dvd_offset_of_dvd_add_mul (a u) p (q u) t hdvd)
  refine ⟨t, htR, ?_⟩
  intro j hKj hjB s hsW
  by_cases hjH : j < H
  · have hjI : j ∈ laterPositionRange K H := by
      simp [laterPositionRange, hjH, hKj]
    have hsI : s ∈ Finset.range W := Finset.mem_range.mpr hsW
    have hleft := havI ((j, s), false) (by
      simp [I, outsideTwoWindowConditions, twoWindowConditions,
        hjI, hsI, hjB])
    have hright := havI ((j, s), true) (by
      simp [I, outsideTwoWindowConditions, twoWindowConditions,
        hjI, hsI, hjB])
    dsimp [a, q, twoWindowOffset, twoWindowModulus] at hleft hright
    constructor
    · simpa [add_assoc, add_comm, add_left_comm] using hleft
    · simpa [add_assoc, add_comm, add_left_comm] using hright
  · have hHj : H ≤ j := by omega
    have hnHj : n H ≤ n j := hmono.monotone hHj
    have hleftPos : 0 < A + p * t + s := by omega
    have hrightPos : 0 < A + p * t + s + X := by omega
    have hpt : p * t ≤ p * R :=
      Nat.mul_le_mul_left p (Nat.le_of_lt htR)
    have hleftLt : A + p * t + s < n H := by omega
    have hrightLt : A + p * t + s + X < n H := by omega
    constructor
    · intro hdvd
      have hle := Nat.le_of_dvd hleftPos hdvd
      omega
    · intro hdvd
      have hle := Nat.le_of_dvd hrightPos hdvd
      omega

/-- The outside-block protected sieve transports an aggregate finite-block
pattern to a genuine full Lambert-coefficient sandwiched mismatch. -/
theorem exists_sandwiched_mismatch_of_finsetBlock_protectedSieve
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H L J A X p R : ℕ) (B : Finset ℕ)
    (hA : 0 < A) (hKH : K < H)
    (hKB : K ∈ B) (hBupper : ∀ k ∈ B, k < H)
    (hprefix : ∀ k < K, fibLambertPeriod (n k) ∣ X)
    (hblockPeriod : ∀ k ∈ B, fibLambertPeriod (n k) ∣ p)
    (htargetPre : ∀ s < L,
      selectedPositionFinsetCoeff n B (A + s + X) =
        selectedPositionFinsetCoeff n B (A + s))
    (htarget : selectedPositionFinsetCoeff n B (A + L + X) ≠
      selectedPositionFinsetCoeff n B (A + L))
    (htargetPost : ∀ s < J,
      selectedPositionFinsetCoeff n B (A + L + 1 + s + X) =
        selectedPositionFinsetCoeff n B (A + L + 1 + s))
    (C O : Finset ((ℕ × ℕ) × Bool))
    (hpartition : C ∪ O = compatibleOutsideTwoWindowConditions n K H
      (L + 1 + J) A X p B)
    (hbudget :
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p R).card)
    (hcut : A + p * R + X + (L + 1 + J) < n H) :
    ∃ t < R,
      let N := A + p * t
      (∀ s < L, selectedFibLambertCoeff n (N + s + X) =
        selectedFibLambertCoeff n (N + s)) ∧
      selectedFibLambertCoeff n (N + L + X) ≠
        selectedFibLambertCoeff n (N + L) ∧
      (∀ s < J, selectedFibLambertCoeff n (N + L + 1 + s + X) =
        selectedFibLambertCoeff n (N + L + 1 + s)) := by
  obtain ⟨t, htR, hav⟩ :=
    exists_two_windows_avoiding_outside_block_protected
      n hpos hmono K H (L + 1 + J) A X p R B hA hKH
        C O hpartition hbudget hcut
  let N := A + p * t
  have htransport (u : ℕ) :
      selectedPositionFinsetCoeff n B (N + u) =
        selectedPositionFinsetCoeff n B (A + u) := by
    have hp := selectedPositionFinsetCoeff_add_period_mul
      n B p (A + u) t hblockPeriod
    simpa [N, add_assoc, add_comm, add_left_comm] using hp
  have htransportX (u : ℕ) :
      selectedPositionFinsetCoeff n B (N + u + X) =
        selectedPositionFinsetCoeff n B (A + u + X) := by
    have hp := selectedPositionFinsetCoeff_add_period_mul
      n B p (A + u + X) t hblockPeriod
    simpa [N, add_assoc, add_comm, add_left_comm] using hp
  have hout (u : ℕ) (hu : u < L + 1 + J) (k : ℕ) (hkB : k ∉ B) :
      fibLambertCoeff (n k) (N + u + X) =
        fibLambertCoeff (n k) (N + u) := by
    by_cases hkK : k < K
    · exact prefix_component_eq_of_minimal_period n K X hprefix k hkK
    · have hKle : K ≤ k := by omega
      have hkNe : k ≠ K := fun heq => hkB (heq ▸ hKB)
      have hKk : K < k := lt_of_le_of_ne hKle (Ne.symm hkNe)
      have hz := hav k hKk hkB u hu
      rw [fibLambertCoeff_eq_zero_of_not_dvd _ _ hz.2,
        fibLambertCoeff_eq_zero_of_not_dvd _ _ hz.1]
  refine ⟨t, htR, ?_, ?_, ?_⟩
  · intro s hs
    apply selectedFibLambertCoeff_eq_of_finsetBlock_eq
      n hpos hmono B H _ _ hBupper
    · rw [htransportX, htransport]
      exact htargetPre s hs
    · exact hout s (by omega)
  · apply selectedFibLambertCoeff_ne_of_finsetBlock_ne
      n hpos hmono B H _ _ hBupper
    · rw [htransportX, htransport]
      exact htarget
    · exact hout L (by omega)
  · intro s hs
    let u := L + 1 + s
    have hcore : selectedFibLambertCoeff n (N + u + X) =
        selectedFibLambertCoeff n (N + u) := by
      apply selectedFibLambertCoeff_eq_of_finsetBlock_eq
        n hpos hmono B H _ _ hBupper
      · have hx := htransportX u
        have hb := htransport u
        calc
          selectedPositionFinsetCoeff n B (N + u + X) =
              selectedPositionFinsetCoeff n B (A + u + X) := hx
          _ = selectedPositionFinsetCoeff n B (A + u) := by
            simpa [u, add_assoc] using htargetPost s hs
          _ = selectedPositionFinsetCoeff n B (N + u) := hb.symm
      · exact hout u (by dsimp [u]; omega)
    simpa [N, u, add_assoc] using hcore

end Research

/-!
# Protected finite-block sieve gate for an arbitrary quadratic total pair
-/

namespace Research

open Real goldenRatio

/-- The protected outside-block sieve, an aggregate finite-block target pattern,
and the quadratic norm bounds together contradict any fixed scaled golden
principal/conjugate pair. -/
theorem finsetBlock_protected_sandwiched_mismatch_pair_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (K H L J A X p R : ℕ) (B : Finset ℕ)
    (hA : 0 < A) (hKH : K < H)
    (hKB : K ∈ B) (hBupper : ∀ k ∈ B, k < H)
    (hprefix : ∀ k < K, fibLambertPeriod (n k) ∣ X)
    (hblockPeriod : ∀ k ∈ B, fibLambertPeriod (n k) ∣ p)
    (htargetPre : ∀ s < L,
      selectedPositionFinsetCoeff n B (A + s + X) =
        selectedPositionFinsetCoeff n B (A + s))
    (htarget : selectedPositionFinsetCoeff n B (A + L + X) ≠
      selectedPositionFinsetCoeff n B (A + L))
    (htargetPost : ∀ s < J,
      selectedPositionFinsetCoeff n B (A + L + 1 + s + X) =
        selectedPositionFinsetCoeff n B (A + L + 1 + s))
    (C O : Finset ((ℕ × ℕ) × Bool))
    (hpartition : C ∪ O = compatibleOutsideTwoWindowConditions n K H
      (L + 1 + J) A X p B)
    (hbudget :
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p R).card)
    (hcut : A + p * R + X + (L + 1 + J) < n H)
    (hsmallPost : ∀ t < R,
      let N := A + p * t
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (N + X + L + 1 + J)) < 1)
    (hsmallPre : ∀ t < R,
      let N := A + p * t
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (N + X + L)) *
        (indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj (N + X)) <
      (((qden : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  obtain ⟨t, htR, hpat⟩ :=
    exists_sandwiched_mismatch_of_finsetBlock_protectedSieve
      n hpos hmono K H L J A X p R B hA hKH hKB hBupper
        hprefix hblockPeriod htargetPre htarget htargetPost
        C O hpartition hbudget hcut
  let N := A + p * t
  apply selected_sandwiched_mismatch_pair_obstruction
    n hpos hmono qden hqden T Tconj hsum htotal N (N + X) L J
  · intro s hs
    simpa [N, add_assoc, add_comm, add_left_comm] using (hpat.1 s hs).symm
  · simpa [N, add_assoc, add_comm, add_left_comm] using ne_comm.mp hpat.2.1
  · intro s hs
    simpa [N, add_assoc, add_comm, add_left_comm] using (hpat.2.2 s hs).symm
  · simpa [N, add_assoc, add_comm, add_left_comm] using hsmallPost t htR
  · simpa [N, add_assoc, add_comm, add_left_comm] using hsmallPre t htR

/-- Uniform cutoff norm bounds for the finite-block gate with an arbitrary
positive progression period. -/
theorem uniform_finsetBlock_protected_pair_norm_bounds_of_cutoff
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (qden : ℕ) (Tconj : ℝ)
    (H L J A X p R : ℕ) (hp : 0 < p)
    (hcut : A + p * R + X + (L + 1 + J) < n H)
    (hpostCap :
      (φ⁻¹) ^ (J + 1) * (2 * cutoffTailCap H) < 1)
    (hpreCap :
      (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap Tconj H) <
        (((qden : ℕ) : ℝ)⁻¹) ^ 2) :
    (∀ t < R,
      let N := A + p * t
      (φ⁻¹) ^ (J + 1) *
        (indexCountTailBound n (N + L + 1 + J) +
          indexCountTailBound n (N + X + L + 1 + J)) < 1) ∧
    (∀ t < R,
      let N := A + p * t
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (N + X + L)) *
        (indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj (N + X)) <
      (((qden : ℕ) : ℝ)⁻¹) ^ 2) := by
  have htailCapNonneg := cutoffTailCap_nonneg H
  have hconjCapNonneg := cutoffConjugateCap_nonneg Tconj H
  constructor
  · intro t ht
    let N := A + p * t
    have hpt : p * t < p * R := (Nat.mul_lt_mul_left hp).mpr ht
    have hx₁ : N + L + 1 + J < n H := by dsimp [N]; omega
    have hx₂ : N + X + L + 1 + J < n H := by dsimp [N]; omega
    have hb₁ := indexCountTailBound_le_cutoffTailCap n hpos hmono hx₁
    have hb₂ := indexCountTailBound_le_cutoffTailCap n hpos hmono hx₂
    calc
      (φ⁻¹) ^ (J + 1) *
          (indexCountTailBound n (N + L + 1 + J) +
            indexCountTailBound n (N + X + L + 1 + J)) ≤
        (φ⁻¹) ^ (J + 1) * (2 * cutoffTailCap H) := by
          gcongr
          linarith
      _ < 1 := hpostCap
  · intro t ht
    let N := A + p * t
    have hpt : p * t < p * R := (Nat.mul_lt_mul_left hp).mpr ht
    have hxN : N < n H := by dsimp [N]; omega
    have hxNX : N + X < n H := by dsimp [N]; omega
    have hxL : N + L < n H := by dsimp [N]; omega
    have hxXL : N + X + L < n H := by dsimp [N]; omega
    have ht₁ := indexCountTailBound_le_cutoffTailCap n hpos hmono hxL
    have ht₂ := indexCountTailBound_le_cutoffTailCap n hpos hmono hxXL
    have hc₁ := indexCountConjugateBound_le_cutoffConjugateCap
      n hpos hmono Tconj hxN
    have hc₂ := indexCountConjugateBound_le_cutoffConjugateCap
      n hpos hmono Tconj hxNX
    have htailSum :
        indexCountTailBound n (N + L) +
          indexCountTailBound n (N + X + L) ≤ 2 * cutoffTailCap H := by
      linarith
    have hconjSum :
        indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj (N + X) ≤
        2 * cutoffConjugateCap Tconj H := by
      linarith
    have hconjSumNonneg : 0 ≤
        indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj (N + X) := by
      unfold indexCountConjugateBound
      have hden : 0 < 1 - φ⁻¹ := sub_pos.mpr
        (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
      positivity
    have hfirstNonneg : 0 ≤
        (φ⁻¹) ^ L * (2 * cutoffTailCap H) := by positivity
    calc
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (N + X + L)) *
        (indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj (N + X)) ≤
        (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
          (indexCountConjugateBound n Tconj N +
            indexCountConjugateBound n Tconj (N + X)) := by
          gcongr
      _ ≤ (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
          (2 * cutoffConjugateCap Tconj H) :=
        mul_le_mul_of_nonneg_left hconjSum hfirstNonneg
      _ < (((qden : ℕ) : ℝ)⁻¹) ^ 2 := hpreCap

end Research

/-!
# Realizing a selected dyadic chain as a finite position block
-/

namespace Research

/-- The finite selected-position image of a parametrized dyadic chain. -/
def dyadicChainPositionBlock
    {R : ℕ} (pos : Fin R → ℕ) : Finset ℕ :=
  Finset.univ.image pos

/-- Summing over the position image gives exactly the abstract dyadic-chain
coefficient. -/
theorem selectedPositionFinsetCoeff_dyadicChainPositionBlock
    (n : ℕ → ℕ) (K R m : ℕ) (pos : Fin R → ℕ)
    (hposMono : StrictMono pos)
    (hvalues : ∀ j : Fin R, n (pos j) = n K * 2 ^ (j : ℕ)) :
    selectedPositionFinsetCoeff n (dyadicChainPositionBlock pos) m =
      dyadicChainCoeff (n K) R m := by
  classical
  unfold selectedPositionFinsetCoeff dyadicChainPositionBlock dyadicChainCoeff
  rw [Finset.sum_image hposMono.injective.injOn]
  calc
    (∑ j : Fin R, fibLambertCoeff (n (pos j)) m) =
        ∑ j : Fin R, fibLambertCoeff (n K * 2 ^ (j : ℕ)) m := by
          apply Finset.sum_congr rfl
          intro j _
          rw [hvalues j]
    _ = ∑ j ∈ Finset.range R, fibLambertCoeff (n K * 2 ^ j) m :=
      Fin.sum_univ_eq_sum_range
        (fun j => fibLambertCoeff (n K * 2 ^ j) m) R

/-- The root position belongs to the chain block. -/
theorem root_mem_dyadicChainPositionBlock
    (K R : ℕ) (pos : Fin R → ℕ) (hR : 0 < R)
    (hzero : pos ⟨0, hR⟩ = K) :
    K ∈ dyadicChainPositionBlock pos := by
  classical
  apply Finset.mem_image.mpr
  exact ⟨⟨0, hR⟩, Finset.mem_univ _, hzero⟩

/-- Every position in the image lies below any common upper cutoff for the
parametrizing positions. -/
theorem dyadicChainPositionBlock_bounded
    {R H : ℕ} (pos : Fin R → ℕ)
    (hupper : ∀ j : Fin R, pos j < H) :
    ∀ k ∈ dyadicChainPositionBlock pos, k < H := by
  classical
  intro k hk
  obtain ⟨j, _, rfl⟩ := Finset.mem_image.mp hk
  exact hupper j

/-- Every displayed dyadic level is represented in the position block. -/
theorem dyadicChain_position_mem_block
    (n : ℕ → ℕ) (hmono : StrictMono n)
    (K R s k : ℕ) (pos : Fin R → ℕ)
    (hvalues : ∀ j : Fin R, n (pos j) = n K * 2 ^ (j : ℕ))
    (hs : s < R) (hk : n k = n K * 2 ^ s) :
    k ∈ dyadicChainPositionBlock pos := by
  classical
  have heq : k = pos ⟨s, hs⟩ := by
    apply hmono.injective
    rw [hk, hvalues]
  rw [heq]
  apply Finset.mem_image.mpr
  exact ⟨⟨s, hs⟩, Finset.mem_univ _, rfl⟩

/-- In a maximal nonempty chain, an exact selected double is either the second
block member or is absent when the chain has length one. Thus every selected
exact double of the root belongs to the distinguished block. -/
theorem double_position_mem_maximal_dyadicChainPositionBlock
    (n : ℕ → ℕ) (hmono : StrictMono n)
    (K R k : ℕ) (pos : Fin R → ℕ)
    (hvalues : ∀ j : Fin R, n (pos j) = n K * 2 ^ (j : ℕ))
    (hmissing : ¬∃ j : ℕ, n j = n K * 2 ^ R)
    (hk : n k = 2 * n K) :
    k ∈ dyadicChainPositionBlock pos := by
  have hRtwo : 2 ≤ R := by
    by_contra hnot
    have hRle : R ≤ 1 := by omega
    have hRpos : 0 < R := by
      by_contra hzero
      have hR0 : R = 0 := by omega
      apply hmissing
      exact ⟨K, by simp [hR0]⟩
    have hR1 : R = 1 := by omega
    apply hmissing
    refine ⟨k, ?_⟩
    simpa [hR1, mul_comm] using hk
  apply dyadicChain_position_mem_block n hmono K R 1 k pos
    hvalues (by omega)
  simpa [mul_comm] using hk

/-- Every sharp component period in the chain divides the explicit common
period `4 * (n_K * 2^R)`. -/
theorem dyadicChainPositionBlock_period_dvd_endpoint_four
    (n : ℕ → ℕ) (K R : ℕ) (pos : Fin R → ℕ)
    (hvalues : ∀ j : Fin R, n (pos j) = n K * 2 ^ (j : ℕ)) :
    ∀ k ∈ dyadicChainPositionBlock pos,
      fibLambertPeriod (n k) ∣ 4 * (n K * 2 ^ R) := by
  classical
  intro k hk
  obtain ⟨j, _, rfl⟩ := Finset.mem_image.mp hk
  rw [hvalues]
  have hlevel : n K * 2 ^ (j : ℕ) ∣ n K * 2 ^ R := by
    exact Nat.mul_dvd_mul_left (n K)
      (Nat.pow_dvd_pow 2 (Nat.le_of_lt j.isLt))
  have hfour : 4 * (n K * 2 ^ (j : ℕ)) ∣ 4 * (n K * 2 ^ R) :=
    Nat.mul_dvd_mul_left 4 hlevel
  apply dvd_trans _ hfour
  unfold fibLambertPeriod
  split_ifs
  · exact ⟨2, by ring⟩
  · exact dvd_rfl

end Research

/-!
# Near-half protected centers outside a finite distinguished position block
-/

namespace Research

open scoped BigOperators

/-- The two aligned near-half center families after deleting every condition
whose selected position belongs to the distinguished finite block. -/
def nearHalfOutsideBlockCenterConditions
    (n : ℕ → ℕ) (K H W A X p L sR : ℕ) (B : Finset ℕ) :
    Finset ((ℕ × ℕ) × Bool) :=
  (nearHalfCenterConditions n K H W A X p L sR).filter fun u =>
    u.1.1 ∉ B

/-- All remaining compatible outside-block conditions. -/
def nearHalfOutsideBlockOffCenterConditions
    (n : ℕ → ℕ) (K H W A X p L sR : ℕ) (B : Finset ℕ) :
    Finset ((ℕ × ℕ) × Bool) :=
  compatibleOutsideTwoWindowConditions n K H W A X p B \
    nearHalfOutsideBlockCenterConditions n K H W A X p L sR B

/-- Reduced moduli represented by the outside-block aligned centers. -/
def nearHalfOutsideBlockCenterReducedModuli
    (n : ℕ → ℕ) (K H W A X p L sR : ℕ) (B : Finset ℕ) : Finset ℕ :=
  (nearHalfOutsideBlockCenterConditions n K H W A X p L sR B).image fun u =>
    twoWindowModulus n u / (twoWindowModulus n u).gcd p

/-- The displayed center/off-center families partition exactly the compatible
conditions outside the distinguished block. -/
theorem nearHalfOutsideBlock_partition
    (n : ℕ → ℕ) (K H W A X p L sR : ℕ) (B : Finset ℕ) :
    nearHalfOutsideBlockCenterConditions n K H W A X p L sR B ∪
      nearHalfOutsideBlockOffCenterConditions n K H W A X p L sR B =
    compatibleOutsideTwoWindowConditions n K H W A X p B := by
  classical
  apply Finset.union_sdiff_of_subset
  intro u hu
  have huOld := (Finset.mem_filter.mp hu).1
  have huNotB := (Finset.mem_filter.mp hu).2
  have huCompat := (Finset.mem_filter.mp huOld).1
  have huBase := (Finset.mem_filter.mp huCompat).1
  have huSol := (Finset.mem_filter.mp huCompat).2
  apply Finset.mem_filter.mpr
  refine ⟨?_, huSol⟩
  exact Finset.mem_filter.mpr ⟨huBase, huNotB⟩

/-- Once exact doubles outside the block are absent, filtering the block from
both aligned center families retains the same scaled polynomial protected
count as the one-target theorem. -/
theorem exists_exact_scaled_polynomially_many_nearHalf_outsideBlock_candidates
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H L J X r v : ℕ) (B : Finset ℕ) (_hKH : K < H)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (_hsRWindow : n K + L - r < L + 1 + J)
    (hnoDoubleOutside : ∀ j, K < j → j < H → j ∉ B →
      n j ≠ 2 * n K) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C := nearHalfOutsideBlockCenterConditions
      n K H W A X p L sR B
    let Q := nearHalfOutsideBlockCenterReducedModuli
      n K H W A X p L sR B
    let S := centerPrimeFactors Q
    ∃ M : ℕ, 0 < M ∧ M = ∏ z ∈ S, z ∧ ∀ T : ℕ,
      2 * (T * M) ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p (T * M)).card := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C := nearHalfOutsideBlockCenterConditions
    n K H W A X p L sR B
  let Q := nearHalfOutsideBlockCenterReducedModuli
    n K H W A X p L sR B
  have hn := hpos K
  have hcenterLeft : A + L = n K := by dsimp [A]; omega
  have hvOdd : Odd (v + 1) := by
    obtain ⟨z, hz⟩ := hv
    exact ⟨z, by omega⟩
  have hcenterRight : A + sR + X = 2 * n K * (v + 1) := by
    have hsrr : sR + r = n K + L := by dsimp [sR]; omega
    rw [hX]
    calc
      A + sR + (r + 2 * n K * v) =
          2 * n K + 2 * n K * v := by
        dsimp [A]
        omega
      _ = 2 * n K * (v + 1) := by ring
  have hQdata : ∀ q ∈ Q, Odd q ∧ 3 ≤ q := by
    intro q hqQ
    obtain ⟨u, huC, rfl⟩ := Finset.mem_image.mp hqQ
    have huOldC := (Finset.mem_filter.mp huC).1
    have huNotB := (Finset.mem_filter.mp huC).2
    have huCompat := (Finset.mem_filter.mp huOldC).1
    have huCenter := (Finset.mem_filter.mp huOldC).2
    have huBase := (Finset.mem_filter.mp huCompat).1
    have huComp := (Finset.mem_filter.mp huCompat).2
    have huPair := Finset.mem_product.mp (Finset.mem_product.mp huBase).1
    have hjData := Finset.mem_filter.mp huPair.1
    have hjH := Finset.mem_range.mp hjData.1
    have hKj := hjData.2
    have hnj := hpos u.1.1
    have hnlt : n K < n u.1.1 := hmono hKj
    rcases huCenter with hleft | hright
    · have hside : u.2 = false := hleft.1
      have hoff : u.1.2 = L := hleft.2
      have hcompLeft : (n u.1.1).gcd (4 * n K) ∣ n K := by
        simpa [twoWindowModulus, twoWindowOffset, p, A,
          hside, hoff, hcenterLeft] using huComp
      exact left_center_reduced_odd_ge_three
        (n u.1.1) (n K) hnj hn hnlt hcompLeft
    · have hside : u.2 = true := hright.1
      have hoff : u.1.2 = sR := hright.2
      have hcompRight : (n u.1.1).gcd (4 * n K) ∣
          2 * n K * (v + 1) := by
        simpa [twoWindowModulus, twoWindowOffset, p, A,
          sR, hside, hoff, hcenterRight] using huComp
      have hd := right_center_reduced_odd_and_eq_one
        (n u.1.1) (n K) (v + 1) hnj hn hnlt hvOdd hcompRight
      refine ⟨hd.1, ?_⟩
      have hqpos : 0 < n u.1.1 / (n u.1.1).gcd (4 * n K) := hd.1.pos
      have hqne : n u.1.1 / (n u.1.1).gcd (4 * n K) ≠ 1 := by
        intro heq
        have heqDouble := hd.2 heq
        exact hnoDoubleOutside u.1.1 hKj hjH huNotB heqDouble
      have hqneTwo : n u.1.1 / (n u.1.1).gcd (4 * n K) ≠ 2 := by
        intro heq
        obtain ⟨z, hz⟩ := hd.1
        omega
      change 3 ≤ n u.1.1 / (n u.1.1).gcd (4 * n K)
      omega
  apply exists_exact_period_with_scaled_polynomially_many_protected_centers
    Q C (fun u => u.2) (twoWindowOffset A X) (twoWindowModulus n)
      p v
  · exact fun q hq => (hQdata q hq).2
  · exact fun q hq => (hQdata q hq).1
  · intro u huC
    have huOldC := (Finset.mem_filter.mp huC).1
    let q0 := twoWindowModulus n u /
      (twoWindowModulus n u).gcd p
    refine ⟨q0, ?_, ?_⟩
    · apply Finset.mem_image.mpr
      exact ⟨u, huC, rfl⟩
    · intro t hbad
      have huCompat := (Finset.mem_filter.mp huOldC).1
      have huCenter := (Finset.mem_filter.mp huOldC).2
      have huComp := (Finset.mem_filter.mp huCompat).2
      let g := (n u.1.1).gcd (4 * n K)
      have hg : 0 < g := Nat.gcd_pos_of_pos_left (4 * n K) (hpos u.1.1)
      have hqFactor : n u.1.1 = g * q0 := by
        dsimp [g, q0, p]
        exact (Nat.mul_div_cancel' (Nat.gcd_dvd_left _ _)).symm
      rcases huCenter with hleft | hright
      · have hside : u.2 = false := hleft.1
        have hoff : u.1.2 = L := hleft.2
        have hgN : g ∣ n K := by
          simpa [g, p, twoWindowModulus, twoWindowOffset,
            A, hside, hoff, hcenterLeft] using huComp
        let u0 := n K / g
        have hnFactor : n K = g * u0 := by
          dsimp [u0]
          exact (Nat.mul_div_cancel' hgN).symm
        have hcop : q0.Coprime u0 := by
          dsimp [q0, u0, g, p]
          exact coprime_reduced_modulus_factor
            (n u.1.1) (4 * n K) (n K) (hpos u.1.1)
              hgN (by exact ⟨4, by ring⟩)
        simp only [hside, Bool.false_eq_true, ↓reduceIte]
        apply (left_center_divisibility_iff_reduced
          (n u.1.1) (n K) g q0 u0 t hg hqFactor hnFactor hcop).mp
        simpa [twoWindowModulus, twoWindowOffset, p, A,
          hside, hoff, hcenterLeft] using hbad
      · have hside : u.2 = true := hright.1
        have hoff : u.1.2 = sR := hright.2
        have hgAligned : g ∣ 2 * n K * (v + 1) := by
          simpa [g, p, twoWindowModulus, twoWindowOffset,
            A, sR, hside, hoff, hcenterRight] using huComp
        have hgTwo : g ∣ 2 * n K :=
          dvd_two_mul_of_dvd_four_mul_and_two_mul_odd
            g (n K) (v + 1) hvOdd
            (by dsimp [g]; exact Nat.gcd_dvd_right _ _) hgAligned
        let u0 := (2 * n K) / g
        have htwoFactor : 2 * n K = g * u0 := by
          dsimp [u0]
          exact (Nat.mul_div_cancel' hgTwo).symm
        have hcop : q0.Coprime u0 := by
          dsimp [q0, u0, g, p]
          exact coprime_reduced_modulus_factor
            (n u.1.1) (4 * n K) (2 * n K) (hpos u.1.1)
              hgTwo (by exact ⟨2, by ring⟩)
        simp only [hside, ite_true]
        apply (right_center_divisibility_iff_reduced
          (n u.1.1) g q0 u0 v t hg hqFactor hcop).mp
        have haligned : A + u.1.2 + X + p * t =
            g * u0 * (v + 1 + 2 * t) := by
          rw [hoff, hcenterRight, ← htwoFactor]
          dsimp [p]
          ring
        simpa [twoWindowModulus, twoWindowOffset, hside, haligned]
          using hbad

/-- Removing block positions can only decrease the off-center budget, so the
existing near-half reciprocal-index bound remains valid verbatim. -/
theorem nearHalf_outsideBlock_offCenter_budget_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K H L J X r v R : ℕ) (B : Finset ℕ) (hL : L < n K)
    (hX : X = r + (2 * n K) * v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let O := nearHalfOutsideBlockOffCenterConditions
      n K H W A X p L sR B
    (∑ u ∈ O, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1)) ≤
      2 * W * ∑ j ∈ laterPositionRange K H,
        ((R * (4 * W)) / n j + 1) := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let O := nearHalfOutsideBlockOffCenterConditions
    n K H W A X p L sR B
  let Oold := nearHalfOffCenterConditions n K H W A X p L sR
  have hsub : O ⊆ Oold := by
    intro u hu
    have huData := Finset.mem_sdiff.mp hu
    have huOutside := huData.1
    have huNotCenter := huData.2
    have huOutsideData := Finset.mem_filter.mp huOutside
    have huOldCompat : u ∈ compatibleTwoWindowConditions n K H W A X p := by
      have huOutBase := (Finset.mem_filter.mp huOutsideData.1).1
      exact Finset.mem_filter.mpr ⟨huOutBase, huOutsideData.2⟩
    apply Finset.mem_sdiff.mpr
    refine ⟨huOldCompat, ?_⟩
    intro huOldCenter
    apply huNotCenter
    apply Finset.mem_filter.mpr
    exact ⟨huOldCenter, (Finset.mem_filter.mp huOutsideData.1).2⟩
  calc
    (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) ≤
      ∑ u ∈ Oold, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1) :=
          Finset.sum_le_sum_of_subset hsub
    _ ≤ 2 * W * ∑ j ∈ laterPositionRange K H,
        ((R * (4 * W)) / n j + 1) := by
      exact nearHalf_offCenter_budget_le n hpos K H L J X r v R
        hL hX hrUpper hsRWindow

end Research

/-!
# Odd reduced sharp quotients isolate a finite dyadic chain
-/

namespace Research

/-- For an even-quotient near-half shift, an odd reduced sharp-period
quotient forces the target residue to stay at least one quarter of the sharp
gcd away from the half-period.  This is the lower-bound counterpart to F-079's
upper displacement estimate. -/
theorem odd_sharpGcd_le_four_nearHalf_distance
    (P n X r v : ℕ) (hn : 0 < n)
    (hPX : P ∣ X)
    (hX : X = r + (2 * n) * v) (hv : Even v)
    (hodd : Odd (fibLambertPeriod n /
      (fibLambertPeriod n).gcd P)) :
    (fibLambertPeriod n).gcd P ≤ 4 * r.dist n := by
  let d := fibLambertPeriod n
  let g := d.gcd P
  let Q := d / g
  have hdpos : 0 < d := by
    dsimp [d]
    unfold fibLambertPeriod
    split_ifs <;> omega
  have hgpos : 0 < g := by
    dsimp [g]
    exact Nat.gcd_pos_of_pos_left P hdpos
  have hgd : g ∣ d := by
    dsimp [g]
    exact Nat.gcd_dvd_left _ _
  have hgP : g ∣ P := by
    dsimp [g]
    exact Nat.gcd_dvd_right _ _
  have hdFour : d ∣ 4 * n := by
    dsimp [d]
    unfold fibLambertPeriod
    split_ifs
    · exact ⟨2, by ring⟩
    · exact dvd_rfl
  have hgFour : g ∣ 4 * n := hgd.trans hdFour
  have hgX : g ∣ X := hgP.trans hPX
  obtain ⟨z, hz⟩ := hv
  have hgTerm : g ∣ (2 * n) * v := by
    have hrewrite : (2 * n) * v = (4 * n) * z := by
      rw [hz]
      ring
    rw [hrewrite]
    exact dvd_mul_of_dvd_left hgFour z
  have hgr : g ∣ r := by
    apply (Nat.dvd_add_iff_left hgTerm).mpr
    rw [← hX]
    exact hgX
  have hoddQ : Odd Q := by
    simpa [Q, d, g] using hodd
  have hrne : r ≠ n := by
    intro hrn
    have hgn : g ∣ n := by simpa [hrn] using hgr
    let u := n / g
    have hnfac : g * u = n := by
      dsimp [u]
      exact Nat.mul_div_cancel' hgn
    have hdfac : g * Q = d := by
      dsimp [Q]
      exact Nat.mul_div_cancel' hgd
    obtain ⟨a, ha⟩ := hoddQ
    by_cases he : Even n
    · have hd : d = 2 * n := by simp [d, fibLambertPeriod, he]
      have heq : g * Q = g * (2 * u) := by
        calc
          g * Q = d := hdfac
          _ = 2 * n := hd
          _ = g * (2 * u) := by rw [← hnfac]; ring
      have hQeq : Q = 2 * u := Nat.mul_left_cancel hgpos heq
      omega
    · have hd : d = 4 * n := by simp [d, fibLambertPeriod, he]
      have heq : g * Q = g * (4 * u) := by
        calc
          g * Q = d := hdfac
          _ = 4 * n := hd
          _ = g * (4 * u) := by rw [← hnfac]; ring
      have hQeq : Q = 4 * u := Nat.mul_left_cancel hgpos heq
      omega
  have hgDist : g ∣ 4 * r.dist n := by
    have hdvd := dvd_natDist_of_dvd g (4 * r) (4 * n)
      (by simpa [mul_comm] using dvd_mul_of_dvd_left hgr 4) hgFour
    simpa [Nat.dist_mul_left] using hdvd
  have hdistPos : 0 < 4 * r.dist n := by
    exact mul_pos (by omega) (Nat.dist_pos_of_ne hrne)
  exact Nat.le_of_dvd hdistPos hgDist

/-- If a near-half residue is farther than the symmetric window from the exact
half-period, shifting the root window cannot hit even the root divisibility
lattice.  Hence every component of a finite dyadic chain vanishes in the
shifted neighboring windows, and the root itself gives one isolated aggregate
mismatch. -/
theorem dyadicChainCoeff_nearHalf_symmetric_pattern_of_distance
    (n R w X r v : ℕ) (hn : 0 < n) (hR : 0 < R)
    (hw : w < n) (hX : X = r + (2 * n) * v)
    (hrpos : 0 < r) (hrlt : r < 2 * n)
    (hwr : w < r) (hrw : r + w < 2 * n)
    (hwdist : w < r.dist n) :
    let A := n - w
    (∀ s < w, dyadicChainCoeff n R (A + s + X) =
      dyadicChainCoeff n R (A + s)) ∧
    dyadicChainCoeff n R (A + w + X) ≠
      dyadicChainCoeff n R (A + w) ∧
    (∀ s < w, dyadicChainCoeff n R (A + w + 1 + s + X) =
      dyadicChainCoeff n R (A + w + 1 + s)) := by
  let A := n - w
  let rho := r % n
  have hrne : r ≠ n := by
    intro heq
    rw [heq, Nat.dist_self] at hwdist
    omega
  have hrho : X % n = rho := by
    dsimp [rho]
    have hdvd : n ∣ (2 * n) * v := ⟨2 * v, by ring⟩
    rw [hX, Nat.add_mod, Nat.mod_eq_zero_of_dvd hdvd, add_zero,
      Nat.mod_mod]
  have hrhopos : 0 < rho := by
    rcases lt_or_gt_of_ne hrne with hrn | hnr
    · dsimp [rho]
      rw [Nat.mod_eq_of_lt hrn]
      exact hrpos
    · have hrsub : r % n = r - n := by
        rw [Nat.mod_eq_sub_mod (by omega), Nat.mod_eq_of_lt (by omega)]
      dsimp [rho]
      rw [hrsub]
      omega
  have hrholt : rho < n := Nat.mod_lt _ hn
  have hwrho : w < rho := by
    rcases lt_or_gt_of_ne hrne with hrn | hnr
    · have hrhoeq : rho = r := by
        dsimp [rho]
        exact Nat.mod_eq_of_lt hrn
      rw [hrhoeq]
      exact hwr
    · have hrhoeq : rho = r - n := by
        dsimp [rho]
        rw [Nat.mod_eq_sub_mod (by omega), Nat.mod_eq_of_lt (by omega)]
      have hdist : r.dist n = r - n := Nat.dist_eq_sub_of_le_right hnr.le
      rw [hrhoeq, ← hdist]
      exact hwdist
  have hrhoW : rho + w < n := by
    rcases lt_or_gt_of_ne hrne with hrn | hnr
    · have hrhoeq : rho = r := by
        dsimp [rho]
        exact Nat.mod_eq_of_lt hrn
      have hdist : r.dist n = n - r := Nat.dist_eq_sub_of_le hrn.le
      rw [hrhoeq]
      rw [hdist] at hwdist
      omega
    · have hrhoeq : rho = r - n := by
        dsimp [rho]
        rw [Nat.mod_eq_sub_mod (by omega), Nat.mod_eq_of_lt (by omega)]
      rw [hrhoeq]
      omega
  have hAL : A + w = n := by dsimp [A]; omega
  have hpreBase (s : ℕ) (hs : s < w) : ¬n ∣ A + s := by
    intro hdvd
    have hapos : 0 < A + s := by dsimp [A]; omega
    have hale : n ≤ A + s := Nat.le_of_dvd hapos hdvd
    dsimp [A] at hale
    omega
  have hpreShift (s : ℕ) (hs : s < w) : ¬n ∣ A + s + X := by
    intro hdvd
    have hmod0 : (A + s + X) % n = 0 := Nat.mod_eq_zero_of_dvd hdvd
    have htpos : 0 < rho - w + s := by omega
    have htlt : rho - w + s < n := by omega
    have hmod : (A + s + X) % n = rho - w + s := by
      rw [Nat.add_mod, hrho, Nat.mod_eq_of_lt
        (show A + s < n by dsimp [A]; omega)]
      have heq : A + s + rho = n + (rho - w + s) := by
        dsimp [A]
        omega
      rw [heq, Nat.add_mod_left, Nat.mod_eq_of_lt htlt]
    omega
  have hpostBase (s : ℕ) (hs : s < w) :
      ¬n ∣ A + w + 1 + s := by
    rw [hAL]
    intro hdvd
    have hdiff : n ∣ (n + (1 + s)) - n :=
      Nat.dvd_sub (by simpa [add_assoc] using hdvd) (dvd_refl n)
    have heq : (n + (1 + s)) - n = 1 + s := by omega
    rw [heq] at hdiff
    have hle := Nat.le_of_dvd (by omega : 0 < 1 + s) hdiff
    omega
  have hpostShift (s : ℕ) (hs : s < w) :
      ¬n ∣ A + w + 1 + s + X := by
    intro hdvd
    have hmod0 := Nat.mod_eq_zero_of_dvd hdvd
    have htpos : 0 < rho + 1 + s := by omega
    have htlt : rho + 1 + s < n := by omega
    have hmod : (A + w + 1 + s + X) % n = rho + 1 + s := by
      rw [hAL, Nat.add_mod, hrho]
      have hbaseMod : (n + 1 + s) % n = 1 + s := by
        rw [show n + 1 + s = n + (1 + s) by omega,
          Nat.add_mod_left, Nat.mod_eq_of_lt (by omega)]
      rw [hbaseMod, show 1 + s + rho = rho + 1 + s by omega,
        Nat.mod_eq_of_lt htlt]
    omega
  have hcenterShift : ¬n ∣ n + X := by
    intro hdvd
    have hmod0 := Nat.mod_eq_zero_of_dvd hdvd
    have hmod : (n + X) % n = rho := by
      rw [Nat.add_mod_left, hrho]
    omega
  refine ⟨?_, ?_, ?_⟩
  · intro s hs
    rw [dyadicChainCoeff_eq_zero_of_not_dvd n R _ (hpreShift s hs),
      dyadicChainCoeff_eq_zero_of_not_dvd n R _ (hpreBase s hs)]
  · rw [hAL, dyadicChainCoeff_at_root n R hn hR,
      dyadicChainCoeff_eq_zero_of_not_dvd n R _ hcenterShift]
    norm_num
  · intro s hs
    rw [dyadicChainCoeff_eq_zero_of_not_dvd n R _ (hpostShift s hs),
      dyadicChainCoeff_eq_zero_of_not_dvd n R _ (hpostBase s hs)]

end Research
/-!
# Complete arithmetic package for odd-quotient finite dyadic-chain targets
-/

namespace Research

/-- A genuinely new sharp period with odd reduced quotient cannot have its
support period `2n` already absorbed by the prefix period. -/
theorem not_two_mul_dvd_of_new_and_odd_reduced_sharpPeriod
    (P n : ℕ) (hn : 0 < n)
    (hnew : ¬fibLambertPeriod n ∣ P)
    (hodd : Odd (fibLambertPeriod n /
      (fibLambertPeriod n).gcd P)) :
    ¬2 * n ∣ P := by
  intro htwoP
  by_cases he : Even n
  · apply hnew
    simpa [fibLambertPeriod, he] using htwoP
  · let d := fibLambertPeriod n
    let g := d.gcd P
    let Q := d / g
    have hd : d = 4 * n := by simp [d, fibLambertPeriod, he]
    have hdpos : 0 < d := by rw [hd]; omega
    have hgpos : 0 < g := by
      dsimp [g]
      exact Nat.gcd_pos_of_pos_left P hdpos
    have hgd : g ∣ d := by
      dsimp [g]
      exact Nat.gcd_dvd_left _ _
    have hgP : g ∣ P := by
      dsimp [g]
      exact Nat.gcd_dvd_right _ _
    have htwoD : 2 * n ∣ d := by rw [hd]; exact ⟨2, by ring⟩
    have htwoG : 2 * n ∣ g := by
      dsimp [g]
      exact Nat.dvd_gcd htwoD htwoP
    have hfac : g * Q = d := by
      dsimp [Q]
      exact Nat.mul_div_cancel' hgd
    have hoddQ : Odd Q := by simpa [Q, d, g] using hodd
    obtain ⟨a, ha⟩ := hoddQ
    have hQone : Q = 1 := by
      by_contra hne
      have hQthree : 3 ≤ Q := by omega
      have hlarge : 3 * (2 * n) ≤ g * Q := by
        calc
          3 * (2 * n) ≤ 3 * g := Nat.mul_le_mul_left 3
            (Nat.le_of_dvd hgpos htwoG)
          _ ≤ g * Q := by nlinarith
      rw [hfac, hd] at hlarge
      omega
    have hgdEq : g = d := by
      rw [hQone, mul_one] at hfac
      exact hfac
    apply hnew
    change d ∣ P
    rw [← hgdEq]
    exact hgP

/-- If `2n` is not absorbed, the gcd with `4n` is at most one third of
`4n`. This gives coarse but uniform middle-half margins for F-079's residue. -/
theorem three_mul_gcd_four_le_of_not_two_mul_dvd
    (P n : ℕ) (hn : 0 < n) (hndvd : ¬2 * n ∣ P) :
    3 * (4 * n).gcd P ≤ 4 * n := by
  let g := (4 * n).gcd P
  let Q := (4 * n) / g
  have hfour : 0 < 4 * n := by omega
  have hgpos : 0 < g := by
    dsimp [g]
    exact Nat.gcd_pos_of_pos_left P hfour
  have hgd : g ∣ 4 * n := by
    dsimp [g]
    exact Nat.gcd_dvd_left _ _
  have hgP : g ∣ P := by
    dsimp [g]
    exact Nat.gcd_dvd_right _ _
  have hfac : g * Q = 4 * n := by
    dsimp [Q]
    exact Nat.mul_div_cancel' hgd
  have hQpos : 0 < Q := by
    dsimp [Q]
    exact Nat.div_pos (Nat.gcd_le_left P hfour) hgpos
  have hQthree : 3 ≤ Q := by
    by_contra hnot
    have hcases : Q = 1 ∨ Q = 2 := by omega
    rcases hcases with hQone | hQtwo
    · have hgEq : g = 4 * n := by
        rw [hQone, mul_one] at hfac
        exact hfac
      apply hndvd
      apply dvd_trans (show 2 * n ∣ 4 * n by exact ⟨2, by ring⟩)
      rw [← hgEq]
      exact hgP
    · have hgEq : g = 2 * n := by
        rw [hQtwo] at hfac
        omega
      apply hndvd
      rw [← hgEq]
      exact hgP
  calc
    3 * g ≤ g * Q := by nlinarith
    _ = 4 * n := hfac

/-- Full target-production package.  A new odd reduced sharp quotient, a
window shorter than one eighth of the sharp gcd, and `3w<n` produce a bounded
prefix-period multiple giving an isolated symmetric pattern for every
nonempty finite dyadic completion chain. -/
theorem exists_oddReducedSharp_dyadicChain_nearHalf_window_package
    (P n R w : ℕ) (hn : 0 < n) (hR : 0 < R)
    (hnew : ¬fibLambertPeriod n ∣ P)
    (hodd : Odd (fibLambertPeriod n /
      (fibLambertPeriod n).gcd P))
    (hwindow : 8 * w ≤ (fibLambertPeriod n).gcd P)
    (hwsmall : 3 * w < n) :
    ∃ X r v : ℕ,
      P ∣ X ∧ X < (4 * n) * P ∧
      X = r + (2 * n) * v ∧ Even v ∧
      0 < r ∧ r < 2 * n ∧
      w < r ∧ r + w < 2 * n ∧
      (∀ s < w, dyadicChainCoeff n R (n - w + s + X) =
        dyadicChainCoeff n R (n - w + s)) ∧
      dyadicChainCoeff n R (n - w + w + X) ≠
        dyadicChainCoeff n R (n - w + w) ∧
      (∀ s < w, dyadicChainCoeff n R
          (n - w + w + 1 + s + X) =
        dyadicChainCoeff n R (n - w + w + 1 + s)) := by
  have hndvd := not_two_mul_dvd_of_new_and_odd_reduced_sharpPeriod
    P n hn hnew hodd
  obtain ⟨X, r, v, hPX, hXbound, hX, hv, hrpos, hrlt, hnear⟩ :=
    exists_nearHalf_evenQuotient_multiplier P n hn hndvd
  have hlower := odd_sharpGcd_le_four_nearHalf_distance
    P n X r v hn hPX hX hv hodd
  have hwdist : w < r.dist n := by
    have hgpos : 0 < (fibLambertPeriod n).gcd P :=
      Nat.gcd_pos_of_pos_left P (by
        unfold fibLambertPeriod
        split_ifs <;> omega)
    omega
  have hthree := three_mul_gcd_four_le_of_not_two_mul_dvd P n hn hndvd
  have hdistCoarse : 3 * r.dist n ≤ 2 * n := by omega
  have hrne : r ≠ n := by
    intro heq
    rw [heq, Nat.dist_self] at hwdist
    omega
  have hwr : w < r := by
    rcases lt_or_gt_of_ne hrne with hrn | hnr
    · have hdist : r.dist n = n - r := Nat.dist_eq_sub_of_le hrn.le
      rw [hdist] at hdistCoarse
      omega
    · omega
  have hrw : r + w < 2 * n := by
    rcases lt_or_gt_of_ne hrne with hrn | hnr
    · omega
    · have hdist : r.dist n = r - n := Nat.dist_eq_sub_of_le_right hnr.le
      rw [hdist] at hdistCoarse
      omega
  have hpattern := dyadicChainCoeff_nearHalf_symmetric_pattern_of_distance
    n R w X r v hn hR (by omega) hX hrpos hrlt hwr hrw hwdist
  exact ⟨X, r, v, hPX, hXbound, hX, hv, hrpos, hrlt, hwr, hrw,
    hpattern.1, hpattern.2.1, hpattern.2.2⟩

end Research

/-!
# Norm gate for a finite central mismatch block
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- A finite coefficient-difference block whose base-`φ⁻¹` value has a fixed
positive lower bound, followed by a sufficiently long equal block, forces the
two coefficient tails to be different. -/
theorem selected_coefficientTail_ne_of_finiteMismatchBlock
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (N M B J : ℕ) (η : ℝ)
    (hblockLower : η ≤
      |∑ t ∈ Finset.range B,
        ((selectedFibLambertCoeff n (N + t) -
          selectedFibLambertCoeff n (M + t) : ℤ) : ℝ) * (φ⁻¹) ^ t|)
    (hpost : ∀ t < J,
      selectedFibLambertCoeff n (N + B + t) =
        selectedFibLambertCoeff n (M + B + t))
    (hsmallPost :
      (φ⁻¹) ^ (B + J) *
        (indexCountTailBound n (N + B + J) +
          indexCountTailBound n (M + B + J)) < η) :
    coefficientTail (selectedFibLambertCoeff n) N ≠
      coefficientTail (selectedFibLambertCoeff n) M := by
  let C := selectedFibLambertCoeff n
  let r : ℝ := φ⁻¹
  let D : ℝ := ∑ t ∈ Finset.range B,
    ((C (N + t) - C (M + t) : ℤ) : ℝ) * r ^ t
  have hsum := (hasSum_selectedFibLambertCoeff n hpos hmono).summable
  have hsplitN := coefficientTail_eq_block_add C hsum N B
  have hsplitM := coefficientTail_eq_block_add C hsum M B
  have hpostFactor := coefficientTail_sub_eq_pow_mul_of_block_eq
    C hsum (N + B) (M + B) J hpost
  have hformula :
      coefficientTail C N - coefficientTail C M =
        D + r ^ (B + J) *
          (coefficientTail C (N + B + J) -
            coefficientTail C (M + B + J)) := by
    rw [hsplitN, hsplitM]
    calc
      (∑ t ∈ Finset.range B, (C (N + t) : ℝ) * φ⁻¹ ^ t) +
            φ⁻¹ ^ B * coefficientTail C (N + B) -
          ((∑ t ∈ Finset.range B, (C (M + t) : ℝ) * φ⁻¹ ^ t) +
            φ⁻¹ ^ B * coefficientTail C (M + B)) =
          ((∑ t ∈ Finset.range B, (C (N + t) : ℝ) * φ⁻¹ ^ t) -
            ∑ t ∈ Finset.range B, (C (M + t) : ℝ) * φ⁻¹ ^ t) +
            φ⁻¹ ^ B * (coefficientTail C (N + B) -
              coefficientTail C (M + B)) := by ring
      _ = D + φ⁻¹ ^ B * (coefficientTail C (N + B) -
              coefficientTail C (M + B)) := by
        apply congrArg₂ (· + ·)
        · dsimp [D, r]
          push_cast
          rw [← Finset.sum_sub_distrib]
          apply Finset.sum_congr rfl
          intro t ht
          ring
        · rfl
      _ = D + r ^ (B + J) *
          (coefficientTail C (N + B + J) -
            coefficientTail C (M + B + J)) := by
        rw [hpostFactor, pow_add]
        dsimp [r]
        ring
  have hlater :
      |coefficientTail C (N + B + J) -
        coefficientTail C (M + B + J)| ≤
        indexCountTailBound n (N + B + J) +
          indexCountTailBound n (M + B + J) := by
    exact (abs_sub _ _).trans <| add_le_add
      (abs_selected_coefficientTail_le_indexCount n hpos hmono (N + B + J))
      (abs_selected_coefficientTail_le_indexCount n hpos hmono (M + B + J))
  have hr0 : 0 ≤ r := by
    dsimp [r]
    exact inv_nonneg.mpr Real.goldenRatio_pos.le
  have hrem :
      |r ^ (B + J) *
        (coefficientTail C (N + B + J) -
          coefficientTail C (M + B + J))| < η := by
    rw [abs_mul, abs_pow, abs_of_nonneg hr0]
    exact (mul_le_mul_of_nonneg_left hlater (pow_nonneg hr0 _)).trans_lt
      (by simpa [r] using hsmallPost)
  intro heq
  have hzero : coefficientTail C N - coefficientTail C M = 0 :=
    sub_eq_zero.mpr heq
  rw [hzero] at hformula
  have habsEq : |D| =
      |r ^ (B + J) *
        (coefficientTail C (N + B + J) -
          coefficientTail C (M + B + J))| := by
    rw [← abs_neg]
    congr 1
    linarith
  have hlower : η ≤ |D| := by
    simpa [D, r, C] using hblockLower
  rw [habsEq] at hlower
  exact (not_lt_of_ge hlower) hrem

/-- Arbitrary-pair norm obstruction with a finite central mismatch block in
place of one isolated mismatch. -/
theorem selected_finiteMismatchBlock_pair_obstruction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (q : ℕ) (hq : 0 < q) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair q T Tconj)
    (N M L B J : ℕ) (η : ℝ)
    (hpre : ∀ t < L,
      selectedFibLambertCoeff n (N + t) =
        selectedFibLambertCoeff n (M + t))
    (hblockLower : η ≤
      |∑ t ∈ Finset.range B,
        ((selectedFibLambertCoeff n (N + L + t) -
          selectedFibLambertCoeff n (M + L + t) : ℤ) : ℝ) * (φ⁻¹) ^ t|)
    (hpost : ∀ t < J,
      selectedFibLambertCoeff n (N + L + B + t) =
        selectedFibLambertCoeff n (M + L + B + t))
    (hsmallPost :
      (φ⁻¹) ^ (B + J) *
        (indexCountTailBound n (N + L + B + J) +
          indexCountTailBound n (M + L + B + J)) < η)
    (hsmallPre :
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + L) +
            indexCountTailBound n (M + L)) *
        (indexCountConjugateBound n Tconj N +
          indexCountConjugateBound n Tconj M) <
      (((q : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  apply selected_matched_block_pair_obstruction
    n hpos hmono q hq T Tconj hsum htotal N M L hpre
  · have hne := selected_coefficientTail_ne_of_finiteMismatchBlock
      n hpos hmono (N + L) (M + L) B J η hblockLower
        (by
          intro t ht
          simpa [add_assoc] using hpost t ht)
        (by simpa [add_assoc] using hsmallPost)
    have hsummable := (hasSum_selectedFibLambertCoeff n hpos hmono).summable
    have hfactor := coefficientTail_sub_eq_pow_mul_of_block_eq
      (selectedFibLambertCoeff n) hsummable N M L hpre
    intro heq
    have hz : coefficientTail (selectedFibLambertCoeff n) N -
        coefficientTail (selectedFibLambertCoeff n) M = 0 :=
      sub_eq_zero.mpr heq
    rw [hz] at hfactor
    have hpne : (φ⁻¹ : ℝ) ^ L ≠ 0 :=
      pow_ne_zero _ (inv_ne_zero Real.goldenRatio_ne_zero)
    exact hne (sub_eq_zero.mp
      (mul_eq_zero.mp hfactor.symm |>.resolve_left hpne))
  · exact hsmallPre

end Research

/-!
# The two-spike finite block produced by a near-half dyadic chain
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

lemma not_dvd_of_pos_lt_two_mul_ne
    (n x : ℕ) (hx : 0 < x) (hxlt : x < 2 * n)
    (hxne : x ≠ n) :
    ¬n ∣ x := by
  rw [Nat.dvd_iff_mod_eq_zero]
  rcases lt_or_gt_of_ne hxne with hxn | hnx
  · rw [Nat.mod_eq_of_lt hxn]
    omega
  · rw [Nat.mod_eq_sub_mod hnx.le, Nat.mod_eq_of_lt (by omega)]
    omega

/-- At an odd multiple of the selected double level, a nontrivial finite
chain contributes exactly one: the root contribution vanishes, the double
contributes one, and all higher levels have too much two-adic divisibility. -/
theorem dyadicChainCoeff_at_double_add_four_mul
    (n R z : ℕ) (hn : 0 < n) (hR : 2 ≤ R) :
    dyadicChainCoeff n R (2 * n + 4 * n * z) = 1 := by
  unfold dyadicChainCoeff
  rw [Finset.sum_eq_single 1]
  · have heven : Even (2 * n) := ⟨n, by omega⟩
    have hp := fibLambertCoeff_add_period_mul_minimal
      (2 * n) (2 * n) z
    have hself := fibLambertCoeff_self (2 * n) (by omega)
    rw [hself] at hp
    simpa [fibLambertPeriod, heven, pow_one, mul_assoc, mul_comm,
      mul_left_comm] using hp
  · intro j hj hjne
    have hjR : j < R := Finset.mem_range.mp hj
    by_cases hj0 : j = 0
    · subst j
      simp only [pow_zero, mul_one]
      apply fibLambertCoeff_eq_zero_of_mod_two_mul_ne n _ hn
      have hdvd : 2 * n ∣ 2 * n + 4 * n * z := by
        refine ⟨1 + 2 * z, ?_⟩
        ring
      rw [Nat.mod_eq_zero_of_dvd hdvd]
      omega
    · have hjtwo : 2 ≤ j := by omega
      apply fibLambertCoeff_eq_zero_of_not_dvd
      intro hdvd
      have hfactor : 2 * n + 4 * n * z = n * (2 * (1 + 2 * z)) := by
        ring
      have hpowDvd : 2 ^ j ∣ 2 * (1 + 2 * z) := by
        apply (Nat.mul_dvd_mul_iff_left hn).mp
        simpa [hfactor] using hdvd
      have hpowEq : 2 ^ j = 2 * 2 ^ (j - 1) := by
        obtain ⟨s, rfl⟩ := Nat.exists_eq_succ_of_ne_zero hj0
        simp [pow_succ, mul_comm]
      have hrest : 2 ^ (j - 1) ∣ 1 + 2 * z := by
        apply (Nat.mul_dvd_mul_iff_left (by omega : 0 < 2)).mp
        simpa [hpowEq] using hpowDvd
      have htwoPow : 2 ∣ 2 ^ (j - 1) := by
        simpa using Nat.pow_dvd_pow 2 (show 1 ≤ j - 1 by omega)
      have htwoOdd : 2 ∣ 1 + 2 * z := htwoPow.trans hrest
      obtain ⟨a, ha⟩ := htwoOdd
      omega
  · intro hnot
    exfalso
    apply hnot
    simp
    omega

/-- In a short symmetric root neighborhood, the unshifted finite chain is the
single spike at the root. -/
theorem dyadicChainCoeff_local_root_formula
    (n R W t : ℕ) (hn : 0 < n) (hR : 0 < R)
    (hW : W < n) (ht : t < 2 * W + 1) :
    dyadicChainCoeff n R (n - W + t) = if t = W then 1 else 0 := by
  by_cases htw : t = W
  · subst t
    rw [show n - W + W = n by omega,
      dyadicChainCoeff_at_root n R hn hR]
    simp
  · have hxpos : 0 < n - W + t := by omega
    have hxlt : n - W + t < 2 * n := by omega
    have hxne : n - W + t ≠ n := by omega
    rw [dyadicChainCoeff_eq_zero_of_not_dvd n R _
      (not_dvd_of_pos_lt_two_mul_ne n _ hxpos hxlt hxne)]
    simp [htw]

/-- Under an even-quotient near-half shift, the shifted finite chain is the
single spike at the unique offset where `r-W+t=n`. -/
theorem dyadicChainCoeff_local_shift_formula
    (n R W X r v e t : ℕ) (hn : 0 < n) (hR : 2 ≤ R)
    (hW : W < n) (hX : X = r + (2 * n) * v) (hv : Even v)
    (hWr : W < r) (hrW : r + W < 2 * n)
    (he : r - W + e = n)
    (ht : t < 2 * W + 1) :
    dyadicChainCoeff n R (n - W + t + X) =
      if t = e then 1 else 0 := by
  obtain ⟨z, hz⟩ := hv
  have hterm : (2 * n) * v = 4 * n * z := by rw [hz]; ring
  have hdecomp (u : ℕ) :
      n - W + u + X = (n + 4 * n * z) + (r - W + u) := by
    rw [hX, hterm]
    omega
  by_cases hte : t = e
  · subst t
    have hvalue : n - W + e + X = 2 * n + 4 * n * z := by
      rw [hdecomp, he]
      ring
    rw [hvalue, dyadicChainCoeff_at_double_add_four_mul n R z hn hR]
    simp
  · have hztpos : 0 < r - W + t := by omega
    have hztlt : r - W + t < 2 * n := by omega
    have hztne : r - W + t ≠ n := by
      intro heq
      have : t = e := by omega
      exact hte this
    have hnot : ¬n ∣ n - W + t + X := by
      rw [hdecomp]
      have hknown : n ∣ n + 4 * n * z := by
        refine ⟨1 + 4 * z, ?_⟩
        ring
      intro hdvd
      exact (not_dvd_of_pos_lt_two_mul_ne n _ hztpos hztlt hztne)
        ((Nat.dvd_add_iff_right hknown).mpr hdvd)
    rw [dyadicChainCoeff_eq_zero_of_not_dvd n R _ hnot]
    simp [hte]

private theorem twoSpike_neg_pos_sum_eq
    (D : ℕ) (hD : 0 < D) :
    (∑ t ∈ Finset.range (D + 1),
      (if t = 0 then (-1 : ℝ) else if t = D then 1 else 0) *
        (φ⁻¹) ^ t) = -(1 - (φ⁻¹) ^ D) := by
  let f₀ : ℕ → ℝ := fun t => if t = 0 then -(φ⁻¹) ^ t else 0
  let fD : ℕ → ℝ := fun t => if t = D then (φ⁻¹) ^ t else 0
  have hD0 : D ≠ 0 := Nat.ne_of_gt hD
  have h0D : (0 : ℕ) ≠ D := Ne.symm hD0
  have hsplit :
      (∑ t ∈ Finset.range (D + 1),
        (if t = 0 then (-1 : ℝ) else if t = D then 1 else 0) *
          (φ⁻¹) ^ t) =
      (∑ t ∈ Finset.range (D + 1), f₀ t) +
        ∑ t ∈ Finset.range (D + 1), fD t := by
    rw [← Finset.sum_add_distrib]
    apply Finset.sum_congr rfl
    intro t ht
    by_cases ht0 : t = 0
    · subst t
      simp [f₀, fD, h0D]
    · by_cases htD : t = D
      · subst t
        simp [f₀, fD, hD0]
      · simp [f₀, fD, ht0, htD]
  have hs0 : (∑ t ∈ Finset.range (D + 1), f₀ t) = -(φ⁻¹) ^ 0 := by
    calc
      (∑ t ∈ Finset.range (D + 1), f₀ t) = f₀ 0 := by
        apply Finset.sum_eq_single 0
        · intro b hb hb0
          simp [f₀, hb0]
        · simp [f₀]
      _ = -(φ⁻¹) ^ 0 := by simp [f₀]
  have hsD : (∑ t ∈ Finset.range (D + 1), fD t) = (φ⁻¹) ^ D := by
    calc
      (∑ t ∈ Finset.range (D + 1), fD t) = fD D := by
        apply Finset.sum_eq_single D
        · intro b hb hbD
          simp [fD, hbD]
        · intro hnot
          exfalso
          apply hnot
          simp
      _ = (φ⁻¹) ^ D := by simp [fD]
  rw [hsplit, hs0, hsD]
  simp
  ring

private theorem twoSpike_pos_neg_sum_eq
    (D : ℕ) (hD : 0 < D) :
    (∑ t ∈ Finset.range (D + 1),
      (if t = 0 then (1 : ℝ) else if t = D then -1 else 0) *
        (φ⁻¹) ^ t) = 1 - (φ⁻¹) ^ D := by
  have hneg := twoSpike_neg_pos_sum_eq D hD
  have hD0 : D ≠ 0 := Nat.ne_of_gt hD
  calc
    (∑ t ∈ Finset.range (D + 1),
      (if t = 0 then (1 : ℝ) else if t = D then -1 else 0) *
        (φ⁻¹) ^ t) =
      -∑ t ∈ Finset.range (D + 1),
        (if t = 0 then (-1 : ℝ) else if t = D then 1 else 0) *
          (φ⁻¹) ^ t := by
            rw [← Finset.sum_neg_distrib]
            apply Finset.sum_congr rfl
            intro t ht
            by_cases ht0 : t = 0
            · subst t
              simp
            · by_cases htD : t = D
              · subst t
                simp [hD0]
              · simp [ht0, htD]
    _ = 1 - (φ⁻¹) ^ D := by rw [hneg]; ring

/-- Both orientations of a unit two-spike block have weighted absolute value at
least `1-φ⁻¹`, uniformly in their positive separation. -/
theorem one_sub_invPhi_le_abs_twoSpike_sum
    (D : ℕ) (hD : 0 < D) (positiveFirst : Bool) :
    1 - φ⁻¹ ≤
      |∑ t ∈ Finset.range (D + 1),
        (if positiveFirst then
          (if t = 0 then (1 : ℝ) else if t = D then -1 else 0)
        else
          (if t = 0 then (-1 : ℝ) else if t = D then 1 else 0)) *
          (φ⁻¹) ^ t| := by
  have hr0 : 0 ≤ (φ⁻¹ : ℝ) := inv_nonneg.mpr Real.goldenRatio_pos.le
  have hrle : (φ⁻¹ : ℝ) ≤ 1 :=
    (inv_le_one₀ Real.goldenRatio_pos).mpr Real.one_lt_goldenRatio.le
  have hpow : (φ⁻¹ : ℝ) ^ D ≤ φ⁻¹ := by
    simpa using pow_le_pow_of_le_one hr0 hrle (show 1 ≤ D by omega)
  have hpowOne : (φ⁻¹ : ℝ) ^ D ≤ 1 := hpow.trans hrle
  cases positiveFirst
  · change 1 - φ⁻¹ ≤
      |∑ t ∈ Finset.range (D + 1),
        (if t = 0 then (-1 : ℝ) else if t = D then 1 else 0) *
          (φ⁻¹) ^ t|
    rw [twoSpike_neg_pos_sum_eq D hD, abs_neg,
      abs_of_nonneg (sub_nonneg.mpr hpowOne)]
    linarith
  · change 1 - φ⁻¹ ≤
      |∑ t ∈ Finset.range (D + 1),
        (if t = 0 then (1 : ℝ) else if t = D then -1 else 0) *
          (φ⁻¹) ^ t|
    rw [twoSpike_pos_neg_sum_eq D hD,
      abs_of_nonneg (sub_nonneg.mpr hpowOne)]
    linarith

end Research

/-!
# Packaging the close near-half two-spike cluster
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- When the near-half displacement `δ` is shorter than an ambient symmetric
window `W`, a nontrivial finite dyadic chain has a two-spike mismatch block of
length `δ+1`, with equal coefficient blocks on both sides and exact weighted
size at least `1-φ⁻¹`. -/
theorem exists_dyadicChain_finiteMismatchBlock_of_close_nearHalf
    (n R W X r v : ℕ) (hn : 0 < n) (hR : 2 ≤ R)
    (hWn : W < n) (hX : X = r + (2 * n) * v) (hv : Even v)
    (hWr : W < r) (hrW : r + W < 2 * n)
    (hrne : r ≠ n) (hclose : r.dist n < W) :
    ∃ L B J : ℕ,
      L + B + J = 2 * W + 1 ∧
      B = r.dist n + 1 ∧
      W - r.dist n ≤ L ∧ W - r.dist n ≤ J ∧
      (∀ t < L,
        dyadicChainCoeff n R (n - W + t + X) =
          dyadicChainCoeff n R (n - W + t)) ∧
      1 - φ⁻¹ ≤
        |∑ t ∈ Finset.range B,
          ((dyadicChainCoeff n R (n - W + L + t + X) -
            dyadicChainCoeff n R (n - W + L + t) : ℤ) : ℝ) *
              (φ⁻¹) ^ t| ∧
      (∀ t < J,
        dyadicChainCoeff n R (n - W + L + B + t + X) =
          dyadicChainCoeff n R (n - W + L + B + t)) := by
  let δ := r.dist n
  have hδpos : 0 < δ := Nat.dist_pos_of_ne hrne
  have hroot (t : ℕ) (ht : t < 2 * W + 1) :
      dyadicChainCoeff n R (n - W + t) = if t = W then 1 else 0 :=
    dyadicChainCoeff_local_root_formula n R W t hn (by omega) hWn ht
  rcases lt_or_gt_of_ne hrne with hrn | hnr
  · have hδ : δ = n - r := Nat.dist_eq_sub_of_le hrn.le
    let e := W + δ
    have he : r - W + e = n := by dsimp [e]; rw [hδ]; omega
    have heRange : e < 2 * W + 1 := by dsimp [e]; omega
    have hshift (t : ℕ) (ht : t < 2 * W + 1) :
        dyadicChainCoeff n R (n - W + t + X) =
          if t = e then 1 else 0 :=
      dyadicChainCoeff_local_shift_formula n R W X r v e t hn hR
        hWn hX hv hWr hrW he ht
    refine ⟨W, δ + 1, W - δ, ?_, rfl, by omega, by omega, ?_, ?_, ?_⟩
    · omega
    · intro t ht
      rw [hshift t (by omega), hroot t (by omega)]
      have hte : t ≠ e := by dsimp [e]; omega
      have htw : t ≠ W := by omega
      simp [hte, htw]
    · calc
        1 - φ⁻¹ ≤
          |∑ t ∈ Finset.range (δ + 1),
            (if t = 0 then (-1 : ℝ) else if t = δ then 1 else 0) *
              (φ⁻¹) ^ t| :=
                one_sub_invPhi_le_abs_twoSpike_sum δ hδpos false
        _ = |∑ t ∈ Finset.range (δ + 1),
          ((dyadicChainCoeff n R (n - W + W + t + X) -
            dyadicChainCoeff n R (n - W + W + t) : ℤ) : ℝ) *
              (φ⁻¹) ^ t| := by
          congr 1
          apply Finset.sum_congr rfl
          intro t ht
          have htδ : t < δ + 1 := Finset.mem_range.mp ht
          have hglobal : W + t < 2 * W + 1 := by omega
          rw [show n - W + W + t + X = n - W + (W + t) + X by omega,
            show n - W + W + t = n - W + (W + t) by omega,
            hshift (W + t) hglobal, hroot (W + t) hglobal]
          by_cases ht0 : t = 0
          · subst t
            simp [e, hδpos.ne']
          · by_cases htδeq : t = δ
            · subst t
              simp [e, hδpos.ne']
            · have hneE : W + t ≠ e := by dsimp [e]; omega
              simp [ht0, htδeq, hneE]
    · intro t ht
      let g := W + (δ + 1) + t
      have hg : g < 2 * W + 1 := by dsimp [g]; omega
      rw [show n - W + W + (δ + 1) + t + X =
          n - W + g + X by dsimp [g]; omega,
        show n - W + W + (δ + 1) + t = n - W + g by
          dsimp [g]; omega,
        hshift g hg, hroot g hg]
      have hge : g ≠ e := by dsimp [g, e]; omega
      have hgw : g ≠ W := by dsimp [g]; omega
      simp [hge, hgw]
  · have hδ : δ = r - n := Nat.dist_eq_sub_of_le_right hnr.le
    let e := W - δ
    have he : r - W + e = n := by dsimp [e]; rw [hδ]; omega
    have heRange : e < 2 * W + 1 := by dsimp [e]; omega
    have hshift (t : ℕ) (ht : t < 2 * W + 1) :
        dyadicChainCoeff n R (n - W + t + X) =
          if t = e then 1 else 0 :=
      dyadicChainCoeff_local_shift_formula n R W X r v e t hn hR
        hWn hX hv hWr hrW he ht
    refine ⟨W - δ, δ + 1, W, ?_, rfl, by omega, by omega, ?_, ?_, ?_⟩
    · omega
    · intro t ht
      rw [hshift t (by omega), hroot t (by omega)]
      have hte : t ≠ e := by dsimp [e]; omega
      have htw : t ≠ W := by omega
      simp [hte, htw]
    · calc
        1 - φ⁻¹ ≤
          |∑ t ∈ Finset.range (δ + 1),
            (if t = 0 then (1 : ℝ) else if t = δ then -1 else 0) *
              (φ⁻¹) ^ t| :=
                one_sub_invPhi_le_abs_twoSpike_sum δ hδpos true
        _ = |∑ t ∈ Finset.range (δ + 1),
          ((dyadicChainCoeff n R (n - W + (W - δ) + t + X) -
            dyadicChainCoeff n R (n - W + (W - δ) + t) : ℤ) : ℝ) *
              (φ⁻¹) ^ t| := by
          congr 1
          apply Finset.sum_congr rfl
          intro t ht
          have htδ : t < δ + 1 := Finset.mem_range.mp ht
          have hglobal : W - δ + t < 2 * W + 1 := by omega
          rw [show n - W + (W - δ) + t + X =
              n - W + (W - δ + t) + X by omega,
            show n - W + (W - δ) + t =
              n - W + (W - δ + t) by omega,
            hshift (W - δ + t) hglobal,
            hroot (W - δ + t) hglobal]
          by_cases ht0 : t = 0
          · subst t
            have hsubne : W - δ ≠ W := by omega
            simp [e, hsubne]
          · by_cases htδeq : t = δ
            · subst t
              have hsum : W - δ + δ = W := by omega
              have hWne : W ≠ W - δ := by omega
              rw [hsum]
              simp [e, hWne, ht0]
            · have hneE : W - δ + t ≠ e := by dsimp [e]; omega
              have hneW : W - δ + t ≠ W := by omega
              simp [ht0, htδeq, hneE, hneW]
    · intro t ht
      let g := W - δ + (δ + 1) + t
      have hg : g < 2 * W + 1 := by dsimp [g]; omega
      rw [show n - W + (W - δ) + (δ + 1) + t + X =
          n - W + g + X by dsimp [g]; omega,
        show n - W + (W - δ) + (δ + 1) + t = n - W + g by
          dsimp [g]; omega,
        hshift g hg, hroot g hg]
      have hge : g ≠ e := by dsimp [g, e]; omega
      have hgw : g ≠ W := by dsimp [g]; omega
      simp [hge, hgw]

end Research

/-!
# Transporting a complete finite-block difference word through the protected sieve
-/

namespace Research

/-- If every component outside a finite block agrees, the full coefficient
difference is exactly the aggregate block difference. -/
theorem selectedFibLambertCoeff_sub_eq_finsetBlock_sub
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (B : Finset ℕ) (H a b : ℕ)
    (hBH : ∀ k ∈ B, k < H)
    (hout : ∀ k, k ∉ B →
      fibLambertCoeff (n k) a = fibLambertCoeff (n k) b) :
    selectedFibLambertCoeff n a - selectedFibLambertCoeff n b =
      selectedPositionFinsetCoeff n B a -
        selectedPositionFinsetCoeff n B b := by
  let Q := max (max a b) H
  have haQ : a ≤ Q := le_trans (le_max_left _ _) (le_max_left _ _)
  have hbQ : b ≤ Q := le_trans (le_max_right _ _) (le_max_left _ _)
  have hHQ : H ≤ Q := le_max_right _ _
  have hBsub : B ⊆ Finset.range Q := by
    intro k hk
    exact Finset.mem_range.mpr ((hBH k hk).trans_le hHQ)
  rw [← prefixFibLambertCoeff_eq_selected n hpos hmono haQ,
    ← prefixFibLambertCoeff_eq_selected n hpos hmono hbQ]
  unfold prefixFibLambertCoeff
  have houtsum :
      (∑ k ∈ Finset.range Q \ B, fibLambertCoeff (n k) a) =
        ∑ k ∈ Finset.range Q \ B, fibLambertCoeff (n k) b := by
    apply Finset.sum_congr rfl
    intro k hk
    exact hout k (Finset.mem_sdiff.mp hk).2
  have hsplitA := Finset.sum_sdiff
    (f := fun k => fibLambertCoeff (n k) a) hBsub
  have hsplitB := Finset.sum_sdiff
    (f := fun k => fibLambertCoeff (n k) b) hBsub
  unfold selectedPositionFinsetCoeff
  omega

/-- The protected outside-block sieve transports not merely one mismatch, but
the complete coefficient-difference word of the distinguished finite block
through an arbitrary finite comparison window. -/
theorem exists_full_difference_word_of_finsetBlock_protectedSieve
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H W A X p R : ℕ) (B : Finset ℕ)
    (hA : 0 < A) (hKH : K < H)
    (hKB : K ∈ B) (hBupper : ∀ k ∈ B, k < H)
    (hprefix : ∀ k < K, fibLambertPeriod (n k) ∣ X)
    (hblockPeriod : ∀ k ∈ B, fibLambertPeriod (n k) ∣ p)
    (C O : Finset ((ℕ × ℕ) × Bool))
    (hpartition : C ∪ O =
      compatibleOutsideTwoWindowConditions n K H W A X p B)
    (hbudget :
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p R).card)
    (hcut : A + p * R + X + W < n H) :
    ∃ t < R,
      let N := A + p * t
      ∀ u < W,
        selectedFibLambertCoeff n (N + u + X) -
            selectedFibLambertCoeff n (N + u) =
          selectedPositionFinsetCoeff n B (A + u + X) -
            selectedPositionFinsetCoeff n B (A + u) := by
  obtain ⟨t, htR, hav⟩ :=
    exists_two_windows_avoiding_outside_block_protected
      n hpos hmono K H W A X p R B hA hKH C O hpartition hbudget hcut
  let N := A + p * t
  have htransport (u : ℕ) :
      selectedPositionFinsetCoeff n B (N + u) =
        selectedPositionFinsetCoeff n B (A + u) := by
    have hp := selectedPositionFinsetCoeff_add_period_mul
      n B p (A + u) t hblockPeriod
    simpa [N, add_assoc, add_comm, add_left_comm] using hp
  have htransportX (u : ℕ) :
      selectedPositionFinsetCoeff n B (N + u + X) =
        selectedPositionFinsetCoeff n B (A + u + X) := by
    have hp := selectedPositionFinsetCoeff_add_period_mul
      n B p (A + u + X) t hblockPeriod
    simpa [N, add_assoc, add_comm, add_left_comm] using hp
  have hout (u : ℕ) (hu : u < W) (k : ℕ) (hkB : k ∉ B) :
      fibLambertCoeff (n k) (N + u + X) =
        fibLambertCoeff (n k) (N + u) := by
    by_cases hkK : k < K
    · exact prefix_component_eq_of_minimal_period n K X hprefix k hkK
    · have hKle : K ≤ k := by omega
      have hkNe : k ≠ K := fun heq => hkB (heq ▸ hKB)
      have hKk : K < k := lt_of_le_of_ne hKle (Ne.symm hkNe)
      have hz := hav k hKk hkB u hu
      rw [fibLambertCoeff_eq_zero_of_not_dvd _ _ hz.2,
        fibLambertCoeff_eq_zero_of_not_dvd _ _ hz.1]
  refine ⟨t, htR, ?_⟩
  dsimp only
  intro u hu
  rw [selectedFibLambertCoeff_sub_eq_finsetBlock_sub
    n hpos hmono B H _ _ hBupper (hout u hu),
    htransportX, htransport]

end Research

/-!
# Protected finite mismatch-block gate for an arbitrary quadratic total pair
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- A protected outside-block sieve, a finite aggregate mismatch block with a
fixed weighted lower bound, and the two quadratic norm caps contradict any
fixed scaled golden principal/conjugate pair. -/
theorem finsetBlock_protected_finiteMismatchBlock_pair_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (K H L Bword J A X p R : ℕ) (B : Finset ℕ) (η : ℝ)
    (hA : 0 < A) (hKH : K < H)
    (hKB : K ∈ B) (hBupper : ∀ k ∈ B, k < H)
    (hprefix : ∀ k < K, fibLambertPeriod (n k) ∣ X)
    (hblockPeriod : ∀ k ∈ B, fibLambertPeriod (n k) ∣ p)
    (htargetPre : ∀ s < L,
      selectedPositionFinsetCoeff n B (A + s + X) =
        selectedPositionFinsetCoeff n B (A + s))
    (htargetBlockLower : η ≤
      |∑ s ∈ Finset.range Bword,
        ((selectedPositionFinsetCoeff n B (A + L + s + X) -
          selectedPositionFinsetCoeff n B (A + L + s) : ℤ) : ℝ) *
            (φ⁻¹) ^ s|)
    (htargetPost : ∀ s < J,
      selectedPositionFinsetCoeff n B (A + L + Bword + s + X) =
        selectedPositionFinsetCoeff n B (A + L + Bword + s))
    (C O : Finset ((ℕ × ℕ) × Bool))
    (hpartition : C ∪ O = compatibleOutsideTwoWindowConditions n K H
      (L + Bword + J) A X p B)
    (hbudget :
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p R).card)
    (hcut : A + p * R + X + (L + Bword + J) < n H)
    (hsmallPost : ∀ t < R,
      let N := A + p * t
      (φ⁻¹) ^ (Bword + J) *
        (indexCountTailBound n (N + X + L + Bword + J) +
          indexCountTailBound n (N + L + Bword + J)) < η)
    (hsmallPre : ∀ t < R,
      let N := A + p * t
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + X + L) +
            indexCountTailBound n (N + L)) *
        (indexCountConjugateBound n Tconj (N + X) +
          indexCountConjugateBound n Tconj N) <
      (((qden : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  obtain ⟨t, htR, hword⟩ :=
    exists_full_difference_word_of_finsetBlock_protectedSieve
      n hpos hmono K H (L + Bword + J) A X p R B hA hKH hKB
        hBupper hprefix hblockPeriod C O hpartition hbudget hcut
  let N := A + p * t
  apply selected_finiteMismatchBlock_pair_obstruction
    n hpos hmono qden hqden T Tconj hsum htotal
      (N + X) N L Bword J η
  · intro s hs
    have hd := hword s (by omega)
    apply sub_eq_zero.mp
    calc
      selectedFibLambertCoeff n (N + X + s) -
          selectedFibLambertCoeff n (N + s) =
        selectedPositionFinsetCoeff n B (A + s + X) -
          selectedPositionFinsetCoeff n B (A + s) := by
            simpa [N, add_assoc, add_comm, add_left_comm] using hd
      _ = 0 := sub_eq_zero.mpr (htargetPre s hs)
  · calc
      η ≤ |∑ s ∈ Finset.range Bword,
        ((selectedPositionFinsetCoeff n B (A + L + s + X) -
          selectedPositionFinsetCoeff n B (A + L + s) : ℤ) : ℝ) *
            (φ⁻¹) ^ s| := htargetBlockLower
      _ = |∑ s ∈ Finset.range Bword,
        ((selectedFibLambertCoeff n (N + X + L + s) -
          selectedFibLambertCoeff n (N + L + s) : ℤ) : ℝ) *
            (φ⁻¹) ^ s| := by
        congr 1
        apply Finset.sum_congr rfl
        intro s hs
        have hsB : s < Bword := Finset.mem_range.mp hs
        have hd := hword (L + s) (by omega)
        congr 1
        exact_mod_cast (by
          simpa [N, add_assoc, add_comm, add_left_comm] using hd.symm)
  · intro s hs
    have hd := hword (L + Bword + s) (by omega)
    apply sub_eq_zero.mp
    calc
      selectedFibLambertCoeff n (N + X + L + Bword + s) -
          selectedFibLambertCoeff n (N + L + Bword + s) =
        selectedPositionFinsetCoeff n B (A + L + Bword + s + X) -
          selectedPositionFinsetCoeff n B (A + L + Bword + s) := by
            simpa [N, add_assoc, add_comm, add_left_comm] using hd
      _ = 0 := sub_eq_zero.mpr (htargetPost s hs)
  · simpa [N, add_assoc, add_comm, add_left_comm] using hsmallPost t htR
  · simpa [N, add_assoc, add_comm, add_left_comm] using hsmallPre t htR

/-- Uniform cutoff reduction for the finite mismatch-block norm hypotheses. -/
theorem uniform_finsetBlock_finiteMismatch_pair_norm_bounds_of_cutoff
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (qden : ℕ) (Tconj η : ℝ)
    (H L Bword J A X p R : ℕ) (hp : 0 < p)
    (hcut : A + p * R + X + (L + Bword + J) < n H)
    (hpostCap :
      (φ⁻¹) ^ (Bword + J) * (2 * cutoffTailCap H) < η)
    (hpreCap :
      (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap Tconj H) <
        (((qden : ℕ) : ℝ)⁻¹) ^ 2) :
    (∀ t < R,
      let N := A + p * t
      (φ⁻¹) ^ (Bword + J) *
        (indexCountTailBound n (N + X + L + Bword + J) +
          indexCountTailBound n (N + L + Bword + J)) < η) ∧
    (∀ t < R,
      let N := A + p * t
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + X + L) +
            indexCountTailBound n (N + L)) *
        (indexCountConjugateBound n Tconj (N + X) +
          indexCountConjugateBound n Tconj N) <
      (((qden : ℕ) : ℝ)⁻¹) ^ 2) := by
  have htailCapNonneg := cutoffTailCap_nonneg H
  have hconjCapNonneg := cutoffConjugateCap_nonneg Tconj H
  constructor
  · intro t ht
    let N := A + p * t
    have hpt : p * t < p * R := (Nat.mul_lt_mul_left hp).mpr ht
    have hx₁ : N + X + L + Bword + J < n H := by dsimp [N]; omega
    have hx₂ : N + L + Bword + J < n H := by dsimp [N]; omega
    have hb₁ := indexCountTailBound_le_cutoffTailCap n hpos hmono hx₁
    have hb₂ := indexCountTailBound_le_cutoffTailCap n hpos hmono hx₂
    calc
      (φ⁻¹) ^ (Bword + J) *
          (indexCountTailBound n (N + X + L + Bword + J) +
            indexCountTailBound n (N + L + Bword + J)) ≤
        (φ⁻¹) ^ (Bword + J) * (2 * cutoffTailCap H) := by
          gcongr
          linarith
      _ < η := hpostCap
  · intro t ht
    let N := A + p * t
    have hpt : p * t < p * R := (Nat.mul_lt_mul_left hp).mpr ht
    have hxN : N < n H := by dsimp [N]; omega
    have hxNX : N + X < n H := by dsimp [N]; omega
    have hxL : N + L < n H := by dsimp [N]; omega
    have hxXL : N + X + L < n H := by dsimp [N]; omega
    have ht₁ := indexCountTailBound_le_cutoffTailCap n hpos hmono hxXL
    have ht₂ := indexCountTailBound_le_cutoffTailCap n hpos hmono hxL
    have hc₁ := indexCountConjugateBound_le_cutoffConjugateCap
      n hpos hmono Tconj hxNX
    have hc₂ := indexCountConjugateBound_le_cutoffConjugateCap
      n hpos hmono Tconj hxN
    have htailSum :
        indexCountTailBound n (N + X + L) +
          indexCountTailBound n (N + L) ≤ 2 * cutoffTailCap H := by
      linarith
    have hconjSum :
        indexCountConjugateBound n Tconj (N + X) +
          indexCountConjugateBound n Tconj N ≤
        2 * cutoffConjugateCap Tconj H := by
      linarith
    have hconjSumNonneg : 0 ≤
        indexCountConjugateBound n Tconj (N + X) +
          indexCountConjugateBound n Tconj N := by
      unfold indexCountConjugateBound
      have hden : 0 < 1 - φ⁻¹ := sub_pos.mpr
        (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
      positivity
    have hfirstNonneg : 0 ≤
        (φ⁻¹) ^ L * (2 * cutoffTailCap H) := by positivity
    calc
      (φ⁻¹) ^ L *
          (indexCountTailBound n (N + X + L) +
            indexCountTailBound n (N + L)) *
        (indexCountConjugateBound n Tconj (N + X) +
          indexCountConjugateBound n Tconj N) ≤
        (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
          (indexCountConjugateBound n Tconj (N + X) +
            indexCountConjugateBound n Tconj N) := by
          gcongr
      _ ≤ (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
          (2 * cutoffConjugateCap Tconj H) :=
        mul_le_mul_of_nonneg_left hconjSum hfirstNonneg
      _ < (((qden : ℕ) : ℝ)⁻¹) ^ 2 := hpreCap

end Research

/-!
# Adaptive cardinality, period, and off-budget bounds after deleting a block
-/

namespace Research

open scoped BigOperators

/-- Filtering a finite target block cannot increase the two-per-position bound
for canonical protected primes. -/
theorem nearHalfOutsideBlock_centerPrimeFactors_card_le
    (n : ℕ → ℕ) (K G W A X p L sR : ℕ) (B : Finset ℕ) :
    (centerPrimeFactors
      (nearHalfOutsideBlockCenterReducedModuli
        n K G W A X p L sR B)).card ≤
      2 * (laterPositionRange K G).card := by
  calc
    (centerPrimeFactors
      (nearHalfOutsideBlockCenterReducedModuli
        n K G W A X p L sR B)).card ≤
      (nearHalfOutsideBlockCenterReducedModuli
        n K G W A X p L sR B).card := Finset.card_image_le
    _ ≤ (nearHalfOutsideBlockCenterConditions
        n K G W A X p L sR B).card := Finset.card_image_le
    _ ≤ (nearHalfCenterConditions n K G W A X p L sR).card :=
      Finset.card_filter_le _ _
    _ ≤ 2 * (laterPositionRange K G).card :=
      nearHalfCenterConditions_card_le n K G W A X p L sR

/-- Every canonical prime left after filtering is bounded by any common upper
bound for selected values between `K` and `G`. -/
theorem nearHalfOutsideBlock_centerPrime_le_threshold
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K G W A X p L sR Bval z : ℕ) (Block : Finset ℕ)
    (hbound : ∀ j, K < j → j < G → n j ≤ Bval)
    (hz : z ∈ centerPrimeFactors
      (nearHalfOutsideBlockCenterReducedModuli
        n K G W A X p L sR Block)) :
    z ≤ Bval := by
  obtain ⟨q, hqQ, hqz⟩ :=
    (mem_centerPrimeFactors_iff
      (nearHalfOutsideBlockCenterReducedModuli
        n K G W A X p L sR Block) z).mp hz
  obtain ⟨u, huC, hqu⟩ := Finset.mem_image.mp hqQ
  rw [← hqz, ← hqu]
  have huOld := (Finset.mem_filter.mp huC).1
  have huCompat := (Finset.mem_filter.mp huOld).1
  have huBase := (Finset.mem_filter.mp huCompat).1
  have huOuter := Finset.mem_product.mp huBase
  have huInner := Finset.mem_product.mp huOuter.1
  have huPos := Finset.mem_filter.mp huInner.1
  have hjG := Finset.mem_range.mp huPos.1
  have hqpos : 0 < n u.1.1 / (n u.1.1).gcd p := by
    apply Nat.div_pos
    · exact Nat.gcd_le_left p (hpos u.1.1)
    · exact Nat.gcd_pos_of_pos_left p (hpos u.1.1)
  exact (Nat.minFac_le hqpos).trans <|
    (Nat.div_le_self _ _).trans (hbound u.1.1 huPos.2 hjG)

/-- The filtered canonical CRT period obeys the same adaptive threshold-power
bound as the unfiltered one. -/
theorem nearHalfOutsideBlock_centerPrime_product_le_threshold_pow
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K G W A X p L sR Bval : ℕ) (Block : Finset ℕ)
    (hBval : 0 < Bval)
    (hbound : ∀ j, K < j → j < G → n j ≤ Bval) :
    let S := centerPrimeFactors
      (nearHalfOutsideBlockCenterReducedModuli
        n K G W A X p L sR Block)
    let d := (laterPositionRange K G).card
    (∏ z ∈ S, z) ≤ Bval ^ (2 * d) := by
  let S := centerPrimeFactors
    (nearHalfOutsideBlockCenterReducedModuli
      n K G W A X p L sR Block)
  let d := (laterPositionRange K G).card
  have hprod : (∏ z ∈ S, z) ≤ Bval ^ S.card := by
    apply Finset.prod_le_pow_card
    intro z hz
    exact nearHalfOutsideBlock_centerPrime_le_threshold
      n hpos K G W A X p L sR Bval z Block hbound hz
  have hcard : S.card ≤ 2 * d :=
    nearHalfOutsideBlock_centerPrimeFactors_card_le
      n K G W A X p L sR Block
  exact hprod.trans (pow_le_pow_right₀ (by omega) hcard)

/-- The outside-block partial-center off-budget is a sub-budget of the old
one, hence inherits its two-tail reciprocal-index estimate. -/
theorem finsetBlock_partialCenter_offBudget_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K G H L J X r v R : ℕ) (Block : Finset ℕ)
    (hKG : K < G) (hGH : G ≤ H) (hL : L < n K)
    (hX : X = r + (2 * n K) * v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C0 := nearHalfOutsideBlockCenterConditions
      n K G W A X p L sR Block
    let O := compatibleOutsideTwoWindowConditions
      n K H W A X p Block \ C0
    (∑ u ∈ O, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1)) ≤
      2 * W * ∑ j ∈ laterPositionRange K H,
        ((R * (4 * W)) / n j + 1) +
      2 * W * ∑ j ∈ Finset.Ico G H,
        ((R * (4 * n K)) / n j + 1) := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C0 := nearHalfOutsideBlockCenterConditions
    n K G W A X p L sR Block
  let O := compatibleOutsideTwoWindowConditions
    n K H W A X p Block \ C0
  let Cold := nearHalfCenterConditions n K G W A X p L sR
  let Oold := compatibleTwoWindowConditions n K H W A X p \ Cold
  have hsub : O ⊆ Oold := by
    intro u hu
    have huData := Finset.mem_sdiff.mp hu
    have huOutside := Finset.mem_filter.mp huData.1
    have huBaseOutside := Finset.mem_filter.mp huOutside.1
    have huOldCompat : u ∈ compatibleTwoWindowConditions n K H W A X p :=
      Finset.mem_filter.mpr ⟨huBaseOutside.1, huOutside.2⟩
    apply Finset.mem_sdiff.mpr
    refine ⟨huOldCompat, ?_⟩
    intro huCold
    apply huData.2
    apply Finset.mem_filter.mpr
    refine ⟨huCold, ?_⟩
    exact huBaseOutside.2
  calc
    (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) ≤
      ∑ u ∈ Oold, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1) :=
          Finset.sum_le_sum_of_subset hsub
    _ ≤ 2 * W * ∑ j ∈ laterPositionRange K H,
        ((R * (4 * W)) / n j + 1) +
      2 * W * ∑ j ∈ Finset.Ico G H,
        ((R * (4 * n K)) / n j + 1) := by
      exact partialCenter_offBudget_le n hpos K G H L J X r v R
        hKG hGH hL hX hrUpper hsRWindow

/-- The same factor-eight analytic density condition follows from the usual
adaptive bounds after filtering a finite block. -/
theorem finsetBlock_partialCenter_density_eight_of_adaptive_bounds
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K G H W A X p L sR : ℕ) (Block : Finset ℕ)
    (hbound :
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K *
            ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1) :
    let Q := nearHalfOutsideBlockCenterReducedModuli
      n K G W A X p L sR Block
    let S := centerPrimeFactors Q
    let D := (S.card + 1) * (S.card + 2)
    (8 : ℝ) * D *
      (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) < 1 := by
  let Q := nearHalfOutsideBlockCenterReducedModuli
    n K G W A X p L sR Block
  let S := centerPrimeFactors Q
  let d := (laterPositionRange K G).card
  let D := (S.card + 1) * (S.card + 2)
  let Dmax := (2 * d + 1) * (2 * d + 2)
  have hScard : S.card ≤ 2 * d :=
    nearHalfOutsideBlock_centerPrimeFactors_card_le
      n K G W A X p L sR Block
  have hD : D ≤ Dmax := by
    dsimp [D, Dmax]
    exact Nat.mul_le_mul (Nat.add_le_add_right hScard 1)
      (Nat.add_le_add_right hScard 2)
  have htail₁ := sum_laterPositionRange_inv_le
    n hpos c hc hratio K H
  have htail₂ := sum_Ico_inv_le_from n hpos c hc hratio G H
  have hinner :
      W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) ≤
      W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹) := by
    gcongr
  have hDreal : (D : ℝ) ≤ (Dmax : ℝ) := by exact_mod_cast hD
  calc
    (8 : ℝ) * D *
      (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) ≤
      8 * (Dmax : ℝ) *
      (W ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
        W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) := by
      gcongr
    _ < 1 := by simpa [d, Dmax] using hbound

end Research

/-!
# A bounded range for the outside-block partial-center protected sieve
-/

namespace Research

open scoped BigOperators

set_option maxHeartbeats 1200000

/-- A strengthened, quantitative version of F-086.  With the slightly stronger
margin `8 D Z < 1`, the protected range can be chosen no larger than the base
CRT period plus the explicit additive endpoint cost.  Exposing this upper bound
is what permits a later lacunary cutoff to dominate the entire search window. -/
theorem exists_bounded_finsetBlock_partialCenter_protected_budget
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K G H L J X r v : ℕ) (Block : Finset ℕ) (hKG : K < G) (hGH : G ≤ H)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDoubleOutside : ∀ j, K < j → j < G → j ∉ Block →
      n j ≠ 2 * n K)
    (hdensity :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let sR := n K + L - r
      let Q := nearHalfOutsideBlockCenterReducedModuli n K G W A X p L sR Block
      let S := centerPrimeFactors Q
      let D := (S.card + 1) * (S.card + 2)
      (8 : ℝ) * D *
        (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
          W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) < 1) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C0 := nearHalfOutsideBlockCenterConditions n K G W A X p L sR Block
    let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
    let Q := nearHalfOutsideBlockCenterReducedModuli n K G W A X p L sR Block
    let S := centerPrimeFactors Q
    let D := (S.card + 1) * (S.card + 2)
    let Z₁ := (laterPositionRange K H).card
    let Z₂ := (Finset.Ico G H).card
    ∃ M R : ℕ,
      0 < M ∧ M = ∏ z ∈ S, z ∧ 0 < R ∧
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      R ≤ M + 2 * D * W * (Z₁ + Z₂) := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C0 := nearHalfOutsideBlockCenterConditions n K G W A X p L sR Block
  let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
  let Q := nearHalfOutsideBlockCenterReducedModuli n K G W A X p L sR Block
  let S := centerPrimeFactors Q
  let D := (S.card + 1) * (S.card + 2)
  let Z₁ := (laterPositionRange K H).card
  let Z₂ := (Finset.Ico G H).card
  let sigma₁ : ℝ := ∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)
  let sigma₂ : ℝ := ∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)
  have hdensity' : (8 : ℝ) * D *
      (W ^ 2 * sigma₁ + W * n K * sigma₂) < 1 := by
    simpa [A, W, p, sR, Q, S, D, sigma₁, sigma₂] using hdensity
  obtain ⟨M, hM, hMeq, hprotected⟩ :=
    exists_exact_scaled_polynomially_many_nearHalf_outsideBlock_candidates
      n hpos hmono K G L J X r v Block hKG hL hX hv hrUpper
        hsRWindow hnoDoubleOutside
  have hDpos : 0 < D := by dsimp [D]; positivity
  let delta : ℝ := 2 - 8 * D *
    (W ^ 2 * sigma₁ + W * n K * sigma₂)
  have hdeltaOne : 1 < delta := by
    dsimp [delta]
    nlinarith
  have hdelta : 0 < delta := lt_trans (by norm_num) hdeltaOne
  have hden : 0 < delta * (M : ℝ) :=
    mul_pos hdelta (by exact_mod_cast hM)
  let E : ℕ := 2 * D * W * (Z₁ + Z₂)
  let q : ℝ := (E : ℝ) / (delta * (M : ℝ))
  let T : ℕ := ⌊q⌋₊ + 1
  have hqnonneg : 0 ≤ q := by
    dsimp [q]
    exact div_nonneg (by positivity) hden.le
  have hqT : q < (T : ℝ) := by
    dsimp [T]
    simpa using (Nat.lt_floor_add_one q)
  have hTpos : 0 < T := by dsimp [T]; omega
  let R := T * M
  have hRpos : 0 < R := mul_pos hTpos hM
  have hendpoint : (E : ℝ) < delta * (R : ℝ) := by
    have hm : (E : ℝ) < (T : ℝ) * (delta * (M : ℝ)) := by
      apply (div_lt_iff₀ hden).mp
      simpa [q] using hqT
    calc
      (E : ℝ) < (T : ℝ) * (delta * (M : ℝ)) := hm
      _ = delta * (R : ℝ) := by
        dsimp [R]
        push_cast
        ring
  have hRbound : R ≤ M + E := by
    have hfloor : ((⌊q⌋₊ : ℕ) : ℝ) ≤ q := Nat.floor_le hqnonneg
    have hTle : (T : ℝ) ≤ q + 1 := by
      dsimp [T]
      push_cast
      linarith
    have hqM : q * (M : ℝ) = (E : ℝ) / delta := by
      dsimp [q]
      field_simp
    have hdivle : (E : ℝ) / delta ≤ (E : ℝ) := by
      apply (div_le_iff₀ hdelta).mpr
      have hEnonneg : (0 : ℝ) ≤ E := by positivity
      nlinarith
    have hreal : (R : ℝ) ≤ (M + E : ℕ) := by
      calc
        (R : ℝ) = (T : ℝ) * (M : ℝ) := by simp [R]
        _ ≤ (q + 1) * (M : ℝ) := by gcongr
        _ = q * (M : ℝ) + (M : ℝ) := by ring
        _ = (E : ℝ) / delta + (M : ℝ) := by rw [hqM]
        _ ≤ (E : ℝ) + (M : ℝ) := by gcongr
        _ = (M + E : ℕ) := by push_cast; ring
    exact_mod_cast hreal
  let B := ∑ u ∈ O, (R / (twoWindowModulus n u /
    (twoWindowModulus n u).gcd p) + 1)
  have hBnat : B ≤
      2 * W * ∑ j ∈ laterPositionRange K H,
        ((R * (4 * W)) / n j + 1) +
      2 * W * ∑ j ∈ Finset.Ico G H,
        ((R * (4 * n K)) / n j + 1) := by
    dsimp [B]
    exact finsetBlock_partialCenter_offBudget_le n hpos K G H L J X r v R Block
      hKG hGH hL hX hrUpper hsRWindow
  have hsum₁ := cast_sum_nat_div_add_one_le
    (laterPositionRange K H) n (fun j hj => hpos j) (R * (4 * W))
  have hsum₂ := cast_sum_nat_div_add_one_le
    (Finset.Ico G H) n (fun j hj => hpos j) (R * (4 * n K))
  have hBreal : (B : ℝ) ≤
      8 * (R : ℝ) *
          (W ^ 2 * sigma₁ + W * n K * sigma₂) +
        2 * W * (Z₁ + Z₂) := by
    have hc : (B : ℝ) ≤
        ((2 * W * ∑ j ∈ laterPositionRange K H,
            ((R * (4 * W)) / n j + 1) +
          2 * W * ∑ j ∈ Finset.Ico G H,
            ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) := by
      exact_mod_cast hBnat
    push_cast at hc
    have hsum₁' :
        ((∑ j ∈ laterPositionRange K H,
          ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) ≤
          (R * (4 * W) : ℕ) * sigma₁ + Z₁ := by
      simpa [sigma₁, Z₁] using hsum₁
    have hsum₂' :
        ((∑ j ∈ Finset.Ico G H,
          ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) ≤
          (R * (4 * n K) : ℕ) * sigma₂ + Z₂ := by
      simpa [sigma₂, Z₂] using hsum₂
    have hs1 :
        ((∑ j ∈ laterPositionRange K H,
          ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) ≤
          (R : ℝ) * (4 * W : ℕ) * sigma₁ + Z₁ := by
      calc
        _ ≤ ((R * (4 * W) : ℕ) : ℝ) * sigma₁ + Z₁ := hsum₁'
        _ = (R : ℝ) * (4 * W : ℕ) * sigma₁ + Z₁ := by
          push_cast
          ring
    have hs2 :
        ((∑ j ∈ Finset.Ico G H,
          ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) ≤
          (R : ℝ) * (4 * n K : ℕ) * sigma₂ + Z₂ := by
      calc
        _ ≤ ((R * (4 * n K) : ℕ) : ℝ) * sigma₂ + Z₂ := hsum₂'
        _ = (R : ℝ) * (4 * n K : ℕ) * sigma₂ + Z₂ := by
          push_cast
          ring
    calc
      (B : ℝ) ≤
          (2 * W : ℕ) *
            ((∑ j ∈ laterPositionRange K H,
              ((R * (4 * W)) / n j + 1) : ℕ) : ℝ) +
          (2 * W : ℕ) *
            ((∑ j ∈ Finset.Ico G H,
              ((R * (4 * n K)) / n j + 1) : ℕ) : ℝ) := by
        simpa using hc
      _ ≤ (2 * W : ℕ) *
            ((R : ℝ) * (4 * W : ℕ) * sigma₁ + Z₁) +
          (2 * W : ℕ) *
            ((R : ℝ) * (4 * n K : ℕ) * sigma₂ + Z₂) := by
        exact add_le_add
          (mul_le_mul_of_nonneg_left hs1 (by positivity))
          (mul_le_mul_of_nonneg_left hs2 (by positivity))
      _ = 8 * (R : ℝ) *
          (W ^ 2 * sigma₁ + W * n K * sigma₂) +
            2 * W * (Z₁ + Z₂) := by
        push_cast
        ring
  have hDBreal : (D * B : ℕ) < 2 * R := by
    have hmain : (D : ℝ) * (B : ℝ) < 2 * (R : ℝ) := by
      have hscaled := mul_le_mul_of_nonneg_left hBreal
        (show (0 : ℝ) ≤ D by positivity)
      dsimp [delta, E] at hendpoint
      push_cast at hendpoint hscaled
      nlinarith
    exact_mod_cast hmain
  have hprot := hprotected T
  have hBcard : B < (protectedCandidates C0 (twoWindowOffset A X)
      (twoWindowModulus n) p R).card := by
    have hchain : D * B < D *
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
      calc
        D * B < 2 * R := hDBreal
        _ ≤ D * (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
            simpa [D, R, S, Q, C0, A, W, p, sR] using hprot
    exact (Nat.mul_lt_mul_left hDpos).mp hchain
  refine ⟨M, R, hM, ?_, hRpos, hBcard, ?_⟩
  · simpa [S, Q, A, W, p, sR] using hMeq
  · simpa [E, D, W, Z₁, Z₂, S, Q, A, p, sR] using hRbound

end Research

/-!
# Explicit adaptive protected cutoff
-/

namespace Research

open scoped BigOperators

/-- The adaptive protected budget at any cutoff already known to dominate its
explicit affine range cost. -/
theorem finsetBlock_partialCenter_budget_at_affine_cutoff
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K G B L J X r v H : ℕ) (Block : Finset ℕ) (hKG : K < G) (hB : 0 < B)
    (hvalues : ∀ j, K < j → j < G → n j ≤ B)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDoubleOutside : ∀ j, K < j → j < G → j ∉ Block →
      n j ≠ 2 * n K)
    (hdensity :
      let W := L + 1 + J
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1)
    (hGH : G ≤ H)
    (haffine :
      let A := n K - L
      let W := L + 1 + J
      let p := 4 * n K
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let Mmax := B ^ (2 * d)
      let U := A + p * Mmax + X + W
      let V := 4 * p * Dmax * W
      U + V * H < n H) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C0 := nearHalfOutsideBlockCenterConditions n K G W A X p L sR Block
    ∃ R : ℕ, 0 < R ∧
      let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let Q := nearHalfOutsideBlockCenterReducedModuli n K G W A X p L sR Block
  let S := centerPrimeFactors Q
  let d := (laterPositionRange K G).card
  let D := (S.card + 1) * (S.card + 2)
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := B ^ (2 * d)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  have haffine' : U + V * H < n H := by
    simpa [A, W, p, d, Dmax, Mmax, U, V] using haffine
  have hdensityH :
      let Q' := nearHalfOutsideBlockCenterReducedModuli n K G W A X p L sR Block
      let S' := centerPrimeFactors Q'
      let D' := (S'.card + 1) * (S'.card + 2)
      (8 : ℝ) * D' *
        (W ^ 2 * (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
          W * n K * (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹))) < 1 := by
    apply finsetBlock_partialCenter_density_eight_of_adaptive_bounds
      n hpos c hc hratio K G H W A X p L sR Block
    simpa [W, d] using hdensity
  obtain ⟨M, R, hM, hMeq, hR, hbudget, hRbound⟩ :=
    exists_bounded_finsetBlock_partialCenter_protected_budget
      n hpos hmono K G H L J X r v Block hKG hGH hL hX hv hrUpper
        hsRWindow hnoDoubleOutside hdensityH
  have hMle : M ≤ Mmax := by
    rw [hMeq]
    dsimp [Mmax]
    exact nearHalfOutsideBlock_centerPrime_product_le_threshold_pow
      n hpos K G W A X p L sR B Block hB hvalues
  have hDle : D ≤ Dmax := by
    have hScard : S.card ≤ 2 * d :=
      nearHalfOutsideBlock_centerPrimeFactors_card_le
        n K G W A X p L sR Block
    dsimp [D, Dmax]
    exact Nat.mul_le_mul (Nat.add_le_add_right hScard 1)
      (Nat.add_le_add_right hScard 2)
  have hZ₁ : (laterPositionRange K H).card ≤ H := by
    calc
      (laterPositionRange K H).card ≤ (Finset.range H).card :=
        Finset.card_le_card (Finset.filter_subset _ _)
      _ = H := Finset.card_range H
  have hZ₂ : (Finset.Ico G H).card ≤ H := by
    have hcard : (Finset.Ico G H).card = H - G := by simp
    omega
  have hZsum : (laterPositionRange K H).card +
      (Finset.Ico G H).card ≤ 2 * H := by omega
  have hendpointCost :
      2 * D * W * ((laterPositionRange K H).card +
        (Finset.Ico G H).card) ≤ 4 * Dmax * W * H := by
    calc
      2 * D * W * ((laterPositionRange K H).card +
          (Finset.Ico G H).card) ≤
          2 * Dmax * W * (2 * H) := by gcongr
      _ = 4 * Dmax * W * H := by ring
  have hRcoarse : R ≤ Mmax + 4 * Dmax * W * H := by
    calc
      R ≤ M + 2 * D * W * ((laterPositionRange K H).card +
          (Finset.Ico G H).card) := by
            simpa [D, S, Q, A, W, p, sR] using hRbound
      _ ≤ Mmax + 4 * Dmax * W * H :=
        Nat.add_le_add hMle hendpointCost
  have hcut : A + p * R + X + W < n H := by
    have hcost : A + p * R + X + W ≤ U + V * H := by
      calc
        A + p * R + X + W ≤
            A + p * (Mmax + 4 * Dmax * W * H) + X + W := by
          gcongr
        _ = U + V * H := by
          dsimp [U, V]
          ring
    exact hcost.trans_lt haffine'
  refine ⟨R, hR, ?_⟩
  simpa [A, W, p, sR] using And.intro hbudget hcut


end Research

/-!
# Logarithmic-size adaptive protected cutoff
-/

namespace Research

open scoped BigOperators

/-- F-098 with F-100's logarithmic affine cutoff.  The exposed `H` is small
enough for the quadratic norm caps to be dominated by sublinear coefficient
windows. -/
theorem exists_logarithmic_finsetBlock_partialCenter_budget
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (K G B L J X r v : ℕ) (Block : Finset ℕ) (hKG : K < G) (hB : 0 < B)
    (hvalues : ∀ j, K < j → j < G → n j ≤ B)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J)
    (hnoDoubleOutside : ∀ j, K < j → j < G → j ∉ Block →
      n j ≠ 2 * n K)
    (hdensity :
      let W := L + 1 + J
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let d := (laterPositionRange K G).card
    let Dmax := (2 * d + 1) * (2 * d + 2)
    let Mmax := B ^ (2 * d)
    let U := A + p * Mmax + X + W
    let V := 4 * p * Dmax * W
    let A₀ := U + V * G
    let B₀ := V * q
    let N := A₀ + B₀ + 1
    let t := Nat.clog 2 N
    let H := G + q * (4 * t + 4)
    let C0 := nearHalfOutsideBlockCenterConditions n K G W A X p L sR Block
    ∃ R : ℕ, 0 < R ∧
      let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H := by
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let d := (laterPositionRange K G).card
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := B ^ (2 * d)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  let A₀ := U + V * G
  let B₀ := V * q
  let N := A₀ + B₀ + 1
  let t := Nat.clog 2 N
  let H := G + q * (4 * t + 4)
  have hAff := logarithmic_ratio_cutoff_dominating_affine
    n hpos c hc hratio q hq G U V
  have hGH : G ≤ H := by omega
  have haffine : U + V * H < n H := by
    simpa [A₀, B₀, N, t, H] using hAff.2
  exact finsetBlock_partialCenter_budget_at_affine_cutoff
    n hpos hmono c hc hratio K G B L J X r v H Block hKG hB hvalues
      hL hX hv hrUpper hsRWindow hnoDoubleOutside hdensity hGH
      (by simpa [A, W, p, d, Dmax, Mmax, U, V] using haffine)

end Research

/-!
# Logarithmic protected cutoff for a finite target block and mismatch word
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- Finite-block analogue of the logarithmic protected pair contradiction.
The sieve geometry uses a symmetric near-half radius `w`, while the transported
target word may have an arbitrary finite central block inside that same window. -/
theorem logarithmic_adaptive_finsetBlock_pair_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (K G Bval w X r v : ℕ) (Block : Finset ℕ)
    (L Bword J : ℕ) (η : ℝ)
    (hKG : K < G) (hBval : 0 < Bval)
    (hvalues : ∀ j, K < j → j < G → n j ≤ Bval)
    (hw : w < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + w)
    (hsRWindow : n K + w - r < w + 1 + w)
    (hKB : K ∈ Block) (hBlockUpperG : ∀ k ∈ Block, k < G)
    (hnoDoubleOutside : ∀ j, K < j → j < G → j ∉ Block →
      n j ≠ 2 * n K)
    (hprefix : sharpPrefixPeriod n K ∣ X)
    (hblockPeriod : ∀ k ∈ Block, fibLambertPeriod (n k) ∣ 4 * n K)
    (hspan : L + Bword + J = w + 1 + w)
    (htargetPre : ∀ s < L,
      selectedPositionFinsetCoeff n Block (n K - w + s + X) =
        selectedPositionFinsetCoeff n Block (n K - w + s))
    (htargetBlockLower : η ≤
      |∑ s ∈ Finset.range Bword,
        ((selectedPositionFinsetCoeff n Block
              (n K - w + L + s + X) -
          selectedPositionFinsetCoeff n Block
              (n K - w + L + s) : ℤ) : ℝ) *
            (φ⁻¹) ^ s|)
    (htargetPost : ∀ s < J,
      selectedPositionFinsetCoeff n Block
          (n K - w + L + Bword + s + X) =
        selectedPositionFinsetCoeff n Block
          (n K - w + L + Bword + s))
    (hdensity :
      let W := w + 1 + w
      let d := (laterPositionRange K G).card
      (8 : ℝ) * ((2 * d + 1) * (2 * d + 2) : ℕ) *
        (W ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          W * n K * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1)
    (hpostCap :
      let A := n K - w
      let W := w + 1 + w
      let p := 4 * n K
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let Mmax := Bval ^ (2 * d)
      let U := A + p * Mmax + X + W
      let V := 4 * p * Dmax * W
      let A₀ := U + V * G
      let B₀ := V * q
      let N := A₀ + B₀ + 1
      let t := Nat.clog 2 N
      let H := G + q * (4 * t + 4)
      (φ⁻¹) ^ (Bword + J) * (2 * cutoffTailCap H) < η)
    (hpreCap :
      let A := n K - w
      let W := w + 1 + w
      let p := 4 * n K
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let Mmax := Bval ^ (2 * d)
      let U := A + p * Mmax + X + W
      let V := 4 * p * Dmax * W
      let A₀ := U + V * G
      let B₀ := V * q
      let N := A₀ + B₀ + 1
      let t := Nat.clog 2 N
      let H := G + q * (4 * t + 4)
      (φ⁻¹) ^ L * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap Tconj H) <
        (((qden : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  classical
  let A := n K - w
  let W := w + 1 + w
  let p := 4 * n K
  let sR := n K + w - r
  let d := (laterPositionRange K G).card
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := Bval ^ (2 * d)
  let U := A + p * Mmax + X + W
  let V := 4 * p * Dmax * W
  let A₀ := U + V * G
  let B₀ := V * q
  let N := A₀ + B₀ + 1
  let t := Nat.clog 2 N
  let H := G + q * (4 * t + 4)
  let C0 := nearHalfOutsideBlockCenterConditions
    n K G W A X p w sR Block
  let O := compatibleOutsideTwoWindowConditions
    n K H W A X p Block \ C0
  have hcert := exists_logarithmic_finsetBlock_partialCenter_budget
    n hpos hmono c hc hratio q hq K G Bval w w X r v Block
      hKG hBval hvalues hw hX hv hrUpper hsRWindow
      hnoDoubleOutside hdensity
  change ∃ R : ℕ, 0 < R ∧
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H at hcert
  obtain ⟨R, hR, hbudget, hcut⟩ := hcert
  have hA : 0 < A := by dsimp [A]; omega
  have hGH : G ≤ H := by dsimp [H]; omega
  have hKH : K < H := lt_of_lt_of_le hKG hGH
  have hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ X := by
    intro k hk
    exact dvd_trans (fibLambertPeriod_dvd_sharpPrefixPeriod n hk) hprefix
  have hBlockUpperH : ∀ k ∈ Block, k < H := by
    intro k hk
    exact (hBlockUpperG k hk).trans_le hGH
  have hCsub : C0 ⊆
      compatibleOutsideTwoWindowConditions n K H W A X p Block := by
    intro u hu
    have huOld := (Finset.mem_filter.mp hu).1
    have huNotBlock := (Finset.mem_filter.mp hu).2
    have huG := (Finset.mem_filter.mp huOld).1
    have huCenter := (Finset.mem_filter.mp huOld).2
    have huGdata := Finset.mem_filter.mp huG
    apply Finset.mem_filter.mpr
    refine ⟨?_, huGdata.2⟩
    apply Finset.mem_filter.mpr
    refine ⟨?_, huNotBlock⟩
    have huOuter := Finset.mem_product.mp huGdata.1
    have huInner := Finset.mem_product.mp huOuter.1
    have hjData := Finset.mem_filter.mp huInner.1
    apply Finset.mem_product.mpr
    refine ⟨Finset.mem_product.mpr ⟨?_, huInner.2⟩, huOuter.2⟩
    apply Finset.mem_filter.mpr
    exact ⟨Finset.mem_range.mpr (lt_of_lt_of_le
      (Finset.mem_range.mp hjData.1) hGH), hjData.2⟩
  have hpartition : C0 ∪ O =
      compatibleOutsideTwoWindowConditions n K H W A X p Block :=
    Finset.union_sdiff_of_subset hCsub
  have hnorm := uniform_finsetBlock_finiteMismatch_pair_norm_bounds_of_cutoff
    n hpos hmono qden Tconj η H L Bword J A X p R
      (by dsimp [p]; omega)
      (by simpa [W, hspan] using hcut)
      (by simpa [A, W, p, d, Dmax, Mmax, U, V, A₀, B₀, N, t, H]
        using hpostCap)
      (by simpa [A, W, p, d, Dmax, Mmax, U, V, A₀, B₀, N, t, H]
        using hpreCap)
  exact finsetBlock_protected_finiteMismatchBlock_pair_contradiction
    n hpos hmono qden hqden T Tconj hsum htotal
      K H L Bword J A X p R Block η hA hKH hKB hBlockUpperH
      hperiod hblockPeriod
      (by simpa [A] using htargetPre)
      (by simpa [A] using htargetBlockLower)
      (by simpa [A] using htargetPost)
      C0 O (by simpa [W, hspan] using hpartition) hbudget
      (by simpa [W, hspan] using hcut) hnorm.1 hnorm.2

end Research

/-!
# Singleton and exact-double target blocks
-/

namespace Research

lemma fibLambertPeriod_dvd_four_mul (a : ℕ) :
    fibLambertPeriod a ∣ 4 * a := by
  unfold fibLambertPeriod
  split_ifs
  · exact ⟨2, by ring⟩
  · exact dvd_rfl

lemma selectedPositionFinsetCoeff_singleton
    (n : ℕ → ℕ) (K m : ℕ) :
    selectedPositionFinsetCoeff n {K} m =
      fibLambertCoeff (n K) m := by
  simp [selectedPositionFinsetCoeff]

lemma selectedPositionFinsetCoeff_pair_eq_dyadicChain_two
    (n : ℕ → ℕ) (K j m : ℕ) (hKj : K < j)
    (hj : n j = 2 * n K) :
    selectedPositionFinsetCoeff n {K, j} m =
      dyadicChainCoeff (n K) 2 m := by
  have hKne : K ∉ ({j} : Finset ℕ) := by simp [ne_of_lt hKj]
  unfold selectedPositionFinsetCoeff dyadicChainCoeff
  rw [Finset.sum_insert hKne]
  simp [hj, Finset.sum_range_succ]
  congr 1
  omega

lemma singleton_period_dvd_four_root
    (n : ℕ → ℕ) (K : ℕ) :
    ∀ k ∈ ({K} : Finset ℕ),
      fibLambertPeriod (n k) ∣ 4 * n K := by
  intro k hk
  have hkEq : k = K := Finset.mem_singleton.mp hk
  subst k
  exact fibLambertPeriod_dvd_four_mul (n K)

lemma pair_period_dvd_four_root
    (n : ℕ → ℕ) (K j : ℕ) (hj : n j = 2 * n K) :
    ∀ k ∈ ({K, j} : Finset ℕ),
      fibLambertPeriod (n k) ∣ 4 * n K := by
  intro k hk
  rcases Finset.mem_insert.mp hk with hkEq | hk
  · subst k
    exact fibLambertPeriod_dvd_four_mul (n K)
  · have hkEq : k = j := Finset.mem_singleton.mp hk
    subst k
    rw [hj]
    have heven : Even (2 * n K) := ⟨n K, by ring⟩
    rw [fibLambertPeriod, if_pos heven]
    exact ⟨1, by ring⟩

end Research

/-!
# A deliberately nonexact near-half prefix-period multiple
-/

namespace Research

/-- If the gcd step is strictly shorter than `n`, one can choose a multiple of
`P` in the lower half modulo `4n`, at positive distance at most one gcd step
from `n`.  When the nearest point is exactly `n`, take the next lattice point. -/
theorem exists_nonexact_nearHalf_evenQuotient_multiplier
    (P n : ℕ) (hn : 0 < n)
    (hglt : (4 * n).gcd P < n) :
    let g := (4 * n).gcd P
    ∃ X r v : ℕ,
      P ∣ X ∧ X < (4 * n) * P ∧
      X = r + (2 * n) * v ∧ Even v ∧
      0 < r ∧ r < 2 * n ∧ r ≠ n ∧
      r.dist n ≤ g := by
  let M := 4 * n
  let g := M.gcd P
  have hndvd : ¬2 * n ∣ P := by
    intro hd
    have htwoM : 2 * n ∣ M := by dsimp [M]; exact ⟨2, by ring⟩
    have htwoG : 2 * n ∣ g := by
      dsimp [g]
      exact Nat.dvd_gcd htwoM hd
    have hgpos : 0 < g := Nat.gcd_pos_of_pos_left P (by dsimp [M]; omega)
    have := Nat.le_of_dvd hgpos htwoG
    change g < n at hglt
    omega
  obtain ⟨X, r, v, hPX, hXbound, hX, hv, hrpos, hrlt, hnear⟩ :=
    exists_nearHalf_evenQuotient_multiplier P n hn hndvd
  by_cases hrne : r ≠ n
  · refine ⟨X, r, v, hPX, hXbound, hX, hv, hrpos, hrlt, hrne, ?_⟩
    omega
  · have hrEq : r = n := not_ne_iff.mp hrne
    have hgpos : 0 < g := Nat.gcd_pos_of_pos_left P (by dsimp [g, M]; omega)
    have hgM : g ∣ M := Nat.gcd_dvd_left M P
    have hgP : g ∣ P := Nat.gcd_dvd_right M P
    have hgn : g ∣ n := by
      rw [← hrEq]
      have hrmod : r = X % M := by
        obtain ⟨z, hz⟩ := hv
        rw [hX, hz, show 2 * n * (z + z) = M * z by
          dsimp [M]; ring,
          Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt]
        exact hrlt.trans (by dsimp [M]; omega)
      rw [hrmod]
      have hgX : g ∣ X := dvd_trans hgP hPX
      have hgTerm : g ∣ M * (X / M) := dvd_mul_of_dvd_left hgM _
      have hx := Nat.mod_add_div X M
      rw [← hx] at hgX
      exact (Nat.dvd_add_iff_left hgTerm).mpr hgX
    let q := M / g
    let P' := P / g
    let a := n / g
    let k := a + 1
    have hMFactor : g * q = M := by
      dsimp [q]
      exact Nat.mul_div_cancel' hgM
    have hPFactor : g * P' = P := by
      dsimp [P']
      exact Nat.mul_div_cancel' hgP
    have hnFactor : g * a = n := by
      dsimp [a]
      exact Nat.mul_div_cancel' hgn
    have hqpos : 0 < q := by
      dsimp [q]
      exact Nat.div_pos (Nat.gcd_le_left P (by dsimp [M]; omega)) hgpos
    have hcop : P'.Coprime q := by
      have hc := Nat.coprime_div_gcd_div_gcd (m := M) (n := P) hgpos
      exact hc.symm
    have hkpos : 0 < k := by dsimp [k]; exact Nat.succ_pos a
    have hklt : k < q := by
      have hqeq : g * q = g * (4 * a) := by
        calc
          g * q = M := hMFactor
          _ = 4 * n := rfl
          _ = 4 * (g * a) := by rw [hnFactor]
          _ = g * (4 * a) := by ring
      have hqeq' : q = 4 * a := Nat.mul_left_cancel hgpos hqeq
      dsimp [k]
      omega
    obtain ⟨u, huq, hu⟩ :=
      Nat.exists_mul_mod_eq_of_coprime k hcop (Nat.ne_of_gt hqpos)
    have hkmod : k % q = k := Nat.mod_eq_of_lt hklt
    rw [hkmod] at hu
    let r' := g * k
    let X' := P * u
    have hr'mod : r' = X' % M := by
      dsimp [r', X']
      rw [← hPFactor, ← hMFactor, mul_assoc, Nat.mul_mod_mul_left, hu]
    have hr'eq : r' = n + g := by dsimp [r', k]; rw [← hnFactor]; ring
    have hr'pos : 0 < r' := by rw [hr'eq]; omega
    have hr'lt : r' < 2 * n := by
      rw [hr'eq]
      change g < n at hglt
      omega
    let z := X' / M
    let v' := X' / (2 * n)
    have hdecomp : X' = r' + (2 * n) * (z * 2) := by
      have hx := Nat.mod_add_div X' M
      rw [← hr'mod] at hx
      calc
        X' = r' + M * (X' / M) := hx.symm
        _ = r' + (2 * n) * (z * 2) := by dsimp [M, z]; ring
    have hv' : v' = z * 2 := by
      dsimp [v']
      rw [hdecomp, Nat.add_mul_div_left r' (z * 2) (by omega : 0 < 2 * n),
        Nat.div_eq_of_lt hr'lt]
      simp
    have hPne : P ≠ 0 := by
      intro hP0
      apply hndvd
      rw [hP0]
      exact dvd_zero _
    have hPpos : 0 < P := Nat.pos_of_ne_zero hPne
    have hqM : q ≤ M := Nat.div_le_self M g
    have hX'bound : X' < (4 * n) * P := by
      dsimp [X', M] at hqM ⊢
      nlinarith
    refine ⟨X', r', v', ⟨u, rfl⟩, hX'bound, ?_, ?_, hr'pos,
      hr'lt, ?_, ?_⟩
    · rw [hdecomp, hv']
    · rw [hv']
      exact ⟨z, by ring⟩
    · rw [hr'eq]
      omega
    · have hdist : r'.dist n = g := by
        rw [hr'eq, Nat.dist_eq_sub_of_le_right (by omega)]
        omega
      rw [hdist]

end Research

/-!
# Favorable gate for a singleton or its exact-double pair
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

private lemma invPhi_pow_le_of_le {a b : ℕ} (hab : a ≤ b) :
    (φ⁻¹ : ℝ) ^ b ≤ (φ⁻¹ : ℝ) ^ a := by
  have hr0 : 0 ≤ (φ⁻¹ : ℝ) := inv_nonneg.mpr Real.goldenRatio_pos.le
  have hrle : (φ⁻¹ : ℝ) ≤ 1 :=
    (inv_le_one₀ Real.goldenRatio_pos).mpr Real.one_lt_goldenRatio.le
  exact pow_le_pow_of_le_one hr0 hrle hab

/-- In a favorable polynomial window, a deliberately nonexact near-half shift
contradicts a scaled golden total whether or not the target's exact double is
selected: exempt the singleton in the first case and the root/double pair in
the second.  Radius `3w` leaves at least `w` clear coefficients on both sides
of the pair's two-spike cluster. -/
theorem favorable_nonexact_doublePair_pair_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q)
    (K w X r v : ℕ) (hwpos : 0 < w) (hsmall : 6 * w < n K)
    (hPX : sharpPrefixPeriod n K ∣ X)
    (hXbound : X < (4 * n K) * sharpPrefixPeriod n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrlt : r < 2 * n K)
    (hrne : r ≠ n K) (hdist : r.dist (n K) < 2 * w)
    (hfirst :
      let a := 3 * w
      let W := a + 1 + a
      (5184 : ℝ) * q ^ 2 *
        (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < n K)
    (hsecond :
      let a := 3 * w
      let W := a + 1 + a
      (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < W ^ 5)
    (hcaps :
      let a := 3 * w
      let W := a + 1 + a
      let P := sharpPrefixPeriod n K
      let Bval := n K * W ^ 8
      let Qpos := 8 * q * W
      ∀ X G,
        X < (4 * n K) * P →
        G ≤ K + Qpos →
        (laterPositionRange K G).card ≤ Qpos →
        let H := adaptiveLogCutoffPosition n K G Bval a a X q
        (φ⁻¹) ^ w * (2 * cutoffTailCap H) < 1 - φ⁻¹ ∧
        (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
          (2 * cutoffConjugateCap Tconj H) <
          (((qden : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  classical
  let a := 3 * w
  let W := a + 1 + a
  let P := sharpPrefixPeriod n K
  let Bval := n K * W ^ 8
  let Qpos := 8 * q * W
  let η : ℝ := 1 - φ⁻¹
  have hapos : 0 < a := by dsimp [a]; omega
  have hWpos : 0 < W := by dsimp [W]; omega
  have hηpos : 0 < η := by
    dsimp [η]
    exact sub_pos.mpr (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
  have haN : a < n K := by dsimp [a]; omega
  have hWr : a < r := by
    rcases lt_or_gt_of_ne hrne with hrn | hnr
    · rw [Nat.dist_eq_sub_of_le hrn.le] at hdist
      dsimp [a]
      omega
    · dsimp [a]
      omega
  have hrW : r + a < 2 * n K := by
    rcases lt_or_gt_of_ne hrne with hrn | hnr
    · dsimp [a]
      omega
    · rw [Nat.dist_eq_sub_of_le_right hnr.le] at hdist
      dsimp [a]
      omega
  have hrUpper : r ≤ n K + a := by
    rcases le_total r (n K) with hrn | hnr
    · omega
    · rw [Nat.dist_eq_sub_of_le_right hnr] at hdist
      dsimp [a]
      omega
  have hsRWindow : n K + a - r < a + 1 + a := by
    rcases le_total r (n K) with hrn | hnr
    · rw [show n K + a - r = a + (n K - r) by omega]
      rw [Nat.dist_eq_sub_of_le hrn] at hdist
      dsimp [a]
      omega
    · have : n K + a - r ≤ a := by omega
      omega
  obtain ⟨G, hKG, hBG, hvalues, hGbound, hdBound⟩ :=
    exists_polynomial_threshold_package
      n hpos hmono c hc hratio q hq K W hWpos
  let d := (laterPositionRange K G).card
  have hBvalPos : 0 < Bval := by
    dsimp [Bval]
    exact mul_pos (hpos K) (pow_pos hWpos _)
  have hsimple := polynomial_threshold_simple_density_of_bounds
    c hc q W (n K) hqpos hWpos (hpos K)
      (by simpa [a, W] using hfirst)
      (by simpa [a, W] using hsecond)
  have hdensity := adaptive_density_of_polynomial_threshold
    n hpos c hc q K G W d hWpos
      (by simpa [d, Qpos] using hdBound)
      (by simpa [Bval] using hBG)
      (by simpa [Bval, Qpos] using hsimple)
  have hcap := hcaps X G
    (by simpa [P] using hXbound)
    (by simpa [Qpos] using hGbound)
    (by simpa [Qpos, d] using hdBound)
  have htwoB : 2 * n K ≤ Bval := by
    have hWge : 2 ≤ W := by dsimp [W, a]; omega
    have hWtwo : 2 ≤ W ^ 8 :=
      (show 2 ≤ 2 ^ 8 by norm_num).trans (Nat.pow_le_pow_left hWge 8)
    dsimp [Bval]
    simpa [mul_comm] using Nat.mul_le_mul_left (n K) hWtwo
  by_cases hdouble : ∃ j, K < j ∧ n j = 2 * n K
  · obtain ⟨j, hKj, hj⟩ := hdouble
    have hjG : j < G := by
      apply (hmono.lt_iff_lt).mp
      rw [hj]
      exact htwoB.trans_lt hBG
    let Block : Finset ℕ := {K, j}
    have hKB : K ∈ Block := by simp [Block]
    have hBlockUpper : ∀ k ∈ Block, k < G := by
      intro k hk
      simp only [Block, Finset.mem_insert, Finset.mem_singleton] at hk
      rcases hk with rfl | rfl
      · exact hKG
      · exact hjG
    have hnoOutside : ∀ l, K < l → l < G → l ∉ Block →
        n l ≠ 2 * n K := by
      intro l hKl hlG hlB hl
      have hlj : l = j := hmono.injective (hl.trans hj.symm)
      apply hlB
      simp [Block, hlj]
    obtain ⟨L, Bword, J, hspan, hBword, hLbound, hJbound,
        hpreChain, hblockChain, hpostChain⟩ :=
      exists_dyadicChain_finiteMismatchBlock_of_close_nearHalf
        (n K) 2 a X r v (hpos K) (by omega) haN hX hv
          hWr hrW hrne (by dsimp [a]; omega)
    have hcoeff (m : ℕ) :
        selectedPositionFinsetCoeff n Block m =
          dyadicChainCoeff (n K) 2 m := by
      exact selectedPositionFinsetCoeff_pair_eq_dyadicChain_two
        n K j m hKj hj
    have hLw : w ≤ L := by
      dsimp [a] at hLbound
      omega
    have hJw : w ≤ J := by
      dsimp [a] at hJbound
      omega
    have hpostPow : (φ⁻¹ : ℝ) ^ (Bword + J) ≤ φ⁻¹ ^ w :=
      invPhi_pow_le_of_le (by omega)
    have hprePow : (φ⁻¹ : ℝ) ^ L ≤ φ⁻¹ ^ w :=
      invPhi_pow_le_of_le hLw
    have htailNonneg : 0 ≤ 2 * cutoffTailCap
        (adaptiveLogCutoffPosition n K G Bval a a X q) := by
      have := cutoffTailCap_nonneg
        (adaptiveLogCutoffPosition n K G Bval a a X q)
      positivity
    have hconjNonneg : 0 ≤ 2 * cutoffConjugateCap Tconj
        (adaptiveLogCutoffPosition n K G Bval a a X q) := by
      have := cutoffConjugateCap_nonneg Tconj
        (adaptiveLogCutoffPosition n K G Bval a a X q)
      positivity
    apply logarithmic_adaptive_finsetBlock_pair_contradiction
      n hpos hmono c hc hratio qden hqden T Tconj hsum htotal
        q hq K G Bval a X r v Block L Bword J η hKG hBvalPos
        hvalues haN hX hv hrUpper hsRWindow hKB hBlockUpper hnoOutside
        hPX (pair_period_dvd_four_root n K j hj)
        (by dsimp [W, a]; omega)
    · intro s hs
      simpa [hcoeff] using hpreChain s hs
    · simpa [hcoeff, η] using hblockChain
    · intro s hs
      simpa [hcoeff] using hpostChain s hs
    · simpa [W, d] using hdensity
    · dsimp only
      calc
        (φ⁻¹) ^ (Bword + J) *
            (2 * cutoffTailCap
              (adaptiveLogCutoffPosition n K G Bval a a X q)) ≤
          (φ⁻¹) ^ w *
            (2 * cutoffTailCap
              (adaptiveLogCutoffPosition n K G Bval a a X q)) :=
            mul_le_mul_of_nonneg_right hpostPow htailNonneg
        _ < η := by simpa [η, P, W, Bval, Qpos, a, d] using hcap.1
    · dsimp only
      have hfirstNonneg : 0 ≤ (φ⁻¹ : ℝ) ^ L *
          (2 * cutoffTailCap
            (adaptiveLogCutoffPosition n K G Bval a a X q)) := by
        positivity
      calc
        (φ⁻¹) ^ L *
            (2 * cutoffTailCap
              (adaptiveLogCutoffPosition n K G Bval a a X q)) *
            (2 * cutoffConjugateCap Tconj
              (adaptiveLogCutoffPosition n K G Bval a a X q)) ≤
          (φ⁻¹) ^ w *
            (2 * cutoffTailCap
              (adaptiveLogCutoffPosition n K G Bval a a X q)) *
            (2 * cutoffConjugateCap Tconj
              (adaptiveLogCutoffPosition n K G Bval a a X q)) := by
            gcongr
        _ < (((qden : ℕ) : ℝ)⁻¹) ^ 2 := by
          simpa [P, W, Bval, Qpos, a, d] using hcap.2
  · let Block : Finset ℕ := {K}
    have hKB : K ∈ Block := by simp [Block]
    have hBlockUpper : ∀ k ∈ Block, k < G := by
      intro k hk
      have : k = K := by simpa [Block] using hk
      subst k
      exact hKG
    have hnoOutside : ∀ j, K < j → j < G → j ∉ Block →
        n j ≠ 2 * n K := by
      intro j hKj hjG hjB hj
      exact hdouble ⟨j, hKj, hj⟩
    have hrmod : r = X % (2 * n K) := by
      rw [hX, Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt hrlt]
    have htarget := target_component_sandwiched_pattern
      (n K) a a X r (hpos K) haN haN hrmod hWr hrW
    have hcoeff (m : ℕ) :
        selectedPositionFinsetCoeff n Block m =
          fibLambertCoeff (n K) m := by
      exact selectedPositionFinsetCoeff_singleton n K m
    let z : ℤ := selectedPositionFinsetCoeff n Block
          (n K - a + a + X) -
        selectedPositionFinsetCoeff n Block (n K - a + a)
    have hz : z ≠ 0 := by
      dsimp [z]
      exact sub_ne_zero.mpr (by simpa [hcoeff] using htarget.2.1)
    have hzone : (1 : ℝ) ≤ |(z : ℝ)| := by
      have hi := Int.one_le_abs hz
      exact_mod_cast hi
    have hηone : η ≤ 1 := by
      dsimp [η]
      have : 0 ≤ (φ⁻¹ : ℝ) := inv_nonneg.mpr Real.goldenRatio_pos.le
      linarith
    have hsingleLower : η ≤
        |∑ s ∈ Finset.range 1,
          ((selectedPositionFinsetCoeff n Block
                (n K - a + a + s + X) -
            selectedPositionFinsetCoeff n Block
                (n K - a + a + s) : ℤ) : ℝ) *
              (φ⁻¹) ^ s| := by
      simpa [z] using hηone.trans hzone
    have hpostPow : (φ⁻¹ : ℝ) ^ (1 + a) ≤ φ⁻¹ ^ w :=
      invPhi_pow_le_of_le (by dsimp [a]; omega)
    have hprePow : (φ⁻¹ : ℝ) ^ a ≤ φ⁻¹ ^ w :=
      invPhi_pow_le_of_le (by dsimp [a]; omega)
    have htailNonneg : 0 ≤ 2 * cutoffTailCap
        (adaptiveLogCutoffPosition n K G Bval a a X q) := by
      have := cutoffTailCap_nonneg
        (adaptiveLogCutoffPosition n K G Bval a a X q)
      positivity
    have hconjNonneg : 0 ≤ 2 * cutoffConjugateCap Tconj
        (adaptiveLogCutoffPosition n K G Bval a a X q) := by
      have := cutoffConjugateCap_nonneg Tconj
        (adaptiveLogCutoffPosition n K G Bval a a X q)
      positivity
    apply logarithmic_adaptive_finsetBlock_pair_contradiction
      n hpos hmono c hc hratio qden hqden T Tconj hsum htotal
        q hq K G Bval a X r v Block a 1 a η hKG hBvalPos
        hvalues haN hX hv hrUpper hsRWindow hKB hBlockUpper hnoOutside
        hPX (singleton_period_dvd_four_root n K) (by rfl)
    · intro s hs
      simpa [hcoeff] using htarget.1 s hs
    · exact hsingleLower
    · intro s hs
      simpa [hcoeff] using htarget.2.2 s hs
    · simpa [W, d] using hdensity
    · dsimp only
      calc
        (φ⁻¹) ^ (1 + a) *
            (2 * cutoffTailCap
              (adaptiveLogCutoffPosition n K G Bval a a X q)) ≤
          (φ⁻¹) ^ w *
            (2 * cutoffTailCap
              (adaptiveLogCutoffPosition n K G Bval a a X q)) :=
            mul_le_mul_of_nonneg_right hpostPow htailNonneg
        _ < η := by simpa [η, P, W, Bval, Qpos, a, d] using hcap.1
    · dsimp only
      calc
        (φ⁻¹) ^ a *
            (2 * cutoffTailCap
              (adaptiveLogCutoffPosition n K G Bval a a X q)) *
            (2 * cutoffConjugateCap Tconj
              (adaptiveLogCutoffPosition n K G Bval a a X q)) ≤
          (φ⁻¹) ^ w *
            (2 * cutoffTailCap
              (adaptiveLogCutoffPosition n K G Bval a a X q)) *
            (2 * cutoffConjugateCap Tconj
              (adaptiveLogCutoffPosition n K G Bval a a X q)) := by
            gcongr
        _ < (((qden : ℕ) : ℝ)⁻¹) ^ 2 := by
          simpa [P, W, Bval, Qpos, a, d] using hcap.2

end Research

/-!
# Exponential norm decay for a triple-radius favorable cutoff
-/

namespace Research

open Filter Topology Real goldenRatio

private lemma tripleWindowCutoff_add_one_le (q w : ℕ) :
    favorableWindowCutoffBound q (3 * w) + 1 ≤
      (60000 * (q + 5) ^ 5 + 1) * 4 ^ 40 * (w + 1) ^ 40 := by
  calc
    favorableWindowCutoffBound q (3 * w) + 1 ≤
        (60000 * (q + 5) ^ 5 + 1) * (3 * w + 1) ^ 40 :=
      favorableWindowCutoffBound_add_one_le q (3 * w)
    _ ≤ (60000 * (q + 5) ^ 5 + 1) *
        (4 * (w + 1)) ^ 40 := by gcongr; omega
    _ = (60000 * (q + 5) ^ 5 + 1) * 4 ^ 40 *
        (w + 1) ^ 40 := by rw [mul_pow]; ring

/-- Even with a cutoff sized for radius `3w`, one golden factor per original
`w` beats the polynomial principal cap. -/
theorem tendsto_tripleRadius_tailCap (q : ℕ) :
    Tendsto (fun w : ℕ =>
      (φ⁻¹) ^ w *
        (2 * cutoffTailCap (favorableWindowCutoffBound q (3 * w))))
      atTop (𝓝 0) := by
  let r : ℝ := φ⁻¹
  let A : ℝ := ((60000 * (q + 5) ^ 5 + 1) * 4 ^ 40 : ℕ)
  let C : ℝ := 2 * cutoffTailLinearConstant * A * r⁻¹
  let g : ℕ → ℝ := fun w =>
    C * ((w + 1 : ℕ) : ℝ) ^ 40 * r ^ (w + 1)
  have hrpos : 0 < r := by dsimp [r]; exact inv_pos.mpr Real.goldenRatio_pos
  have hr0 : 0 ≤ r := hrpos.le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hg : Tendsto g atTop (𝓝 0) := by
    have hbase := tendsto_pow_const_mul_const_pow_of_lt_one 40 hr0 hr1
    have hshift := hbase.comp (Filter.tendsto_add_atTop_nat 1)
    have hconst := hshift.const_mul C
    simpa [g, mul_assoc] using hconst
  apply squeeze_zero
  · intro w
    have ht := cutoffTailCap_nonneg (favorableWindowCutoffBound q (3 * w))
    positivity
  · intro w
    have hcap := cutoffTailCap_le_linear
      (favorableWindowCutoffBound q (3 * w))
    have hnat := tripleWindowCutoff_add_one_le q w
    have hcast :
        ((favorableWindowCutoffBound q (3 * w) : ℕ) : ℝ) + 1 ≤
          A * ((w + 1 : ℕ) : ℝ) ^ 40 := by
      dsimp [A]
      exact_mod_cast hnat
    have hlinear : cutoffTailCap (favorableWindowCutoffBound q (3 * w)) ≤
        cutoffTailLinearConstant * A * ((w + 1 : ℕ) : ℝ) ^ 40 := by
      calc
        _ ≤ cutoffTailLinearConstant *
            (((favorableWindowCutoffBound q (3 * w) : ℕ) : ℝ) + 1) := hcap
        _ ≤ cutoffTailLinearConstant *
            (A * ((w + 1 : ℕ) : ℝ) ^ 40) :=
          mul_le_mul_of_nonneg_left hcast cutoffTailLinearConstant_nonneg
        _ = cutoffTailLinearConstant * A *
            ((w + 1 : ℕ) : ℝ) ^ 40 := by ring
    have hrpow : 0 ≤ r ^ w := pow_nonneg hr0 _
    calc
      r ^ w * (2 * cutoffTailCap (favorableWindowCutoffBound q (3 * w))) ≤
        r ^ w * (2 * (cutoffTailLinearConstant * A *
          ((w + 1 : ℕ) : ℝ) ^ 40)) := by gcongr
      _ = C * ((w + 1 : ℕ) : ℝ) ^ 40 * r ^ (w + 1) := by
        dsimp [C]
        rw [pow_succ]
        field_simp [hrpos.ne']; ring
  · exact hg

/-- The same triple-radius cutoff is dominated by one golden factor per `w`
after multiplying principal and conjugate caps. -/
theorem tendsto_tripleRadius_normProduct (q : ℕ) (T : ℝ) :
    Tendsto (fun w : ℕ =>
      (φ⁻¹) ^ w *
        (2 * cutoffTailCap (favorableWindowCutoffBound q (3 * w))) *
        (2 * cutoffConjugateCap T
          (favorableWindowCutoffBound q (3 * w))))
      atTop (𝓝 0) := by
  let r : ℝ := φ⁻¹
  let A : ℝ := ((60000 * (q + 5) ^ 5 + 1) * 4 ^ 40 : ℕ)
  let C : ℝ := 4 * cutoffTailLinearConstant *
    cutoffConjugateLinearConstant T * A ^ 2 * r⁻¹
  let g : ℕ → ℝ := fun w =>
    C * ((w + 1 : ℕ) : ℝ) ^ 80 * r ^ (w + 1)
  have hrpos : 0 < r := by dsimp [r]; exact inv_pos.mpr Real.goldenRatio_pos
  have hr0 : 0 ≤ r := hrpos.le
  have hr1 : r < 1 := by
    dsimp [r]
    exact inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio
  have hg : Tendsto g atTop (𝓝 0) := by
    have hbase := tendsto_pow_const_mul_const_pow_of_lt_one 80 hr0 hr1
    have hshift := hbase.comp (Filter.tendsto_add_atTop_nat 1)
    have hconst := hshift.const_mul C
    simpa [g, mul_assoc] using hconst
  apply squeeze_zero
  · intro w
    have ht := cutoffTailCap_nonneg (favorableWindowCutoffBound q (3 * w))
    have hc := cutoffConjugateCap_nonneg T
      (favorableWindowCutoffBound q (3 * w))
    positivity
  · intro w
    have ht := cutoffTailCap_le_linear
      (favorableWindowCutoffBound q (3 * w))
    have hc := cutoffConjugateCap_le_linear T
      (favorableWindowCutoffBound q (3 * w))
    have hnat := tripleWindowCutoff_add_one_le q w
    have hcast :
        ((favorableWindowCutoffBound q (3 * w) : ℕ) : ℝ) + 1 ≤
          A * ((w + 1 : ℕ) : ℝ) ^ 40 := by
      dsimp [A]
      exact_mod_cast hnat
    have ht' : cutoffTailCap (favorableWindowCutoffBound q (3 * w)) ≤
        cutoffTailLinearConstant * A * ((w + 1 : ℕ) : ℝ) ^ 40 := by
      calc
        _ ≤ cutoffTailLinearConstant *
            (((favorableWindowCutoffBound q (3 * w) : ℕ) : ℝ) + 1) := ht
        _ ≤ cutoffTailLinearConstant *
            (A * ((w + 1 : ℕ) : ℝ) ^ 40) :=
          mul_le_mul_of_nonneg_left hcast cutoffTailLinearConstant_nonneg
        _ = _ := by ring
    have hc' : cutoffConjugateCap T
          (favorableWindowCutoffBound q (3 * w)) ≤
        cutoffConjugateLinearConstant T * A *
          ((w + 1 : ℕ) : ℝ) ^ 40 := by
      calc
        _ ≤ cutoffConjugateLinearConstant T *
            (((favorableWindowCutoffBound q (3 * w) : ℕ) : ℝ) + 1) := hc
        _ ≤ cutoffConjugateLinearConstant T *
            (A * ((w + 1 : ℕ) : ℝ) ^ 40) :=
          mul_le_mul_of_nonneg_left hcast
            (cutoffConjugateLinearConstant_nonneg T)
        _ = _ := by ring
    have ht0 := cutoffTailCap_nonneg (favorableWindowCutoffBound q (3 * w))
    have hc0 := cutoffConjugateCap_nonneg T
      (favorableWindowCutoffBound q (3 * w))
    have hAt : 0 ≤ cutoffTailLinearConstant * A *
        ((w + 1 : ℕ) : ℝ) ^ 40 := ht0.trans ht'
    have hAc : 0 ≤ cutoffConjugateLinearConstant T * A *
        ((w + 1 : ℕ) : ℝ) ^ 40 := hc0.trans hc'
    calc
      r ^ w * (2 * cutoffTailCap (favorableWindowCutoffBound q (3 * w))) *
          (2 * cutoffConjugateCap T
            (favorableWindowCutoffBound q (3 * w))) ≤
        r ^ w * (2 * (cutoffTailLinearConstant * A *
          ((w + 1 : ℕ) : ℝ) ^ 40)) *
          (2 * (cutoffConjugateLinearConstant T * A *
            ((w + 1 : ℕ) : ℝ) ^ 40)) := by gcongr
      _ = C * ((w + 1 : ℕ) : ℝ) ^ 80 * r ^ (w + 1) := by
        dsimp [C]
        rw [pow_succ]
        field_simp [hrpos.ne']; ring
  · exact hg

/-- Density estimates for the radius-`3w` symmetric window. -/
theorem eventually_tripleRadius_polynomialDensity
    (c : ℝ) (hc : 1 < c) (q : ℕ) :
    ∀ᶠ w : ℕ in atTop,
      let a := 3 * w
      let W := a + 1 + a
      (5184 : ℝ) * q ^ 2 *
          (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < (w : ℝ) ^ 8 ∧
        (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < (W : ℝ) ^ 5 := by
  have hinvpos : 0 < c⁻¹ := inv_pos.mpr (lt_trans zero_lt_one hc)
  have hden : 0 < 1 - c⁻¹ := sub_pos.mpr (inv_lt_one_of_one_lt₀ hc)
  let A : ℝ := (5184 : ℝ) * q ^ 2 * (c⁻¹ * (1 - c⁻¹)⁻¹)
  let B : ℝ := (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹
  have hA : 0 ≤ A := by dsimp [A]; positivity
  have hp4 : Tendsto (fun w : ℕ => (w : ℝ) ^ 4) atTop atTop :=
    (Filter.tendsto_pow_atTop (α := ℝ) (by norm_num)).comp
      (tendsto_natCast_atTop_atTop (R := ℝ))
  have hp5 : Tendsto (fun w : ℕ => (w : ℝ) ^ 5) atTop atTop :=
    (Filter.tendsto_pow_atTop (α := ℝ) (by norm_num)).comp
      (tendsto_natCast_atTop_atTop (R := ℝ))
  filter_upwards [eventually_ge_atTop 1,
    hp4.eventually_gt_atTop (7 ^ 4 * A),
    hp5.eventually_gt_atTop B] with w hw h4 h5
  have hW : 3 * w + 1 + 3 * w ≤ 7 * w := by omega
  have hw4 : 0 < (w : ℝ) ^ 4 := by positivity
  dsimp only
  constructor
  · have hstrict := mul_lt_mul_of_pos_right h4 hw4
    calc
      A * (((3 * w + 1 + 3 * w : ℕ) : ℝ) ^ 4) ≤
          A * ((7 * (w : ℝ)) ^ 4) := by
            gcongr
            exact_mod_cast hW
      _ = (7 ^ 4 * A) * (w : ℝ) ^ 4 := by ring
      _ < (w : ℝ) ^ 4 * (w : ℝ) ^ 4 := hstrict
      _ = (w : ℝ) ^ 8 := by ring
  · calc
      B < (w : ℝ) ^ 5 := h5
      _ ≤ (((3 * w + 1 + 3 * w : ℕ) : ℝ) ^ 5) := by
        gcongr
        omega

end Research

/-!
# Exact doubles no longer obstruct eventual prefix-gcd growth
-/

namespace Research

open Filter Topology Real goldenRatio

set_option maxHeartbeats 1200000

/-- Once singleton/double-pair blocks are allowed, the old `large gcd or exact
double` dichotomy sharpens to unconditional eventual large gcd. -/
theorem eventually_two_eighthRoot_le_prefixGcd_of_pair
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (q : ℕ) (hqpos : 0 < q) (hq : (2 : ℝ) ≤ c ^ q) :
    ∀ᶠ K : ℕ in atTop,
      2 * targetEighthRoot n K ≤
        (4 * n K).gcd (sharpPrefixPeriod n K) := by
  let ε : ℝ := (((qden : ℕ) : ℝ)⁻¹) ^ 2
  let η : ℝ := 1 - φ⁻¹
  have hε : 0 < ε := by dsimp [ε]; positivity
  have hη : 0 < η := by
    dsimp [η]
    exact sub_pos.mpr (inv_lt_one_of_one_lt₀ Real.one_lt_goldenRatio)
  have hevent : ∀ᶠ w : ℕ in atTop,
      2 ≤ w ∧
      (let a := 3 * w
       let W := a + 1 + a
       (5184 : ℝ) * q ^ 2 *
            (c⁻¹ * (1 - c⁻¹)⁻¹) * W ^ 4 < (w : ℝ) ^ 8 ∧
         (5184 : ℝ) * q ^ 2 * (1 - c⁻¹)⁻¹ < (W : ℝ) ^ 5) ∧
      ((φ⁻¹) ^ w *
          (2 * cutoffTailCap
            (favorableWindowCutoffBound q (3 * w))) < η ∧
       (φ⁻¹) ^ w *
          (2 * cutoffTailCap
            (favorableWindowCutoffBound q (3 * w))) *
          (2 * cutoffConjugateCap Tconj
            (favorableWindowCutoffBound q (3 * w))) < ε) := by
    exact (eventually_ge_atTop 2).and
      ((eventually_tripleRadius_polynomialDensity c hc q).and
        (((tendsto_tripleRadius_tailCap q).eventually
          (gt_mem_nhds hη)).and
         ((tendsto_tripleRadius_normProduct q Tconj).eventually
          (gt_mem_nhds hε))))
  have hroot := tendsto_targetEighthRoot_atTop n hmono
  filter_upwards [hroot.eventually hevent] with K hK
  let w := targetEighthRoot n K
  change 2 * w ≤ (4 * n K).gcd (sharpPrefixPeriod n K)
  by_contra hgnot
  have hgsmall : (4 * n K).gcd (sharpPrefixPeriod n K) < 2 * w := by omega
  have hw : 2 ≤ w := hK.1
  have hdensity := hK.2.1
  have hnorm := hK.2.2
  have hlow : w ^ 8 ≤ n K := targetEighthRoot_pow_le n K
  have hupp : n K ≤ (w + 1) ^ 8 :=
    (target_lt_eighthRoot_add_one_pow n K).le
  have h6cube : 6 ≤ w ^ 3 := by
    calc
      6 ≤ 2 ^ 3 := by norm_num
      _ ≤ w ^ 3 := Nat.pow_le_pow_left hw 3
  have h6four : 6 * w ≤ w ^ 4 := by
    calc
      6 * w ≤ w ^ 3 * w := Nat.mul_le_mul_right w h6cube
      _ = w ^ 4 := by ring
  have hfourEight : w ^ 4 < w ^ 8 :=
    Nat.pow_lt_pow_right (by omega) (by norm_num)
  have hsmall : 6 * w < n K :=
    (h6four.trans_lt hfourEight).trans_le hlow
  have hgltN : (4 * n K).gcd (sharpPrefixPeriod n K) < n K :=
    hgsmall.trans (by omega)
  obtain ⟨X, r, v, hPX, hXbound, hX, hv, _hrpos, hrlt, hrne,
      hdistle⟩ :=
    exists_nonexact_nearHalf_evenQuotient_multiplier
      (sharpPrefixPeriod n K) (n K) (hpos K) hgltN
  apply favorable_nonexact_doublePair_pair_contradiction
    n hpos hmono c hc hratio qden hqden T Tconj hsum htotal
      q hqpos hq K w X r v (by omega) hsmall hPX hXbound hX hv
      hrlt hrne (hdistle.trans_lt hgsmall)
  · dsimp only
    exact hdensity.1.trans_le (by exact_mod_cast hlow)
  · exact hdensity.2
  · let a := 3 * w
    let W := a + 1 + a
    let P := sharpPrefixPeriod n K
    let Bval := n K * W ^ 8
    let Qpos := 8 * q * W
    dsimp only
    intro X' G hX' hG hdG
    let H := adaptiveLogCutoffPosition n K G Bval a a X' q
    have hHupper : H ≤ favorableCutoffUpper n K a q := by
      exact adaptiveLogCutoffPosition_le_favorableCutoffUpper
        n hpos K a q X' G (by dsimp [a]; omega)
          (by simpa [P] using hX')
          (by simpa [Qpos, W] using hG)
          (by simpa [Qpos, W] using hdG)
    have huppA : n K ≤ (a + 1) ^ 8 := by
      have hwa : w + 1 ≤ a + 1 := by dsimp [a]; omega
      exact hupp.trans (Nat.pow_le_pow_left hwa 8)
    have hUpperWindow : favorableCutoffUpper n K a q ≤
        favorableWindowCutoffBound q a :=
      favorableCutoffUpper_le_windowCutoffBound
        n hpos hmono K a q huppA
    let HB := favorableWindowCutoffBound q (3 * w)
    have hHH : H ≤ HB := by
      simpa [HB, a] using hHupper.trans hUpperWindow
    have ht : cutoffTailCap H ≤ cutoffTailCap HB :=
      cutoffTailCap_mono hHH
    have hcj : cutoffConjugateCap Tconj H ≤
        cutoffConjugateCap Tconj HB :=
      cutoffConjugateCap_mono Tconj hHH
    have ht2 : 2 * cutoffTailCap H ≤ 2 * cutoffTailCap HB :=
      mul_le_mul_of_nonneg_left ht (by norm_num)
    have hc2 : 2 * cutoffConjugateCap Tconj H ≤
        2 * cutoffConjugateCap Tconj HB :=
      mul_le_mul_of_nonneg_left hcj (by norm_num)
    have hpow : 0 ≤ (φ⁻¹ : ℝ) ^ w := by positivity
    have htailH :
        (φ⁻¹) ^ w * (2 * cutoffTailCap H) ≤
          (φ⁻¹) ^ w * (2 * cutoffTailCap HB) :=
      mul_le_mul_of_nonneg_left ht2 hpow
    constructor
    · exact htailH.trans_lt (by simpa [η, HB] using hnorm.1)
    · have hconjH : 0 ≤ 2 * cutoffConjugateCap Tconj H := by
        exact mul_nonneg (by norm_num) (cutoffConjugateCap_nonneg Tconj H)
      have htailHB : 0 ≤
          (φ⁻¹) ^ w * (2 * cutoffTailCap HB) := by
        exact mul_nonneg hpow
          (mul_nonneg (by norm_num) (cutoffTailCap_nonneg HB))
      calc
        (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
            (2 * cutoffConjugateCap Tconj H) ≤
          (φ⁻¹) ^ w * (2 * cutoffTailCap HB) *
            (2 * cutoffConjugateCap Tconj H) :=
              mul_le_mul_of_nonneg_right htailH hconjH
        _ ≤ (φ⁻¹) ^ w * (2 * cutoffTailCap HB) *
            (2 * cutoffConjugateCap Tconj HB) :=
              mul_le_mul_of_nonneg_left hc2 htailHB
        _ < ε := by simpa [HB] using hnorm.2

end Research

/-!
# Exact count of soluble offsets for one progression modulus
-/

namespace Research

/-- In a consecutive window of length `W`, one fixed divisibility class modulo
`g>0` occurs at most `W/g+1` times. -/
theorem card_range_filter_dvd_add_le
    (g A W : ℕ) (hg : 0 < g) :
    ((Finset.range W).filter fun s => g ∣ A + s).card ≤ W / g + 1 := by
  classical
  let S := (Finset.range W).filter fun s => g ∣ A + s
  let f : ℕ → ℕ := fun s => s / g
  have hmap : Set.MapsTo f (S : Set ℕ) (Finset.range (W / g + 1) : Set ℕ) := by
    intro s hs
    have hsW : s < W := Finset.mem_range.mp (Finset.mem_filter.mp hs).1
    apply Finset.mem_range.mpr
    change s / g < W / g + 1
    have hdiv : s / g ≤ W / g :=
      Nat.div_le_div_right (Nat.le_of_lt hsW)
    exact Nat.lt_succ_of_le hdiv
  have hinj : Set.InjOn f (S : Set ℕ) := by
    intro s hs t ht heq
    have hsD : g ∣ A + s := (Finset.mem_filter.mp hs).2
    have htD : g ∣ A + t := (Finset.mem_filter.mp ht).2
    rcases le_total s t with hst | hts
    · have hdiffD : g ∣ t - s := by
        have hsub : (A + t) - (A + s) = t - s := by omega
        rw [← hsub]
        exact Nat.dvd_sub htD hsD
      have hsmod : s % g < g := Nat.mod_lt s hg
      have htmod : t % g < g := Nat.mod_lt t hg
      have hsdecomp := Nat.mod_add_div s g
      have htdecomp := Nat.mod_add_div t g
      have hdiffLt : t - s < g := by
        dsimp [f] at heq
        rw [heq] at hsdecomp
        omega
      have hzero := Nat.eq_zero_of_dvd_of_lt hdiffD hdiffLt
      omega
    · have hdiffD : g ∣ s - t := by
        have hsub : (A + s) - (A + t) = s - t := by omega
        rw [← hsub]
        exact Nat.dvd_sub hsD htD
      have hsmod : s % g < g := Nat.mod_lt s hg
      have htmod : t % g < g := Nat.mod_lt t hg
      have hsdecomp := Nat.mod_add_div s g
      have htdecomp := Nat.mod_add_div t g
      have hdiffLt : s - t < g := by
        dsimp [f] at heq
        rw [heq] at hsdecomp
        omega
      have hzero := Nat.eq_zero_of_dvd_of_lt hdiffD hdiffLt
      omega
  have hc := Finset.card_le_card_of_injOn f hmap hinj
  simpa [S] using hc

/-- The same count after translating the window by an arbitrary base. -/
theorem card_range_filter_gcd_compatible_le
    (m p A W : ℕ) (hm : 0 < m) :
    ((Finset.range W).filter fun s => m.gcd p ∣ A + s).card ≤
      W / m.gcd p + 1 := by
  exact card_range_filter_dvd_add_le (m.gcd p) A W
    (Nat.gcd_pos_of_pos_left p hm)

/-- If the compatible gcd exceeds the window length, at most one offset is
soluble. -/
theorem card_range_filter_dvd_add_le_one
    (g A W : ℕ) (hgW : W < g) :
    ((Finset.range W).filter fun s => g ∣ A + s).card ≤ 1 := by
  have hg : 0 < g := by omega
  have hc := card_range_filter_dvd_add_le g A W hg
  rw [Nat.div_eq_of_lt hgW] at hc
  simpa using hc

end Research

/-!
# Weighted budget for one component after exact compatibility counting
-/

namespace Research

open scoped BigOperators

/-- The union-bound contribution of one component and one window side is its
constant reduced-modulus cost times the number of compatible offsets. -/
theorem compatibleOffset_budget_le
    (m p A W R : ℕ) (hm : 0 < m) :
    let g := m.gcd p
    (∑ _s ∈ (Finset.range W).filter fun s => g ∣ A + s,
      (R / (m / g) + 1)) ≤
      (W / g + 1) * (R / (m / g) + 1) := by
  let g := m.gcd p
  have hg : 0 < g := Nat.gcd_pos_of_pos_left p hm
  have hc := card_range_filter_dvd_add_le g A W hg
  calc
    (∑ _s ∈ (Finset.range W).filter fun s => g ∣ A + s,
      (R / (m / g) + 1)) =
        ((Finset.range W).filter fun s => g ∣ A + s).card *
          (R / (m / g) + 1) := by simp
    _ ≤ (W / g + 1) * (R / (m / g) + 1) :=
      Nat.mul_le_mul_right _ hc

/-- For a low compatible gcd `g≤W`, the real-valued one-side budget is at most
`2RW/m + 2W/g`; the gcd cancels from the main density term. -/
theorem compatibleOffset_budget_cast_le
    (m p A W R : ℕ) (hm : 0 < m)
    (hgW : m.gcd p ≤ W) :
    ((∑ _s ∈ (Finset.range W).filter fun s => m.gcd p ∣ A + s,
      (R / (m / m.gcd p) + 1) : ℕ) : ℝ) ≤
      2 * (R : ℝ) * W / m + 2 * (W : ℝ) / m.gcd p := by
  let g := m.gcd p
  let q := m / g
  have hg : 0 < g := Nat.gcd_pos_of_pos_left p hm
  have hgm : g ∣ m := Nat.gcd_dvd_left m p
  have hq : 0 < q := Nat.div_pos (Nat.gcd_le_left p hm) hg
  have hsumNat := compatibleOffset_budget_le m p A W R hm
  have hsumCast :
      ((∑ s ∈ (Finset.range W).filter fun s => g ∣ A + s,
        (R / q + 1) : ℕ) : ℝ) ≤
      ((W / g + 1) * (R / q + 1) : ℕ) := by
    exact_mod_cast hsumNat
  have hcountCast : ((W / g + 1 : ℕ) : ℝ) ≤
      (W : ℝ) / g + 1 := by
    push_cast
    gcongr
    exact Nat.cast_div_le
  have htermCast : ((R / q + 1 : ℕ) : ℝ) ≤
      (R : ℝ) * g / m + 1 := by
    push_cast
    have hdiv : ((R / q : ℕ) : ℝ) ≤ (R : ℝ) / q := Nat.cast_div_le
    have hqcast : (q : ℝ) = (m : ℝ) / g := by
      dsimp [q, g]
      rw [Nat.cast_div hgm]
      exact_mod_cast (Nat.ne_of_gt hg)
    rw [hqcast] at hdiv
    have hmg : (0 : ℝ) < g := by exact_mod_cast hg
    have hmm : (0 : ℝ) < m := by exact_mod_cast hm
    calc
      ((R / q : ℕ) : ℝ) + 1 ≤ (R : ℝ) / ((m : ℝ) / g) + 1 := by
        linarith
      _ = (R : ℝ) * g / m + 1 := by field_simp
  have hWg : (1 : ℝ) ≤ (W : ℝ) / g := by
    have hgWreal : (g : ℝ) ≤ W := by exact_mod_cast hgW
    have hgreal : (0 : ℝ) < g := by exact_mod_cast hg
    exact (le_div_iff₀ hgreal).mpr (by simpa using hgWreal)
  have hcountTwo : (W : ℝ) / g + 1 ≤ 2 * (W : ℝ) / g := by
    calc
      (W : ℝ) / g + 1 ≤ (W : ℝ) / g + (W : ℝ) / g := by
        simpa using add_le_add_left hWg ((W : ℝ) / g)
      _ = 2 * (W : ℝ) / g := by ring
  have htermNonneg : 0 ≤ (R : ℝ) * g / m + 1 := by positivity
  have hcountNonneg : 0 ≤ ((W / g + 1 : ℕ) : ℝ) := by positivity
  calc
    ((∑ _s ∈ (Finset.range W).filter fun s => m.gcd p ∣ A + s,
      (R / (m / m.gcd p) + 1) : ℕ) : ℝ) ≤
        ((W / g + 1) * (R / q + 1) : ℕ) := by
          simpa [g, q] using hsumCast
    _ = ((W / g + 1 : ℕ) : ℝ) * ((R / q + 1 : ℕ) : ℝ) := by push_cast; ring
    _ ≤ ((W / g + 1 : ℕ) : ℝ) *
        ((R : ℝ) * g / m + 1) :=
      mul_le_mul_of_nonneg_left htermCast hcountNonneg
    _ ≤ ((W : ℝ) / g + 1) * ((R : ℝ) * g / m + 1) :=
      mul_le_mul_of_nonneg_right hcountCast htermNonneg
    _ ≤ (2 * (W : ℝ) / g) * ((R : ℝ) * g / m + 1) :=
      mul_le_mul_of_nonneg_right hcountTwo htermNonneg
    _ = 2 * (R : ℝ) * W / m + 2 * (W : ℝ) / g := by
      have hgreal : (g : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt hg)
      have hmreal : (m : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt hm)
      field_simp [hgreal, hmreal]

end Research

/-!
# Summing the gcd-cancelled budget over all low-gcd components
-/

namespace Research

open scoped BigOperators

/-- Soluble two-window conditions whose component gcd with the progression step
is no larger than the window width. -/
def lowGcdCompatibleTwoWindowConditions
    (n : ℕ → ℕ) (K H W A X p : ℕ) : Finset ((ℕ × ℕ) × Bool) :=
  (compatibleTwoWindowConditions n K H W A X p).filter fun u =>
    (n u.1.1).gcd p ≤ W

/-- Reindex the low-gcd compatible budget by selected position, side, and the
exact finite set of soluble offsets. -/
theorem lowGcdCompatible_budget_eq_component_sums
    (n : ℕ → ℕ) (K H W A X p R : ℕ) :
    (∑ u ∈ lowGcdCompatibleTwoWindowConditions n K H W A X p,
      (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) =
    ∑ j ∈ laterPositionRange K H,
      ((∑ _s ∈ (Finset.range W).filter fun s =>
          (n j).gcd p ∣ A + s,
          (R / (n j / (n j).gcd p) + 1)) +
       (∑ _s ∈ (Finset.range W).filter fun s =>
          (n j).gcd p ∣ A + X + s,
          (R / (n j / (n j).gcd p) + 1))) *
        (if (n j).gcd p ≤ W then 1 else 0) := by
  classical
  unfold lowGcdCompatibleTwoWindowConditions
  rw [Finset.sum_filter]
  unfold compatibleTwoWindowConditions
  rw [Finset.sum_filter]
  unfold twoWindowConditions
  let F : ((ℕ × ℕ) × Bool) → ℕ := fun u =>
    if (twoWindowModulus n u).gcd p ∣ twoWindowOffset A X u then
      if (n u.1.1).gcd p ≤ W then
        R / (twoWindowModulus n u / (twoWindowModulus n u).gcd p) + 1
      else 0
    else 0
  change (∑ u ∈ ((laterPositionRange K H).product
      (Finset.range W)).product Finset.univ, F u) = _
  calc
    (∑ u ∈ ((laterPositionRange K H).product
        (Finset.range W)).product Finset.univ, F u) =
      ∑ js ∈ (laterPositionRange K H).product (Finset.range W),
        ∑ b ∈ (Finset.univ : Finset Bool), F (js, b) :=
          Finset.sum_product _ _ F
    _ = ∑ j ∈ laterPositionRange K H,
        ∑ s ∈ Finset.range W,
          ∑ b ∈ (Finset.univ : Finset Bool), F ((j, s), b) :=
      Finset.sum_product _ _ _
    _ = _ := by
      apply Finset.sum_congr rfl
      intro j hj
      by_cases hg : (n j).gcd p ≤ W
      · simp [F, hg, twoWindowModulus, twoWindowOffset,
          add_assoc, add_comm, add_left_comm]
        rw [Finset.sum_add_distrib]
        congr 1
        · rw [← Finset.sum_filter]
          simp
        · rw [← Finset.sum_filter]
          simp
      · simp [F, hg, twoWindowModulus]

/-- Summed over all later positions and both window sides, the low-gcd main
budget is linear in `W`: `4RW Σ 1/n_j`; only the finite endpoint cost
`4W·#positions` remains. -/
theorem lowGcdCompatible_budget_cast_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K H W A X p R : ℕ) :
    ((∑ u ∈ lowGcdCompatibleTwoWindowConditions n K H W A X p,
      (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) ≤
      4 * (R : ℝ) * W *
          (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        4 * W * (laterPositionRange K H).card := by
  rw [lowGcdCompatible_budget_eq_component_sums]
  push_cast
  calc
    _ ≤ ∑ j ∈ laterPositionRange K H,
        (4 * (R : ℝ) * W / n j + 4 * W) := by
      apply Finset.sum_le_sum
      intro j hj
      by_cases hgW : (n j).gcd p ≤ W
      · have hleft := compatibleOffset_budget_cast_le
          (n j) p A W R (hpos j) hgW
        have hright := compatibleOffset_budget_cast_le
          (n j) p (A + X) W R (hpos j) hgW
        have hgpos : 0 < (n j).gcd p :=
          Nat.gcd_pos_of_pos_left p (hpos j)
        have hWg : (W : ℝ) / (n j).gcd p ≤ W := by
          have hgOne : (1 : ℝ) ≤ (n j).gcd p := by exact_mod_cast hgpos
          have hWnonneg : (0 : ℝ) ≤ W := by positivity
          exact (div_le_iff₀ (by exact_mod_cast hgpos)).mpr <| by
            nlinarith
        push_cast at hleft hright
        simp only [hgW, if_true, mul_one]
        calc
          _ ≤ (2 * (R : ℝ) * W / n j +
              2 * (W : ℝ) / (n j).gcd p) +
            (2 * (R : ℝ) * W / n j +
              2 * (W : ℝ) / (n j).gcd p) :=
                add_le_add hleft hright
          _ = 4 * (R : ℝ) * W / n j +
              4 * (W : ℝ) / (n j).gcd p := by ring
          _ ≤ 4 * (R : ℝ) * W / n j + 4 * W := by
            have h4 : 4 * (W : ℝ) / (n j).gcd p ≤ 4 * W := by
              calc
                4 * (W : ℝ) / (n j).gcd p =
                    4 * ((W : ℝ) / (n j).gcd p) := by ring
                _ ≤ 4 * W := mul_le_mul_of_nonneg_left hWg (by norm_num)
            exact add_le_add_right h4 _
      · simp [hgW]
        have hnj : (0 : ℝ) < n j := by exact_mod_cast hpos j
        positivity
    _ = 4 * (R : ℝ) * W *
          (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        4 * W * (laterPositionRange K H).card := by
      rw [Finset.sum_add_distrib, Finset.mul_sum]
      simp
      ring_nf

end Research

/-!
# The sparse high-gcd remainder of the compatible two-window family
-/

namespace Research

/-- Soluble conditions whose component gcd with the progression step is larger
than the window width. -/
def highGcdCompatibleTwoWindowConditions
    (n : ℕ → ℕ) (K H W A X p : ℕ) : Finset ((ℕ × ℕ) × Bool) :=
  (compatibleTwoWindowConditions n K H W A X p).filter fun u =>
    W < (n u.1.1).gcd p

/-- A high-gcd component contributes at most one soluble offset on each of the
two sides, hence at most two conditions total. -/
theorem card_highGcdCompatibleTwoWindowConditions_le
    (n : ℕ → ℕ) (K H W A X p : ℕ) :
    (highGcdCompatibleTwoWindowConditions n K H W A X p).card ≤
      2 * (laterPositionRange K H).card := by
  classical
  let S := highGcdCompatibleTwoWindowConditions n K H W A X p
  let T := (laterPositionRange K H).product (Finset.univ : Finset Bool)
  let f : ((ℕ × ℕ) × Bool) → ℕ × Bool := fun u => (u.1.1, u.2)
  have hmap : Set.MapsTo f (S : Set ((ℕ × ℕ) × Bool)) (T : Set (ℕ × Bool)) := by
    intro u hu
    have huComp : u ∈ compatibleTwoWindowConditions n K H W A X p :=
      (Finset.mem_filter.mp hu).1
    have huTwo : u ∈ twoWindowConditions K H W :=
      (Finset.mem_filter.mp huComp).1
    have hj : u.1.1 ∈ laterPositionRange K H := by
      simpa [twoWindowConditions] using
        (Finset.mem_product.mp (Finset.mem_product.mp huTwo).1).1
    exact Finset.mem_product.mpr ⟨hj, Finset.mem_univ _⟩
  have hinj : Set.InjOn f (S : Set ((ℕ × ℕ) × Bool)) := by
    intro u hu v hv huv
    have huComp := (Finset.mem_filter.mp hu).1
    have hvComp := (Finset.mem_filter.mp hv).1
    have huHigh := (Finset.mem_filter.mp hu).2
    have hvHigh := (Finset.mem_filter.mp hv).2
    have huTwo := (Finset.mem_filter.mp huComp).1
    have hvTwo := (Finset.mem_filter.mp hvComp).1
    have huCompat := (Finset.mem_filter.mp huComp).2
    have hvCompat := (Finset.mem_filter.mp hvComp).2
    dsimp [f] at huv
    have hju : u.1.1 = v.1.1 :=
      congrArg (fun z : ℕ × Bool => z.1) huv
    have hbu : u.2 = v.2 :=
      congrArg (fun z : ℕ × Bool => z.2) huv
    have hsu : u.1.2 < W := by
      have hs := (Finset.mem_product.mp (Finset.mem_product.mp huTwo).1).2
      exact Finset.mem_range.mp hs
    have hsv : v.1.2 < W := by
      have hs := (Finset.mem_product.mp (Finset.mem_product.mp hvTwo).1).2
      exact Finset.mem_range.mp hs
    let g := (n u.1.1).gcd p
    have hgW : W < g := by simpa [g] using huHigh
    have hg : 0 < g := by omega
    have huD : g ∣ A + u.1.2 + (if u.2 = true then X else 0) := by
      simpa [g, twoWindowModulus, twoWindowOffset] using huCompat
    have hvD : g ∣ A + v.1.2 + (if u.2 = true then X else 0) := by
      simpa [g, twoWindowModulus, twoWindowOffset, hju, hbu] using hvCompat
    have hsEq : u.1.2 = v.1.2 := by
      rcases le_total u.1.2 v.1.2 with hle | hle
      · have hd : g ∣ v.1.2 - u.1.2 := by
          have hsub :
              (A + v.1.2 + (if u.2 = true then X else 0)) -
                (A + u.1.2 + (if u.2 = true then X else 0)) =
                  v.1.2 - u.1.2 := by omega
          rw [← hsub]
          exact Nat.dvd_sub hvD huD
        have hlt : v.1.2 - u.1.2 < g := by omega
        have hz := Nat.eq_zero_of_dvd_of_lt hd hlt
        omega
      · have hd : g ∣ u.1.2 - v.1.2 := by
          have hsub :
              (A + u.1.2 + (if u.2 = true then X else 0)) -
                (A + v.1.2 + (if u.2 = true then X else 0)) =
                  u.1.2 - v.1.2 := by omega
          rw [← hsub]
          exact Nat.dvd_sub huD hvD
        have hlt : u.1.2 - v.1.2 < g := by omega
        have hz := Nat.eq_zero_of_dvd_of_lt hd hlt
        omega
    rcases u with ⟨⟨uj, us⟩, ub⟩
    rcases v with ⟨⟨vj, vs⟩, vb⟩
    simp only at hju hbu hsEq
    subst vj
    subst vs
    subst vb
    rfl
  have hc := Finset.card_le_card_of_injOn f hmap hinj
  have hT : T.card = 2 * (laterPositionRange K H).card := by
    simp [T, Nat.mul_comm]
  simpa [S, hT] using hc

/-- Low and high gcd conditions partition the complete compatible family. -/
theorem lowGcd_union_highGcd_eq_compatible
    (n : ℕ → ℕ) (K H W A X p : ℕ) :
    lowGcdCompatibleTwoWindowConditions n K H W A X p ∪
      highGcdCompatibleTwoWindowConditions n K H W A X p =
    compatibleTwoWindowConditions n K H W A X p := by
  classical
  ext u
  by_cases hu : u ∈ compatibleTwoWindowConditions n K H W A X p
  · simp [lowGcdCompatibleTwoWindowConditions,
      highGcdCompatibleTwoWindowConditions, hu]
    omega
  · simp [lowGcdCompatibleTwoWindowConditions,
      highGcdCompatibleTwoWindowConditions, hu]

/-- The two parts of the gcd partition are disjoint. -/
theorem disjoint_lowGcd_highGcd
    (n : ℕ → ℕ) (K H W A X p : ℕ) :
    Disjoint
      (lowGcdCompatibleTwoWindowConditions n K H W A X p)
      (highGcdCompatibleTwoWindowConditions n K H W A X p) := by
  classical
  apply Finset.disjoint_left.mpr
  intro u hlu hhu
  have hl := (Finset.mem_filter.mp hlu).2
  have hh := (Finset.mem_filter.mp hhu).2
  omega

end Research

/-!
# Linear compatible budget whenever the gcd is at most four window widths
-/

namespace Research

open scoped BigOperators

/-- The per-side gcd-cancellation estimate remains linear in `W` under the
weaker geometric bound `gcd(m,p)≤4W`. -/
theorem compatibleOffset_budget_cast_le_fourWidth
    (m p A W R : ℕ) (hm : 0 < m)
    (hgW : m.gcd p ≤ 4 * W) :
    ((∑ _s ∈ (Finset.range W).filter fun s => m.gcd p ∣ A + s,
      (R / (m / m.gcd p) + 1) : ℕ) : ℝ) ≤
      5 * (R : ℝ) * W / m + 5 * (W : ℝ) / m.gcd p := by
  let g := m.gcd p
  let q := m / g
  have hg : 0 < g := Nat.gcd_pos_of_pos_left p hm
  have hgm : g ∣ m := Nat.gcd_dvd_left m p
  have hsumNat := compatibleOffset_budget_le m p A W R hm
  have hsumCast :
      ((∑ _s ∈ (Finset.range W).filter fun s => g ∣ A + s,
        (R / q + 1) : ℕ) : ℝ) ≤
      ((W / g + 1) * (R / q + 1) : ℕ) := by
    exact_mod_cast hsumNat
  have hcountCast : ((W / g + 1 : ℕ) : ℝ) ≤
      (W : ℝ) / g + 1 := by
    push_cast
    gcongr
    exact Nat.cast_div_le
  have htermCast : ((R / q + 1 : ℕ) : ℝ) ≤
      (R : ℝ) * g / m + 1 := by
    push_cast
    have hdiv : ((R / q : ℕ) : ℝ) ≤ (R : ℝ) / q := Nat.cast_div_le
    have hqcast : (q : ℝ) = (m : ℝ) / g := by
      dsimp [q, g]
      rw [Nat.cast_div hgm]
      exact_mod_cast (Nat.ne_of_gt hg)
    rw [hqcast] at hdiv
    calc
      ((R / q : ℕ) : ℝ) + 1 ≤ (R : ℝ) / ((m : ℝ) / g) + 1 := by
        linarith
      _ = (R : ℝ) * g / m + 1 := by field_simp
  have hOne : (1 : ℝ) ≤ 4 * (W : ℝ) / g := by
    have hcast : (g : ℝ) ≤ 4 * W := by exact_mod_cast hgW
    have hgr : (0 : ℝ) < g := by exact_mod_cast hg
    exact (le_div_iff₀ hgr).mpr (by simpa [mul_comm] using hcast)
  have hcountFive : (W : ℝ) / g + 1 ≤ 5 * (W : ℝ) / g := by
    calc
      (W : ℝ) / g + 1 ≤ (W : ℝ) / g + 4 * (W : ℝ) / g :=
        add_le_add_right hOne _
      _ = 5 * (W : ℝ) / g := by ring
  have htermNonneg : 0 ≤ (R : ℝ) * g / m + 1 := by positivity
  have hcountNonneg : 0 ≤ ((W / g + 1 : ℕ) : ℝ) := by positivity
  calc
    ((∑ _s ∈ (Finset.range W).filter fun s => m.gcd p ∣ A + s,
      (R / (m / m.gcd p) + 1) : ℕ) : ℝ) ≤
        ((W / g + 1) * (R / q + 1) : ℕ) := by
          simpa [g, q] using hsumCast
    _ = ((W / g + 1 : ℕ) : ℝ) * ((R / q + 1 : ℕ) : ℝ) := by push_cast; ring
    _ ≤ ((W / g + 1 : ℕ) : ℝ) *
        ((R : ℝ) * g / m + 1) :=
      mul_le_mul_of_nonneg_left htermCast hcountNonneg
    _ ≤ ((W : ℝ) / g + 1) * ((R : ℝ) * g / m + 1) :=
      mul_le_mul_of_nonneg_right hcountCast htermNonneg
    _ ≤ (5 * (W : ℝ) / g) * ((R : ℝ) * g / m + 1) :=
      mul_le_mul_of_nonneg_right hcountFive htermNonneg
    _ = 5 * (R : ℝ) * W / m + 5 * (W : ℝ) / g := by
      have hgr : (g : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt hg)
      have hmr : (m : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt hm)
      field_simp [hgr, hmr]

/-- All compatible conditions satisfying the geometric four-width gcd bound. -/
def fourWidthGcdCompatibleTwoWindowConditions
    (n : ℕ → ℕ) (K H W A X p : ℕ) : Finset ((ℕ × ℕ) × Bool) :=
  (compatibleTwoWindowConditions n K H W A X p).filter fun u =>
    (n u.1.1).gcd p ≤ 4 * W

/-- Exact reindexing of the four-width family by component and side. -/
theorem fourWidthGcdCompatible_budget_eq_component_sums
    (n : ℕ → ℕ) (K H W A X p R : ℕ) :
    (∑ u ∈ fourWidthGcdCompatibleTwoWindowConditions n K H W A X p,
      (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) =
    ∑ j ∈ laterPositionRange K H,
      ((∑ _s ∈ (Finset.range W).filter fun s =>
          (n j).gcd p ∣ A + s,
          (R / (n j / (n j).gcd p) + 1)) +
       (∑ _s ∈ (Finset.range W).filter fun s =>
          (n j).gcd p ∣ A + X + s,
          (R / (n j / (n j).gcd p) + 1))) *
        (if (n j).gcd p ≤ 4 * W then 1 else 0) := by
  classical
  unfold fourWidthGcdCompatibleTwoWindowConditions
  rw [Finset.sum_filter]
  unfold compatibleTwoWindowConditions
  rw [Finset.sum_filter]
  unfold twoWindowConditions
  let F : ((ℕ × ℕ) × Bool) → ℕ := fun u =>
    if (twoWindowModulus n u).gcd p ∣ twoWindowOffset A X u then
      if (n u.1.1).gcd p ≤ 4 * W then
        R / (twoWindowModulus n u / (twoWindowModulus n u).gcd p) + 1
      else 0
    else 0
  change (∑ u ∈ ((laterPositionRange K H).product
      (Finset.range W)).product Finset.univ, F u) = _
  calc
    (∑ u ∈ ((laterPositionRange K H).product
        (Finset.range W)).product Finset.univ, F u) =
      ∑ js ∈ (laterPositionRange K H).product (Finset.range W),
        ∑ b ∈ (Finset.univ : Finset Bool), F (js, b) :=
          Finset.sum_product _ _ F
    _ = ∑ j ∈ laterPositionRange K H,
        ∑ s ∈ Finset.range W,
          ∑ b ∈ (Finset.univ : Finset Bool), F ((j, s), b) :=
      Finset.sum_product _ _ _
    _ = _ := by
      apply Finset.sum_congr rfl
      intro j hj
      by_cases hg : (n j).gcd p ≤ 4 * W
      · simp [F, hg, twoWindowModulus, twoWindowOffset,
          add_assoc, add_comm, add_left_comm]
        rw [Finset.sum_add_distrib]
        congr 1
        · rw [← Finset.sum_filter]
          simp
        · rw [← Finset.sum_filter]
          simp
      · simp [F, hg, twoWindowModulus]

/-- The complete four-width family over both sides has a main term linear in
`W`, plus only a finite endpoint cost. -/
theorem fourWidthGcdCompatible_budget_cast_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K H W A X p R : ℕ) :
    ((∑ u ∈ fourWidthGcdCompatibleTwoWindowConditions n K H W A X p,
      (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) ≤
      10 * (R : ℝ) * W *
          (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        10 * W * (laterPositionRange K H).card := by
  rw [fourWidthGcdCompatible_budget_eq_component_sums]
  push_cast
  calc
    _ ≤ ∑ j ∈ laterPositionRange K H,
        (10 * (R : ℝ) * W / n j + 10 * W) := by
      apply Finset.sum_le_sum
      intro j hj
      by_cases hgW : (n j).gcd p ≤ 4 * W
      · have hleft := compatibleOffset_budget_cast_le_fourWidth
          (n j) p A W R (hpos j) hgW
        have hright := compatibleOffset_budget_cast_le_fourWidth
          (n j) p (A + X) W R (hpos j) hgW
        have hgpos : 0 < (n j).gcd p :=
          Nat.gcd_pos_of_pos_left p (hpos j)
        have hWg : (W : ℝ) / (n j).gcd p ≤ W := by
          have hgOne : (1 : ℝ) ≤ (n j).gcd p := by exact_mod_cast hgpos
          exact (div_le_iff₀ (by exact_mod_cast hgpos)).mpr <| by
            have hWnonneg : (0 : ℝ) ≤ W := by positivity
            nlinarith
        push_cast at hleft hright
        simp only [hgW, if_true, mul_one]
        calc
          _ ≤ (5 * (R : ℝ) * W / n j +
              5 * (W : ℝ) / (n j).gcd p) +
            (5 * (R : ℝ) * W / n j +
              5 * (W : ℝ) / (n j).gcd p) :=
                add_le_add hleft hright
          _ = 10 * (R : ℝ) * W / n j +
              10 * (W : ℝ) / (n j).gcd p := by ring
          _ ≤ 10 * (R : ℝ) * W / n j + 10 * W := by
            have h10 : 10 * (W : ℝ) / (n j).gcd p ≤ 10 * W := by
              calc
                10 * (W : ℝ) / (n j).gcd p =
                    10 * ((W : ℝ) / (n j).gcd p) := by ring
                _ ≤ 10 * W := mul_le_mul_of_nonneg_left hWg (by norm_num)
            exact add_le_add_right h10 _
      · simp [hgW]
        have hnj : (0 : ℝ) < n j := by exact_mod_cast hpos j
        positivity
    _ = 10 * (R : ℝ) * W *
          (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        10 * W * (laterPositionRange K H).card := by
      rw [Finset.sum_add_distrib, Finset.mul_sum]
      simp
      ring_nf

end Research

/-!
# Linear-width near-half off-center budget
-/

namespace Research

open scoped BigOperators

/-- The geometric core of the near-half construction: deleting the two aligned
centers forces every remaining soluble gcd below four window widths. -/
theorem nearHalf_offCenter_gcd_le_fourWidth
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K H L J X r v : ℕ) (hL : L < n K)
    (hX : X = r + (2 * n K) * v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    ∀ u ∈ nearHalfOffCenterConditions n K H W A X p L sR,
      (twoWindowModulus n u).gcd p ≤ 4 * W := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C := nearHalfCenterConditions n K H W A X p L sR
  let I := compatibleTwoWindowConditions n K H W A X p
  let O := nearHalfOffCenterConditions n K H W A X p L sR
  have hcenterRight : A + sR + X = 2 * n K * (v + 1) := by
    have hsrr : sR + r = n K + L := by dsimp [sR]; omega
    rw [hX]
    calc
      A + sR + (r + 2 * n K * v) =
          2 * n K + 2 * n K * v := by
        dsimp [A]
        omega
      _ = 2 * n K * (v + 1) := by ring
  have hspecialRight : 4 * n K ∣ 2 * (A + sR + X) := by
    rw [hcenterRight]
    exact ⟨v + 1, by ring⟩
  dsimp only
  intro u huO
  have huData := Finset.mem_sdiff.mp huO
  have huI := huData.1
  have huNotC := huData.2
  have huBase := (Finset.mem_filter.mp huI).1
  have huComp := (Finset.mem_filter.mp huI).2
  have huInner := (Finset.mem_product.mp huBase).1
  have huPair := Finset.mem_product.mp huInner
  have hsW := Finset.mem_range.mp huPair.2
  by_cases hside : u.2 = false
  · have hcomp : (n u.1.1).gcd (4 * n K) ∣ n K - L + u.1.2 := by
      simpa [twoWindowModulus, twoWindowOffset, p, A, hside] using huComp
    have hne : u.1.2 ≠ L := by
      intro heq
      apply huNotC
      apply Finset.mem_filter.mpr
      exact ⟨huI, Or.inl ⟨hside, heq⟩⟩
    have hbound := (left_window_compatible_gcd_le
      (n u.1.1) (n K) L u.1.2 (hpos u.1.1) hL.le hcomp).resolve_left hne
    have hdist : u.1.2.dist L ≤ W := by
      have hLW : L < W := by dsimp [W]; omega
      rcases le_total u.1.2 L with hle | hge
      · rw [Nat.dist_eq_sub_of_le hle]
        omega
      · rw [Nat.dist_eq_sub_of_le_right hge]
        omega
    dsimp [twoWindowModulus, p]
    exact hbound.trans (Nat.mul_le_mul_left 4 hdist)
  · have hsideTrue : u.2 = true := Bool.eq_true_of_not_eq_false hside
    have hcomp : (n u.1.1).gcd (4 * n K) ∣ A + u.1.2 + X := by
      simpa [twoWindowModulus, twoWindowOffset, p, hsideTrue] using huComp
    have hne : u.1.2 ≠ sR := by
      intro heq
      apply huNotC
      apply Finset.mem_filter.mpr
      exact ⟨huI, Or.inr ⟨hsideTrue, heq⟩⟩
    have hbound := (right_window_compatible_gcd_le
      (n u.1.1) (n K) A X u.1.2 sR (hpos u.1.1)
        hcomp hspecialRight).resolve_left hne
    have hdist : u.1.2.dist sR ≤ W := by
      rcases le_total u.1.2 sR with hle | hge
      · rw [Nat.dist_eq_sub_of_le hle]
        omega
      · rw [Nat.dist_eq_sub_of_le_right hge]
        omega
    dsimp [twoWindowModulus, p]
    exact hbound.trans <| calc
      2 * u.1.2.dist sR ≤ 2 * W := Nat.mul_le_mul_left 2 hdist
      _ ≤ 4 * W := by omega

/-- The outside-block off-center family is a subset of the geometric
four-width compatible family. -/
theorem nearHalfOutsideBlock_offCenter_subset_fourWidth
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K H L J X r v : ℕ) (B : Finset ℕ) (hL : L < n K)
    (hX : X = r + (2 * n K) * v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    nearHalfOutsideBlockOffCenterConditions n K H W A X p L sR B ⊆
      fourWidthGcdCompatibleTwoWindowConditions n K H W A X p := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  dsimp only
  intro u hu
  have huData := Finset.mem_sdiff.mp hu
  have huOutsideCompat := huData.1
  have huNotOutsideCenter := huData.2
  have huBaseOutside := (Finset.mem_filter.mp huOutsideCompat).1
  have huNotB := (Finset.mem_filter.mp huBaseOutside).2
  have huCompat := (Finset.mem_filter.mp huOutsideCompat).2
  have huBase := (Finset.mem_filter.mp huBaseOutside).1
  have huOldCompat : u ∈ compatibleTwoWindowConditions n K H W A X p :=
    Finset.mem_filter.mpr ⟨huBase, huCompat⟩
  have huNotOldCenter :
      u ∉ nearHalfCenterConditions n K H W A X p L sR := by
    intro huCenter
    apply huNotOutsideCenter
    exact Finset.mem_filter.mpr ⟨huCenter, huNotB⟩
  have huOldOff : u ∈ nearHalfOffCenterConditions n K H W A X p L sR :=
    Finset.mem_sdiff.mpr ⟨huOldCompat, huNotOldCenter⟩
  apply Finset.mem_filter.mpr
  refine ⟨huOldCompat, ?_⟩
  exact nearHalf_offCenter_gcd_le_fourWidth n hpos K H L J X r v
    hL hX hrUpper hsRWindow u huOldOff

/-- Exact compatibility counting improves the filtered near-half off-center
budget from quadratic to linear dependence on the window width. -/
theorem nearHalfOutsideBlock_offCenter_linear_budget_cast_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K H L J X r v R : ℕ) (B : Finset ℕ) (hL : L < n K)
    (hX : X = r + (2 * n K) * v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let O := nearHalfOutsideBlockOffCenterConditions
      n K H W A X p L sR B
    ((∑ u ∈ O, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) ≤
      10 * (R : ℝ) * W *
          (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        10 * W * (laterPositionRange K H).card := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let O := nearHalfOutsideBlockOffCenterConditions
    n K H W A X p L sR B
  dsimp only
  have hsub : O ⊆
      fourWidthGcdCompatibleTwoWindowConditions n K H W A X p :=
    nearHalfOutsideBlock_offCenter_subset_fourWidth n hpos
      K H L J X r v B hL hX hrUpper hsRWindow
  have hnat :
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) ≤
      ∑ u ∈ fourWidthGcdCompatibleTwoWindowConditions n K H W A X p,
        (R / (twoWindowModulus n u /
          (twoWindowModulus n u).gcd p) + 1) :=
    Finset.sum_le_sum_of_subset hsub
  have hcast :
      (((∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) : ℕ) : ℝ) ≤
      ((∑ u ∈ fourWidthGcdCompatibleTwoWindowConditions n K H W A X p,
        (R / (twoWindowModulus n u /
          (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) := by
    exact_mod_cast hnat
  exact hcast.trans
    (fourWidthGcdCompatible_budget_cast_le n hpos K H W A X p R)

end Research

/-!
# Linear budget when only an initial cluster of aligned centers is protected
-/

namespace Research

open scoped BigOperators

/-- A four-condition-per-position envelope containing both possible aligned
center conditions after the protected cutoff. -/
def lateAlignedCenterEnvelope (G H L sR : ℕ) :
    Finset ((ℕ × ℕ) × Bool) :=
  (((Finset.Ico G H).product ({L, sR} : Finset ℕ)).product
    (Finset.univ : Finset Bool))

/-- Protecting aligned centers only before `G` leaves the true full off-center
family plus at most four fixed center labels per position in `[G,H)`. -/
theorem partialOutsideBlock_subset_fullOffCenter_union_lateEnvelope
    (n : ℕ → ℕ) (K G H W A X p L sR : ℕ) (Block : Finset ℕ) :
    let C0 := nearHalfOutsideBlockCenterConditions
      n K G W A X p L sR Block
    let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
    let Oall := nearHalfOutsideBlockOffCenterConditions
      n K H W A X p L sR Block
    O ⊆ Oall ∪ lateAlignedCenterEnvelope G H L sR := by
  classical
  dsimp only
  intro u huO
  have huData := Finset.mem_sdiff.mp huO
  have huCompatH := huData.1
  have huNotC0 := huData.2
  by_cases huCH : u ∈ nearHalfOutsideBlockCenterConditions
      n K H W A X p L sR Block
  · apply Finset.mem_union.mpr
    right
    have huOldCenter := (Finset.mem_filter.mp huCH).1
    have huCenter := (Finset.mem_filter.mp huOldCenter).2
    have huCompat := (Finset.mem_filter.mp huOldCenter).1
    have huBase := (Finset.mem_filter.mp huCompat).1
    have huOuter := Finset.mem_product.mp huBase
    have huInner := Finset.mem_product.mp huOuter.1
    have hjRange := Finset.mem_filter.mp huInner.1
    have hjH := Finset.mem_range.mp hjRange.1
    have hKj := hjRange.2
    have hsCenter : u.1.2 ∈ ({L, sR} : Finset ℕ) := by
      rcases huCenter with hleft | hright
      · simp [hleft.2]
      · simp [hright.2]
    have hGj : G ≤ u.1.1 := by
      by_contra hnot
      have hjG : u.1.1 < G := by omega
      apply huNotC0
      apply Finset.mem_filter.mpr
      refine ⟨?_, (Finset.mem_filter.mp huCH).2⟩
      apply Finset.mem_filter.mpr
      refine ⟨?_, huCenter⟩
      apply Finset.mem_filter.mpr
      refine ⟨?_, (Finset.mem_filter.mp huCompat).2⟩
      apply Finset.mem_product.mpr
      refine ⟨Finset.mem_product.mpr ⟨?_, huInner.2⟩, huOuter.2⟩
      apply Finset.mem_filter.mpr
      exact ⟨Finset.mem_range.mpr hjG, hKj⟩
    apply Finset.mem_product.mpr
    refine ⟨Finset.mem_product.mpr ⟨?_, hsCenter⟩, Finset.mem_univ _⟩
    exact Finset.mem_Ico.mpr ⟨hGj, hjH⟩
  · apply Finset.mem_union.mpr
    left
    exact Finset.mem_sdiff.mpr ⟨huCompatH, huCH⟩

/-- The late aligned-center envelope has only four labels per position, so its
reduced-modulus budget has no factor of the window width. -/
theorem lateAlignedCenterEnvelope_budget_cast_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (G H L sR p R : ℕ) (hp : 0 < p) :
    ((∑ u ∈ lateAlignedCenterEnvelope G H L sR,
      (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) ≤
      4 * ((R : ℝ) * p *
        (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) +
        (Finset.Ico G H).card) := by
  classical
  let cost : ((ℕ × ℕ) × Bool) → ℕ := fun u =>
    R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1
  let upper : ℕ → ℕ := fun j => (R * p) / n j + 1
  have hpoint : ∀ u, cost u ≤ upper u.1.1 := by
    intro u
    dsimp [cost, upper]
    rw [div_div_gcd_eq_mul_div R (twoWindowModulus n u) p]
    · apply Nat.add_le_add_right
      apply Nat.div_le_div_right
      exact Nat.mul_le_mul_left R (Nat.gcd_le_right _ hp)
    · exact hpos u.1.1
  have hnat : (∑ u ∈ lateAlignedCenterEnvelope G H L sR, cost u) ≤
      4 * ∑ j ∈ Finset.Ico G H, upper j := by
    calc
      (∑ u ∈ lateAlignedCenterEnvelope G H L sR, cost u) ≤
          ∑ u ∈ lateAlignedCenterEnvelope G H L sR, upper u.1.1 := by
            apply Finset.sum_le_sum
            intro u hu
            exact hpoint u
      _ = ({L, sR} : Finset ℕ).card * 2 *
          ∑ j ∈ Finset.Ico G H, upper j := by
            simp [lateAlignedCenterEnvelope, Finset.sum_product]
            simp_rw [← mul_assoc]
            rw [← Finset.mul_sum]
      _ ≤ 4 * ∑ j ∈ Finset.Ico G H, upper j := by
        have hc : ({L, sR} : Finset ℕ).card ≤ 2 := by
          simpa using Finset.card_insert_le L ({sR} : Finset ℕ)
        have hc2 : ({L, sR} : Finset ℕ).card * 2 ≤ 4 := by omega
        exact Nat.mul_le_mul_right _ hc2
  have hcast :
      (((∑ u ∈ lateAlignedCenterEnvelope G H L sR, cost u) : ℕ) : ℝ) ≤
        (4 * ∑ j ∈ Finset.Ico G H, upper j : ℕ) := by
    exact_mod_cast hnat
  have hsum := cast_sum_nat_div_add_one_le
    (Finset.Ico G H) n (fun j hj => hpos j) (R * p)
  dsimp [cost] at hcast
  calc
    ((∑ u ∈ lateAlignedCenterEnvelope G H L sR,
      (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) ≤
        ((4 * ∑ j ∈ Finset.Ico G H, upper j : ℕ) : ℝ) := hcast
    _ = 4 * (((∑ j ∈ Finset.Ico G H, upper j) : ℕ) : ℝ) := by
      push_cast
      ring
    _ ≤ 4 * (((R * p : ℕ) : ℝ) *
        (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) +
        (Finset.Ico G H).card) := by
      apply mul_le_mul_of_nonneg_left
      · simpa [upper] using hsum
      · norm_num
    _ = 4 * ((R : ℝ) * p *
        (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) +
        (Finset.Ico G H).card) := by
      push_cast
      ring

/-- Hybrid bound: exact counting handles all true off-center conditions
linearly in `W`, while unprotected later aligned centers cost only four labels
per position. -/
theorem finsetBlock_partialCenter_linear_offBudget_cast_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K G H L J X r v R : ℕ) (Block : Finset ℕ)
    (hL : L < n K) (hX : X = r + (2 * n K) * v)
    (hrUpper : r ≤ n K + L)
    (hsRWindow : n K + L - r < L + 1 + J) :
    let A := n K - L
    let W := L + 1 + J
    let p := 4 * n K
    let sR := n K + L - r
    let C0 := nearHalfOutsideBlockCenterConditions
      n K G W A X p L sR Block
    let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
    ((∑ u ∈ O, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) ≤
      10 * (R : ℝ) * W *
          (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        10 * W * (laterPositionRange K H).card +
        4 * ((R : ℝ) * p *
          (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) +
          (Finset.Ico G H).card) := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := 4 * n K
  let sR := n K + L - r
  let C0 := nearHalfOutsideBlockCenterConditions
    n K G W A X p L sR Block
  let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
  let Oall := nearHalfOutsideBlockOffCenterConditions
    n K H W A X p L sR Block
  let Late := lateAlignedCenterEnvelope G H L sR
  dsimp only
  have hsub : O ⊆ Oall ∪ Late :=
    partialOutsideBlock_subset_fullOffCenter_union_lateEnvelope
      n K G H W A X p L sR Block
  let cost : ((ℕ × ℕ) × Bool) → ℕ := fun u =>
    R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1
  have hsplitNat : (∑ u ∈ O, cost u) ≤
      (∑ u ∈ Oall, cost u) + ∑ u ∈ Late, cost u := by
    calc
      (∑ u ∈ O, cost u) ≤ ∑ u ∈ Oall ∪ Late, cost u :=
        Finset.sum_le_sum_of_subset hsub
      _ ≤ (∑ u ∈ Oall, cost u) + ∑ u ∈ Late, cost u := by
        have hu := Finset.sum_union_inter (s₁ := Oall) (s₂ := Late)
          (f := cost)
        omega
  have hsplit : (((∑ u ∈ O, cost u) : ℕ) : ℝ) ≤
      (((∑ u ∈ Oall, cost u) : ℕ) : ℝ) +
        (((∑ u ∈ Late, cost u) : ℕ) : ℝ) := by
    exact_mod_cast hsplitNat
  have hoff := nearHalfOutsideBlock_offCenter_linear_budget_cast_le
    n hpos K H L J X r v R Block hL hX hrUpper hsRWindow
  have hlate := lateAlignedCenterEnvelope_budget_cast_le
    n hpos G H L sR p R (by
      dsimp [p]
      exact mul_pos (by norm_num) (hpos K))
  dsimp [cost] at hsplit
  exact hsplit.trans (add_le_add hoff hlate)

end Research
/-!
# Protected center density after a power-of-two rescaling of the progression
-/

namespace Research

/-- Pull back the standard globally safe residues under multiplication by a
power of two modulo the odd CRT period. -/
def powerTwoScaledGlobalCenterSafeResidues
    {k : ℕ} (p : Fin k → ℕ) (v e : ℕ) : Finset ℕ :=
  let M := ∏ i, p i
  (Finset.range M).filter fun t =>
    (2 ^ e * t) % M ∈ globalCenterSafeResidues p v

/-- Multiplication by `2^e` permutes the odd CRT residue ring, so pulling back
safe residues preserves their exact cardinality. -/
theorem card_powerTwoScaledGlobalCenterSafeResidues
    {k : ℕ} (p : Fin k → ℕ) (v e : ℕ) (hpOdd : ∀ i, Odd (p i))
    (hM : 0 < ∏ i, p i) :
    (powerTwoScaledGlobalCenterSafeResidues p v e).card =
      (globalCenterSafeResidues p v).card := by
  classical
  let M := ∏ i, p i
  let E := 2 ^ e
  let f : ℕ → ℕ := fun t => (E * t) % M
  have hEM : E.Coprime M := by
    apply Nat.Coprime.prod_right
    intro i hi
    exact (Nat.coprime_two_left.mpr (hpOdd i)).pow_left e
  have hmap : Set.MapsTo f (Finset.range M : Set ℕ)
      (Finset.range M : Set ℕ) := by
    intro t ht
    exact Finset.mem_range.mpr (Nat.mod_lt _ hM)
  have hinj : Set.InjOn f (Finset.range M : Set ℕ) := by
    intro a ha b hb hab
    have hmod : E * a ≡ E * b [MOD M] := hab
    have hcancel : a ≡ b [MOD M] :=
      Nat.ModEq.cancel_left_of_coprime hEM.symm.gcd_eq_one hmod
    exact hcancel.eq_of_lt_of_lt (Finset.mem_range.mp ha)
      (Finset.mem_range.mp hb)
  have hsurj : Set.SurjOn f (Finset.range M : Set ℕ)
      (Finset.range M : Set ℕ) :=
    Finset.surjOn_of_injOn_of_card_le f hmap hinj (by simp)
  apply Finset.card_bij
      (fun t ht => f t)
  · intro t ht
    have htData := Finset.mem_filter.mp ht
    exact (Finset.mem_filter.mp ht).2
  · intro a ha b hb hab
    exact hinj (Finset.mem_filter.mp ha).1
      (Finset.mem_filter.mp hb).1 hab
  · intro z hz
    have hzRange : z ∈ Finset.range M := by
      exact Finset.mem_range.mpr <| by
        have := (Finset.mem_filter.mp hz).1
        simpa [globalCenterSafeResidues, M] using this
    obtain ⟨t, htRange, hft⟩ := hsurj hzRange
    refine ⟨t, Finset.mem_filter.mpr ⟨htRange, ?_⟩, hft⟩
    have hft' : (2 ^ e * t) % (∏ i, p i) = z := by
      simpa [f, E, M] using hft
    rw [hft']
    exact hz

/-- Replicate the pulled-back safe residues through `T` complete CRT periods. -/
def replicatedPowerTwoScaledGlobalCenterSafeResidues
    {k : ℕ} (p : Fin k → ℕ) (v e T : ℕ) : Finset ℕ :=
  let M := ∏ i, p i
  ((Finset.range T).product
      (powerTwoScaledGlobalCenterSafeResidues p v e)).image fun z =>
    z.2 + M * z.1

/-- Exact cardinality of the replicated pulled-back safe family. -/
theorem card_replicatedPowerTwoScaledGlobalCenterSafeResidues
    {k : ℕ} (p : Fin k → ℕ) (v e T : ℕ) (hM : 0 < ∏ i, p i) :
    (replicatedPowerTwoScaledGlobalCenterSafeResidues p v e T).card =
      T * (powerTwoScaledGlobalCenterSafeResidues p v e).card := by
  classical
  unfold replicatedPowerTwoScaledGlobalCenterSafeResidues
  rw [Finset.card_image_of_injOn]
  · simp
  · intro z hz w hw hzw
    have hzlt : z.2 < ∏ i, p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp
        (Finset.mem_product.mp hz).2).1
    have hwlt : w.2 < ∏ i, p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp
        (Finset.mem_product.mp hw).2).1
    have hrem := congrArg (fun x => x % (∏ i, p i)) hzw
    simp only [Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt hzlt,
      Nat.mod_eq_of_lt hwlt] at hrem
    have hblock : z.1 = w.1 := by
      change z.2 + (∏ i, p i) * z.1 =
        w.2 + (∏ i, p i) * w.1 at hzw
      rw [hrem] at hzw
      exact Nat.mul_left_cancel hM (Nat.add_left_cancel hzw)
    cases z
    cases w
    simp_all

/-- The standard polynomial protected density survives replacing `t` by
`2^e t` in both center congruence forms. -/
theorem exists_exact_period_with_scaled_polynomially_many_powerTwo_centers
    {ι : Type*} [DecidableEq ι]
    (Q : Finset ℕ) (C : Finset ι) (side : ι → Bool)
    (a qmod : ι → ℕ) (step v e : ℕ)
    (hQ3 : ∀ q ∈ Q, 3 ≤ q)
    (hQodd : ∀ q ∈ Q, Odd q)
    (hcover : ∀ u ∈ C, ∃ q ∈ Q, ∀ t,
      qmod u ∣ a u + step * t →
        if side u then q ∣ v + 1 + 2 * (2 ^ e * t)
        else q ∣ 4 * (2 ^ e * t) + 1) :
    let S := centerPrimeFactors Q
    ∃ M : ℕ, 0 < M ∧ M = ∏ z ∈ S, z ∧ ∀ T : ℕ,
      2 * (T * M) ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C a qmod step (T * M)).card := by
  classical
  let S := centerPrimeFactors Q
  have hSdata := centerPrimeFactors_prime_odd_ge_three Q hQ3 hQodd
  have hSprime : ∀ z ∈ S, z.Prime := fun z hz => (hSdata z hz).1
  have hSodd : ∀ z ∈ S, Odd z := fun z hz => (hSdata z hz).2.1
  obtain ⟨p, hprod, hpPrime, hp3, hpTwo, hpPair, hEnumCovers,
      hsafeBound⟩ :=
    exists_prime_enumeration_with_global_safe_bound_onto
      S v hSprime hSodd
  let M := ∏ i, p i
  have hMpos : 0 < M := by
    dsimp [M]
    apply Finset.prod_pos
    intro i hi
    exact lt_of_lt_of_le (by norm_num) (hp3 i)
  have hpOdd : ∀ i, Odd (p i) := by
    intro i
    exact Nat.coprime_two_right.mp (hpTwo i)
  have hscaledCard := card_powerTwoScaledGlobalCenterSafeResidues
    p v e hpOdd hMpos
  refine ⟨M, hMpos, hprod, ?_⟩
  intro T
  have hsubset : replicatedPowerTwoScaledGlobalCenterSafeResidues p v e T ⊆
      protectedCandidates C a qmod step (T * M) := by
    intro t htRep
    obtain ⟨z, hzProd, rfl⟩ := Finset.mem_image.mp htRep
    have hzT := Finset.mem_range.mp (Finset.mem_product.mp hzProd).1
    have hzSafe := (Finset.mem_product.mp hzProd).2
    have hzData := Finset.mem_filter.mp hzSafe
    let y := (2 ^ e * z.2) % M
    have hySafe : y ∈ globalCenterSafeResidues p v := by
      simpa [powerTwoScaledGlobalCenterSafeResidues, M, y] using hzData.2
    have hyData := Finset.mem_filter.mp hySafe
    apply Finset.mem_filter.mpr
    refine ⟨Finset.mem_range.mpr ?_, ?_⟩
    · have hzlt := Finset.mem_range.mp hzData.1
      dsimp [M]
      nlinarith
    · intro u huC hbad
      obtain ⟨q, hqQ, himp⟩ := hcover u huC
      have hform := himp (z.2 + M * z.1) hbad
      have hqne : q ≠ 1 := by have := hQ3 q hqQ; omega
      let prime := q.minFac
      have hprimeS : prime ∈ S := by
        apply (mem_centerPrimeFactors_iff Q prime).mpr
        exact ⟨q, hqQ, rfl⟩
      obtain ⟨i, hpi⟩ := hEnumCovers prime hprimeS
      have hsafeI := hyData.2 i
      have hpM : p i ∣ M := by
        dsimp [M]
        exact Finset.dvd_prod_of_mem p (by simp)
      have hylt : y < M := Finset.mem_range.mp hyData.1
      have hbaseModM : 2 ^ e * (z.2 + M * z.1) ≡ y [MOD M] := by
        change (2 ^ e * (z.2 + M * z.1)) % M = y % M
        rw [Nat.mod_eq_of_lt hylt]
        dsimp [y]
        rw [show 2 ^ e * (z.2 + M * z.1) =
          2 ^ e * z.2 + M * (2 ^ e * z.1) by ring]
        exact Nat.add_mul_mod_self_left _ _ _
      have hbaseMod : 2 ^ e * (z.2 + M * z.1) ≡ y [MOD p i] :=
        Nat.ModEq.of_dvd hpM hbaseModM
      have hleftMod : 4 * (2 ^ e * (z.2 + M * z.1)) + 1 ≡
          4 * y + 1 [MOD p i] :=
        (Nat.ModEq.refl 4).mul hbaseMod |>.add (Nat.ModEq.refl 1)
      have hrightMod : v + 1 + 2 * (2 ^ e * (z.2 + M * z.1)) ≡
          v + 1 + 2 * y [MOD p i] :=
        (Nat.ModEq.refl (v + 1)).add <|
          (Nat.ModEq.refl 2).mul hbaseMod
      have hprimeDvd : prime ∣ q := Nat.minFac_dvd q
      split at hform
      · apply hsafeI.2
        have hpActual : p i ∣ v + 1 + 2 * (2 ^ e * (z.2 + M * z.1)) := by
          simpa [hpi] using dvd_trans hprimeDvd hform
        exact (hrightMod.dvd_iff (dvd_refl (p i))).mp hpActual
      · apply hsafeI.1
        have hpActual : p i ∣ 4 * (2 ^ e * (z.2 + M * z.1)) + 1 := by
          simpa [hpi] using dvd_trans hprimeDvd hform
        exact (hleftMod.dvd_iff (dvd_refl (p i))).mp hpActual
  have hcard := Finset.card_le_card hsubset
  have hrepCard := card_replicatedPowerTwoScaledGlobalCenterSafeResidues
    p v e T hMpos
  have hbaseScaled := Nat.mul_le_mul_left T hsafeBound
  calc
    2 * (T * M) = T * (2 * (∏ i, p i)) := by dsimp [M]; ring
    _ ≤ T * ((S.card + 1) * (S.card + 2) *
        (globalCenterSafeResidues p v).card) := hbaseScaled
    _ = (S.card + 1) * (S.card + 2) *
        (replicatedPowerTwoScaledGlobalCenterSafeResidues p v e T).card := by
      rw [hrepCard, hscaledCard]
      ring
    _ ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C a qmod step (T * M)).card :=
      Nat.mul_le_mul_left _ hcard

end Research
/-!
# Near-half center protection with a power-of-two enlarged block period
-/

namespace Research

open scoped BigOperators

/-- An odd multiplier cannot supply any factor from a power of two.  This is
used to recover the aligned factor `A` from divisibility by both
`A * 2^s` and `A * odd`. -/
lemma dvd_base_of_dvd_base_mul_twoPow_and_odd
    (g A s z : ℕ) (hgp : g ∣ A * 2 ^ s) (hgz : g ∣ A * z)
    (hz : Odd z) :
    g ∣ A := by
  have hcop : (2 ^ s).Coprime z :=
    (Nat.coprime_two_left.mpr hz).pow_left s
  have hgd : g ∣ (A * 2 ^ s).gcd (A * z) := Nat.dvd_gcd hgp hgz
  rw [Nat.gcd_mul_left, hcop.gcd_eq_one, mul_one] at hgd
  exact hgd

/-- Outside a distinguished block, suppose every reduced modulus for the
larger period `4 n_K 2^e` is odd and no selected value divides that period.
Then the two aligned center families retain the standard polynomial protected
count, with their center forms evaluated at `2^e t`. -/
theorem exists_exact_scaled_powerTwo_nearHalf_outsideBlock_candidates
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (_hmono : StrictMono n)
    (K H L J X r v e : ℕ) (B : Finset ℕ) (_hKH : K < H)
    (hL : L < n K)
    (hX : X = r + (2 * n K) * v) (hv : Even v)
    (hrUpper : r ≤ n K + L)
    (_hsRWindow : n K + L - r < L + 1 + J)
    (hoddOutside : ∀ j, K < j → j < H → j ∉ B →
      Odd (n j / (n j).gcd ((4 * n K) * 2 ^ e)))
    (hnoDvdOutside : ∀ j, K < j → j < H → j ∉ B →
      ¬n j ∣ (4 * n K) * 2 ^ e) :
    let A := n K - L
    let W := L + 1 + J
    let p := (4 * n K) * 2 ^ e
    let sR := n K + L - r
    let C := nearHalfOutsideBlockCenterConditions
      n K H W A X p L sR B
    let Q := nearHalfOutsideBlockCenterReducedModuli
      n K H W A X p L sR B
    let S := centerPrimeFactors Q
    ∃ M : ℕ, 0 < M ∧ M = ∏ z ∈ S, z ∧ ∀ T : ℕ,
      2 * (T * M) ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p (T * M)).card := by
  classical
  let A := n K - L
  let W := L + 1 + J
  let p := (4 * n K) * 2 ^ e
  let sR := n K + L - r
  let C := nearHalfOutsideBlockCenterConditions
    n K H W A X p L sR B
  let Q := nearHalfOutsideBlockCenterReducedModuli
    n K H W A X p L sR B
  have hn := hpos K
  have hcenterLeft : A + L = n K := by dsimp [A]; omega
  have hvOdd : Odd (v + 1) := by
    obtain ⟨z, hz⟩ := hv
    exact ⟨z, by omega⟩
  have hcenterRight : A + sR + X = 2 * n K * (v + 1) := by
    have hAr : A + L = n K := hcenterLeft
    have hsrr : sR + r = n K + L := by dsimp [sR]; omega
    rw [hX]
    calc
      A + sR + (r + 2 * n K * v) =
          2 * n K + 2 * n K * v := by omega
      _ = 2 * n K * (v + 1) := by ring
  have hQdata : ∀ q ∈ Q, Odd q ∧ 3 ≤ q := by
    intro q hqQ
    obtain ⟨u, huC, rfl⟩ := Finset.mem_image.mp hqQ
    have huOldC := (Finset.mem_filter.mp huC).1
    have huNotB := (Finset.mem_filter.mp huC).2
    have huCompat := (Finset.mem_filter.mp huOldC).1
    have huBase := (Finset.mem_filter.mp huCompat).1
    have huPair := Finset.mem_product.mp (Finset.mem_product.mp huBase).1
    have hjData := Finset.mem_filter.mp huPair.1
    have hjH := Finset.mem_range.mp hjData.1
    have hKj := hjData.2
    have hodd := hoddOutside u.1.1 hKj hjH huNotB
    refine ⟨by simpa [twoWindowModulus, p] using hodd, ?_⟩
    let g := (n u.1.1).gcd p
    let q0 := n u.1.1 / g
    have hgpos : 0 < g := Nat.gcd_pos_of_pos_left p (hpos u.1.1)
    have hgd : g ∣ n u.1.1 := by dsimp [g]; exact Nat.gcd_dvd_left _ _
    have hfac : n u.1.1 = g * q0 := by
      dsimp [q0]
      exact (Nat.mul_div_cancel' hgd).symm
    have hqpos : 0 < q0 := by
      dsimp [q0, g]
      exact Nat.div_pos (Nat.gcd_le_left p (hpos u.1.1)) hgpos
    have hqne : q0 ≠ 1 := by
      intro heq
      apply hnoDvdOutside u.1.1 hKj hjH huNotB
      rw [hfac, heq, mul_one]
      dsimp [g, p]
      exact Nat.gcd_dvd_right _ _
    have hqodd : Odd q0 := by
      simpa [q0, g, p, twoWindowModulus] using hodd
    change 3 ≤ n u.1.1 / (n u.1.1).gcd p
    change 3 ≤ q0
    obtain ⟨z, hz⟩ := hqodd
    omega
  apply exists_exact_period_with_scaled_polynomially_many_powerTwo_centers
    Q C (fun u => u.2) (twoWindowOffset A X) (twoWindowModulus n)
      p v e
  · exact fun q hq => (hQdata q hq).2
  · exact fun q hq => (hQdata q hq).1
  · intro u huC
    have huOldC := (Finset.mem_filter.mp huC).1
    let q0 := twoWindowModulus n u /
      (twoWindowModulus n u).gcd p
    refine ⟨q0, ?_, ?_⟩
    · exact Finset.mem_image.mpr ⟨u, huC, rfl⟩
    · intro t hbad
      have huCompat := (Finset.mem_filter.mp huOldC).1
      have huCenter := (Finset.mem_filter.mp huOldC).2
      have huComp := (Finset.mem_filter.mp huCompat).2
      let g := (n u.1.1).gcd p
      have hg : 0 < g := Nat.gcd_pos_of_pos_left p (hpos u.1.1)
      have hqFactor : n u.1.1 = g * q0 := by
        dsimp [g, q0]
        exact (Nat.mul_div_cancel' (Nat.gcd_dvd_left _ _)).symm
      rcases huCenter with hleft | hright
      · have hside : u.2 = false := hleft.1
        have hoff : u.1.2 = L := hleft.2
        have hgN : g ∣ n K := by
          simpa [g, p, twoWindowModulus, twoWindowOffset,
            A, hside, hoff, hcenterLeft] using huComp
        let u0 := n K / g
        have hnFactor : n K = g * u0 := by
          dsimp [u0]
          exact (Nat.mul_div_cancel' hgN).symm
        have hcop : q0.Coprime u0 := by
          dsimp [q0, u0, g]
          exact coprime_reduced_modulus_factor
            (n u.1.1) p (n K) (hpos u.1.1) hgN
              (by dsimp [p]; exact ⟨4 * 2 ^ e, by ring⟩)
        simp only [hside, Bool.false_eq_true, ↓reduceIte]
        apply (left_center_divisibility_iff_reduced
          (n u.1.1) (n K) g q0 u0 (2 ^ e * t)
            hg hqFactor hnFactor hcop).mp
        simpa [twoWindowModulus, twoWindowOffset, p, A,
          hside, hoff, hcenterLeft, mul_assoc] using hbad
      · have hside : u.2 = true := hright.1
        have hoff : u.1.2 = sR := hright.2
        have hgAligned : g ∣ 2 * n K * (v + 1) := by
          simpa [g, p, twoWindowModulus, twoWindowOffset,
            A, sR, hside, hoff, hcenterRight] using huComp
        have hgPeriod : g ∣ (2 * n K) * 2 ^ (e + 1) := by
          have hgp : g ∣ p := by
            dsimp [g]
            exact Nat.gcd_dvd_right _ _
          rw [show (2 * n K) * 2 ^ (e + 1) = p by
            dsimp [p]
            rw [pow_succ]
            ring]
          exact hgp
        have hgTwo : g ∣ 2 * n K :=
          dvd_base_of_dvd_base_mul_twoPow_and_odd
            g (2 * n K) (e + 1) (v + 1) hgPeriod hgAligned hvOdd
        let u0 := (2 * n K) / g
        have htwoFactor : 2 * n K = g * u0 := by
          dsimp [u0]
          exact (Nat.mul_div_cancel' hgTwo).symm
        have hcop : q0.Coprime u0 := by
          dsimp [q0, u0, g]
          exact coprime_reduced_modulus_factor
            (n u.1.1) p (2 * n K) (hpos u.1.1) hgTwo
              (by dsimp [p]; exact ⟨2 * 2 ^ e, by ring⟩)
        simp only [hside, ite_true]
        apply (right_center_divisibility_iff_reduced
          (n u.1.1) g q0 u0 v (2 ^ e * t)
            hg hqFactor hcop).mp
        have haligned : A + u.1.2 + X + p * t =
            g * u0 * (v + 1 + 2 * (2 ^ e * t)) := by
          rw [hoff, hcenterRight, ← htwoFactor]
          dsimp [p]
          ring
        simpa [twoWindowModulus, twoWindowOffset, hside, haligned]
          using hbad

end Research
/-!
# A maximal recurrent two-adic level in every bounded sequence
-/

namespace Research

open Filter

/-- A natural-valued function which is eventually bounded has a largest value
that occurs frequently; all sufficiently late values are at most it. -/
theorem exists_maximal_frequent_nat_value
    (f : ℕ → ℕ) (V : ℕ) (hV : ∀ᶠ k : ℕ in atTop, f k ≤ V) :
    ∃ s ≤ V, (∀ᶠ k : ℕ in atTop, f k ≤ s) ∧
      (∃ᶠ k : ℕ in atTop, f k = s) := by
  induction V with
  | zero =>
      refine ⟨0, le_rfl, hV, ?_⟩
      have heq : ∀ᶠ k : ℕ in atTop, f k = 0 := by
        filter_upwards [hV] with k hk
        omega
      exact heq.frequently
  | succ V ih =>
      by_cases htop : ∃ᶠ k : ℕ in atTop, f k = V + 1
      · exact ⟨V + 1, le_rfl, hV, htop⟩
      · have hnot : ∀ᶠ k : ℕ in atTop, f k ≠ V + 1 :=
          Filter.not_frequently.mp htop
        have hsmall : ∀ᶠ k : ℕ in atTop, f k ≤ V := by
          filter_upwards [hV, hnot] with k hkV hkne
          omega
        obtain ⟨s, hsV, hsBound, hsFreq⟩ := ih hsmall
        exact ⟨s, hsV.trans (Nat.le_succ V), hsBound, hsFreq⟩

/-- For a positive sequence of uniformly bounded two-adic order, frequently a
selected target lies on a maximal recurrent level and has no later exact
double. -/
theorem frequently_noDouble_at_maximal_frequent_twoAdicLevel
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (V : ℕ) (hV : ∀ k, twoAdicOrder (n k) ≤ V) :
    ∃ s ≤ V,
      (∀ᶠ k : ℕ in atTop, twoAdicOrder (n k) ≤ s) ∧
      (∃ᶠ K : ℕ in atTop,
        twoAdicOrder (n K) = s ∧
          ∀ j, K < j → n j ≠ 2 * n K) := by
  have hbound : ∀ᶠ k : ℕ in atTop, twoAdicOrder (n k) ≤ V :=
    Filter.Eventually.of_forall hV
  obtain ⟨s, hsV, hsBound, hsFreq⟩ :=
    exists_maximal_frequent_nat_value
      (fun k => twoAdicOrder (n k)) V hbound
  obtain ⟨N, hN⟩ := Filter.eventually_atTop.mp hsBound
  have hgood : ∀ᶠ K : ℕ in atTop,
      twoAdicOrder (n K) = s →
        ∀ j, K < j → n j ≠ 2 * n K := by
    apply Filter.eventually_atTop.mpr
    refine ⟨N, ?_⟩
    intro K hNK hKs j hKj hj
    have hjBound : twoAdicOrder (n j) ≤ s :=
      hN j (hNK.trans hKj.le)
    have hjOrder : twoAdicOrder (n j) = s + 1 := by
      rw [hj, twoAdicOrder_two_mul (n K) (hpos K), hKs]
    omega
  refine ⟨s, hsV, hsBound, ?_⟩
  exact (hsFreq.and_eventually hgood).mono fun K hK =>
    ⟨hK.1, hK.2 hK.1⟩

end Research
/-!
# Reversing a below-half near-half shift
-/

namespace Research

/-- At an odd multiple congruent to the root modulo `4n`, a nonempty finite
chain contributes exactly its root term. -/
theorem dyadicChainCoeff_at_root_add_four_mul
    (n R z : ℕ) (hn : 0 < n) (hR : 0 < R) :
    dyadicChainCoeff n R (n + 4 * n * z) = 1 := by
  unfold dyadicChainCoeff
  rw [Finset.sum_eq_single 0]
  · simp only [pow_zero, mul_one]
    unfold fibLambertCoeff
    split
    · rw [show n + 4 * n * z = n + (2 * n) * (2 * z) by ring,
        Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt (by omega)]
      simp
    · rw [show n + 4 * n * z = n + (4 * n) * z by ring,
        Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt (by omega)]
      simp
  · intro j hj hjne
    apply fibLambertCoeff_eq_zero_of_not_dvd
    intro hdvd
    have hjpos : 0 < j := Nat.pos_of_ne_zero hjne
    have htwoPow : 2 ∣ 2 ^ j := by
      simpa using Nat.pow_dvd_pow 2 hjpos
    have hfactor : n + 4 * n * z = n * (1 + 4 * z) := by ring
    have hpowDvd : 2 ^ j ∣ 1 + 4 * z := by
      apply (Nat.mul_dvd_mul_iff_left hn).mp
      rw [hfactor] at hdvd
      exact hdvd
    have htwoOdd : 2 ∣ 1 + 4 * z := htwoPow.trans hpowDvd
    obtain ⟨a, ha⟩ := htwoOdd
    omega
  · intro hnot
    exfalso
    apply hnot
    simp [hR]

/-- A translated root neighborhood is still a single-spike finite-chain word. -/
theorem dyadicChainCoeff_local_root_add_four_mul_formula
    (n R W z t : ℕ) (hn : 0 < n) (hR : 0 < R)
    (hW : W < n) (ht : t < 2 * W + 1) :
    dyadicChainCoeff n R (n - W + t + 4 * n * z) =
      if t = W then 1 else 0 := by
  by_cases htw : t = W
  · subst t
    rw [show n - W + W + 4 * n * z = n + 4 * n * z by omega,
      dyadicChainCoeff_at_root_add_four_mul n R z hn hR]
    simp
  · apply Eq.trans (dyadicChainCoeff_eq_zero_of_not_dvd n R _ ?_)
      (by simp [htw])
    intro hdvd
    have hnPeriod : n ∣ 4 * n * z := by exact ⟨4 * z, by ring⟩
    have hdvd' : n ∣ (n - W + t) + 4 * n * z := by
      simpa [add_assoc] using hdvd
    have hnBase : n ∣ n - W + t :=
      (Nat.dvd_add_iff_left hnPeriod).mpr hdvd'
    have hpos : 0 < n - W + t := by omega
    have hlt : n - W + t < 2 * n := by omega
    have hne : n - W + t ≠ n := by omega
    exact not_dvd_of_pos_lt_two_mul_ne n _ hpos hlt hne hnBase

/-- If a near-half prefix multiple lands below the half point, reverse the
comparison.  The low window is then entirely below the chain root, while the
high window is a `4n`-translate of the root neighborhood.  This gives an
isolated unit mismatch without paying the half-grid displacement as a window
radius. -/
theorem reverse_belowHalf_dyadicChain_sandwiched_pattern
    (n R w X r v : ℕ) (hn : 0 < n) (hR : 0 < R)
    (hX : X = r + (2 * n) * v) (hv : Even v)
    (_hrpos : 0 < r) (hrn : r < n)
    (hwr : w < r) (hw : w < n - r) :
    let A := n - r - w
    (0 < A) ∧
    (∀ s < w, dyadicChainCoeff n R (A + s + X) =
      dyadicChainCoeff n R (A + s)) ∧
    dyadicChainCoeff n R (A + w + X) ≠
      dyadicChainCoeff n R (A + w) ∧
    (∀ s < w, dyadicChainCoeff n R (A + w + 1 + s + X) =
      dyadicChainCoeff n R (A + w + 1 + s)) := by
  let A := n - r - w
  obtain ⟨z, hz⟩ := hv
  have hterm : (2 * n) * v = 4 * n * z := by rw [hz]; ring
  have hAeq : A + r + w = n := by dsimp [A]; omega
  have hshift (t : ℕ) (_ht : t < 2 * w + 1) :
      A + t + X = n - w + t + 4 * n * z := by
    rw [hX, hterm]
    omega
  have hlowPos (t : ℕ) : 0 < A + t := by dsimp [A]; omega
  have hlowLt (t : ℕ) (ht : t < 2 * w + 1) : A + t < n := by
    dsimp [A]
    omega
  have hlowZero (t : ℕ) (ht : t < 2 * w + 1) :
      dyadicChainCoeff n R (A + t) = 0 := by
    apply dyadicChainCoeff_eq_zero_of_not_dvd
    intro hdvd
    exact (Nat.not_dvd_of_pos_of_lt (hlowPos t) (hlowLt t ht)) hdvd
  have hhigh (t : ℕ) (ht : t < 2 * w + 1) :
      dyadicChainCoeff n R (A + t + X) = if t = w then 1 else 0 := by
    rw [hshift t ht]
    exact dyadicChainCoeff_local_root_add_four_mul_formula
      n R w z t hn hR (by omega) ht
  refine ⟨by omega, ?_, ?_, ?_⟩
  · intro s hs
    rw [hhigh s (by omega), hlowZero s (by omega)]
    simp [show s ≠ w by omega]
  · rw [hhigh w (by omega), hlowZero w (by omega)]
    simp
  · intro s hs
    let t := w + 1 + s
    have ht : t < 2 * w + 1 := by dsimp [t]; omega
    have htw : t ≠ w := by dsimp [t]; omega
    rw [show n - r - w + w + 1 + s = A + t by
      dsimp [A, t]
      omega]
    rw [hhigh t ht, hlowZero t ht]
    simp [htw]

end Research
/-!
# Exact below-half residues and reverse isolation without a parity restriction
-/

namespace Research

/-- At every positive odd multiple of the root, a nonempty finite dyadic chain
has exactly its root contribution.  For an odd root the sign records the parity
of the half-period quotient. -/
theorem dyadicChainCoeff_at_root_add_two_mul
    (n R v : ℕ) (hn : 0 < n) (hR : 0 < R) :
    dyadicChainCoeff n R (n + (2 * n) * v) =
      if Even n ∨ Even v then 1 else -1 := by
  unfold dyadicChainCoeff
  rw [Finset.sum_eq_single 0]
  · simp only [pow_zero, mul_one]
    unfold fibLambertCoeff
    by_cases hen : Even n
    · simp only [hen, if_pos, true_or]
      rw [show n + 2 * n * v = n + (2 * n) * v by rfl,
        Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt (by omega)]
      simp
    · simp only [hen, false_or]
      by_cases hev : Even v
      · obtain ⟨z, hz⟩ := hev
        have hev' : Even v := ⟨z, hz⟩
        have heq : n + 2 * n * v = n + (4 * n) * z := by rw [hz]; ring
        rw [heq, Nat.add_mul_mod_self_left]
        rw [Nat.mod_eq_of_lt (show n < 4 * n by omega)]
        simp [hev']
      · have hov : Odd v := Nat.not_even_iff_odd.mp hev
        obtain ⟨z, hz⟩ := hov
        have heq : n + 2 * n * v = 3 * n + (4 * n) * z := by
          rw [hz]
          ring
        rw [heq, Nat.add_mul_mod_self_left]
        rw [Nat.mod_eq_of_lt (show 3 * n < 4 * n by omega)]
        simp [hev, show 3 * n ≠ n by omega]
  · intro j hj hjne
    apply fibLambertCoeff_eq_zero_of_not_dvd
    intro hdvd
    have hjpos : 0 < j := Nat.pos_of_ne_zero hjne
    have htwoPow : 2 ∣ 2 ^ j := by
      simpa using Nat.pow_dvd_pow 2 hjpos
    have hfactor : n + (2 * n) * v = n * (1 + 2 * v) := by ring
    have hpowDvd : 2 ^ j ∣ 1 + 2 * v := by
      apply (Nat.mul_dvd_mul_iff_left hn).mp
      rw [hfactor] at hdvd
      exact hdvd
    have htwoOdd : 2 ∣ 1 + 2 * v := htwoPow.trans hpowDvd
    obtain ⟨a, ha⟩ := htwoOdd
    omega
  · intro hnot
    exfalso
    apply hnot
    simp [hR]

/-- The translated root neighborhood formula with an arbitrary half-period
quotient. -/
theorem dyadicChainCoeff_local_root_add_two_mul_formula
    (n R W v t : ℕ) (hn : 0 < n) (hR : 0 < R)
    (hW : W < n) (ht : t < 2 * W + 1) :
    dyadicChainCoeff n R (n - W + t + (2 * n) * v) =
      if t = W then (if Even n ∨ Even v then 1 else -1) else 0 := by
  by_cases htw : t = W
  · subst t
    rw [show n - W + W + 2 * n * v = n + (2 * n) * v by omega,
      dyadicChainCoeff_at_root_add_two_mul n R v hn hR]
    simp
  · apply Eq.trans (dyadicChainCoeff_eq_zero_of_not_dvd n R _ ?_)
      (by simp [htw])
    intro hdvd
    have hnPeriod : n ∣ (2 * n) * v := ⟨2 * v, by ring⟩
    have hdvd' : n ∣ (n - W + t) + (2 * n) * v := by
      simpa [add_assoc] using hdvd
    have hnBase : n ∣ n - W + t :=
      (Nat.dvd_add_iff_left hnPeriod).mpr hdvd'
    exact not_dvd_of_pos_lt_two_mul_ne n _ (by omega) (by omega)
      (by omega) hnBase

/-- Reverse isolation for a below-half residue requires no parity hypothesis on
`v`; the central high coefficient is `±1`, hence still a genuine mismatch. -/
theorem reverse_belowHalf_dyadicChain_sandwiched_pattern_anyParity
    (n R w X r v : ℕ) (hn : 0 < n) (hR : 0 < R)
    (hX : X = r + (2 * n) * v)
    (_hrpos : 0 < r) (hrn : r < n)
    (hwr : w < r) (hw : w < n - r) :
    let A := n - r - w
    (0 < A) ∧
    (∀ s < w, dyadicChainCoeff n R (A + s + X) =
      dyadicChainCoeff n R (A + s)) ∧
    dyadicChainCoeff n R (A + w + X) ≠
      dyadicChainCoeff n R (A + w) ∧
    (∀ s < w, dyadicChainCoeff n R (A + w + 1 + s + X) =
      dyadicChainCoeff n R (A + w + 1 + s)) := by
  let A := n - r - w
  have hAeq : A + r + w = n := by dsimp [A]; omega
  have hshift (t : ℕ) (_ht : t < 2 * w + 1) :
      A + t + X = n - w + t + (2 * n) * v := by
    rw [hX]
    omega
  have hlowPos (t : ℕ) : 0 < A + t := by dsimp [A]; omega
  have hlowLt (t : ℕ) (ht : t < 2 * w + 1) : A + t < n := by
    dsimp [A]
    omega
  have hlowZero (t : ℕ) (ht : t < 2 * w + 1) :
      dyadicChainCoeff n R (A + t) = 0 := by
    apply dyadicChainCoeff_eq_zero_of_not_dvd
    exact Nat.not_dvd_of_pos_of_lt (hlowPos t) (hlowLt t ht)
  have hhigh (t : ℕ) (ht : t < 2 * w + 1) :
      dyadicChainCoeff n R (A + t + X) =
        if t = w then (if Even n ∨ Even v then 1 else -1) else 0 := by
    rw [hshift t ht]
    exact dyadicChainCoeff_local_root_add_two_mul_formula
      n R w v t hn hR (by omega) ht
  refine ⟨by omega, ?_, ?_, ?_⟩
  · intro s hs
    rw [hhigh s (by omega), hlowZero s (by omega)]
    simp [show s ≠ w by omega]
  · rw [hhigh w (by omega), hlowZero w (by omega)]
    by_cases hpar : Even n ∨ Even v <;> simp [hpar]
  · intro s hs
    let t := w + 1 + s
    have ht : t < 2 * w + 1 := by dsimp [t]; omega
    have htw : t ≠ w := by dsimp [t]; omega
    rw [show n - r - w + w + 1 + s = A + t by
      dsimp [A, t]
      omega]
    rw [hhigh t ht, hlowZero t ht]
    simp [htw]

/-- If the quotient of `2n` by its gcd with `P` is odd and at least three,
there is a positive multiple of `P` whose residue modulo `2n` lies strictly
below `n`, at exact displacement half the gcd. -/
theorem exists_exact_belowHalf_multiplier_of_odd_reduced_twoPeriod
    (P n : ℕ) (hn : 0 < n)
    (hodd : Odd ((2 * n) / (2 * n).gcd P))
    (hthree : 3 ≤ (2 * n) / (2 * n).gcd P) :
    let d := (2 * n).gcd P
    ∃ X r v : ℕ,
      P ∣ X ∧ X < (2 * n) * P ∧
      X = r + (2 * n) * v ∧
      0 < r ∧ r < n ∧
      2 * (n - r) = d := by
  let d := (2 * n).gcd P
  let q := (2 * n) / d
  have htwo : 0 < 2 * n := by omega
  have hdpos : 0 < d := by
    dsimp [d]
    exact Nat.gcd_pos_of_pos_left P htwo
  have hdTwo : d ∣ 2 * n := by dsimp [d]; exact Nat.gcd_dvd_left _ _
  have hdP : d ∣ P := by dsimp [d]; exact Nat.gcd_dvd_right _ _
  have hfac : d * q = 2 * n := by
    dsimp [q]
    exact Nat.mul_div_cancel' hdTwo
  have hqodd : Odd q := by simpa [q, d] using hodd
  have hqthree : 3 ≤ q := by simpa [q, d] using hthree
  have hdEven : Even d := by
    apply Nat.not_odd_iff_even.mp
    intro hdOdd
    have hprodOdd : Odd (d * q) := hdOdd.mul hqodd
    rw [hfac] at hprodOdd
    exact (Nat.not_odd_iff_even.mpr ⟨n, by ring⟩) hprodOdd
  obtain ⟨d0, hd0⟩ := hdEven
  let k := (q - 1) / 2
  have hkpos : 0 < k := by dsimp [k]; omega
  have hklt : k < q := by dsimp [k]; omega
  have hqpos : 0 < q := by omega
  let P' := P / d
  have hPfac : d * P' = P := by
    dsimp [P']
    exact Nat.mul_div_cancel' hdP
  have hcop : P'.Coprime q := by
    have hc := Nat.coprime_div_gcd_div_gcd (m := 2 * n) (n := P) hdpos
    exact hc.symm
  obtain ⟨u, huq, hu⟩ :=
    Nat.exists_mul_mod_eq_of_coprime k hcop (Nat.ne_of_gt hqpos)
  have hkmod : k % q = k := Nat.mod_eq_of_lt hklt
  rw [hkmod] at hu
  let r := d * k
  let X := P * u
  have hrmod : r = X % (2 * n) := by
    dsimp [r, X]
    rw [← hPfac, ← hfac, mul_assoc, Nat.mul_mod_mul_left, hu]
  have hrpos : 0 < r := mul_pos hdpos hkpos
  have hqform : q = 2 * k + 1 := by
    obtain ⟨a, ha⟩ := hqodd
    dsimp [k]
    omega
  have hsum : 2 * r + d = 2 * n := by
    dsimp [r]
    rw [← hfac, hqform]
    ring
  have hrn : r < n := by omega
  let v := X / (2 * n)
  have hdecomp : X = r + (2 * n) * v := by
    have hx := Nat.mod_add_div X (2 * n)
    rw [← hrmod] at hx
    simpa [v] using hx.symm
  have hPpos : 0 < P := by
    by_contra hnot
    have hPzero : P = 0 := by omega
    dsimp [d, q] at hqthree
    simp only [hPzero, Nat.gcd_zero_right] at hqthree
    rw [Nat.div_self htwo] at hqthree
    omega
  have hqle : q ≤ 2 * n := Nat.div_le_self _ _
  have hXbound : X < (2 * n) * P := by
    dsimp [X]
    calc
      P * u < P * q := Nat.mul_lt_mul_of_pos_left huq hPpos
      _ ≤ P * (2 * n) := Nat.mul_le_mul_left P hqle
      _ = (2 * n) * P := by ring
  have hdist : 2 * (n - r) = d := by omega
  exact ⟨X, r, v, ⟨u, rfl⟩, hXbound, hdecomp,
    hrpos, hrn, hdist⟩

end Research
/-!
# Below-half reverse package from an odd reduced sharp period
-/

namespace Research

/-- Oddness of the quotient after removing a gcd is equivalent to saying that
all factors of two in the numerator are already available in the denominator;
this is the converse direction to `odd_div_gcd_of_twoAdicOrder_le`. -/
theorem twoAdicOrder_le_of_odd_div_gcd
    (a b : ℕ) (ha : 0 < a) (hb : 0 < b)
    (hodd : Odd (a / a.gcd b)) :
    twoAdicOrder a ≤ twoAdicOrder b := by
  by_contra hnot
  have hlt : twoAdicOrder b < twoAdicOrder a := by omega
  have htwoG : 2 * b.gcd a ∣ a :=
    (two_mul_gcd_dvd_iff_twoAdicOrder_lt b a hb ha).mpr hlt
  let g := a.gcd b
  let q := a / g
  have hgpos : 0 < g := by
    dsimp [g]
    exact Nat.gcd_pos_of_pos_left b ha
  have hga : g ∣ a := by dsimp [g]; exact Nat.gcd_dvd_left _ _
  have hfac : g * q = a := by
    dsimp [q]
    exact Nat.mul_div_cancel' hga
  obtain ⟨z, hz⟩ := htwoG
  have hqeven : q = 2 * z := by
    have heq : g * q = g * (2 * z) := by
      calc
        g * q = a := hfac
        _ = 2 * b.gcd a * z := hz
        _ = g * (2 * z) := by dsimp [g]; rw [Nat.gcd_comm b a]; ring
    exact Nat.mul_left_cancel hgpos heq
  have : Even q := ⟨z, by rw [hqeven]; ring⟩
  exact (Nat.not_even_iff_odd.mpr (by simpa [q, g] using hodd)) this

/-- An odd reduced sharp-period quotient forces the analogous quotient for
`2n` to be odd. -/
theorem odd_reduced_twoPeriod_of_odd_reduced_sharpPeriod
    (P n : ℕ) (hP : 0 < P) (hn : 0 < n)
    (hodd : Odd (fibLambertPeriod n /
      (fibLambertPeriod n).gcd P)) :
    Odd ((2 * n) / (2 * n).gcd P) := by
  have hsharpPos : 0 < fibLambertPeriod n := by
    unfold fibLambertPeriod
    split <;> omega
  have horderSharp : twoAdicOrder (fibLambertPeriod n) ≤
      twoAdicOrder P :=
    twoAdicOrder_le_of_odd_div_gcd
      (fibLambertPeriod n) P hsharpPos hP hodd
  have htwoDvd : 2 * n ∣ fibLambertPeriod n := by
    unfold fibLambertPeriod
    split_ifs
    · exact dvd_rfl
    · exact ⟨2, by ring⟩
  have horderTwo : twoAdicOrder (2 * n) ≤
      twoAdicOrder (fibLambertPeriod n) := by
    have hfac := (Nat.factorization_le_iff_dvd
      (by omega : 2 * n ≠ 0) (Nat.ne_of_gt hsharpPos)).mpr htwoDvd
    exact hfac 2
  apply odd_div_gcd_of_twoAdicOrder_le (2 * n) P (by omega) hP
  exact horderTwo.trans horderSharp

/-- If the odd reduced sharp period is genuinely new, the reduced `2n`
quotient is odd and at least three. -/
theorem odd_three_reduced_twoPeriod_of_new_odd_reduced_sharpPeriod
    (P n : ℕ) (hP : 0 < P) (hn : 0 < n)
    (hnew : ¬fibLambertPeriod n ∣ P)
    (hodd : Odd (fibLambertPeriod n /
      (fibLambertPeriod n).gcd P)) :
    Odd ((2 * n) / (2 * n).gcd P) ∧
      3 ≤ (2 * n) / (2 * n).gcd P := by
  have hoddTwo := odd_reduced_twoPeriod_of_odd_reduced_sharpPeriod
    P n hP hn hodd
  refine ⟨hoddTwo, ?_⟩
  have hqpos : 0 < (2 * n) / (2 * n).gcd P :=
    Nat.div_pos (Nat.gcd_le_left P (by omega))
      (Nat.gcd_pos_of_pos_left P (by omega))
  have hqne : (2 * n) / (2 * n).gcd P ≠ 1 := by
    intro heq
    have hgEq : (2 * n).gcd P = 2 * n := by
      have hgd : (2 * n).gcd P ∣ 2 * n := Nat.gcd_dvd_left _ _
      have hfac := Nat.mul_div_cancel' hgd
      rw [heq, mul_one] at hfac
      exact hfac
    have htwoP : 2 * n ∣ P := by
      rw [← hgEq]
      exact Nat.gcd_dvd_right _ _
    exact not_two_mul_dvd_of_new_and_odd_reduced_sharpPeriod
      P n hn hnew hodd htwoP
  obtain ⟨z, hz⟩ := hoddTwo
  omega

/-- Doubling the first gcd argument can enlarge the gcd by at most a factor of
`2`. -/
theorem gcd_four_mul_dvd_two_mul_gcd_two_mul
    (n P : ℕ) :
    (4 * n).gcd P ∣ 2 * (2 * n).gcd P := by
  have hleft : (4 * n).gcd P ∣ 2 * (2 * n) := by
    rw [show 2 * (2 * n) = 4 * n by ring]
    exact Nat.gcd_dvd_left _ _
  have hright : (4 * n).gcd P ∣ 2 * P :=
    dvd_mul_of_dvd_right (Nat.gcd_dvd_right (4 * n) P) 2
  have hg := Nat.dvd_gcd hleft hright
  simpa [Nat.gcd_mul_left, mul_assoc] using hg

/-- Complete reverse target package.  A new odd reduced sharp period and any
radius shorter than one quarter of the `4n` prefix gcd give a below-half
prefix multiple and an isolated finite-chain unit mismatch. -/
theorem exists_oddReducedSharp_belowHalf_dyadicChain_window_package
    (P n R w : ℕ) (hP : 0 < P) (hn : 0 < n) (hR : 0 < R)
    (hnew : ¬fibLambertPeriod n ∣ P)
    (hodd : Odd (fibLambertPeriod n /
      (fibLambertPeriod n).gcd P))
    (hwindow : 4 * w < (4 * n).gcd P) :
    ∃ A X r v : ℕ,
      0 < A ∧ P ∣ X ∧ X < (2 * n) * P ∧
      X = r + (2 * n) * v ∧
      0 < r ∧ r < n ∧
      (∀ s < w, dyadicChainCoeff n R (A + s + X) =
        dyadicChainCoeff n R (A + s)) ∧
      dyadicChainCoeff n R (A + w + X) ≠
        dyadicChainCoeff n R (A + w) ∧
      (∀ s < w, dyadicChainCoeff n R (A + w + 1 + s + X) =
        dyadicChainCoeff n R (A + w + 1 + s)) := by
  have hq := odd_three_reduced_twoPeriod_of_new_odd_reduced_sharpPeriod
    P n hP hn hnew hodd
  obtain ⟨X, r, v, hPX, hXbound, hX, hrpos, hrn, hdist⟩ :=
    exists_exact_belowHalf_multiplier_of_odd_reduced_twoPeriod
      P n hn hq.1 hq.2
  let d := (2 * n).gcd P
  have hgDvd : (4 * n).gcd P ∣ 2 * d := by
    simpa [d] using gcd_four_mul_dvd_two_mul_gcd_two_mul n P
  have hgLe : (4 * n).gcd P ≤ 2 * d :=
    Nat.le_of_dvd (by omega) hgDvd
  have hwD : w < n - r := by
    have hfour : 4 * w < 4 * (n - r) := calc
      4 * w < (4 * n).gcd P := hwindow
      _ ≤ 2 * d := hgLe
      _ = 4 * (n - r) := by
        have hdistd : 2 * (n - r) = d := by simpa [d] using hdist
        rw [← hdistd]
        ring
    omega
  have hwr : w < r := by
    have hqthree := hq.2
    have hdpos : 0 < d := by
      dsimp [d]
      exact Nat.gcd_pos_of_pos_left P (by omega)
    have hfac : d * ((2 * n) / d) = 2 * n :=
      Nat.mul_div_cancel' (by dsimp [d]; exact Nat.gcd_dvd_left _ _)
    have hqthree' : 3 ≤ (2 * n) / d := by simpa [d] using hqthree
    have hmul := Nat.mul_le_mul_left d hqthree'
    have hthreeD : 3 * (n - r) ≤ n := by
      rw [hfac] at hmul
      rw [show d = 2 * (n - r) by omega] at hmul
      nlinarith
    omega
  obtain ⟨hA, hpre, hmid, hpost⟩ :=
    reverse_belowHalf_dyadicChain_sandwiched_pattern_anyParity
      n R w X r v hn hR hX hrpos hrn hwr hwD
  exact ⟨n - r - w, X, r, v, hA, hPX, hXbound, hX,
    hrpos, hrn, hpre, hmid, hpost⟩

end Research
/-!
# Polynomial CRT protection for two arbitrary invertible affine forms

The original center sieve used the two special forms `4t+1` and
`2t+(v+1)`.  This file records the invariant content: two affine forms whose
slopes are units modulo every odd reduced center modulus remove at most two
residues per canonical prime, with the same polynomial protected density.
-/

namespace Research

open scoped BigOperators

/-- Residues modulo `q` avoiding two affine divisibility conditions. -/
def affinePairSafeResidues
    (q a b c d : ℕ) : Finset ℕ :=
  (Finset.range q).filter fun t =>
    (¬q ∣ b + a * t) ∧ (¬q ∣ d + c * t)

/-- Two affine forms with invertible slopes remove at most two residues. -/
theorem sub_two_le_card_affinePairSafeResidues
    (q a b c d : ℕ) (hq : 3 ≤ q)
    (ha : q.gcd a = 1) (hc : q.gcd c = 1) :
    q - 2 ≤ (affinePairSafeResidues q a b c d).card := by
  classical
  let B₁ := (Finset.range q).filter fun t => q ∣ b + a * t
  let B₂ := (Finset.range q).filter fun t => q ∣ d + c * t
  let B := (Finset.range q).filter fun t =>
    q ∣ b + a * t ∨ q ∣ d + c * t
  have hB₁ : B₁.card ≤ 1 := by
    dsimp [B₁]
    exact card_affine_bad_residues_le_one b a q (by omega) ha
  have hB₂ : B₂.card ≤ 1 := by
    dsimp [B₂]
    exact card_affine_bad_residues_le_one d c q (by omega) hc
  have hBunion : B = B₁ ∪ B₂ := by
    dsimp [B, B₁, B₂]
    rw [← Finset.filter_or]
  have hB : B.card ≤ 2 := by
    rw [hBunion]
    exact (Finset.card_union_le _ _).trans (by omega)
  have hpartition := Finset.card_filter_add_card_filter_not
    (s := Finset.range q)
    (fun t => q ∣ b + a * t ∨ q ∣ d + c * t)
  have hsafe :
      ((Finset.range q).filter fun t =>
        ¬(q ∣ b + a * t ∨ q ∣ d + c * t)) =
        affinePairSafeResidues q a b c d := by
    ext t
    simp [affinePairSafeResidues]
  have hpart : B.card + (affinePairSafeResidues q a b c d).card = q := by
    rw [← hsafe]
    simpa [B] using hpartition
  omega

/-- Simultaneous affine-pair-safe residues in one product period. -/
def globalAffinePairSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (a b c d : ℕ) : Finset ℕ :=
  (Finset.range (∏ i, p i)).filter fun t =>
    ∀ i, (¬p i ∣ b + a * t) ∧ (¬p i ∣ d + c * t)

/-- The Cartesian product of local safe sets injects into the global CRT-safe
set. -/
theorem prod_card_affinePairSafeResidues_le_global
    {r : ℕ} (p : Fin r → ℕ) (a b c d : ℕ)
    (hp : ∀ i, 0 < p i)
    (hpair : ∀ i j, i ≠ j → (p i).Coprime (p j)) :
    (∏ i, (affinePairSafeResidues (p i) a b c d).card) ≤
      (globalAffinePairSafeResidues p a b c d).card := by
  classical
  let S : Finset (Fin r) := Finset.univ
  have hpne : ∀ i ∈ S, p i ≠ 0 := by
    intro i _
    exact Nat.ne_of_gt (hp i)
  have hpairS : Set.Pairwise S (fun i j => (p i).Coprime (p j)) := by
    intro i _ j _ hij
    exact hpair i j hij
  let α := ∀ i : Fin r,
    {x // x ∈ affinePairSafeResidues (p i) a b c d}
  let crt (x : α) : ℕ :=
    Nat.chineseRemainderOfFinset (fun i => (x i : ℕ)) p S hpne hpairS
  have hcrt_lt (x : α) : crt x < ∏ i, p i := by
    have h := Nat.chineseRemainderOfFinset_lt_prod
      (fun i => (x i : ℕ)) p hpne hpairS
    simpa [crt, S] using h
  have hcrt_safe (x : α) (i : Fin r) :
      (¬p i ∣ b + a * crt x) ∧ (¬p i ∣ d + c * crt x) := by
    have hz : crt x ≡ (x i : ℕ) [MOD p i] :=
      (Nat.chineseRemainderOfFinset
        (fun j => (x j : ℕ)) p S hpne hpairS).property i (by simp [S])
    have hx := Finset.mem_filter.mp (x i).property
    have hlin₁ : b + a * crt x ≡ b + a * (x i : ℕ) [MOD p i] :=
      (Nat.ModEq.refl b).add (hz.mul_left a)
    have hlin₂ : d + c * crt x ≡ d + c * (x i : ℕ) [MOD p i] :=
      (Nat.ModEq.refl d).add (hz.mul_left c)
    constructor
    · intro hdvd
      exact hx.2.1 ((hlin₁.dvd_iff dvd_rfl).mp hdvd)
    · intro hdvd
      exact hx.2.2 ((hlin₂.dvd_iff dvd_rfl).mp hdvd)
  let f : α → {t // t ∈ globalAffinePairSafeResidues p a b c d} := fun x =>
    ⟨crt x, Finset.mem_filter.mpr
      ⟨Finset.mem_range.mpr (hcrt_lt x), fun i => hcrt_safe x i⟩⟩
  have hf : Function.Injective f := by
    intro x y hxy
    funext i
    apply Subtype.ext
    have hzx : crt x ≡ (x i : ℕ) [MOD p i] :=
      (Nat.chineseRemainderOfFinset
        (fun j => (x j : ℕ)) p S hpne hpairS).property i (by simp [S])
    have hzy : crt y ≡ (y i : ℕ) [MOD p i] :=
      (Nat.chineseRemainderOfFinset
        (fun j => (y j : ℕ)) p S hpne hpairS).property i (by simp [S])
    have hcrt : crt x = crt y := congrArg Subtype.val hxy
    have hmod : (x i : ℕ) ≡ (y i : ℕ) [MOD p i] :=
      hzx.symm.trans (by simpa [hcrt] using hzy)
    have hxlt : (x i : ℕ) < p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp (x i).property).1
    have hylt : (y i : ℕ) < p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp (y i).property).1
    exact hmod.eq_of_lt_of_lt hxlt hylt
  have hcard := Fintype.card_le_of_injective f hf
  simpa [α, Fintype.card_pi, globalAffinePairSafeResidues] using hcard

/-- Product lower bound for arbitrary affine-pair-safe CRT residues. -/
theorem prod_sub_two_le_globalAffinePairSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (a b c d : ℕ)
    (hp3 : ∀ i, 3 ≤ p i)
    (ha : ∀ i, (p i).gcd a = 1)
    (hc : ∀ i, (p i).gcd c = 1)
    (hpair : ∀ i j, i ≠ j → (p i).Coprime (p j)) :
    (∏ i, (p i - 2)) ≤
      (globalAffinePairSafeResidues p a b c d).card := by
  calc
    (∏ i, (p i - 2)) ≤
        ∏ i, (affinePairSafeResidues (p i) a b c d).card := by
      apply Finset.prod_le_prod
      · intro i hi
        exact Nat.zero_le _
      · intro i hi
        exact sub_two_le_card_affinePairSafeResidues
          (p i) a b c d (hp3 i) (ha i) (hc i)
    _ ≤ (globalAffinePairSafeResidues p a b c d).card :=
      prod_card_affinePairSafeResidues_le_global p a b c d
        (fun i => lt_of_lt_of_le (by norm_num) (hp3 i)) hpair

/-- Enumerate a finite odd-prime family and obtain the usual polynomial density
for any two slopes which are units modulo those primes. -/
theorem exists_prime_enumeration_with_globalAffinePair_safe_bound_onto
    (S : Finset ℕ) (a b c d : ℕ)
    (hprime : ∀ z ∈ S, z.Prime)
    (hodd : ∀ z ∈ S, Odd z)
    (ha : ∀ z ∈ S, z.gcd a = 1)
    (hc : ∀ z ∈ S, z.gcd c = 1) :
    ∃ p : Fin S.card → ℕ,
      (∏ i, p i) = ∏ z ∈ S, z ∧
      (∀ i, (p i).Prime) ∧
      (∀ i, 3 ≤ p i) ∧
      (∀ i j, i ≠ j → (p i).Coprime (p j)) ∧
      (∀ z ∈ S, ∃ i, p i = z) ∧
      2 * (∏ i, p i) ≤
        (S.card + 1) * (S.card + 2) *
          (globalAffinePairSafeResidues p a b c d).card := by
  classical
  let e : Fin S.card ≃ {x // x ∈ S} :=
    (Fin.castOrderIso (Fintype.card_coe S).symm).toEquiv.trans
      (Fintype.equivFin {x // x ∈ S}).symm
  let p : Fin S.card → ℕ := fun i => (e i : ℕ)
  have hpMem (i : Fin S.card) : p i ∈ S := (e i).property
  have hpPrime (i : Fin S.card) : (p i).Prime :=
    hprime (p i) (hpMem i)
  have hpOdd (i : Fin S.card) : Odd (p i) := hodd (p i) (hpMem i)
  have hp3 (i : Fin S.card) : 3 ≤ p i := by
    have h2 := (hpPrime i).two_le
    have hne : p i ≠ 2 := by
      intro heq
      have heven : Even (p i) := by rw [heq]; norm_num
      exact (Nat.not_even_iff_odd.mpr (hpOdd i)) heven
    omega
  have hpPair : ∀ i j, i ≠ j → (p i).Coprime (p j) := by
    intro i j hij
    apply (Nat.coprime_primes (hpPrime i) (hpPrime j)).mpr
    intro hpij
    apply hij
    exact e.injective (Subtype.ext hpij)
  have hprod : (∏ i, p i) = ∏ z ∈ S, z := by
    calc
      (∏ i, p i) = ∏ x : {x // x ∈ S}, (x : ℕ) :=
        Equiv.prod_comp e (fun x : {x // x ∈ S} => (x : ℕ))
      _ = ∏ z ∈ S, z := Finset.prod_coe_sort S (fun z => z)
  have hprodSub : (∏ i, (p i - 2)) = ∏ z ∈ S, (z - 2) := by
    calc
      (∏ i, (p i - 2)) =
          ∏ x : {x // x ∈ S}, ((x : ℕ) - 2) :=
        Equiv.prod_comp e (fun x : {x // x ∈ S} => ((x : ℕ) - 2))
      _ = ∏ z ∈ S, (z - 2) :=
        Finset.prod_coe_sort S (fun z => z - 2)
  have hpa : ∀ i, (p i).gcd a = 1 := fun i => ha (p i) (hpMem i)
  have hpc : ∀ i, (p i).gcd c = 1 := fun i => hc (p i) (hpMem i)
  have hsafe : (∏ i, (p i - 2)) ≤
      (globalAffinePairSafeResidues p a b c d).card :=
    prod_sub_two_le_globalAffinePairSafeResidues
      p a b c d hp3 hpa hpc hpPair
  have honto : ∀ z ∈ S, ∃ i, p i = z := by
    intro z hz
    obtain ⟨i, hi⟩ := e.surjective ⟨z, hz⟩
    exact ⟨i, congrArg Subtype.val hi⟩
  have hdensity := two_mul_prod_le_card_factor_mul_prod_sub_two S
    (fun z hz => by
      have hz2 := (hprime z hz).two_le
      have hzNe : z ≠ 2 := by
        intro h
        have : Even z := by rw [h]; norm_num
        exact (Nat.not_even_iff_odd.mpr (hodd z hz)) this
      omega)
  refine ⟨p, hprod, hpPrime, hp3, hpPair, honto, ?_⟩
  calc
    2 * (∏ i, p i) = 2 * (∏ z ∈ S, z) := by rw [hprod]
    _ ≤ (S.card + 1) * (S.card + 2) *
        (∏ z ∈ S, (z - 2)) := hdensity
    _ = (S.card + 1) * (S.card + 2) *
        (∏ i, (p i - 2)) := by rw [hprodSub]
    _ ≤ (S.card + 1) * (S.card + 2) *
        (globalAffinePairSafeResidues p a b c d).card :=
      Nat.mul_le_mul_left _ hsafe

/-- Repeat the affine-pair-safe set through `T` complete CRT periods. -/
def replicatedGlobalAffinePairSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (a b c d T : ℕ) : Finset ℕ :=
  ((Finset.range T).product
    (globalAffinePairSafeResidues p a b c d)).image fun z =>
      z.2 + (∏ i, p i) * z.1

lemma card_replicatedGlobalAffinePairSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (a b c d T : ℕ)
    (hM : 0 < ∏ i, p i) :
    (replicatedGlobalAffinePairSafeResidues p a b c d T).card =
      T * (globalAffinePairSafeResidues p a b c d).card := by
  classical
  unfold replicatedGlobalAffinePairSafeResidues
  rw [Finset.card_image_of_injOn]
  · simp
  · intro z hz w hw hzw
    have hzlt : z.2 < ∏ i, p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp
        (Finset.mem_product.mp hz).2).1
    have hwlt : w.2 < ∏ i, p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp
        (Finset.mem_product.mp hw).2).1
    have hrem := congrArg (fun x => x % (∏ i, p i)) hzw
    simp only [Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt hzlt,
      Nat.mod_eq_of_lt hwlt] at hrem
    have hblock : z.1 = w.1 := by
      change z.2 + (∏ i, p i) * z.1 =
        w.2 + (∏ i, p i) * w.1 at hzw
      rw [hrem] at hzw
      exact Nat.mul_left_cancel hM (Nat.add_left_cancel hzw)
    cases z
    cases w
    simp_all

/-- Scaled protected-candidate theorem for two arbitrary coherent affine
forms. -/
theorem exists_exact_period_with_scaled_polynomially_many_affinePair_centers
    {ι : Type*} [DecidableEq ι]
    (Q : Finset ℕ) (C : Finset ι) (side : ι → Bool)
    (offset qmod : ι → ℕ) (step a b c d : ℕ)
    (hQ3 : ∀ q ∈ Q, 3 ≤ q)
    (hQodd : ∀ q ∈ Q, Odd q)
    (hQa : ∀ q ∈ Q, q.gcd a = 1)
    (hQc : ∀ q ∈ Q, q.gcd c = 1)
    (hcover : ∀ u ∈ C, ∃ q ∈ Q, ∀ t,
      qmod u ∣ offset u + step * t →
        if side u then q ∣ d + c * t else q ∣ b + a * t) :
    let S := centerPrimeFactors Q
    ∃ M : ℕ, 0 < M ∧ M = ∏ z ∈ S, z ∧ ∀ T : ℕ,
      2 * (T * M) ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C offset qmod step (T * M)).card := by
  classical
  let S := centerPrimeFactors Q
  have hSdata := centerPrimeFactors_prime_odd_ge_three Q hQ3 hQodd
  have hSprime : ∀ z ∈ S, z.Prime := fun z hz => (hSdata z hz).1
  have hSodd : ∀ z ∈ S, Odd z := fun z hz => (hSdata z hz).2.1
  have hSa : ∀ z ∈ S, z.gcd a = 1 := by
    intro z hz
    obtain ⟨q, hqQ, hqz⟩ := (mem_centerPrimeFactors_iff Q z).mp hz
    have hzd : z ∣ q := by simpa [hqz] using Nat.minFac_dvd q
    exact (Nat.Coprime.of_dvd_left hzd (hQa q hqQ)).gcd_eq_one
  have hSc : ∀ z ∈ S, z.gcd c = 1 := by
    intro z hz
    obtain ⟨q, hqQ, hqz⟩ := (mem_centerPrimeFactors_iff Q z).mp hz
    have hzd : z ∣ q := by simpa [hqz] using Nat.minFac_dvd q
    exact (Nat.Coprime.of_dvd_left hzd (hQc q hqQ)).gcd_eq_one
  obtain ⟨p, hprod, hpPrime, hp3, hpPair, honto, hsafeBound⟩ :=
    exists_prime_enumeration_with_globalAffinePair_safe_bound_onto
      S a b c d hSprime hSodd hSa hSc
  let M := ∏ i, p i
  have hMpos : 0 < M := by
    dsimp [M]
    apply Finset.prod_pos
    intro i hi
    exact lt_of_lt_of_le (by norm_num) (hp3 i)
  refine ⟨M, hMpos, hprod, ?_⟩
  intro T
  have hsubset : replicatedGlobalAffinePairSafeResidues p a b c d T ⊆
      protectedCandidates C offset qmod step (T * M) := by
    intro t htRep
    obtain ⟨z, hzProd, rfl⟩ := Finset.mem_image.mp htRep
    have hzT := Finset.mem_range.mp (Finset.mem_product.mp hzProd).1
    have hzSafe := (Finset.mem_product.mp hzProd).2
    have hzData := Finset.mem_filter.mp hzSafe
    apply Finset.mem_filter.mpr
    refine ⟨Finset.mem_range.mpr ?_, ?_⟩
    · have hzlt := Finset.mem_range.mp hzData.1
      dsimp [M]
      nlinarith
    · intro u huC hbad
      obtain ⟨q, hqQ, himp⟩ := hcover u huC
      have hform := himp (z.2 + M * z.1) hbad
      have hqne : q ≠ 1 := by have := hQ3 q hqQ; omega
      let prime := q.minFac
      have hprimeS : prime ∈ S :=
        (mem_centerPrimeFactors_iff Q prime).mpr ⟨q, hqQ, rfl⟩
      obtain ⟨i, hpi⟩ := honto prime hprimeS
      have hsafeI := hzData.2 i
      have hpM : p i ∣ M := by
        dsimp [M]
        exact Finset.dvd_prod_of_mem p (by simp)
      have hreduceA : p i ∣ b + a * z.2 ↔
          p i ∣ b + a * (z.2 + M * z.1) := by
        have hdvd : p i ∣ a * M * z.1 := by
          exact dvd_mul_of_dvd_left (dvd_mul_of_dvd_right hpM a) z.1
        rw [show b + a * (z.2 + M * z.1) =
          a * M * z.1 + (b + a * z.2) by ring]
        exact Nat.dvd_add_iff_right hdvd
      have hreduceC : p i ∣ d + c * z.2 ↔
          p i ∣ d + c * (z.2 + M * z.1) := by
        have hdvd : p i ∣ c * M * z.1 := by
          exact dvd_mul_of_dvd_left (dvd_mul_of_dvd_right hpM c) z.1
        rw [show d + c * (z.2 + M * z.1) =
          c * M * z.1 + (d + c * z.2) by ring]
        exact Nat.dvd_add_iff_right hdvd
      have hprimeDvd : prime ∣ q := Nat.minFac_dvd q
      split at hform
      · apply hsafeI.2
        rw [hreduceC]
        simpa [hpi] using dvd_trans hprimeDvd hform
      · apply hsafeI.1
        rw [hreduceA]
        simpa [hpi] using dvd_trans hprimeDvd hform
  have hcard := Finset.card_le_card hsubset
  have hrepCard := card_replicatedGlobalAffinePairSafeResidues
    p a b c d T hMpos
  have hbaseScaled := Nat.mul_le_mul_left T hsafeBound
  calc
    2 * (T * M) = T * (2 * (∏ i, p i)) := by dsimp [M]; ring
    _ ≤ T * ((S.card + 1) * (S.card + 2) *
        (globalAffinePairSafeResidues p a b c d).card) := hbaseScaled
    _ = (S.card + 1) * (S.card + 2) *
        (replicatedGlobalAffinePairSafeResidues p a b c d T).card := by
      rw [hrepCard]
      ring
    _ ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C offset qmod step (T * M)).card :=
      Nat.mul_le_mul_left _ hcard

end Research
/-!
# Center and exceptional-condition geometry for reverse below-half windows
-/

namespace Research

/-- The enlarged target step captures every factor of two of a number whose
2-adic order is at most `V`; hence its reduced modulus is odd. -/
theorem odd_reduced_modulus_of_twoAdicOrder_le_enlarged_target
    (m n V : ℕ) (hm : 0 < m) (hn : 0 < n)
    (hV : twoAdicOrder m ≤ V) :
    Odd (m / m.gcd ((4 * n) * 2 ^ V)) := by
  have hp : 0 < (4 * n) * 2 ^ V := by positivity
  have horderP : V ≤ twoAdicOrder ((4 * n) * 2 ^ V) := by
    unfold twoAdicOrder
    rw [Nat.factorization_mul (by positivity : 4 * n ≠ 0)
      (by positivity : 2 ^ V ≠ 0), Finsupp.add_apply,
      Nat.factorization_pow]
    simp only [Finsupp.smul_apply, smul_eq_mul, factorization_two_at_two]
    omega
  exact odd_div_gcd_of_twoAdicOrder_le m ((4 * n) * 2 ^ V)
    hm hp (hV.trans horderP)

/-- Compatible conditions at the common center offset of the two reverse
windows. -/
def reverseWindowCenterConditions
    (n : ℕ → ℕ) (K H W A X p w : ℕ) :
    Finset ((ℕ × ℕ) × Bool) :=
  (compatibleTwoWindowConditions n K H W A X p).filter fun u =>
    u.1.2 = w

/-- All compatible reverse-window conditions except the two center labels. -/
def reverseWindowOffCenterConditions
    (n : ℕ → ℕ) (K H W A X p w : ℕ) :
    Finset ((ℕ × ℕ) × Bool) :=
  compatibleTwoWindowConditions n K H W A X p \
    reverseWindowCenterConditions n K H W A X p w

/-- A common divisor of two naturals divides their natural distance. -/
lemma dvd_natDist {g a b : ℕ} (ha : g ∣ a) (hb : g ∣ b) :
    g ∣ a.dist b := by
  rcases le_total a b with hab | hba
  · rw [Nat.dist_eq_sub_of_le hab]
    exact Nat.dvd_sub hb ha
  · rw [Nat.dist_eq_sub_of_le_right hba]
    exact Nat.dvd_sub ha hb

/-- Away from the center of the shifted/root window, compatibility forces the
gcd below `scale*w`. -/
theorem reverseWindow_offCenter_large_is_left_center_incompatible
    (m n D w s X scale v : ℕ)
    (_hn : 0 < n) (hD : w < D) (hs : s < 2 * w + 1)
    (hX : D + X = n * (2 * v + 1))
    (hscale : 0 < scale)
    (hcomp : m.gcd (scale * n) ∣ D - w + s + X)
    (hoff : s ≠ w)
    (hlarge : scale * w < m.gcd (scale * n)) :
    False := by
  let g := m.gcd (scale * n)
  have hgStep : g ∣ scale * n := by
    dsimp [g]
    exact Nat.gcd_dvd_right _ _
  have hgScaleCenter : g ∣ scale * (D + X) := by
    rw [hX, show scale * (n * (2 * v + 1)) =
      (scale * n) * (2 * v + 1) by ring]
    exact dvd_mul_of_dvd_left hgStep _
  have hcomp' : g ∣ D - w + s + X := by simpa [g] using hcomp
  have hgScaleComp : g ∣ scale * (D - w + s + X) :=
    dvd_mul_of_dvd_right hcomp' scale
  have hdiff : (D - w + s + X).dist (D + X) = s.dist w := by
    rcases le_total s w with hsw | hws
    · rw [Nat.dist_eq_sub_of_le (by omega : D - w + s + X ≤ D + X),
        Nat.dist_eq_sub_of_le hsw]
      omega
    · rw [Nat.dist_eq_sub_of_le_right (by omega : D + X ≤ D - w + s + X),
        Nat.dist_eq_sub_of_le_right hws]
      omega
  have hgScaleDist : g ∣ scale * (s.dist w) := by
    have hd := dvd_natDist hgScaleComp hgScaleCenter
    rw [Nat.dist_mul_left, hdiff] at hd
    exact hd
  have hdistPos : 0 < s.dist w := Nat.dist_pos_of_ne hoff
  have hgLe : g ≤ scale * (s.dist w) :=
    Nat.le_of_dvd (mul_pos hscale hdistPos) hgScaleDist
  have hdistLe : s.dist w ≤ w := by
    rcases le_total s w with hsw | hws
    · rw [Nat.dist_eq_sub_of_le hsw]
      omega
    · rw [Nat.dist_eq_sub_of_le_right hws]
      omega
  have : g ≤ scale * w :=
    hgLe.trans (Nat.mul_le_mul_left scale hdistLe)
  dsimp [g] at this
  omega

/-- General side-aware version of the preceding geometry.  Every off-center
condition with gcd greater than `scale*w` is on the lower window and its lower
center is incompatible. -/
theorem reverseWindow_large_offCenter_data
    (m n D w s X scale v : ℕ)
    (hn : 0 < n) (hD : w < D) (hs : s < 2 * w + 1)
    (hroot : D + X = n * (2 * v + 1))
    (hscale : 0 < scale) (side : Bool)
    (hcomp : m.gcd (scale * n) ∣
      (if side then D - w + s + X else D - w + s))
    (hoff : s ≠ w)
    (hlarge : scale * w < m.gcd (scale * n)) :
    side = false ∧ ¬m.gcd (scale * n) ∣ D := by
  by_cases hside : side = true
  · subst side
    exfalso
    exact reverseWindow_offCenter_large_is_left_center_incompatible
      m n D w s X scale v hn hD hs hroot hscale hcomp hoff hlarge
  · have hsideFalse : side = false := Bool.eq_false_of_not_eq_true hside
    refine ⟨hsideFalse, ?_⟩
    intro hgD
    let g := m.gcd (scale * n)
    have hcomp' : g ∣ D - w + s := by
      simpa [g, hsideFalse] using hcomp
    have hgDist : g ∣ s.dist w := by
      have hEq : (D - w + s).dist D = s.dist w := by
        rcases le_total s w with hsw | hws
        · rw [Nat.dist_eq_sub_of_le (by omega : D - w + s ≤ D),
            Nat.dist_eq_sub_of_le hsw]
          omega
        · rw [Nat.dist_eq_sub_of_le_right (by omega : D ≤ D - w + s),
            Nat.dist_eq_sub_of_le_right hws]
          omega
      rw [← hEq]
      exact dvd_natDist hcomp' hgD
    have hgLe : g ≤ s.dist w :=
      Nat.le_of_dvd (Nat.dist_pos_of_ne hoff) hgDist
    have hdistLe : s.dist w ≤ w := by
      rcases le_total s w with hsw | hws
      · rw [Nat.dist_eq_sub_of_le hsw]; omega
      · rw [Nat.dist_eq_sub_of_le_right hws]; omega
    have : g ≤ w := hgLe.trans hdistLe
    dsimp [g] at this
    nlinarith

/-- A compatible noncentral lower offset has a very large reduced modulus.
The bound is uniform in the target odd quotient: if `n` dominates
`2*scale*B^2*w`, then the reduced modulus is greater than `B`. -/
theorem reverseWindow_left_incompatible_reduced_modulus_gt
    (m n D Q w s scale B : ℕ)
    (hn : 0 < n) (hm : n < m) (hD : w < D) (hQ : n = Q * D)
    (hs : s < 2 * w + 1) (hscale : 0 < scale)
    (hcomp : m.gcd (scale * n) ∣ D - w + s)
    (hincompat : ¬m.gcd (scale * n) ∣ D)
    (hsize : 2 * scale * B ^ 2 * w ≤ n) :
    B < m / m.gcd (scale * n) := by
  let g := m.gcd (scale * n)
  let q := m / g
  let E := D - w + s
  have hgpos : 0 < g := by
    dsimp [g]
    exact Nat.gcd_pos_of_pos_left (scale * n) (by omega)
  have hgM : g ∣ m := by dsimp [g]; exact Nat.gcd_dvd_left _ _
  have hfac : m = g * q := by
    dsimp [q]
    exact (Nat.mul_div_cancel' hgM).symm
  have hEpos : 0 < E := by dsimp [E]; omega
  have hcompE : g ∣ E := by simpa [g, E] using hcomp
  have hEle : E ≤ D + w := by dsimp [E]; omega
  have hgLtTwoD : g < 2 * D := by
    have hgE := Nat.le_of_dvd hEpos hcompE
    omega
  have hEneD : E ≠ D := by
    intro heq
    apply hincompat
    simpa [g, E, heq] using hcompE
  have hdistPos : 0 < E.dist D := Nat.dist_pos_of_ne hEneD
  have hdistLe : E.dist D ≤ w := by
    dsimp [E]
    rcases le_total s w with hsw | hws
    · rw [Nat.dist_eq_sub_of_le (by omega : D - w + s ≤ D)]
      omega
    · rw [Nat.dist_eq_sub_of_le_right (by omega : D ≤ D - w + s)]
      omega
  have hgScaleN : g ∣ scale * n := by
    dsimp [g]
    exact Nat.gcd_dvd_right _ _
  have hQpos : 0 < Q := by
    rw [hQ] at hn
    exact Nat.pos_of_mul_pos_right hn
  have hgScaleQD : g ∣ scale * Q * D := by
    simpa [hQ, mul_assoc] using hgScaleN
  have hgScaleQE : g ∣ scale * Q * E := by
    simpa [mul_assoc] using
      (dvd_mul_of_dvd_right (dvd_mul_of_dvd_right hcompE Q) scale)
  have hgDist : g ∣ scale * Q * (E.dist D) := by
    rcases le_total E D with hED | hDE
    · rw [Nat.dist_eq_sub_of_le hED, Nat.mul_sub_left_distrib]
      exact Nat.dvd_sub hgScaleQD hgScaleQE
    · rw [Nat.dist_eq_sub_of_le_right hDE, Nat.mul_sub_left_distrib]
      exact Nat.dvd_sub hgScaleQE hgScaleQD
  have hgBound : g ≤ scale * Q * w := by
    have hle := Nat.le_of_dvd
      (mul_pos (mul_pos hscale hQpos) hdistPos) hgDist
    exact hle.trans (Nat.mul_le_mul_left (scale * Q) hdistLe)
  by_contra hnot
  have hqB : q ≤ B := by simpa [q, g] using Nat.not_lt.mp hnot
  have hQlt : Q < 2 * q := by
    have hmLt : m < 2 * D * q := by
      rw [hfac]
      exact Nat.mul_lt_mul_of_pos_right hgLtTwoD (by
        have hqpos : 0 < q := by
          dsimp [q, g]
          exact Nat.div_pos (Nat.gcd_le_left (scale * n) (by omega)) hgpos
        exact hqpos)
    rw [hQ] at hm
    nlinarith
  have hQle : Q ≤ 2 * B := by omega
  have hmBound : m ≤ 2 * scale * B ^ 2 * w := calc
    m = g * q := hfac
    _ ≤ (scale * Q * w) * B :=
      Nat.mul_le_mul hgBound hqB
    _ ≤ (scale * (2 * B) * w) * B := by
      exact Nat.mul_le_mul_right B
        (Nat.mul_le_mul_right w (Nat.mul_le_mul_left scale hQle))
    _ = 2 * scale * B ^ 2 * w := by ring
  omega

/-- A compatible lower reverse center has an odd nontrivial reduced modulus. -/
theorem reverse_left_center_reduced_odd_ge_three
    (m n D V : ℕ) (hm : n < m) (hn : 0 < n) (hDpos : 0 < D)
    (horder : twoAdicOrder m ≤ V)
    (hcomp : m.gcd ((4 * n) * 2 ^ V) ∣ D)
    (hDn : D < n) :
    Odd (m / m.gcd ((4 * n) * 2 ^ V)) ∧
      3 ≤ m / m.gcd ((4 * n) * 2 ^ V) := by
  let p := (4 * n) * 2 ^ V
  let g := m.gcd p
  let q := m / g
  have hodd : Odd q := by
    simpa [q, g, p] using
      odd_reduced_modulus_of_twoAdicOrder_le_enlarged_target
        m n V (by omega) hn horder
  have hgpos : 0 < g := by
    dsimp [g, p]
    exact Nat.gcd_pos_of_pos_left _ (by omega)
  have hgM : g ∣ m := by dsimp [g]; exact Nat.gcd_dvd_left _ _
  have hfac : m = g * q := by
    dsimp [q]
    exact (Nat.mul_div_cancel' hgM).symm
  have hqne : q ≠ 1 := by
    intro hq
    have hgleD : g ≤ D := Nat.le_of_dvd hDpos (by simpa [g, p] using hcomp)
    rw [hfac, hq, mul_one] at hm
    omega
  refine ⟨by simpa [q, g, p] using hodd, ?_⟩
  obtain ⟨z, hz⟩ := hodd
  change 3 ≤ q
  have hqpos : 0 < q := by
    dsimp [q, g, p]
    exact Nat.div_pos (Nat.gcd_le_left _ (by omega)) hgpos
  omega

/-- A compatible shifted/root reverse center also has an odd nontrivial
reduced modulus.  Quotient one would divide both a power-of-two multiple of
`n` and an odd multiple of `n`, hence divide `n`. -/
theorem reverse_right_center_reduced_odd_ge_three
    (m n V v : ℕ) (hm : n < m) (hn : 0 < n)
    (horder : twoAdicOrder m ≤ V)
    (hcomp : m.gcd ((4 * n) * 2 ^ V) ∣ n * (2 * v + 1)) :
    Odd (m / m.gcd ((4 * n) * 2 ^ V)) ∧
      3 ≤ m / m.gcd ((4 * n) * 2 ^ V) := by
  let p := (4 * n) * 2 ^ V
  let g := m.gcd p
  let q := m / g
  have hodd : Odd q := by
    simpa [q, g, p] using
      odd_reduced_modulus_of_twoAdicOrder_le_enlarged_target
        m n V (by omega) hn horder
  have hgpos : 0 < g := by
    dsimp [g, p]
    exact Nat.gcd_pos_of_pos_left _ (by omega)
  have hgM : g ∣ m := by dsimp [g]; exact Nat.gcd_dvd_left _ _
  have hfac : m = g * q := by
    dsimp [q]
    exact (Nat.mul_div_cancel' hgM).symm
  have hqne : q ≠ 1 := by
    intro hq
    have hgp : g ∣ n * 2 ^ (V + 2) := by
      have hg := Nat.gcd_dvd_right m p
      have hpEq : p = n * 2 ^ (V + 2) := by
        dsimp [p]
        rw [pow_succ, pow_succ]
        ring
      simpa [g, hpEq] using hg
    have hgo : g ∣ n * (2 * v + 1) := by simpa [g, p] using hcomp
    have hOdd : Odd (2 * v + 1) := ⟨v, by omega⟩
    have hgn : g ∣ n :=
      dvd_base_of_dvd_base_mul_twoPow_and_odd
        g n (V + 2) (2 * v + 1) hgp hgo hOdd
    rw [hfac, hq, mul_one] at hm
    exact (not_le_of_gt hm) (Nat.le_of_dvd hn hgn)
  refine ⟨by simpa [q, g, p] using hodd, ?_⟩
  obtain ⟨z, hz⟩ := hodd
  change 3 ≤ q
  have hqpos : 0 < q := by
    dsimp [q, g, p]
    exact Nat.div_pos (Nat.gcd_le_left _ (by omega)) hgpos
  omega

/-- Exact reduced affine form at a compatible lower reverse center. -/
theorem reverse_left_center_divisibility_iff_reduced
    (m n D Q V t : ℕ) (hm : 0 < m) (hnD : n = Q * D)
    (hcomp : m.gcd ((4 * n) * 2 ^ V) ∣ D) :
    m ∣ D + ((4 * n) * 2 ^ V) * t ↔
      m / m.gcd ((4 * n) * 2 ^ V) ∣
        1 + (4 * 2 ^ V * Q) * t := by
  let p := (4 * n) * 2 ^ V
  let g := m.gcd p
  let q := m / g
  let u := D / g
  have hgpos : 0 < g := by
    dsimp [g, p]
    exact Nat.gcd_pos_of_pos_left _ hm
  have hgm : m = g * q := by
    dsimp [q]
    exact (Nat.mul_div_cancel' (by dsimp [g]; exact Nat.gcd_dvd_left _ _)).symm
  have hgD : g ∣ D := by simpa [g, p] using hcomp
  have hD : D = g * u := by
    dsimp [u]
    exact (Nat.mul_div_cancel' hgD).symm
  have hDp : D ∣ p := by
    dsimp [p]
    rw [hnD]
    exact ⟨4 * 2 ^ V * Q, by ring⟩
  have hcop : q.Coprime u := by
    dsimp [q, u, g, p]
    exact coprime_reduced_modulus_factor m ((4 * n) * 2 ^ V) D
      hm hcomp hDp
  change m ∣ D + p * t ↔ q ∣ 1 + (4 * 2 ^ V * Q) * t
  rw [hgm, hD]
  have hpForm : p = 4 * (Q * (g * u)) * 2 ^ V := by
    dsimp [p]
    rw [hnD, hD]
  rw [hpForm]
  rw [show g * u + (4 * (Q * (g * u)) * 2 ^ V) * t =
    g * (u * (1 + (4 * 2 ^ V * Q) * t)) by ring]
  exact mul_mul_dvd_mul_mul_iff_right g q u _ hgpos hcop

/-- Exact reduced affine form at the shifted/root reverse center. -/
theorem reverse_right_center_divisibility_iff_reduced
    (m n V v t : ℕ) (hm : 0 < m)
    (hcomp : m.gcd ((4 * n) * 2 ^ V) ∣ n * (2 * v + 1)) :
    m ∣ n * (2 * v + 1) + ((4 * n) * 2 ^ V) * t ↔
      m / m.gcd ((4 * n) * 2 ^ V) ∣
        (2 * v + 1) + (4 * 2 ^ V) * t := by
  let p := (4 * n) * 2 ^ V
  let g := m.gcd p
  let q := m / g
  have hgpos : 0 < g := by
    dsimp [g, p]
    exact Nat.gcd_pos_of_pos_left _ hm
  have hgm : m = g * q := by
    dsimp [q]
    exact (Nat.mul_div_cancel' (by dsimp [g]; exact Nat.gcd_dvd_left _ _)).symm
  have hgp : g ∣ n * 2 ^ (V + 2) := by
    have hg := Nat.gcd_dvd_right m p
    have hpEq : p = n * 2 ^ (V + 2) := by
      dsimp [p]
      rw [pow_succ, pow_succ]
      ring
    simpa [g, hpEq] using hg
  have hgo : g ∣ n * (2 * v + 1) := by simpa [g, p] using hcomp
  have hOdd : Odd (2 * v + 1) := ⟨v, by omega⟩
  have hgn : g ∣ n :=
    dvd_base_of_dvd_base_mul_twoPow_and_odd
      g n (V + 2) (2 * v + 1) hgp hgo hOdd
  let u := n / g
  have hn : n = g * u := by
    dsimp [u]
    exact (Nat.mul_div_cancel' hgn).symm
  have hnp : n ∣ p := ⟨4 * 2 ^ V, by dsimp [p]; ring⟩
  have hcop : q.Coprime u := by
    dsimp [q, u, g, p]
    exact coprime_reduced_modulus_factor m ((4 * n) * 2 ^ V) n
      hm hgn hnp
  change m ∣ n * (2 * v + 1) + p * t ↔
    q ∣ (2 * v + 1) + (4 * 2 ^ V) * t
  rw [hgm, hn]
  have hpForm : p = 4 * (g * u) * 2 ^ V := by
    dsimp [p]
    rw [hn]
  rw [hpForm]
  rw [show g * u * (2 * v + 1) +
      (4 * (g * u) * 2 ^ V) * t =
    g * (u * ((2 * v + 1) + (4 * 2 ^ V) * t)) by ring]
  exact mul_mul_dvd_mul_mul_iff_right g q u _ hgpos hcop

end Research
/-!
# Side-aware polynomial protection for reverse-window center forms

The lower reverse-center slope contains the target quotient `Q`, while the
upper slope does not.  A canonical prime dividing `Q` can therefore protect
only upper-center conditions.  This file makes that harmless by activating the
lower form only at primes coprime to `Q`.
-/

namespace Research

open scoped BigOperators

/-- Local safe residues for the two reverse-center forms.  If the prime is not
coprime to the target quotient, the lower condition is inactive. -/
def reverseCenterSafeResidues
    (z Q scale root : ℕ) : Finset ℕ :=
  (Finset.range z).filter fun t =>
    (¬z ∣ root + scale * t) ∧
      (z.gcd Q = 1 → ¬z ∣ 1 + (scale * Q) * t)

/-- At least `z-2` residues survive at every canonical prime. -/
theorem sub_two_le_card_reverseCenterSafeResidues
    (z Q scale root : ℕ) (hz : 3 ≤ z)
    (hscale : z.gcd scale = 1) :
    z - 2 ≤ (reverseCenterSafeResidues z Q scale root).card := by
  by_cases hQ : z.gcd Q = 1
  · have hprod : z.gcd (scale * Q) = 1 := by
      exact (show z.Coprime scale from hscale).mul_right
        (show z.Coprime Q from hQ) |>.gcd_eq_one
    have heq : reverseCenterSafeResidues z Q scale root =
        affinePairSafeResidues z (scale * Q) 1 scale root := by
      ext t
      simp [reverseCenterSafeResidues, affinePairSafeResidues, hQ,
        and_comm]
    rw [heq]
    exact sub_two_le_card_affinePairSafeResidues
      z (scale * Q) 1 scale root hz hprod hscale
  · have heq : reverseCenterSafeResidues z Q scale root =
        affinePairSafeResidues z scale root scale root := by
      ext t
      simp [reverseCenterSafeResidues, affinePairSafeResidues, hQ,
        and_self]
    rw [heq]
    exact sub_two_le_card_affinePairSafeResidues
      z scale root scale root hz hscale hscale

/-- Simultaneous reverse-center-safe residues in one canonical-prime product
period. -/
def globalReverseCenterSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (Q scale root : ℕ) : Finset ℕ :=
  (Finset.range (∏ i, p i)).filter fun t =>
    ∀ i, t % p i ∈ reverseCenterSafeResidues (p i) Q scale root

/-- CRT injection from local reverse-center-safe residue sets. -/
theorem prod_card_reverseCenterSafeResidues_le_global
    {r : ℕ} (p : Fin r → ℕ) (Q scale root : ℕ)
    (hp : ∀ i, 0 < p i)
    (hpair : ∀ i j, i ≠ j → (p i).Coprime (p j)) :
    (∏ i, (reverseCenterSafeResidues (p i) Q scale root).card) ≤
      (globalReverseCenterSafeResidues p Q scale root).card := by
  classical
  let S : Finset (Fin r) := Finset.univ
  have hpne : ∀ i ∈ S, p i ≠ 0 := by
    intro i _
    exact Nat.ne_of_gt (hp i)
  have hpairS : Set.Pairwise S (fun i j => (p i).Coprime (p j)) := by
    intro i _ j _ hij
    exact hpair i j hij
  let α := ∀ i : Fin r,
    {x // x ∈ reverseCenterSafeResidues (p i) Q scale root}
  let crt (x : α) : ℕ :=
    Nat.chineseRemainderOfFinset (fun i => (x i : ℕ)) p S hpne hpairS
  have hcrt_lt (x : α) : crt x < ∏ i, p i := by
    have h := Nat.chineseRemainderOfFinset_lt_prod
      (fun i => (x i : ℕ)) p hpne hpairS
    simpa [crt, S] using h
  have hcrt_mod (x : α) (i : Fin r) : crt x % p i = (x i : ℕ) := by
    have hz : crt x ≡ (x i : ℕ) [MOD p i] :=
      (Nat.chineseRemainderOfFinset
        (fun j => (x j : ℕ)) p S hpne hpairS).property i (by simp [S])
    have hxlt : (x i : ℕ) < p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp (x i).property).1
    rw [Nat.ModEq] at hz
    simpa [Nat.mod_eq_of_lt hxlt] using hz
  let f : α → {t // t ∈ globalReverseCenterSafeResidues p Q scale root} :=
    fun x => ⟨crt x, Finset.mem_filter.mpr
      ⟨Finset.mem_range.mpr (hcrt_lt x), fun i => by
        rw [hcrt_mod x i]
        exact (x i).property⟩⟩
  have hf : Function.Injective f := by
    intro x y hxy
    funext i
    apply Subtype.ext
    have hcrt : crt x = crt y := congrArg Subtype.val hxy
    have hx := hcrt_mod x i
    have hy := hcrt_mod y i
    calc
      (x i : ℕ) = crt x % p i := hx.symm
      _ = crt y % p i := by rw [hcrt]
      _ = (y i : ℕ) := hy
  have hcard := Fintype.card_le_of_injective f hf
  simpa [α, Fintype.card_pi, globalReverseCenterSafeResidues] using hcard

/-- Polynomial product density for the side-aware global safe set. -/
theorem prod_sub_two_le_globalReverseCenterSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (Q scale root : ℕ)
    (hp3 : ∀ i, 3 ≤ p i)
    (hscale : ∀ i, (p i).gcd scale = 1)
    (hpair : ∀ i j, i ≠ j → (p i).Coprime (p j)) :
    (∏ i, (p i - 2)) ≤
      (globalReverseCenterSafeResidues p Q scale root).card := by
  calc
    (∏ i, (p i - 2)) ≤
        ∏ i, (reverseCenterSafeResidues (p i) Q scale root).card := by
      apply Finset.prod_le_prod
      · intro i hi
        exact Nat.zero_le _
      · intro i hi
        exact sub_two_le_card_reverseCenterSafeResidues
          (p i) Q scale root (hp3 i) (hscale i)
    _ ≤ (globalReverseCenterSafeResidues p Q scale root).card :=
      prod_card_reverseCenterSafeResidues_le_global p Q scale root
        (fun i => by have := hp3 i; omega) hpair

/-- Enumerate an unordered canonical-prime family and retain polynomially many
side-aware reverse-center-safe residues. -/
theorem exists_prime_enumeration_with_reverseCenter_safe_bound_onto
    (S : Finset ℕ) (Q scale root : ℕ)
    (hprime : ∀ z ∈ S, z.Prime)
    (hodd : ∀ z ∈ S, Odd z)
    (hscale : ∀ z ∈ S, z.gcd scale = 1) :
    ∃ p : Fin S.card → ℕ,
      (∏ i, p i) = ∏ z ∈ S, z ∧
      (∀ i, 3 ≤ p i) ∧
      (∀ i j, i ≠ j → (p i).Coprime (p j)) ∧
      (∀ z ∈ S, ∃ i, p i = z) ∧
      2 * (∏ i, p i) ≤
        (S.card + 1) * (S.card + 2) *
          (globalReverseCenterSafeResidues p Q scale root).card := by
  classical
  let e : Fin S.card ≃ {x // x ∈ S} :=
    (Fin.castOrderIso (Fintype.card_coe S).symm).toEquiv.trans
      (Fintype.equivFin {x // x ∈ S}).symm
  let p : Fin S.card → ℕ := fun i => (e i : ℕ)
  have hpMem (i : Fin S.card) : p i ∈ S := (e i).property
  have hpPrime (i : Fin S.card) : (p i).Prime :=
    hprime (p i) (hpMem i)
  have hpOdd (i : Fin S.card) : Odd (p i) := hodd (p i) (hpMem i)
  have hp3 (i : Fin S.card) : 3 ≤ p i := by
    have h2 := (hpPrime i).two_le
    have hne : p i ≠ 2 := by
      intro heq
      have heven : Even (p i) := by rw [heq]; norm_num
      exact (Nat.not_even_iff_odd.mpr (hpOdd i)) heven
    omega
  have hpPair : ∀ i j, i ≠ j → (p i).Coprime (p j) := by
    intro i j hij
    apply (Nat.coprime_primes (hpPrime i) (hpPrime j)).mpr
    intro hpij
    apply hij
    exact e.injective (Subtype.ext hpij)
  have hprod : (∏ i, p i) = ∏ z ∈ S, z := by
    calc
      (∏ i, p i) = ∏ x : {x // x ∈ S}, (x : ℕ) :=
        Equiv.prod_comp e (fun x : {x // x ∈ S} => (x : ℕ))
      _ = ∏ z ∈ S, z := Finset.prod_coe_sort S (fun z => z)
  have hprodSub : (∏ i, (p i - 2)) = ∏ z ∈ S, (z - 2) := by
    calc
      (∏ i, (p i - 2)) =
          ∏ x : {x // x ∈ S}, ((x : ℕ) - 2) :=
        Equiv.prod_comp e (fun x : {x // x ∈ S} => ((x : ℕ) - 2))
      _ = ∏ z ∈ S, (z - 2) :=
        Finset.prod_coe_sort S (fun z => z - 2)
  have hsafe : (∏ i, (p i - 2)) ≤
      (globalReverseCenterSafeResidues p Q scale root).card :=
    prod_sub_two_le_globalReverseCenterSafeResidues p Q scale root hp3
      (fun i => hscale (p i) (hpMem i)) hpPair
  have honto : ∀ z ∈ S, ∃ i, p i = z := by
    intro z hz
    obtain ⟨i, hi⟩ := e.surjective ⟨z, hz⟩
    exact ⟨i, congrArg Subtype.val hi⟩
  have hS3 : ∀ z ∈ S, 3 ≤ z := by
    intro z hz
    have h2 := (hprime z hz).two_le
    have hne : z ≠ 2 := by
      intro heq
      have heven : Even z := by rw [heq]; norm_num
      exact (Nat.not_even_iff_odd.mpr (hodd z hz)) heven
    omega
  have hdensity := two_mul_prod_le_card_factor_mul_prod_sub_two S hS3
  refine ⟨p, hprod, hp3, hpPair, honto, ?_⟩
  calc
    2 * (∏ i, p i) = 2 * (∏ z ∈ S, z) := by rw [hprod]
    _ ≤ (S.card + 1) * (S.card + 2) *
        (∏ z ∈ S, (z - 2)) := hdensity
    _ = (S.card + 1) * (S.card + 2) *
        (∏ i, (p i - 2)) := by rw [hprodSub]
    _ ≤ (S.card + 1) * (S.card + 2) *
        (globalReverseCenterSafeResidues p Q scale root).card :=
      Nat.mul_le_mul_left _ hsafe

/-- Replicate one complete side-aware safe period. -/
def replicatedGlobalReverseCenterSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (Q scale root T : ℕ) : Finset ℕ :=
  ((Finset.range T).product
    (globalReverseCenterSafeResidues p Q scale root)).image fun z =>
      z.2 + (∏ i, p i) * z.1

lemma card_replicatedGlobalReverseCenterSafeResidues
    {r : ℕ} (p : Fin r → ℕ) (Q scale root T : ℕ)
    (hM : 0 < ∏ i, p i) :
    (replicatedGlobalReverseCenterSafeResidues p Q scale root T).card =
      T * (globalReverseCenterSafeResidues p Q scale root).card := by
  classical
  unfold replicatedGlobalReverseCenterSafeResidues
  rw [Finset.card_image_of_injOn]
  · simp
  · intro z hz w hw hzw
    have hzlt : z.2 < ∏ i, p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp
        (Finset.mem_product.mp hz).2).1
    have hwlt : w.2 < ∏ i, p i :=
      Finset.mem_range.mp (Finset.mem_filter.mp
        (Finset.mem_product.mp hw).2).1
    have hrem := congrArg (fun x => x % (∏ i, p i)) hzw
    simp only [Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt hzlt,
      Nat.mod_eq_of_lt hwlt] at hrem
    have hblock : z.1 = w.1 := by
      change z.2 + (∏ i, p i) * z.1 =
        w.2 + (∏ i, p i) * w.1 at hzw
      rw [hrem] at hzw
      exact Nat.mul_left_cancel hM (Nat.add_left_cancel hzw)
    cases z
    cases w
    simp_all

/-- Complete scaled side-aware center protection.  Lower center moduli must be
coprime to the target quotient; upper moduli need not be. -/
theorem exists_exact_period_with_scaled_polynomially_many_reverse_centers
    {ι : Type*} [DecidableEq ι]
    (Qmods : Finset ℕ) (C : Finset ι) (side : ι → Bool)
    (offset qmod : ι → ℕ) (step targetQ scale root : ℕ)
    (hQ3 : ∀ q ∈ Qmods, 3 ≤ q)
    (hQodd : ∀ q ∈ Qmods, Odd q)
    (hQscale : ∀ q ∈ Qmods, q.gcd scale = 1)
    (hcover : ∀ u ∈ C, ∃ q ∈ Qmods,
      (side u = false → q.gcd targetQ = 1) ∧
      ∀ t, qmod u ∣ offset u + step * t →
        if side u then q ∣ root + scale * t
        else q ∣ 1 + (scale * targetQ) * t) :
    let S := centerPrimeFactors Qmods
    ∃ M : ℕ, 0 < M ∧ M = ∏ z ∈ S, z ∧ ∀ T : ℕ,
      2 * (T * M) ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C offset qmod step (T * M)).card := by
  classical
  let S := centerPrimeFactors Qmods
  have hSdata := centerPrimeFactors_prime_odd_ge_three Qmods hQ3 hQodd
  have hSprime : ∀ z ∈ S, z.Prime := fun z hz => (hSdata z hz).1
  have hSodd : ∀ z ∈ S, Odd z := fun z hz => (hSdata z hz).2.1
  have hSscale : ∀ z ∈ S, z.gcd scale = 1 := by
    intro z hz
    obtain ⟨q, hqQ, hqz⟩ := (mem_centerPrimeFactors_iff Qmods z).mp hz
    have hzd : z ∣ q := by simpa [hqz] using Nat.minFac_dvd q
    exact (Nat.Coprime.of_dvd_left hzd (hQscale q hqQ)).gcd_eq_one
  obtain ⟨p, hprod, hp3, hpPair, honto, hsafeBound⟩ :=
    exists_prime_enumeration_with_reverseCenter_safe_bound_onto
      S targetQ scale root hSprime hSodd hSscale
  let M := ∏ i, p i
  have hMpos : 0 < M := by
    dsimp [M]
    apply Finset.prod_pos
    intro i hi
    exact lt_of_lt_of_le (by norm_num) (hp3 i)
  refine ⟨M, hMpos, hprod, ?_⟩
  intro T
  have hsubset :
      replicatedGlobalReverseCenterSafeResidues p targetQ scale root T ⊆
        protectedCandidates C offset qmod step (T * M) := by
    intro t htRep
    obtain ⟨z, hzProd, rfl⟩ := Finset.mem_image.mp htRep
    have hzT := Finset.mem_range.mp (Finset.mem_product.mp hzProd).1
    have hzSafe := (Finset.mem_product.mp hzProd).2
    have hzData := Finset.mem_filter.mp hzSafe
    apply Finset.mem_filter.mpr
    refine ⟨Finset.mem_range.mpr ?_, ?_⟩
    · have hzlt := Finset.mem_range.mp hzData.1
      dsimp [M]
      nlinarith
    · intro u huC hbad
      obtain ⟨q, hqQ, hlowCop, himp⟩ := hcover u huC
      have hform := himp (z.2 + M * z.1) hbad
      have hqne : q ≠ 1 := by have := hQ3 q hqQ; omega
      let prime := q.minFac
      have hprimeS : prime ∈ S :=
        (mem_centerPrimeFactors_iff Qmods prime).mpr ⟨q, hqQ, rfl⟩
      obtain ⟨i, hpi⟩ := honto prime hprimeS
      have hsafeI := Finset.mem_filter.mp (hzData.2 i)
      have hpM : p i ∣ M := by
        dsimp [M]
        exact Finset.dvd_prod_of_mem p (by simp)
      have hprimeDvd : prime ∣ q := Nat.minFac_dvd q
      by_cases hside : side u = true
      · have hform' : q ∣ root + scale * (z.2 + M * z.1) := by
          simpa [hside] using hform
        have hpbad : p i ∣ root + scale * z.2 := by
          have hd : p i ∣ root + scale * (z.2 + M * z.1) := by
            simpa [hpi] using dvd_trans hprimeDvd hform'
          rw [show root + scale * (z.2 + M * z.1) =
            scale * M * z.1 + (root + scale * z.2) by ring] at hd
          have htail : p i ∣ scale * M * z.1 :=
            dvd_mul_of_dvd_left (dvd_mul_of_dvd_right hpM scale) z.1
          exact (Nat.dvd_add_iff_right htail).mpr hd
        apply hsafeI.2.1
        have hzmod : z.2 ≡ z.2 % p i [MOD p i] :=
          (Nat.mod_modEq z.2 (p i)).symm
        have hlin : root + scale * z.2 ≡
            root + scale * (z.2 % p i) [MOD p i] :=
          (Nat.ModEq.refl root).add (hzmod.mul_left scale)
        exact (hlin.dvd_iff dvd_rfl).mp hpbad
      · have hsideFalse : side u = false := Bool.eq_false_of_not_eq_true hside
        have hqCop : q.gcd targetQ = 1 := hlowCop hsideFalse
        have hpCop : (p i).gcd targetQ = 1 := by
          have hpq : p i ∣ q := by simpa [hpi] using hprimeDvd
          exact (Nat.Coprime.of_dvd_left hpq hqCop).gcd_eq_one
        have hform' : q ∣ 1 + (scale * targetQ) *
            (z.2 + M * z.1) := by simpa [hsideFalse] using hform
        have hpbad : p i ∣ 1 + (scale * targetQ) * z.2 := by
          have hd : p i ∣ 1 + (scale * targetQ) *
              (z.2 + M * z.1) := by
            simpa [hpi] using dvd_trans hprimeDvd hform'
          rw [show 1 + (scale * targetQ) * (z.2 + M * z.1) =
            (scale * targetQ) * M * z.1 +
              (1 + (scale * targetQ) * z.2) by ring] at hd
          have htail : p i ∣ (scale * targetQ) * M * z.1 :=
            dvd_mul_of_dvd_left
              (dvd_mul_of_dvd_right hpM (scale * targetQ)) z.1
          exact (Nat.dvd_add_iff_right htail).mpr hd
        apply hsafeI.2.2 hpCop
        have hzmod : z.2 ≡ z.2 % p i [MOD p i] :=
          (Nat.mod_modEq z.2 (p i)).symm
        have hlin : 1 + (scale * targetQ) * z.2 ≡
            1 + (scale * targetQ) * (z.2 % p i) [MOD p i] :=
          (Nat.ModEq.refl 1).add (hzmod.mul_left (scale * targetQ))
        exact (hlin.dvd_iff dvd_rfl).mp hpbad
  have hcard := Finset.card_le_card hsubset
  have hrepCard := card_replicatedGlobalReverseCenterSafeResidues
    p targetQ scale root T hMpos
  have hbaseScaled := Nat.mul_le_mul_left T hsafeBound
  calc
    2 * (T * M) = T * (2 * (∏ i, p i)) := by dsimp [M]; ring
    _ ≤ T * ((S.card + 1) * (S.card + 2) *
        (globalReverseCenterSafeResidues p targetQ scale root).card) :=
      hbaseScaled
    _ = (S.card + 1) * (S.card + 2) *
        (replicatedGlobalReverseCenterSafeResidues
          p targetQ scale root T).card := by
      rw [hrepCard]
      ring
    _ ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C offset qmod step (T * M)).card :=
      Nat.mul_le_mul_left _ hcard

end Research
/-!
# Polynomially many protected candidates for actual reverse-window centers
-/

namespace Research

open scoped BigOperators

/-- Reduced moduli represented by the compatible reverse-window centers. -/
def reverseWindowCenterReducedModuli
    (n : ℕ → ℕ) (K H W A X p w : ℕ) : Finset ℕ :=
  (reverseWindowCenterConditions n K H W A X p w).image fun u =>
    twoWindowModulus n u / (twoWindowModulus n u).gcd p

/-- The actual lower/root reverse centers retain polynomially many protected
candidates for the enlarged step `(4n_K)2^V`. -/
theorem exists_exact_scaled_polynomially_many_reverseWindow_center_candidates
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K G w D Q X V v : ℕ) (_hKG : K < G)
    (hD : w < D) (hDn : D < n K) (hQ : n K = Q * D)
    (hX : D + X = n K * (2 * v + 1))
    (horder : ∀ j, K < j → j < G → twoAdicOrder (n j) ≤ V) :
    let W := 2 * w + 1
    let A := D - w
    let p := (4 * n K) * 2 ^ V
    let C := reverseWindowCenterConditions n K G W A X p w
    let Qmods := reverseWindowCenterReducedModuli n K G W A X p w
    let S := centerPrimeFactors Qmods
    ∃ M : ℕ, 0 < M ∧ M = ∏ z ∈ S, z ∧ ∀ T : ℕ,
      2 * (T * M) ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p (T * M)).card := by
  classical
  let W := 2 * w + 1
  let A := D - w
  let p := (4 * n K) * 2 ^ V
  let scale := 4 * 2 ^ V
  let C := reverseWindowCenterConditions n K G W A X p w
  let Qmods := reverseWindowCenterReducedModuli n K G W A X p w
  have hcenterLow : A + w = D := by dsimp [A]; omega
  have hcenterHigh : A + w + X = n K * (2 * v + 1) := by
    rw [hcenterLow]
    exact hX
  have hQdata : ∀ q ∈ Qmods, Odd q ∧ 3 ≤ q := by
    intro q hqQ
    obtain ⟨u, huC, rfl⟩ := Finset.mem_image.mp hqQ
    have huCompat := (Finset.mem_filter.mp huC).1
    have huCenter := (Finset.mem_filter.mp huC).2
    have huBase := (Finset.mem_filter.mp huCompat).1
    have huComp := (Finset.mem_filter.mp huCompat).2
    have huPair := Finset.mem_product.mp (Finset.mem_product.mp huBase).1
    have hjData := Finset.mem_filter.mp huPair.1
    have hjG := Finset.mem_range.mp hjData.1
    have hKj := hjData.2
    have hm : n K < n u.1.1 := hmono hKj
    have hord := horder u.1.1 hKj hjG
    by_cases hside : u.2 = true
    · have hcompHigh : (n u.1.1).gcd p ∣ n K * (2 * v + 1) := by
        simpa [twoWindowModulus, twoWindowOffset, hside, huCenter,
          p, A, hcenterHigh] using huComp
      simpa [twoWindowModulus, p] using
        reverse_right_center_reduced_odd_ge_three
          (n u.1.1) (n K) V v hm (hpos K) hord
            (by simpa [p] using hcompHigh)
    · have hsideFalse : u.2 = false := Bool.eq_false_of_not_eq_true hside
      have hcompLow : (n u.1.1).gcd p ∣ D := by
        simpa [twoWindowModulus, twoWindowOffset, hsideFalse, huCenter,
          p, A, hcenterLow] using huComp
      simpa [twoWindowModulus, p] using
        reverse_left_center_reduced_odd_ge_three
          (n u.1.1) (n K) D V hm (hpos K) (by omega) hord
            (by simpa [p] using hcompLow) hDn
  have hQscale : ∀ q ∈ Qmods, q.gcd scale = 1 := by
    intro q hqQ
    have hodd := (hQdata q hqQ).1
    have hc : q.Coprime (2 ^ (V + 2)) :=
      (Nat.coprime_two_right.mpr hodd).pow_right (V + 2)
    have hscaleEq : scale = 2 ^ (V + 2) := by
      dsimp [scale]
      rw [pow_succ, pow_succ]
      ring
    rw [hscaleEq]
    exact hc.gcd_eq_one
  apply exists_exact_period_with_scaled_polynomially_many_reverse_centers
    Qmods C (fun u => u.2) (twoWindowOffset A X)
      (twoWindowModulus n) p Q scale (2 * v + 1)
  · exact fun q hq => (hQdata q hq).2
  · exact fun q hq => (hQdata q hq).1
  · exact hQscale
  · intro u huC
    have huCompat := (Finset.mem_filter.mp huC).1
    have huCenter := (Finset.mem_filter.mp huC).2
    have huComp := (Finset.mem_filter.mp huCompat).2
    let m := n u.1.1
    let g := m.gcd p
    let q := m / g
    refine ⟨q, ?_, ?_, ?_⟩
    · exact Finset.mem_image.mpr ⟨u, huC, rfl⟩
    · intro hsideFalse
      have hcompLow : g ∣ D := by
        simpa [g, m, twoWindowModulus, twoWindowOffset, hsideFalse,
          huCenter, A, hcenterLow] using huComp
      have hgpos : 0 < g := by
        dsimp [g, m, p]
        exact Nat.gcd_pos_of_pos_left _ (hpos u.1.1)
      have hcopFull : q.Coprime (p / g) := by
        dsimp [q, g, m]
        exact Nat.coprime_div_gcd_div_gcd hgpos
      have hgQp : g * Q ∣ p := by
        obtain ⟨z, hz⟩ := hcompLow
        refine ⟨scale * z, ?_⟩
        dsimp [p, scale] at *
        rw [hQ, hz]
        ring
      have hQdiv : Q ∣ p / g := by
        apply (Nat.dvd_div_iff_mul_dvd (by dsimp [g]; exact Nat.gcd_dvd_right _ _)).mpr
        simpa [mul_comm] using hgQp
      exact (hcopFull.of_dvd_right hQdiv).gcd_eq_one
    · intro t hbad
      by_cases hside : u.2 = true
      · have hcompHigh : g ∣ n K * (2 * v + 1) := by
          simpa [g, m, twoWindowModulus, twoWindowOffset, hside,
            huCenter, A, hcenterHigh] using huComp
        simp only [hside, ite_true]
        apply (reverse_right_center_divisibility_iff_reduced
          m (n K) V v t (hpos u.1.1)
            (by simpa [g, m, p] using hcompHigh)).mp
        simpa [m, p, twoWindowModulus, twoWindowOffset, hside,
          huCenter, A, hcenterHigh] using hbad
      · have hsideFalse : u.2 = false := Bool.eq_false_of_not_eq_true hside
        have hcompLow : g ∣ D := by
          simpa [g, m, twoWindowModulus, twoWindowOffset, hsideFalse,
            huCenter, A, hcenterLow] using huComp
        simp only [hsideFalse, Bool.false_eq_true, ↓reduceIte]
        apply (reverse_left_center_divisibility_iff_reduced
          m (n K) D Q V t (hpos u.1.1) hQ
            (by simpa [g, m, p] using hcompLow)).mp
        simpa [m, p, twoWindowModulus, twoWindowOffset, hsideFalse,
          huCenter, A, hcenterLow] using hbad

end Research
/-!
# Weighted budgets for sparse high-gcd compatible conditions
-/

namespace Research

open scoped BigOperators

/-- On any family of compatible conditions with gcd larger than the window,
position and side determine the unique compatible offset. -/
theorem positionSide_injective_on_sparse_highGcd
    (n : ℕ → ℕ) (K H W A X p : ℕ) (S : Finset ((ℕ × ℕ) × Bool))
    (hsub : S ⊆ compatibleTwoWindowConditions n K H W A X p)
    (hhigh : ∀ u ∈ S, W < (n u.1.1).gcd p) :
    Set.InjOn (fun u : ((ℕ × ℕ) × Bool) => (u.1.1, u.2)) S := by
  intro u hu v hv huv
  have huComp := hsub hu
  have hvComp := hsub hv
  have huBase := (Finset.mem_filter.mp huComp).1
  have hvBase := (Finset.mem_filter.mp hvComp).1
  have huSol := (Finset.mem_filter.mp huComp).2
  have hvSol := (Finset.mem_filter.mp hvComp).2
  have hsu : u.1.2 < W :=
    Finset.mem_range.mp
      (Finset.mem_product.mp (Finset.mem_product.mp huBase).1).2
  have hsv : v.1.2 < W :=
    Finset.mem_range.mp
      (Finset.mem_product.mp (Finset.mem_product.mp hvBase).1).2
  have hju : u.1.1 = v.1.1 :=
    congrArg (fun z : ℕ × Bool => z.1) huv
  have hbu : u.2 = v.2 :=
    congrArg (fun z : ℕ × Bool => z.2) huv
  let g := (n u.1.1).gcd p
  have hgW : W < g := by simpa [g] using hhigh u hu
  have huD : g ∣ A + u.1.2 + (if u.2 = true then X else 0) := by
    simpa [g, twoWindowModulus, twoWindowOffset] using huSol
  have hvD : g ∣ A + v.1.2 + (if u.2 = true then X else 0) := by
    simpa [g, twoWindowModulus, twoWindowOffset, hju, hbu] using hvSol
  have hsEq : u.1.2 = v.1.2 := by
    rcases le_total u.1.2 v.1.2 with hle | hle
    · have hd : g ∣ v.1.2 - u.1.2 := by
        have heq :
            (A + v.1.2 + (if u.2 = true then X else 0)) -
              (A + u.1.2 + (if u.2 = true then X else 0)) =
                v.1.2 - u.1.2 := by omega
        rw [← heq]
        exact Nat.dvd_sub hvD huD
      have hz := Nat.eq_zero_of_dvd_of_lt hd (by omega)
      omega
    · have hd : g ∣ u.1.2 - v.1.2 := by
        have heq :
            (A + u.1.2 + (if u.2 = true then X else 0)) -
              (A + v.1.2 + (if u.2 = true then X else 0)) =
                u.1.2 - v.1.2 := by omega
        rw [← heq]
        exact Nat.dvd_sub huD hvD
      have hz := Nat.eq_zero_of_dvd_of_lt hd (by omega)
      omega
  rcases u with ⟨⟨uj, us⟩, ub⟩
  rcases v with ⟨⟨vj, vs⟩, vb⟩
  simp only at hju hbu hsEq
  subst vj
  subst vs
  subst vb
  rfl

/-- A sparse high-gcd family whose gcds are at most `Z` has weighted budget at
most two copies of `RZ/n_j+1`, one per side. -/
theorem sparse_highGcd_budget_cast_le_of_gcd_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K H W A X p R Z : ℕ) (S : Finset ((ℕ × ℕ) × Bool))
    (hsub : S ⊆ compatibleTwoWindowConditions n K H W A X p)
    (hhigh : ∀ u ∈ S, W < (n u.1.1).gcd p)
    (hle : ∀ u ∈ S, (n u.1.1).gcd p ≤ Z) :
    ((∑ u ∈ S, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) ≤
      2 * (∑ j ∈ laterPositionRange K H,
        ((R : ℝ) * Z / n j + 1)) := by
  classical
  let f : ((ℕ × ℕ) × Bool) → ℕ × Bool := fun u => (u.1.1, u.2)
  let T := (laterPositionRange K H).product (Finset.univ : Finset Bool)
  let upper : ℕ × Bool → ℝ := fun y => (R : ℝ) * Z / n y.1 + 1
  have hmap : S.image f ⊆ T := by
    intro y hy
    obtain ⟨u, hu, rfl⟩ := Finset.mem_image.mp hy
    have huBase := (Finset.mem_filter.mp (hsub hu)).1
    have hj := (Finset.mem_product.mp (Finset.mem_product.mp huBase).1).1
    exact Finset.mem_product.mpr ⟨hj, Finset.mem_univ _⟩
  have hinj := positionSide_injective_on_sparse_highGcd
    n K H W A X p S hsub hhigh
  have hpoint : ∀ u ∈ S,
      (((R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1 : ℕ) : ℝ)) ≤ upper (f u) := by
    intro u hu
    let m := n u.1.1
    let g := m.gcd p
    have hm : 0 < m := hpos u.1.1
    have hdiv := div_div_gcd_eq_mul_div R m p hm
    have hcast : (((R * g) / m : ℕ) : ℝ) ≤ (R : ℝ) * g / m := by
      have hc : (((R * g) / m : ℕ) : ℝ) ≤ ((R * g : ℕ) : ℝ) / m :=
        Nat.cast_div_le
      push_cast at hc
      exact hc
    have hgZreal : (g : ℝ) ≤ Z := by exact_mod_cast hle u hu
    have hmreal : (0 : ℝ) < m := by exact_mod_cast hm
    have hmain : (((R / (m / g) + 1 : ℕ) : ℝ)) ≤
        (R : ℝ) * Z / m + 1 := by
      push_cast
      rw [show R / (m / g) = (R * g) / m by
        simpa [g] using hdiv]
      calc
        (((R * g) / m : ℕ) : ℝ) + 1 ≤ (R : ℝ) * g / m + 1 := by
          linarith
        _ ≤ (R : ℝ) * Z / m + 1 := by
          gcongr
    simpa [upper, f, m, g, twoWindowModulus] using hmain
  calc
    ((∑ u ∈ S, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) =
        ∑ u ∈ S, (((R / (twoWindowModulus n u /
          (twoWindowModulus n u).gcd p) + 1 : ℕ) : ℝ)) := by push_cast; rfl
    _ ≤ ∑ u ∈ S, upper (f u) := by
      apply Finset.sum_le_sum
      intro u hu
      exact hpoint u hu
    _ = ∑ y ∈ S.image f, upper y := by
      symm
      exact Finset.sum_image hinj
    _ ≤ ∑ y ∈ T, upper y :=
      Finset.sum_le_sum_of_subset_of_nonneg hmap (by
        intro y hyT hyS
        dsimp [upper]
        positivity)
    _ = 2 * (∑ j ∈ laterPositionRange K H,
        ((R : ℝ) * Z / n j + 1)) := by
      simp [T, upper, Finset.sum_product]
      rw [Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro j hj
      ring

/-- If every reduced modulus in a sparse family is greater than `B>0`, its
budget is at most two conditions per position times `R/B+1`. -/
theorem sparse_highGcd_budget_cast_le_of_reduced_gt
    (n : ℕ → ℕ) (_hpos : ∀ k, 0 < n k)
    (K H W A X p R B : ℕ) (S : Finset ((ℕ × ℕ) × Bool))
    (hB : 0 < B)
    (hsub : S ⊆ compatibleTwoWindowConditions n K H W A X p)
    (hhigh : ∀ u ∈ S, W < (n u.1.1).gcd p)
    (hred : ∀ u ∈ S, B < n u.1.1 / (n u.1.1).gcd p) :
    ((∑ u ∈ S, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) ≤
      2 * (laterPositionRange K H).card * ((R : ℝ) / B + 1) := by
  classical
  let f : ((ℕ × ℕ) × Bool) → ℕ × Bool := fun u => (u.1.1, u.2)
  let T := (laterPositionRange K H).product (Finset.univ : Finset Bool)
  have hmap : S.image f ⊆ T := by
    intro y hy
    obtain ⟨u, hu, rfl⟩ := Finset.mem_image.mp hy
    have huBase := (Finset.mem_filter.mp (hsub hu)).1
    have hj := (Finset.mem_product.mp (Finset.mem_product.mp huBase).1).1
    exact Finset.mem_product.mpr ⟨hj, Finset.mem_univ _⟩
  have hinj := positionSide_injective_on_sparse_highGcd
    n K H W A X p S hsub hhigh
  have hpoint : ∀ u ∈ S,
      (((R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1 : ℕ) : ℝ)) ≤
        (R : ℝ) / B + 1 := by
    intro u hu
    let q := n u.1.1 / (n u.1.1).gcd p
    have hq : B < q := by simpa [q] using hred u hu
    have hqpos : (0 : ℝ) < q := by exact_mod_cast (lt_of_lt_of_le hB hq.le)
    have hBreal : (0 : ℝ) < B := by exact_mod_cast hB
    have hc : (((R / q : ℕ) : ℝ)) ≤ (R : ℝ) / q := Nat.cast_div_le
    have hmain : (((R / q + 1 : ℕ) : ℝ)) ≤ (R : ℝ) / B + 1 := by
      push_cast
      calc
        (((R / q : ℕ) : ℝ)) + 1 ≤ (R : ℝ) / q + 1 := by linarith
        _ ≤ (R : ℝ) / B + 1 := by
          have hdivle : (R : ℝ) / q ≤ (R : ℝ) / B :=
            div_le_div_of_nonneg_left (by positivity) hBreal
              (by exact_mod_cast hq.le)
          linarith
    simpa [q, twoWindowModulus] using hmain
  have hcard : S.card ≤ 2 * (laterPositionRange K H).card := by
    calc
      S.card = (S.image f).card := (Finset.card_image_iff.mpr hinj).symm
      _ ≤ T.card := Finset.card_le_card hmap
      _ = 2 * (laterPositionRange K H).card := by simp [T, Nat.mul_comm]
  calc
    ((∑ u ∈ S, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) =
        ∑ u ∈ S, (((R / (twoWindowModulus n u /
          (twoWindowModulus n u).gcd p) + 1 : ℕ) : ℝ)) := by push_cast; rfl
    _ ≤ ∑ _u ∈ S, ((R : ℝ) / B + 1) := by
      apply Finset.sum_le_sum
      intro u hu
      exact hpoint u hu
    _ = S.card * ((R : ℝ) / B + 1) := by simp; ring
    _ ≤ (2 * (laterPositionRange K H).card) * ((R : ℝ) / B + 1) := by
      apply mul_le_mul_of_nonneg_right
      · exact_mod_cast hcard
      · positivity
    _ = 2 * (laterPositionRange K H).card * ((R : ℝ) / B + 1) := by ring

end Research
/-!
# Complete reverse-window off-center budget
-/

namespace Research

open scoped BigOperators

/-- Low, intermediate, and exceptional pieces of the reverse off-center family. -/
def reverseWindowLowOffCenterConditions
    (n : ℕ → ℕ) (K H W A X p w : ℕ) : Finset ((ℕ × ℕ) × Bool) :=
  (reverseWindowOffCenterConditions n K H W A X p w).filter fun u =>
    (n u.1.1).gcd p ≤ W

def reverseWindowMidOffCenterConditions
    (n : ℕ → ℕ) (K H W A X p w Z : ℕ) : Finset ((ℕ × ℕ) × Bool) :=
  (reverseWindowOffCenterConditions n K H W A X p w).filter fun u =>
    W < (n u.1.1).gcd p ∧ (n u.1.1).gcd p ≤ Z

def reverseWindowExceptionalConditions
    (n : ℕ → ℕ) (K H W A X p w Z : ℕ) : Finset ((ℕ × ℕ) × Bool) :=
  (reverseWindowOffCenterConditions n K H W A X p w).filter fun u =>
    Z < (n u.1.1).gcd p

/-- The three displayed pieces cover every reverse off-center condition when
`W≤Z`. -/
theorem reverseWindow_offCenter_subset_three_parts
    (n : ℕ → ℕ) (K H W A X p w Z : ℕ) :
    reverseWindowOffCenterConditions n K H W A X p w ⊆
      reverseWindowLowOffCenterConditions n K H W A X p w ∪
        reverseWindowMidOffCenterConditions n K H W A X p w Z ∪
          reverseWindowExceptionalConditions n K H W A X p w Z := by
  intro u hu
  simp only [reverseWindowLowOffCenterConditions,
    reverseWindowMidOffCenterConditions, reverseWindowExceptionalConditions,
    Finset.mem_union, Finset.mem_filter]
  by_cases hlo : (n u.1.1).gcd p ≤ W
  · exact Or.inl (Or.inl ⟨hu, hlo⟩)
  · by_cases hmid : (n u.1.1).gcd p ≤ Z
    · exact Or.inl (Or.inr ⟨hu, Nat.lt_of_not_ge hlo, hmid⟩)
    · exact Or.inr ⟨hu, Nat.lt_of_not_ge hmid⟩

/-- Complete finite reverse-window budget.  Ordinary low gcds retain the
linear F-163 bound; intermediate gcds are sparse and bounded by `scale*w`;
all remaining conditions have reduced modulus greater than `B`. -/
theorem reverseWindow_offCenter_budget_cast_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K H w D Q X V v R B : ℕ)
    (_hKH : K < H) (hw : 0 < w) (hD : w < D) (hB : 0 < B)
    (hQ : n K = Q * D) (hX : D + X = n K * (2 * v + 1))
    (hsize : 2 * (4 * 2 ^ V) * B ^ 2 * w ≤ n K) :
    let W := 2 * w + 1
    let A := D - w
    let p := (4 * n K) * 2 ^ V
    let Z := (4 * 2 ^ V) * w
    let O := reverseWindowOffCenterConditions n K H W A X p w
    ((∑ u ∈ O, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) ≤
      (4 * (R : ℝ) * W *
          (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        4 * W * (laterPositionRange K H).card) +
      2 * (∑ j ∈ laterPositionRange K H,
        ((R : ℝ) * Z / n j + 1)) +
      2 * (laterPositionRange K H).card * ((R : ℝ) / B + 1) := by
  classical
  let W := 2 * w + 1
  let A := D - w
  let p := (4 * n K) * 2 ^ V
  let scale := 4 * 2 ^ V
  let Z := scale * w
  let O := reverseWindowOffCenterConditions n K H W A X p w
  let Low := reverseWindowLowOffCenterConditions n K H W A X p w
  let Mid := reverseWindowMidOffCenterConditions n K H W A X p w Z
  let Exc := reverseWindowExceptionalConditions n K H W A X p w Z
  have hscale : 0 < scale := by dsimp [scale]; positivity
  have hWZ : W ≤ Z := by
    dsimp [W, Z, scale]
    have hpow : 0 < 2 ^ V := pow_pos (by norm_num) V
    nlinarith
  have hcover : O ⊆ Low ∪ Mid ∪ Exc :=
    reverseWindow_offCenter_subset_three_parts
      n K H W A X p w Z
  let cost : ((ℕ × ℕ) × Bool) → ℕ := fun u =>
    R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1
  have hsplitNat : (∑ u ∈ O, cost u) ≤
      (∑ u ∈ Low, cost u) + (∑ u ∈ Mid, cost u) +
        ∑ u ∈ Exc, cost u := by
    calc
      (∑ u ∈ O, cost u) ≤ ∑ u ∈ Low ∪ Mid ∪ Exc, cost u :=
        Finset.sum_le_sum_of_subset hcover
      _ ≤ (∑ u ∈ Low, cost u) + (∑ u ∈ Mid, cost u) +
          ∑ u ∈ Exc, cost u := by
        have h1 := Finset.sum_union_inter (s₁ := Low ∪ Mid) (s₂ := Exc)
          (f := cost)
        have h2 := Finset.sum_union_inter (s₁ := Low) (s₂ := Mid)
          (f := cost)
        omega
  have hsplit : (((∑ u ∈ O, cost u) : ℕ) : ℝ) ≤
      (((∑ u ∈ Low, cost u) : ℕ) : ℝ) +
        (((∑ u ∈ Mid, cost u) : ℕ) : ℝ) +
          (((∑ u ∈ Exc, cost u) : ℕ) : ℝ) := by
    exact_mod_cast hsplitNat
  have hLowSub : Low ⊆ lowGcdCompatibleTwoWindowConditions
      n K H W A X p := by
    intro u hu
    have huData := Finset.mem_filter.mp hu
    have huOff := huData.1
    have huComp := (Finset.mem_sdiff.mp huOff).1
    exact Finset.mem_filter.mpr ⟨huComp, huData.2⟩
  have hLowNat : (∑ u ∈ Low, cost u) ≤
      ∑ u ∈ lowGcdCompatibleTwoWindowConditions n K H W A X p,
        cost u := Finset.sum_le_sum_of_subset hLowSub
  have hLowCast : (((∑ u ∈ Low, cost u) : ℕ) : ℝ) ≤
      ((∑ u ∈ lowGcdCompatibleTwoWindowConditions n K H W A X p,
        cost u : ℕ) : ℝ) := by exact_mod_cast hLowNat
  have hLowBound := lowGcdCompatible_budget_cast_le
    n hpos K H W A X p R
  have hLow : (((∑ u ∈ Low, cost u) : ℕ) : ℝ) ≤
      4 * (R : ℝ) * W *
          (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        4 * W * (laterPositionRange K H).card := by
    exact hLowCast.trans (by simpa [cost] using hLowBound)
  have hMidSub : Mid ⊆ compatibleTwoWindowConditions n K H W A X p := by
    intro u hu
    exact (Finset.mem_sdiff.mp (Finset.mem_filter.mp hu).1).1
  have hMidHigh : ∀ u ∈ Mid, W < (n u.1.1).gcd p := by
    intro u hu
    exact (Finset.mem_filter.mp hu).2.1
  have hMidLe : ∀ u ∈ Mid, (n u.1.1).gcd p ≤ Z := by
    intro u hu
    exact (Finset.mem_filter.mp hu).2.2
  have hMidBound := sparse_highGcd_budget_cast_le_of_gcd_le
    n hpos K H W A X p R Z Mid hMidSub hMidHigh hMidLe
  have hMid : (((∑ u ∈ Mid, cost u) : ℕ) : ℝ) ≤
      2 * (∑ j ∈ laterPositionRange K H,
        ((R : ℝ) * Z / n j + 1)) := by
    simpa [cost] using hMidBound
  have hExcSub : Exc ⊆ compatibleTwoWindowConditions n K H W A X p := by
    intro u hu
    exact (Finset.mem_sdiff.mp (Finset.mem_filter.mp hu).1).1
  have hExcHigh : ∀ u ∈ Exc, W < (n u.1.1).gcd p := by
    intro u hu
    have hz := (Finset.mem_filter.mp hu).2
    exact lt_of_le_of_lt hWZ hz
  have hExcRed : ∀ u ∈ Exc,
      B < n u.1.1 / (n u.1.1).gcd p := by
    intro u hu
    have huData := Finset.mem_filter.mp hu
    have huOffData := Finset.mem_sdiff.mp huData.1
    have huComp := (Finset.mem_filter.mp huOffData.1).2
    have huBase := (Finset.mem_filter.mp huOffData.1).1
    have huPair := Finset.mem_product.mp (Finset.mem_product.mp huBase).1
    have hsW := Finset.mem_range.mp huPair.2
    have hoff : u.1.2 ≠ w := by
      intro heq
      apply huOffData.2
      exact Finset.mem_filter.mpr ⟨huOffData.1, heq⟩
    have hlarge : scale * w < (n u.1.1).gcd (scale * n K) := by
      simpa [Z, p, scale, mul_assoc, mul_comm, mul_left_comm] using huData.2
    have hcomp : (n u.1.1).gcd (scale * n K) ∣
        (if u.2 then D - w + u.1.2 + X else D - w + u.1.2) := by
      by_cases hside : u.2 = true
      · simpa [twoWindowModulus, twoWindowOffset, p, A, scale, hside,
          mul_assoc, mul_comm, mul_left_comm] using huComp
      · have hsideFalse : u.2 = false := Bool.eq_false_of_not_eq_true hside
        simpa [twoWindowModulus, twoWindowOffset, p, A, scale, hsideFalse,
          mul_assoc, mul_comm, mul_left_comm] using huComp
    obtain ⟨hside, hincompat⟩ := reverseWindow_large_offCenter_data
      (n u.1.1) (n K) D w u.1.2 X scale v (hpos K) hD hsW
        hX hscale u.2 hcomp hoff hlarge
    have hm : n K < n u.1.1 := by
      have hj := (Finset.mem_filter.mp huPair.1).2
      exact hmono hj
    have hleftComp : (n u.1.1).gcd (scale * n K) ∣
        D - w + u.1.2 := by simpa [hside] using hcomp
    have hgt := reverseWindow_left_incompatible_reduced_modulus_gt
      (n u.1.1) (n K) D Q w u.1.2 scale B (hpos K) hm hD hQ
        hsW hscale hleftComp hincompat (by simpa [scale] using hsize)
    simpa [p, scale, mul_assoc, mul_comm, mul_left_comm] using hgt
  have hExcBound := sparse_highGcd_budget_cast_le_of_reduced_gt
    n hpos K H W A X p R B Exc hB hExcSub hExcHigh hExcRed
  have hExc : (((∑ u ∈ Exc, cost u) : ℕ) : ℝ) ≤
      2 * (laterPositionRange K H).card * ((R : ℝ) / B + 1) := by
    simpa [cost] using hExcBound
  exact hsplit.trans (add_le_add (add_le_add hLow hMid) hExc)

end Research
/-!
# Reverse-window centers outside a finite distinguished block
-/

namespace Research

open scoped BigOperators

/-- Reverse-window centers after deleting distinguished selected positions. -/
def reverseWindowOutsideBlockCenterConditions
    (n : ℕ → ℕ) (K H W A X p w : ℕ) (Block : Finset ℕ) :
    Finset ((ℕ × ℕ) × Bool) :=
  (reverseWindowCenterConditions n K H W A X p w).filter fun u =>
    u.1.1 ∉ Block

/-- Compatible outside-block conditions other than the reverse centers. -/
def reverseWindowOutsideBlockOffCenterConditions
    (n : ℕ → ℕ) (K H W A X p w : ℕ) (Block : Finset ℕ) :
    Finset ((ℕ × ℕ) × Bool) :=
  compatibleOutsideTwoWindowConditions n K H W A X p Block \
    reverseWindowOutsideBlockCenterConditions n K H W A X p w Block

/-- Reduced moduli among outside-block reverse centers. -/
def reverseWindowOutsideBlockCenterReducedModuli
    (n : ℕ → ℕ) (K H W A X p w : ℕ) (Block : Finset ℕ) : Finset ℕ :=
  (reverseWindowOutsideBlockCenterConditions n K H W A X p w Block).image
    fun u => twoWindowModulus n u / (twoWindowModulus n u).gcd p

/-- The displayed center and off-center sets partition all compatible
outside-block conditions. -/
theorem reverseWindowOutsideBlock_partition
    (n : ℕ → ℕ) (K H W A X p w : ℕ) (Block : Finset ℕ) :
    reverseWindowOutsideBlockCenterConditions n K H W A X p w Block ∪
      reverseWindowOutsideBlockOffCenterConditions n K H W A X p w Block =
    compatibleOutsideTwoWindowConditions n K H W A X p Block := by
  apply Finset.union_sdiff_of_subset
  intro u hu
  have huOld := (Finset.mem_filter.mp hu).1
  have huNot := (Finset.mem_filter.mp hu).2
  have huCompat := (Finset.mem_filter.mp huOld).1
  have huBase := (Finset.mem_filter.mp huCompat).1
  have huSol := (Finset.mem_filter.mp huCompat).2
  exact Finset.mem_filter.mpr
    ⟨Finset.mem_filter.mpr ⟨huBase, huNot⟩, huSol⟩

/-- The outside-block center family has at most two labels per later position. -/
theorem reverseWindowOutsideBlockCenterConditions_card_le
    (n : ℕ → ℕ) (K G W A X p w : ℕ) (Block : Finset ℕ) :
    (reverseWindowOutsideBlockCenterConditions
      n K G W A X p w Block).card ≤
      2 * (laterPositionRange K G).card := by
  classical
  let C := reverseWindowOutsideBlockCenterConditions
    n K G W A X p w Block
  let T := (laterPositionRange K G).product (Finset.univ : Finset Bool)
  let f : ((ℕ × ℕ) × Bool) → ℕ × Bool := fun u => (u.1.1, u.2)
  have hmap : Set.MapsTo f C T := by
    intro u hu
    have huOld := (Finset.mem_filter.mp hu).1
    have huCompat := (Finset.mem_filter.mp huOld).1
    have huBase := (Finset.mem_filter.mp huCompat).1
    have huInner := (Finset.mem_product.mp
      (Finset.mem_product.mp huBase).1)
    exact Finset.mem_product.mpr ⟨huInner.1, Finset.mem_univ _⟩
  have hinj : Set.InjOn f C := by
    intro u hu v hv huv
    have huCenter := (Finset.mem_filter.mp (Finset.mem_filter.mp hu).1).2
    have hvCenter := (Finset.mem_filter.mp (Finset.mem_filter.mp hv).1).2
    have hj : u.1.1 = v.1.1 :=
      congrArg (fun z : ℕ × Bool => z.1) huv
    have hb : u.2 = v.2 :=
      congrArg (fun z : ℕ × Bool => z.2) huv
    have hs : u.1.2 = v.1.2 := by omega
    rcases u with ⟨⟨uj, us⟩, ub⟩
    rcases v with ⟨⟨vj, vs⟩, vb⟩
    simp only at hj hb hs
    subst vj
    subst vs
    subst vb
    rfl
  have hc := Finset.card_le_card_of_injOn f hmap hinj
  simpa [C, T, Nat.mul_comm] using hc

/-- Canonical primes inherit the two-per-position center count. -/
theorem reverseWindowOutsideBlock_centerPrimeFactors_card_le
    (n : ℕ → ℕ) (K G W A X p w : ℕ) (Block : Finset ℕ) :
    (centerPrimeFactors
      (reverseWindowOutsideBlockCenterReducedModuli
        n K G W A X p w Block)).card ≤
      2 * (laterPositionRange K G).card := by
  calc
    _ ≤ (reverseWindowOutsideBlockCenterReducedModuli
        n K G W A X p w Block).card := Finset.card_image_le
    _ ≤ (reverseWindowOutsideBlockCenterConditions
        n K G W A X p w Block).card := Finset.card_image_le
    _ ≤ _ := reverseWindowOutsideBlockCenterConditions_card_le
      n K G W A X p w Block

/-- Every canonical center prime before `G` is at most a uniform threshold
bounding the intervening selected values. -/
theorem reverseWindowOutsideBlock_centerPrime_le_threshold
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K G W A X p w B z : ℕ) (Block : Finset ℕ)
    (hvalues : ∀ j, K < j → j < G → n j ≤ B)
    (hz : z ∈ centerPrimeFactors
      (reverseWindowOutsideBlockCenterReducedModuli
        n K G W A X p w Block)) :
    z ≤ B := by
  obtain ⟨q, hqQ, hqz⟩ :=
    (mem_centerPrimeFactors_iff
      (reverseWindowOutsideBlockCenterReducedModuli
        n K G W A X p w Block) z).mp hz
  obtain ⟨u, huC, hqu⟩ := Finset.mem_image.mp hqQ
  have huOld := (Finset.mem_filter.mp huC).1
  have huCompat := (Finset.mem_filter.mp huOld).1
  have huBase := (Finset.mem_filter.mp huCompat).1
  have huPair := Finset.mem_product.mp (Finset.mem_product.mp huBase).1
  have hjData := Finset.mem_filter.mp huPair.1
  have hjG := Finset.mem_range.mp hjData.1
  have hqLe : q ≤ n u.1.1 := by
    calc
      q = twoWindowModulus n u /
          (twoWindowModulus n u).gcd p := hqu.symm
      _ ≤ twoWindowModulus n u := Nat.div_le_self _ _
      _ = n u.1.1 := rfl
  have hzLe : z ≤ q := by
    rw [← hqz]
    exact Nat.minFac_le (by
      have hqpos : 0 < q := by
        rw [← hqu]
        exact Nat.div_pos
          (Nat.gcd_le_left p (hpos u.1.1))
          (Nat.gcd_pos_of_pos_left p (hpos u.1.1))
      exact hqpos)
  exact hzLe.trans (hqLe.trans (hvalues u.1.1 hjData.2 hjG))

/-- The canonical reverse-center CRT period before `G` is bounded by
`B^(2d)`, where `d` is the number of intervening positions. -/
theorem reverseWindowOutsideBlock_centerPrime_product_le_threshold_pow
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (K G W A X p w B : ℕ) (Block : Finset ℕ) (hB : 0 < B)
    (hvalues : ∀ j, K < j → j < G → n j ≤ B) :
    let S := centerPrimeFactors
      (reverseWindowOutsideBlockCenterReducedModuli
        n K G W A X p w Block)
    let d := (laterPositionRange K G).card
    (∏ z ∈ S, z) ≤ B ^ (2 * d) := by
  let S := centerPrimeFactors
    (reverseWindowOutsideBlockCenterReducedModuli
      n K G W A X p w Block)
  let d := (laterPositionRange K G).card
  have hprod : (∏ z ∈ S, z) ≤ B ^ S.card := by
    apply Finset.prod_le_pow_card
    intro z hz
    exact reverseWindowOutsideBlock_centerPrime_le_threshold
      n hpos K G W A X p w B z Block hvalues hz
  exact hprod.trans (Nat.pow_le_pow_right hB
    (reverseWindowOutsideBlock_centerPrimeFactors_card_le
      n K G W A X p w Block))

/-- Actual outside-block reverse centers retain the standard scaled polynomial
protected density. -/
theorem exists_exact_scaled_polynomially_many_reverseWindow_outsideBlock_centers
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K G w D Q X V v : ℕ) (Block : Finset ℕ) (_hKG : K < G)
    (hD : w < D) (hDn : D < n K) (hQ : n K = Q * D)
    (hX : D + X = n K * (2 * v + 1))
    (horder : ∀ j, K < j → j < G → j ∉ Block →
      twoAdicOrder (n j) ≤ V) :
    let W := 2 * w + 1
    let A := D - w
    let p := (4 * n K) * 2 ^ V
    let C := reverseWindowOutsideBlockCenterConditions
      n K G W A X p w Block
    let Qmods := reverseWindowOutsideBlockCenterReducedModuli
      n K G W A X p w Block
    let S := centerPrimeFactors Qmods
    ∃ M : ℕ, 0 < M ∧ M = ∏ z ∈ S, z ∧ ∀ T : ℕ,
      2 * (T * M) ≤ (S.card + 1) * (S.card + 2) *
        (protectedCandidates C (twoWindowOffset A X)
          (twoWindowModulus n) p (T * M)).card := by
  classical
  let W := 2 * w + 1
  let A := D - w
  let p := (4 * n K) * 2 ^ V
  let scale := 4 * 2 ^ V
  let C := reverseWindowOutsideBlockCenterConditions
    n K G W A X p w Block
  let Qmods := reverseWindowOutsideBlockCenterReducedModuli
    n K G W A X p w Block
  have hcenterLow : A + w = D := by dsimp [A]; omega
  have hcenterHigh : A + w + X = n K * (2 * v + 1) := by
    rw [hcenterLow]
    exact hX
  have hQdata : ∀ q ∈ Qmods, Odd q ∧ 3 ≤ q := by
    intro q hqQ
    obtain ⟨u, huC, rfl⟩ := Finset.mem_image.mp hqQ
    have huOld := (Finset.mem_filter.mp huC).1
    have huNot := (Finset.mem_filter.mp huC).2
    have huCompat := (Finset.mem_filter.mp huOld).1
    have huCenter := (Finset.mem_filter.mp huOld).2
    have huBase := (Finset.mem_filter.mp huCompat).1
    have huComp := (Finset.mem_filter.mp huCompat).2
    have huPair := Finset.mem_product.mp (Finset.mem_product.mp huBase).1
    have hjData := Finset.mem_filter.mp huPair.1
    have hjG := Finset.mem_range.mp hjData.1
    have hKj := hjData.2
    have hm := hmono hKj
    have hord := horder u.1.1 hKj hjG huNot
    by_cases hside : u.2 = true
    · have hc : (n u.1.1).gcd p ∣ n K * (2 * v + 1) := by
        simpa [twoWindowModulus, twoWindowOffset, hside, huCenter,
          A, hcenterHigh] using huComp
      simpa [twoWindowModulus, p] using
        reverse_right_center_reduced_odd_ge_three
          (n u.1.1) (n K) V v hm (hpos K) hord (by simpa [p] using hc)
    · have hsideFalse : u.2 = false := Bool.eq_false_of_not_eq_true hside
      have hc : (n u.1.1).gcd p ∣ D := by
        simpa [twoWindowModulus, twoWindowOffset, hsideFalse, huCenter,
          A, hcenterLow] using huComp
      simpa [twoWindowModulus, p] using
        reverse_left_center_reduced_odd_ge_three
          (n u.1.1) (n K) D V hm (hpos K) (by omega) hord
            (by simpa [p] using hc) hDn
  have hQscale : ∀ q ∈ Qmods, q.gcd scale = 1 := by
    intro q hq
    have ho := (hQdata q hq).1
    have hc : q.Coprime (2 ^ (V + 2)) :=
      (Nat.coprime_two_right.mpr ho).pow_right (V + 2)
    have hs : scale = 2 ^ (V + 2) := by
      dsimp [scale]
      rw [pow_succ, pow_succ]
      ring
    rw [hs]
    exact hc.gcd_eq_one
  apply exists_exact_period_with_scaled_polynomially_many_reverse_centers
    Qmods C (fun u => u.2) (twoWindowOffset A X)
      (twoWindowModulus n) p Q scale (2 * v + 1)
  · exact fun q hq => (hQdata q hq).2
  · exact fun q hq => (hQdata q hq).1
  · exact hQscale
  · intro u huC
    have huOld := (Finset.mem_filter.mp huC).1
    have huCompat := (Finset.mem_filter.mp huOld).1
    have huCenter := (Finset.mem_filter.mp huOld).2
    have huComp := (Finset.mem_filter.mp huCompat).2
    let m := n u.1.1
    let g := m.gcd p
    let q := m / g
    refine ⟨q, Finset.mem_image.mpr ⟨u, huC, rfl⟩, ?_, ?_⟩
    · intro hsideFalse
      have hcompLow : g ∣ D := by
        simpa [g, m, twoWindowModulus, twoWindowOffset, hsideFalse,
          huCenter, A, hcenterLow] using huComp
      have hgpos : 0 < g := by
        dsimp [g, m, p]
        exact Nat.gcd_pos_of_pos_left _ (hpos u.1.1)
      have hcopFull : q.Coprime (p / g) := by
        dsimp [q, g, m]
        exact Nat.coprime_div_gcd_div_gcd hgpos
      have hgQp : g * Q ∣ p := by
        obtain ⟨z, hz⟩ := hcompLow
        refine ⟨scale * z, ?_⟩
        dsimp [p, scale] at *
        rw [hQ, hz]
        ring
      have hQdiv : Q ∣ p / g := by
        apply (Nat.dvd_div_iff_mul_dvd
          (by dsimp [g]; exact Nat.gcd_dvd_right _ _)).mpr
        simpa [mul_comm] using hgQp
      exact (hcopFull.of_dvd_right hQdiv).gcd_eq_one
    · intro t hbad
      by_cases hside : u.2 = true
      · have hc : g ∣ n K * (2 * v + 1) := by
          simpa [g, m, twoWindowModulus, twoWindowOffset, hside,
            huCenter, A, hcenterHigh] using huComp
        simp only [hside, ite_true]
        apply (reverse_right_center_divisibility_iff_reduced
          m (n K) V v t (hpos u.1.1) (by simpa [g, m, p] using hc)).mp
        simpa [m, p, twoWindowModulus, twoWindowOffset, hside,
          huCenter, A, hcenterHigh] using hbad
      · have hsideFalse : u.2 = false := Bool.eq_false_of_not_eq_true hside
        have hc : g ∣ D := by
          simpa [g, m, twoWindowModulus, twoWindowOffset, hsideFalse,
            huCenter, A, hcenterLow] using huComp
        simp only [hsideFalse, Bool.false_eq_true, ↓reduceIte]
        apply (reverse_left_center_divisibility_iff_reduced
          m (n K) D Q V t (hpos u.1.1) hQ
            (by simpa [g, m, p] using hc)).mp
        simpa [m, p, twoWindowModulus, twoWindowOffset, hsideFalse,
          huCenter, A, hcenterLow] using hbad

end Research
/-!
# Partial-center budget for reverse below-half windows
-/

namespace Research

open scoped BigOperators

/-- Filtering a finite target block can only remove full reverse off-center
conditions. -/
theorem reverseWindowOutsideBlockOffCenter_subset
    (n : ℕ → ℕ) (K H W A X p w : ℕ) (Block : Finset ℕ) :
    reverseWindowOutsideBlockOffCenterConditions n K H W A X p w Block ⊆
      reverseWindowOffCenterConditions n K H W A X p w := by
  intro u hu
  have huData := Finset.mem_sdiff.mp hu
  have huOutside := huData.1
  have huNotCenter := huData.2
  have huOutsideData := Finset.mem_filter.mp huOutside
  have huOldCompat : u ∈ compatibleTwoWindowConditions n K H W A X p :=
    Finset.mem_filter.mpr
      ⟨(Finset.mem_filter.mp huOutsideData.1).1, huOutsideData.2⟩
  apply Finset.mem_sdiff.mpr
  refine ⟨huOldCompat, ?_⟩
  intro huOldCenter
  apply huNotCenter
  exact Finset.mem_filter.mpr
    ⟨huOldCenter, (Finset.mem_filter.mp huOutsideData.1).2⟩

/-- Protecting reverse centers only before `G` leaves the true full filtered
off-center family plus the two center labels at each position in `[G,H)`. -/
theorem reverseWindow_partialOutsideBlock_subset
    (n : ℕ → ℕ) (K G H W A X p w : ℕ) (Block : Finset ℕ) :
    let C0 := reverseWindowOutsideBlockCenterConditions
      n K G W A X p w Block
    let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
    let Oall := reverseWindowOutsideBlockOffCenterConditions
      n K H W A X p w Block
    O ⊆ Oall ∪ lateAlignedCenterEnvelope G H w w := by
  classical
  dsimp only
  intro u huO
  have huData := Finset.mem_sdiff.mp huO
  have huCompatH := huData.1
  have huNotC0 := huData.2
  by_cases huCH : u ∈ reverseWindowOutsideBlockCenterConditions
      n K H W A X p w Block
  · apply Finset.mem_union.mpr
    right
    have huOldCenter := (Finset.mem_filter.mp huCH).1
    have huCenter := (Finset.mem_filter.mp huOldCenter).2
    have huCompat := (Finset.mem_filter.mp huOldCenter).1
    have huBase := (Finset.mem_filter.mp huCompat).1
    have huOuter := Finset.mem_product.mp huBase
    have huInner := Finset.mem_product.mp huOuter.1
    have hjRange := Finset.mem_filter.mp huInner.1
    have hjH := Finset.mem_range.mp hjRange.1
    have hKj := hjRange.2
    have hGj : G ≤ u.1.1 := by
      by_contra hnot
      have hjG : u.1.1 < G := by omega
      apply huNotC0
      apply Finset.mem_filter.mpr
      refine ⟨?_, (Finset.mem_filter.mp huCH).2⟩
      apply Finset.mem_filter.mpr
      refine ⟨?_, huCenter⟩
      apply Finset.mem_filter.mpr
      refine ⟨?_, (Finset.mem_filter.mp huCompat).2⟩
      apply Finset.mem_product.mpr
      refine ⟨Finset.mem_product.mpr ⟨?_, huInner.2⟩, huOuter.2⟩
      exact Finset.mem_filter.mpr ⟨Finset.mem_range.mpr hjG, hKj⟩
    apply Finset.mem_product.mpr
    refine ⟨Finset.mem_product.mpr ⟨Finset.mem_Ico.mpr ⟨hGj, hjH⟩,
      ?_⟩, Finset.mem_univ _⟩
    simp [huCenter]
  · exact Finset.mem_union.mpr (Or.inl
      (Finset.mem_sdiff.mpr ⟨huCompatH, huCH⟩))

/-- Complete partial-center real budget for reverse windows. -/
theorem reverseWindow_finsetBlock_partialCenter_budget_cast_le
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K G H w D Q X V v R B : ℕ) (Block : Finset ℕ)
    (hKH : K < H) (hw : 0 < w) (hD : w < D) (hB : 0 < B)
    (hQ : n K = Q * D) (hX : D + X = n K * (2 * v + 1))
    (hsize : 2 * (4 * 2 ^ V) * B ^ 2 * w ≤ n K) :
    let W := 2 * w + 1
    let A := D - w
    let p := (4 * n K) * 2 ^ V
    let Z := (4 * 2 ^ V) * w
    let C0 := reverseWindowOutsideBlockCenterConditions
      n K G W A X p w Block
    let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
    ((∑ u ∈ O, (R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1) : ℕ) : ℝ) ≤
      (4 * (R : ℝ) * W *
          (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        4 * W * (laterPositionRange K H).card) +
      2 * (∑ j ∈ laterPositionRange K H,
        ((R : ℝ) * Z / n j + 1)) +
      2 * (laterPositionRange K H).card * ((R : ℝ) / B + 1) +
      4 * ((R : ℝ) * p *
        (∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)) +
        (Finset.Ico G H).card) := by
  classical
  let W := 2 * w + 1
  let A := D - w
  let p := (4 * n K) * 2 ^ V
  let Z := (4 * 2 ^ V) * w
  let C0 := reverseWindowOutsideBlockCenterConditions
    n K G W A X p w Block
  let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
  let Oall := reverseWindowOutsideBlockOffCenterConditions
    n K H W A X p w Block
  let Full := reverseWindowOffCenterConditions n K H W A X p w
  let Late := lateAlignedCenterEnvelope G H w w
  have hsub : O ⊆ Oall ∪ Late :=
    reverseWindow_partialOutsideBlock_subset n K G H W A X p w Block
  let cost : ((ℕ × ℕ) × Bool) → ℕ := fun u =>
    R / (twoWindowModulus n u /
      (twoWindowModulus n u).gcd p) + 1
  have hsplitNat : (∑ u ∈ O, cost u) ≤
      (∑ u ∈ Oall, cost u) + ∑ u ∈ Late, cost u := by
    calc
      _ ≤ ∑ u ∈ Oall ∪ Late, cost u := Finset.sum_le_sum_of_subset hsub
      _ ≤ _ := by
        have hu := Finset.sum_union_inter (s₁ := Oall) (s₂ := Late)
          (f := cost)
        omega
  have hsplit : (((∑ u ∈ O, cost u) : ℕ) : ℝ) ≤
      (((∑ u ∈ Oall, cost u) : ℕ) : ℝ) +
        (((∑ u ∈ Late, cost u) : ℕ) : ℝ) := by exact_mod_cast hsplitNat
  have hOsub : Oall ⊆ Full :=
    reverseWindowOutsideBlockOffCenter_subset n K H W A X p w Block
  have hOnat : (∑ u ∈ Oall, cost u) ≤ ∑ u ∈ Full, cost u :=
    Finset.sum_le_sum_of_subset hOsub
  have hOcast : (((∑ u ∈ Oall, cost u) : ℕ) : ℝ) ≤
      (((∑ u ∈ Full, cost u) : ℕ) : ℝ) := by exact_mod_cast hOnat
  have hfull := reverseWindow_offCenter_budget_cast_le
    n hpos hmono K H w D Q X V v R B hKH hw hD hB hQ hX hsize
  have hfull' : (((∑ u ∈ Full, cost u) : ℕ) : ℝ) ≤
      (4 * (R : ℝ) * W *
          (∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)) +
        4 * W * (laterPositionRange K H).card) +
      2 * (∑ j ∈ laterPositionRange K H,
        ((R : ℝ) * Z / n j + 1)) +
      2 * (laterPositionRange K H).card * ((R : ℝ) / B + 1) := by
    simpa [Full, cost, W, A, p, Z] using hfull
  have hp : 0 < p := by
    dsimp [p]
    exact mul_pos (mul_pos (by norm_num) (hpos K)) (pow_pos (by norm_num) V)
  have hlate := lateAlignedCenterEnvelope_budget_cast_le
    n hpos G H w w p R hp
  exact hsplit.trans (add_le_add (hOcast.trans hfull')
    (by simpa [Late, cost, p] using hlate))

end Research
/-!
# Bounded protected range for reverse below-half windows
-/

namespace Research

open scoped BigOperators

set_option maxHeartbeats 1200000

/-- A strict density margin yields a protected reverse-window search range
bounded by one CRT period plus an explicit endpoint cost. -/
theorem exists_bounded_reverseWindow_finsetBlock_protected_budget
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (K G H w Dtarget Q X V v B : ℕ) (Block : Finset ℕ)
    (hKG : K < G) (hKH : K < H) (hw : 0 < w)
    (hDtarget : w < Dtarget) (hDlt : Dtarget < n K) (hB : 0 < B)
    (hQ : n K = Q * Dtarget)
    (hX : Dtarget + X = n K * (2 * v + 1))
    (horder : ∀ j, K < j → j < G → j ∉ Block →
      twoAdicOrder (n j) ≤ V)
    (hsize : 2 * (4 * 2 ^ V) * B ^ 2 * w ≤ n K)
    (hdensity :
      let W := 2 * w + 1
      let A := Dtarget - w
      let p := (4 * n K) * 2 ^ V
      let Z := (4 * 2 ^ V) * w
      let Qmods := reverseWindowOutsideBlockCenterReducedModuli
        n K G W A X p w Block
      let S := centerPrimeFactors Qmods
      let D := (S.card + 1) * (S.card + 2)
      let Z₁ := (laterPositionRange K H).card
      let sigma₁ := ∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)
      let sigma₂ := ∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)
      (D : ℝ) *
        (4 * W * sigma₁ + 2 * Z * sigma₁ +
          2 * Z₁ / B + 4 * p * sigma₂) < 1) :
    let W := 2 * w + 1
    let A := Dtarget - w
    let p := (4 * n K) * 2 ^ V
    let C0 := reverseWindowOutsideBlockCenterConditions
      n K G W A X p w Block
    let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
    let Qmods := reverseWindowOutsideBlockCenterReducedModuli
      n K G W A X p w Block
    let S := centerPrimeFactors Qmods
    let D := (S.card + 1) * (S.card + 2)
    let Z₁ := (laterPositionRange K H).card
    let Z₂ := (Finset.Ico G H).card
    ∃ M R : ℕ,
      0 < M ∧ M = ∏ z ∈ S, z ∧ 0 < R ∧
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      R ≤ M + D * (4 * W * Z₁ + 4 * Z₁ + 4 * Z₂) := by
  classical
  let W := 2 * w + 1
  let A := Dtarget - w
  let p := (4 * n K) * 2 ^ V
  let Z := (4 * 2 ^ V) * w
  let C0 := reverseWindowOutsideBlockCenterConditions
    n K G W A X p w Block
  let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
  let Qmods := reverseWindowOutsideBlockCenterReducedModuli
    n K G W A X p w Block
  let S := centerPrimeFactors Qmods
  let D := (S.card + 1) * (S.card + 2)
  let Z₁ := (laterPositionRange K H).card
  let Z₂ := (Finset.Ico G H).card
  let sigma₁ : ℝ := ∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)
  let sigma₂ : ℝ := ∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)
  let alpha : ℝ := 4 * W * sigma₁ + 2 * Z * sigma₁ +
    2 * Z₁ / B + 4 * p * sigma₂
  let endpoint : ℕ := 4 * W * Z₁ + 4 * Z₁ + 4 * Z₂
  have hdensity' : (D : ℝ) * alpha < 1 := by
    simpa [W, A, p, Z, Qmods, S, D, Z₁, sigma₁, sigma₂, alpha]
      using hdensity
  obtain ⟨M, hM, hMeq, hprotected⟩ :=
    exists_exact_scaled_polynomially_many_reverseWindow_outsideBlock_centers
      n hpos hmono K G w Dtarget Q X V v Block hKG hDtarget hDlt hQ hX
        horder
  have hDpos : 0 < D := by dsimp [D]; positivity
  let delta : ℝ := 2 - (D : ℝ) * alpha
  have hdeltaOne : 1 < delta := by dsimp [delta]; nlinarith
  have hdelta : 0 < delta := lt_trans (by norm_num) hdeltaOne
  have hden : 0 < delta * (M : ℝ) :=
    mul_pos hdelta (by exact_mod_cast hM)
  let E : ℕ := D * endpoint
  let q : ℝ := (E : ℝ) / (delta * (M : ℝ))
  let T : ℕ := ⌊q⌋₊ + 1
  have hqnonneg : 0 ≤ q := by
    dsimp [q]
    exact div_nonneg (by positivity) hden.le
  have hqT : q < (T : ℝ) := by
    dsimp [T]
    simpa using Nat.lt_floor_add_one q
  have hTpos : 0 < T := by dsimp [T]; omega
  let R := T * M
  have hRpos : 0 < R := mul_pos hTpos hM
  have hendpoint : (E : ℝ) < delta * (R : ℝ) := by
    have hm : (E : ℝ) < (T : ℝ) * (delta * (M : ℝ)) := by
      apply (div_lt_iff₀ hden).mp
      simpa [q] using hqT
    calc
      (E : ℝ) < (T : ℝ) * (delta * (M : ℝ)) := hm
      _ = delta * (R : ℝ) := by dsimp [R]; push_cast; ring
  have hRbound : R ≤ M + E := by
    have hfloor : ((⌊q⌋₊ : ℕ) : ℝ) ≤ q := Nat.floor_le hqnonneg
    have hTle : (T : ℝ) ≤ q + 1 := by
      dsimp [T]
      push_cast
      linarith
    have hqM : q * (M : ℝ) = (E : ℝ) / delta := by
      dsimp [q]
      field_simp
    have hdivle : (E : ℝ) / delta ≤ (E : ℝ) := by
      apply (div_le_iff₀ hdelta).mpr
      have hEnonneg : (0 : ℝ) ≤ E := by positivity
      nlinarith
    have hreal : (R : ℝ) ≤ (M + E : ℕ) := by
      calc
        (R : ℝ) = (T : ℝ) * (M : ℝ) := by simp [R]
        _ ≤ (q + 1) * (M : ℝ) := by gcongr
        _ = q * (M : ℝ) + (M : ℝ) := by ring
        _ = (E : ℝ) / delta + (M : ℝ) := by rw [hqM]
        _ ≤ (E : ℝ) + (M : ℝ) := by gcongr
        _ = (M + E : ℕ) := by push_cast; ring
    exact_mod_cast hreal
  let Budget := ∑ u ∈ O, (R / (twoWindowModulus n u /
    (twoWindowModulus n u).gcd p) + 1)
  have hBudgetReal : (Budget : ℝ) ≤ (R : ℝ) * alpha + endpoint := by
    have hb := reverseWindow_finsetBlock_partialCenter_budget_cast_le
      n hpos hmono K G H w Dtarget Q X V v R B Block
        hKH hw hDtarget hB hQ hX hsize
    have hb' : (Budget : ℝ) ≤
        (4 * (R : ℝ) * W * sigma₁ + 4 * W * Z₁) +
        2 * (∑ j ∈ laterPositionRange K H,
          ((R : ℝ) * Z / n j + 1)) +
        2 * Z₁ * ((R : ℝ) / B + 1) +
        4 * ((R : ℝ) * p * sigma₂ + Z₂) := by
      simpa [Budget, O, C0, W, A, p, Z, sigma₁, sigma₂, Z₁, Z₂]
        using hb
    calc
      (Budget : ℝ) ≤
          (4 * (R : ℝ) * W * sigma₁ + 4 * W * Z₁) +
          2 * (∑ j ∈ laterPositionRange K H,
            ((R : ℝ) * Z / n j + 1)) +
          2 * Z₁ * ((R : ℝ) / B + 1) +
          4 * ((R : ℝ) * p * sigma₂ + Z₂) := hb'
      _ = (R : ℝ) * alpha + endpoint := by
        dsimp [alpha, endpoint]
        push_cast
        rw [Finset.sum_add_distrib]
        simp only [Finset.sum_const, nsmul_eq_mul]
        have hsum : ∑ j ∈ laterPositionRange K H,
            ((R : ℝ) * Z / n j) = (R : ℝ) * Z * sigma₁ := by
          dsimp [sigma₁]
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j hj
          ring
        rw [hsum]
        ring
  have hDBudget : D * Budget < 2 * R := by
    have hmain : (D : ℝ) * (Budget : ℝ) < 2 * (R : ℝ) := by
      have hscaled := mul_le_mul_of_nonneg_left hBudgetReal
        (show (0 : ℝ) ≤ D by positivity)
      dsimp [delta, E] at hendpoint
      push_cast at hendpoint hscaled
      nlinarith
    exact_mod_cast hmain
  have hprot := hprotected T
  have hBudgetCard : Budget <
      (protectedCandidates C0 (twoWindowOffset A X)
        (twoWindowModulus n) p R).card := by
    have hchain : D * Budget < D *
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
      calc
        D * Budget < 2 * R := hDBudget
        _ ≤ D * (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card := by
            simpa [R, D, S, Qmods, C0, W, A, p] using hprot
    exact (Nat.mul_lt_mul_left hDpos).mp hchain
  refine ⟨M, R, hM, ?_, hRpos, hBudgetCard, ?_⟩
  · simpa [S, Qmods, W, A, p] using hMeq
  · simpa [E, endpoint, D, Z₁, Z₂, S, Qmods, W, A, p] using hRbound

end Research
/-!
# Logarithmic position bound for a polynomial value threshold
-/

namespace Research

/-- Crossing the value threshold `n_K W^8` needs only logarithmically many
ratio-doubling blocks. -/
theorem exists_logarithmic_polynomial_threshold_package
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (q : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (K W : ℕ) (hW : 0 < W) :
    let B := n K * W ^ 8
    let l := Nat.clog 2 W
    let Q := q * (8 * l + 1)
    ∃ G : ℕ, K < G ∧ B < n G ∧
      (∀ j, K < j → j < G → n j ≤ B) ∧
      G ≤ K + Q ∧ (laterPositionRange K G).card ≤ Q := by
  let B := n K * W ^ 8
  let l := Nat.clog 2 W
  let Q := q * (8 * l + 1)
  have hWle : W ≤ 2 ^ l := by
    dsimp [l]
    exact Nat.le_pow_clog (by norm_num) W
  have hWpow : W ^ 8 < 2 ^ (8 * l + 1) := by
    have hp : W ^ 8 ≤ (2 ^ l) ^ 8 := Nat.pow_le_pow_left hWle 8
    calc
      W ^ 8 ≤ (2 ^ l) ^ 8 := hp
      _ = 2 ^ (8 * l) := by rw [← pow_mul]; congr 1; omega
      _ < 2 ^ (8 * l + 1) := Nat.pow_lt_pow_right (by norm_num) (by omega)
  have hbase : (2 : ℝ) ^ (8 * l + 1) ≤
      (c ^ q) ^ (8 * l + 1) :=
    pow_le_pow_left₀ (by norm_num) hq (8 * l + 1)
  have hcQ : (2 : ℝ) ^ (8 * l + 1) ≤ c ^ Q := by
    calc
      _ ≤ (c ^ q) ^ (8 * l + 1) := hbase
      _ = c ^ (q * (8 * l + 1)) := (pow_mul c q (8 * l + 1)).symm
      _ = c ^ Q := rfl
  have hcross : (B : ℝ) < c ^ Q * (n K : ℝ) := by
    have hnreal : (0 : ℝ) < n K := by exact_mod_cast hpos K
    have hpowReal : ((W ^ 8 : ℕ) : ℝ) <
        (2 : ℝ) ^ (8 * l + 1) := by exact_mod_cast hWpow
    have hlt : ((W ^ 8 : ℕ) : ℝ) < c ^ Q := hpowReal.trans_le hcQ
    have hm := mul_lt_mul_of_pos_right hlt hnreal
    simpa [B, mul_comm] using hm
  have hKB : n K ≤ B := by
    dsimp [B]
    have hone : 1 ≤ W ^ 8 := one_le_pow₀ (by omega)
    nlinarith
  exact exists_first_index_above_with_position_bound
    n hmono c hc hratio K B Q hKB hcross

end Research
/-!
# Logarithmic cutoff for reverse-window protected budgets
-/

namespace Research

open scoped BigOperators

/-- Replace finite reciprocal sums and center-prime count by ratio-tail and
position bounds in the reverse-window density condition. -/
theorem reverseWindow_density_of_adaptive_bounds
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (K G H w Dtarget X V B : ℕ) (Block : Finset ℕ)
    (hbound :
      let W := 2 * w + 1
      let p := (4 * n K) * 2 ^ V
      let Z := (4 * 2 ^ V) * w
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      (Dmax : ℝ) *
        ((4 * W + 2 * Z) *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          2 * H / B +
          4 * p * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1) :
    let W := 2 * w + 1
    let A := Dtarget - w
    let p := (4 * n K) * 2 ^ V
    let Z := (4 * 2 ^ V) * w
    let Qmods := reverseWindowOutsideBlockCenterReducedModuli
      n K G W A X p w Block
    let S := centerPrimeFactors Qmods
    let D := (S.card + 1) * (S.card + 2)
    let Z₁ := (laterPositionRange K H).card
    let sigma₁ := ∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)
    let sigma₂ := ∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)
    (D : ℝ) *
      (4 * W * sigma₁ + 2 * Z * sigma₁ +
        2 * Z₁ / B + 4 * p * sigma₂) < 1 := by
  let W := 2 * w + 1
  let A := Dtarget - w
  let p := (4 * n K) * 2 ^ V
  let Z := (4 * 2 ^ V) * w
  let Qmods := reverseWindowOutsideBlockCenterReducedModuli
    n K G W A X p w Block
  let S := centerPrimeFactors Qmods
  let d := (laterPositionRange K G).card
  let D := (S.card + 1) * (S.card + 2)
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Z₁ := (laterPositionRange K H).card
  let sigma₁ : ℝ := ∑ j ∈ laterPositionRange K H, ((n j : ℝ)⁻¹)
  let sigma₂ : ℝ := ∑ j ∈ Finset.Ico G H, ((n j : ℝ)⁻¹)
  have hScard : S.card ≤ 2 * d :=
    reverseWindowOutsideBlock_centerPrimeFactors_card_le
      n K G W A X p w Block
  have hD : D ≤ Dmax := by
    dsimp [D, Dmax]
    exact Nat.mul_le_mul (Nat.add_le_add_right hScard 1)
      (Nat.add_le_add_right hScard 2)
  have htail₁ := sum_laterPositionRange_inv_le
    n hpos c hc hratio K H
  have htail₂ := sum_Ico_inv_le_from n hpos c hc hratio G H
  have hZ₁ : Z₁ ≤ H := by
    dsimp [Z₁]
    calc
      (laterPositionRange K H).card ≤ (Finset.range H).card :=
        Finset.card_le_card (Finset.filter_subset _ _)
      _ = H := Finset.card_range H
  have hinner :
      4 * (W : ℝ) * sigma₁ + 2 * (Z : ℝ) * sigma₁ +
          2 * (Z₁ : ℝ) / B + 4 * (p : ℝ) * sigma₂ ≤
        (4 * W + 2 * Z) *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          2 * H / B +
          4 * p * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹) := by
    have hBnonneg : (0 : ℝ) ≤ B := by positivity
    have hZcast : (Z₁ : ℝ) ≤ H := by exact_mod_cast hZ₁
    calc
      4 * (W : ℝ) * sigma₁ + 2 * (Z : ℝ) * sigma₁ +
          2 * (Z₁ : ℝ) / B + 4 * (p : ℝ) * sigma₂ ≤
        4 * W * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          2 * Z * (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          2 * H / B +
          4 * p * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹) := by
            gcongr
      _ = (4 * W + 2 * Z) *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          2 * H / B +
          4 * p * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹) := by ring
  have hDreal : (D : ℝ) ≤ Dmax := by exact_mod_cast hD
  calc
    (D : ℝ) * (4 * W * sigma₁ + 2 * Z * sigma₁ +
        2 * Z₁ / B + 4 * p * sigma₂) ≤
      (Dmax : ℝ) *
        ((4 * W + 2 * Z) *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          2 * H / B +
          4 * p * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) := by
      gcongr
    _ < 1 := by simpa [W, p, Z, d, Dmax] using hbound

/-- Explicit logarithmic cutoff position for reverse-window budgets. -/
def reverseWindowLogCutoffPosition
    (n : ℕ → ℕ) (K G Bval w Dtarget X V q : ℕ) : ℕ :=
  let W := 2 * w + 1
  let A := Dtarget - w
  let p := (4 * n K) * 2 ^ V
  let d := (laterPositionRange K G).card
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := Bval ^ (2 * d)
  let U := A + p * Mmax + X + W
  let Vaff := 12 * p * Dmax * W
  let A₀ := U + Vaff * G
  let B₀ := Vaff * q
  let N := A₀ + B₀ + 1
  let t := Nat.clog 2 N
  G + q * (4 * t + 4)

/-- At the standard logarithmic cutoff, adaptive density supplies a valid
reverse-window protected range and a coefficient cutoff. -/
theorem exists_logarithmic_reverseWindow_finsetBlock_budget
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qratio : ℕ) (hq : (2 : ℝ) ≤ c ^ qratio)
    (K G Bval w Dtarget Q X V v Bexc : ℕ) (Block : Finset ℕ)
    (hKG : K < G) (hBval : 0 < Bval)
    (hvalues : ∀ j, K < j → j < G → n j ≤ Bval)
    (hw : 0 < w) (hDtarget : w < Dtarget) (hDlt : Dtarget < n K)
    (hBexc : 0 < Bexc) (hQ : n K = Q * Dtarget)
    (hX : Dtarget + X = n K * (2 * v + 1))
    (horder : ∀ j, K < j → j < G → j ∉ Block →
      twoAdicOrder (n j) ≤ V)
    (hsize : 2 * (4 * 2 ^ V) * Bexc ^ 2 * w ≤ n K)
    (hdensity :
      let W := 2 * w + 1
      let p := (4 * n K) * 2 ^ V
      let Z := (4 * 2 ^ V) * w
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let H := reverseWindowLogCutoffPosition
        n K G Bval w Dtarget X V qratio
      (Dmax : ℝ) *
        ((4 * W + 2 * Z) *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          2 * H / Bexc +
          4 * p * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1) :
    let W := 2 * w + 1
    let A := Dtarget - w
    let p := (4 * n K) * 2 ^ V
    let H := reverseWindowLogCutoffPosition
      n K G Bval w Dtarget X V qratio
    let C0 := reverseWindowOutsideBlockCenterConditions
      n K G W A X p w Block
    ∃ R : ℕ, 0 < R ∧
      let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
      (∑ u ∈ O, (R / (twoWindowModulus n u /
        (twoWindowModulus n u).gcd p) + 1)) <
        (protectedCandidates C0 (twoWindowOffset A X)
          (twoWindowModulus n) p R).card ∧
      A + p * R + X + W < n H := by
  classical
  let W := 2 * w + 1
  let A := Dtarget - w
  let p := (4 * n K) * 2 ^ V
  let d := (laterPositionRange K G).card
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := Bval ^ (2 * d)
  let U := A + p * Mmax + X + W
  let Vaff := 12 * p * Dmax * W
  let A₀ := U + Vaff * G
  let B₀ := Vaff * qratio
  let N := A₀ + B₀ + 1
  let t := Nat.clog 2 N
  let H := G + qratio * (4 * t + 4)
  have hAff := logarithmic_ratio_cutoff_dominating_affine
    n hpos c hc hratio qratio hq G U Vaff
  have hGH : G ≤ H := by omega
  have hKH : K < H := hKG.trans_le hGH
  have haffine : U + Vaff * H < n H := by
    simpa [A₀, B₀, N, t, H] using hAff.2
  have hdensityH := reverseWindow_density_of_adaptive_bounds
    n hpos c hc hratio K G H w Dtarget X V Bexc Block
      (by simpa [W, p, d, Dmax, H,
        reverseWindowLogCutoffPosition, A₀, B₀, N, t, U, Vaff]
        using hdensity)
  obtain ⟨M, R, hM, hMeq, hR, hbudget, hRbound⟩ :=
    exists_bounded_reverseWindow_finsetBlock_protected_budget
      n hpos hmono K G H w Dtarget Q X V v Bexc Block hKG hKH hw
        hDtarget hDlt hBexc hQ hX horder hsize hdensityH
  have hMle : M ≤ Mmax := by
    rw [hMeq]
    dsimp [Mmax]
    exact reverseWindowOutsideBlock_centerPrime_product_le_threshold_pow
      n hpos K G W A X p w Bval Block hBval hvalues
  let Qmods := reverseWindowOutsideBlockCenterReducedModuli
    n K G W A X p w Block
  let S := centerPrimeFactors Qmods
  let Dfac := (S.card + 1) * (S.card + 2)
  have hDle : Dfac ≤ Dmax := by
    have hScard : S.card ≤ 2 * d :=
      reverseWindowOutsideBlock_centerPrimeFactors_card_le
        n K G W A X p w Block
    dsimp [Dfac, Dmax]
    exact Nat.mul_le_mul (Nat.add_le_add_right hScard 1)
      (Nat.add_le_add_right hScard 2)
  have hZ₁ : (laterPositionRange K H).card ≤ H := by
    calc
      _ ≤ (Finset.range H).card :=
        Finset.card_le_card (Finset.filter_subset _ _)
      _ = H := Finset.card_range H
  have hZ₂ : (Finset.Ico G H).card ≤ H := by simp
  have hendpoint : Dfac *
      (4 * W * (laterPositionRange K H).card +
        4 * (laterPositionRange K H).card +
        4 * (Finset.Ico G H).card) ≤
      12 * Dmax * W * H := by
    calc
      _ ≤ Dmax * (4 * W * H + 4 * H + 4 * H) := by gcongr
      _ ≤ Dmax * (12 * W * H) := by
        gcongr
        have hWpos : 0 < W := by dsimp [W]; omega
        nlinarith
      _ = 12 * Dmax * W * H := by ring
  have hRcoarse : R ≤ Mmax + 12 * Dmax * W * H := by
    calc
      R ≤ M + Dfac *
          (4 * W * (laterPositionRange K H).card +
            4 * (laterPositionRange K H).card +
            4 * (Finset.Ico G H).card) := by
        simpa [Dfac, S, Qmods, W, A, p] using hRbound
      _ ≤ Mmax + 12 * Dmax * W * H :=
        Nat.add_le_add hMle hendpoint
  have hcut : A + p * R + X + W < n H := by
    have hcost : A + p * R + X + W ≤ U + Vaff * H := by
      calc
        _ ≤ A + p * (Mmax + 12 * Dmax * W * H) + X + W := by gcongr
        _ = U + Vaff * H := by dsimp [U, Vaff]; ring
    exact hcost.trans_lt haffine
  refine ⟨R, hR, ?_⟩
  simpa [W, A, p, H, reverseWindowLogCutoffPosition,
    d, Dmax, Mmax, U, Vaff, A₀, B₀, N, t] using And.intro hbudget hcut

end Research
/-!
# Complete logarithmic reverse-window gate for quadratic totals
-/

namespace Research

open Real goldenRatio
open scoped BigOperators

/-- A reverse isolated finite target block, the logarithmic reverse protected
budget, and cutoff norm caps contradict any fixed scaled golden total. -/
theorem logarithmic_reverseWindow_finsetBlock_pair_contradiction
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (qden : ℕ) (hqden : 0 < qden) (T Tconj : ℝ)
    (hsum : HasSum (fun m : ℕ =>
      (selectedFibLambertCoeff n m : ℝ) * (φ⁻¹) ^ m) T)
    (htotal : InScaledGoldenPair qden T Tconj)
    (qratio : ℕ) (hq : (2 : ℝ) ≤ c ^ qratio)
    (K G Bval w Dtarget Q X V v Bexc : ℕ) (Block : Finset ℕ)
    (hKG : K < G) (hBval : 0 < Bval)
    (hvalues : ∀ j, K < j → j < G → n j ≤ Bval)
    (hw : 0 < w) (hDtarget : w < Dtarget) (hDlt : Dtarget < n K)
    (hBexc : 0 < Bexc) (hQ : n K = Q * Dtarget)
    (hXcenter : Dtarget + X = n K * (2 * v + 1))
    (horder : ∀ j, K < j → j < G → j ∉ Block →
      twoAdicOrder (n j) ≤ V)
    (hsize : 2 * (4 * 2 ^ V) * Bexc ^ 2 * w ≤ n K)
    (hKB : K ∈ Block) (hBlockUpper : ∀ k ∈ Block, k < G)
    (hprefix : sharpPrefixPeriod n K ∣ X)
    (hblockPeriod : ∀ k ∈ Block,
      fibLambertPeriod (n k) ∣ (4 * n K) * 2 ^ V)
    (htargetPre : ∀ s < w,
      selectedPositionFinsetCoeff n Block (Dtarget - w + s + X) =
        selectedPositionFinsetCoeff n Block (Dtarget - w + s))
    (htarget : selectedPositionFinsetCoeff n Block
        (Dtarget - w + w + X) ≠
      selectedPositionFinsetCoeff n Block (Dtarget - w + w))
    (htargetPost : ∀ s < w,
      selectedPositionFinsetCoeff n Block
          (Dtarget - w + w + 1 + s + X) =
        selectedPositionFinsetCoeff n Block
          (Dtarget - w + w + 1 + s))
    (hdensity :
      let W := 2 * w + 1
      let p := (4 * n K) * 2 ^ V
      let Z := (4 * 2 ^ V) * w
      let d := (laterPositionRange K G).card
      let Dmax := (2 * d + 1) * (2 * d + 2)
      let H := reverseWindowLogCutoffPosition
        n K G Bval w Dtarget X V qratio
      (Dmax : ℝ) *
        ((4 * W + 2 * Z) *
            (c⁻¹ * (1 - c⁻¹)⁻¹ * (n K : ℝ)⁻¹) +
          2 * H / Bexc +
          4 * p * ((1 - c⁻¹)⁻¹ * (n G : ℝ)⁻¹)) < 1)
    (hpostCap :
      let H := reverseWindowLogCutoffPosition
        n K G Bval w Dtarget X V qratio
      (φ⁻¹) ^ (w + 1) * (2 * cutoffTailCap H) < 1)
    (hpreCap :
      let H := reverseWindowLogCutoffPosition
        n K G Bval w Dtarget X V qratio
      (φ⁻¹) ^ w * (2 * cutoffTailCap H) *
        (2 * cutoffConjugateCap Tconj H) <
        (((qden : ℕ) : ℝ)⁻¹) ^ 2) :
    False := by
  classical
  let W := 2 * w + 1
  let A := Dtarget - w
  let p := (4 * n K) * 2 ^ V
  let H := reverseWindowLogCutoffPosition
    n K G Bval w Dtarget X V qratio
  let C0 := reverseWindowOutsideBlockCenterConditions
    n K G W A X p w Block
  let O := compatibleOutsideTwoWindowConditions n K H W A X p Block \ C0
  obtain ⟨R, hR, hbudget, hcut⟩ :=
    exists_logarithmic_reverseWindow_finsetBlock_budget
      n hpos hmono c hc hratio qratio hq K G Bval w Dtarget Q X V v
        Bexc Block hKG hBval hvalues hw hDtarget hDlt hBexc hQ hXcenter
        horder hsize hdensity
  have hA : 0 < A := by dsimp [A]; omega
  have hWeq : W = w + 1 + w := by dsimp [W]; omega
  have hGH : G ≤ H := by
    dsimp [H, reverseWindowLogCutoffPosition]
    omega
  have hKH : K < H := hKG.trans_le hGH
  have hCsub : C0 ⊆
      compatibleOutsideTwoWindowConditions n K H W A X p Block := by
    intro u hu
    have huOldG := (Finset.mem_filter.mp hu).1
    have huNot := (Finset.mem_filter.mp hu).2
    have huCompatG := (Finset.mem_filter.mp huOldG).1
    have huCenter := (Finset.mem_filter.mp huOldG).2
    have huData := Finset.mem_filter.mp huCompatG
    have huOuter := Finset.mem_product.mp huData.1
    have huInner := Finset.mem_product.mp huOuter.1
    have hjData := Finset.mem_filter.mp huInner.1
    apply Finset.mem_filter.mpr
    refine ⟨?_, huData.2⟩
    apply Finset.mem_filter.mpr
    refine ⟨?_, huNot⟩
    apply Finset.mem_product.mpr
    refine ⟨Finset.mem_product.mpr ⟨?_, huInner.2⟩, huOuter.2⟩
    exact Finset.mem_filter.mpr
      ⟨Finset.mem_range.mpr ((Finset.mem_range.mp hjData.1).trans_le hGH),
        hjData.2⟩
  have hpartition : C0 ∪ O =
      compatibleOutsideTwoWindowConditions n K H W A X p Block :=
    Finset.union_sdiff_of_subset hCsub
  have hperiod : ∀ k < K, fibLambertPeriod (n k) ∣ X := by
    intro k hk
    exact dvd_trans (fibLambertPeriod_dvd_sharpPrefixPeriod n hk) hprefix
  have hp : 0 < p := by
    dsimp [p]
    exact mul_pos (mul_pos (by norm_num) (hpos K)) (pow_pos (by norm_num) V)
  have hnorm := uniform_finsetBlock_protected_pair_norm_bounds_of_cutoff
    n hpos hmono qden Tconj H w w A X p R hp
      (by simpa [A, p, H, ← hWeq] using hcut)
      (by simpa [H] using hpostCap)
      (by simpa [H] using hpreCap)
  exact finsetBlock_protected_sandwiched_mismatch_pair_contradiction
    n hpos hmono qden hqden T Tconj hsum htotal
      K H w w A X p R Block hA hKH hKB
      (fun k hk => (hBlockUpper k hk).trans_le hGH)
      hperiod hblockPeriod
      (by simpa [A] using htargetPre)
      (by simpa [A] using htarget)
      (by simpa [A] using htargetPost)
      C0 O (by simpa [← hWeq] using hpartition)
      (by simpa [A, p, W, H] using hbudget)
      (by simpa [A, p, H, ← hWeq] using hcut) hnorm.1 hnorm.2

end Research
/-!
# Polynomial upper bounds for the logarithmic reverse-window cutoff
-/

namespace Research

set_option maxHeartbeats 3000000
set_option maxRecDepth 10000

/-- A ratio-doubling block bounds a selected position by the binary logarithm
of its selected value. -/
theorem position_le_ratioBlock_mul_clog_target
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (q K : ℕ) (hq : (2 : ℝ) ≤ c ^ q) :
    K ≤ q * (Nat.clog 2 (n K) + 1) := by
  have hqpos : 0 < q := by
    by_contra hnot
    have hq0 : q = 0 := by omega
    rw [hq0, pow_zero] at hq
    norm_num at hq
  let a := K / q
  have hqa : q * a ≤ K := by
    dsimp [a]
    simpa [mul_comm] using Nat.div_mul_le_self K q
  have hgrowth := ratio_gap_geometric_growth_from
    n c (le_of_lt (lt_trans zero_lt_one hc)) hratio 0 (q * a)
  have hpow : (2 : ℝ) ^ a ≤ (c ^ q) ^ a :=
    pow_le_pow_left₀ (by norm_num) hq a
  have hca : (c ^ q) ^ a = c ^ (q * a) := (pow_mul c q a).symm
  have hn0 : (1 : ℝ) ≤ n 0 := by exact_mod_cast hpos 0
  have htwoReal : (2 : ℝ) ^ a ≤ n K := by
    calc
      (2 : ℝ) ^ a ≤ (c ^ q) ^ a := hpow
      _ = c ^ (q * a) := hca
      _ ≤ c ^ (q * a) * (n 0 : ℝ) := by
        have hcPow : 0 ≤ c ^ (q * a) := by positivity
        nlinarith
      _ ≤ n (q * a) := by simpa using hgrowth
      _ ≤ n K := by exact_mod_cast hmono.monotone hqa
  have htwoNat : 2 ^ a ≤ n K := by exact_mod_cast htwoReal
  have haclog : a ≤ Nat.clog 2 (n K) := by
    rw [← Nat.clog_pow 2 a (by norm_num)]
    exact Nat.clog_mono (by norm_num) (by norm_num) htwoNat
  have hKlt : K < q * (a + 1) := by
    simpa [a] using Nat.lt_mul_div_succ K hqpos
  exact (Nat.le_of_lt hKlt).trans
    (Nat.mul_le_mul_left q (Nat.add_le_add_right haclog 1))

/-- A target bounded by an eighth power of `4W` has logarithmic size at
most `8(clog₂ W+2)`. -/
theorem clog_target_le_eight_mul_clog_window_add_two
    (m W : ℕ) (hm : m ≤ (4 * W) ^ 8) :
    Nat.clog 2 m ≤ 8 * (Nat.clog 2 W + 2) := by
  let l := Nat.clog 2 W
  have hW : W ≤ 2 ^ l := Nat.le_pow_clog (by norm_num) W
  have h4W : 4 * W ≤ 2 ^ (l + 2) := by
    calc
      4 * W ≤ 4 * 2 ^ l := Nat.mul_le_mul_left 4 hW
      _ = 2 ^ (l + 2) := by rw [pow_add]; norm_num; ring
  have hp : (4 * W) ^ 8 ≤ 2 ^ (8 * (l + 2)) := by
    calc
      _ ≤ (2 ^ (l + 2)) ^ 8 := Nat.pow_le_pow_left h4W 8
      _ = 2 ^ (8 * (l + 2)) := by rw [← pow_mul]; congr 1; omega
  apply (Nat.clog_le_iff_le_pow (by norm_num)).mpr
  exact hm.trans hp

/-- Ratio position bound expressed only through the logarithmic window size. -/
theorem position_le_seventeen_ratio_clogWindow
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (q K W : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (hn : n K ≤ (4 * W) ^ 8) :
    K ≤ 17 * q * (Nat.clog 2 W + 1) := by
  have hK := position_le_ratioBlock_mul_clog_target
    n hpos hmono c hc hratio q K hq
  have hclog := clog_target_le_eight_mul_clog_window_add_two (n K) W hn
  calc
    K ≤ q * (Nat.clog 2 (n K) + 1) := hK
    _ ≤ q * (8 * (Nat.clog 2 W + 2) + 1) := by gcongr
    _ ≤ 17 * q * (Nat.clog 2 W + 1) := by
      nlinarith

/-- A target-specific upper bound for the reverse logarithmic cutoff.  The
bound is quadratic in the binary window length, rather than polynomial in the
target value. -/
theorem reverseWindowLogCutoffPosition_le_binaryWindowBound
    (n : ℕ → ℕ) (hpos : ∀ k, 0 < n k) (hmono : StrictMono n)
    (c : ℝ) (hc : 1 < c)
    (hratio : ∀ k, c * (n k : ℝ) ≤ n (k + 1))
    (q K G w Dtarget X V : ℕ) (hq : (2 : ℝ) ≤ c ^ q)
    (hDlt : Dtarget < n K)
    (hn : n K ≤ (4 * (2 * w + 1)) ^ 8)
    (hG : G ≤ K + q * (8 * Nat.clog 2 (2 * w + 1) + 1))
    (hd : (laterPositionRange K G).card ≤
      q * (8 * Nat.clog 2 (2 * w + 1) + 1))
    (hX : X < (2 * n K) * sharpPrefixPeriod n K) :
    reverseWindowLogCutoffPosition
      n K G (n K * (2 * w + 1) ^ 8) w Dtarget X V q ≤
      50000 * (q + V + 2) ^ 3 *
        (Nat.clog 2 (2 * w + 1) + 1) ^ 2 := by
  let W := 2 * w + 1
  let l := Nat.clog 2 W
  let L := l + 1
  let C := q + V + 2
  let d := (laterPositionRange K G).card
  let Bval := n K * W ^ 8
  let A := Dtarget - w
  let p := (4 * n K) * 2 ^ V
  let Dmax := (2 * d + 1) * (2 * d + 2)
  let Mmax := Bval ^ (2 * d)
  let U := A + p * Mmax + X + W
  let Vaff := 12 * p * Dmax * W
  let A₀ := U + Vaff * G
  let B₀ := Vaff * q
  let N := A₀ + B₀ + 1
  let E := 10000 * C ^ 2 * L ^ 2
  have hLpos : 0 < L := by dsimp [L]; omega
  have hCpos : 0 < C := by dsimp [C]; omega
  have hWpow : W ≤ 2 ^ l := by
    dsimp [l]
    exact Nat.le_pow_clog (by norm_num) W
  have hnPow : n K ≤ 2 ^ (24 * L) := by
    have hclog := clog_target_le_eight_mul_clog_window_add_two
      (n K) W (by simpa [W] using hn)
    apply (Nat.clog_le_iff_le_pow (by norm_num)).mp
    calc
      Nat.clog 2 (n K) ≤ 8 * (l + 2) := by simpa [l] using hclog
      _ ≤ 24 * L := by dsimp [L]; nlinarith
  have hK : K ≤ 17 * q * L := by
    simpa [W, l, L] using position_le_seventeen_ratio_clogWindow
      n hpos hmono c hc hratio q K W hq (by simpa [W] using hn)
  have hQpos : q * (8 * l + 1) ≤ 9 * q * L := by
    calc
      q * (8 * l + 1) ≤ q * (9 * L) := by
        apply Nat.mul_le_mul_left
        dsimp [L]
        omega
      _ = 9 * q * L := by ring
  have hG' : G ≤ 26 * q * L := by
    calc
      G ≤ K + q * (8 * l + 1) := by simpa [W, l] using hG
      _ ≤ 17 * q * L + 9 * q * L := Nat.add_le_add hK hQpos
      _ = 26 * q * L := by ring
  have hd' : d ≤ 9 * q * L := by
    have hd0 : d ≤ q * (8 * l + 1) := by
      simpa [d, W, l] using hd
    exact hd0.trans hQpos
  have hFourN : 4 * n K ≤ 2 ^ (26 * L) := by
    have h4 : 4 ≤ 2 ^ 2 := by norm_num
    have hm := mul_le_two_pow_add h4 hnPow
    exact hm.trans (pow_le_pow_right₀ (by norm_num) (by omega))
  have hP : sharpPrefixPeriod n K ≤ 2 ^ (442 * q * L ^ 2) := by
    have hp0 := sharpPrefixPeriod_le_pow_target n hpos hmono K
    have hp1 := pow_le_two_pow_mul hFourN K
    calc
      sharpPrefixPeriod n K ≤ (4 * n K) ^ K := hp0
      _ ≤ 2 ^ ((26 * L) * K) := hp1
