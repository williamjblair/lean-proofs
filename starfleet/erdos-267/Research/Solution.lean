        Nat.mul_le_mul h2d1 h2d2
      _ = 400 * (q + 1) ^ 2 * L ^ 2 := by ring
  have hDpow : Dmax ≤ 2 ^ (800 * C ^ 2 * L ^ 2) := by
    have hraw := nat_le_two_pow_two_mul Dmax
    have hqC : q + 1 ≤ C := by dsimp [C]; omega
