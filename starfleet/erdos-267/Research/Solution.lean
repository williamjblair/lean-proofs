      let Z0 := C ^ 2 * L ^ 2
      have hZpos : 1 ≤ Z0 := by
        dsimp [Z0]
        exact mul_pos (pow_pos hCpos 2) (pow_pos hLpos 2)
      have hl : l ≤ Z0 := by
        dsimp [Z0]
        exact (by dsimp [L]; omega : l ≤ L).trans hLCL
      have h4 : 4 ≤ 4 * Z0 := Nat.mul_le_mul_left 4 hZpos
      have hv : (V + 26) * L ^ 2 ≤ 13 * Z0 := by
